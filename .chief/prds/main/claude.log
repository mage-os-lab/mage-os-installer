{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LjPV19GWEhNUsTCDssNnWV","type":"tool_result","content":"1\tpackage tui\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"path/filepath\"\n7\t\t\"testing\"\n8\t\n9\t\ttea \"github.com/charmbracelet/bubbletea\"\n10\t\t\"github.com/mage-os/mage-os-install/internal/detector\"\n11\t)\n12\t\n13\t// mockDetector satisfies the detector.Detector interface for tests.\n14\ttype mockDetector struct {\n15\t\tinfo       detector.DetectorInfo\n16\t\tenv        *detector.Environment\n17\t\tinstallErr error\n18\t}\n19\t\n20\tfunc (d *mockDetector) Info() detector.DetectorInfo            { return d.info }\n21\tfunc (d *mockDetector) Steps() []detector.Step                 { return nil }\n22\tfunc (d *mockDetector) PrepareSteps(_ *detector.Config)        {}\n23\tfunc (d *mockDetector) Detect() (*detector.Environment, error) { return d.env, nil }\n24\tfunc (d *mockDetector) Install(cfg *detector.Config) error     { return d.installErr }\n25\tfunc (d *mockDetector) SetupInstallFlags(cfg *detector.Config) []detector.SetupFlag {\n26\t\treturn []detector.SetupFlag{\n27\t\t\t{Flag: \"--db-host\", Value: \"db\", Editable: false},\n28\t\t\t{Flag: \"--admin-user\", Value: cfg.AdminUser, Editable: true},\n29\t\t\t{Flag: \"--admin-password\", Value: cfg.AdminPassword, Editable: true},\n30\t\t}\n31\t}\n32\tfunc (d *mockDetector) SetupCommandPrefix() string { return \"mock exec bin/magento setup:install\" }\n33\tfunc (d *mockDetector) BaseURL(projectName string) string {\n34\t\treturn \"https://\" + projectName + \".test\"\n35\t}\n36\t\n37\t// sendMsg sends a message into the model and returns the updated model.\n38\t// The returned tea.Cmd is discarded — no side-effects run during tests.\n39\tfunc sendMsg(m Model, msg tea.Msg) Model {\n40\t\tnewModel, _ := m.Update(msg)\n41\t\treturn newModel.(Model)\n42\t}\n43\t\n44\tfunc pressEnter(m Model) Model {\n45\t\treturn sendMsg(m, tea.KeyMsg{Type: tea.KeyEnter})\n46\t}\n47\t\n48\t// makeDetectedEnv builds a DetectedEnvironment backed by a mockDetector.\n49\tfunc makeDetectedEnv(name string) detector.DetectedEnvironment {\n50\t\treturn detector.DetectedEnvironment{\n51\t\t\tEnv:      detector.Environment{Name: name, Version: \"1.0.0\"},\n52\t\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: name, InstallURL: \"https://example.com\"}},\n53\t\t}\n54\t}\n55\t\n56\t// --- initial state ---\n57\t\n58\tfunc TestNew_StartsInNameInputPhase(t *testing.T) {\n59\t\tm := New()\n60\t\tif m.phase != phaseNameInput {\n61\t\t\tt.Errorf(\"expected phaseNameInput, got %d\", m.phase)\n62\t\t}\n63\t}\n64\t\n65\tfunc TestNew_NameInputMatchesOriginalName(t *testing.T) {\n66\t\tm := New()\n67\t\tif m.nameInput.Value() == \"\" {\n68\t\t\tt.Error(\"nameInput should have a non-empty default\")\n69\t\t}\n70\t\tif m.nameInput.Value() != m.originalName {\n71\t\t\tt.Errorf(\"nameInput.Value() %q should equal originalName %q\", m.nameInput.Value(), m.originalName)\n72\t\t}\n73\t}\n74\t\n75\t// --- name → directory phase ---\n76\t\n77\tfunc TestUpdate_EnterOnNameGoesToDirectoryPhase(t *testing.T) {\n78\t\tm := pressEnter(New())\n79\t\tif m.phase != phaseDirectoryInput {\n80\t\t\tt.Errorf(\"expected phaseDirectoryInput, got %d\", m.phase)\n81\t\t}\n82\t}\n83\t\n84\tfunc TestUpdate_DirDefault_WhenNameUnchanged_IsCurrentDir(t *testing.T) {\n85\t\tm := pressEnter(New()) // name → dir\n86\t\twd, _ := os.Getwd()\n87\t\tif m.dirInput.Value() != wd {\n88\t\t\tt.Errorf(\"expected dir %q, got %q\", wd, m.dirInput.Value())\n89\t\t}\n90\t}\n91\t\n92\tfunc TestUpdate_DirDefault_WhenNameChanged_IsCwdPlusName(t *testing.T) {\n93\t\tm := New()\n94\t\tm.originalName = \"original\"\n95\t\tm.nameInput.SetValue(\"my-custom-project\")\n96\t\tm = pressEnter(m) // name → dir\n97\t\twd, _ := os.Getwd()\n98\t\texpected := filepath.Join(wd, \"my-custom-project\")\n99\t\tif m.dirInput.Value() != expected {\n100\t\t\tt.Errorf(\"expected dir %q, got %q\", expected, m.dirInput.Value())\n101\t\t}\n102\t}\n103\t\n104\t// --- detection caching during input phases ---\n105\t\n106\tfunc TestUpdate_DetectionCachedDuringNameInput(t *testing.T) {\n107\t\tm := sendMsg(New(), detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n108\t\tif m.phase != phaseNameInput {\n109\t\t\tt.Errorf(\"phase should stay phaseNameInput, got %d\", m.phase)\n110\t\t}\n111\t\tif m.envs == nil {\n112\t\t\tt.Error(\"envs should be cached (non-nil)\")\n113\t\t}\n114\t}\n115\t\n116\tfunc TestUpdate_DetectionCachedDuringDirInput(t *testing.T) {\n117\t\tm := pressEnter(New()) // go to dir phase\n118\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n119\t\tif m.phase != phaseDirectoryInput {\n120\t\t\tt.Errorf(\"phase should stay phaseDirectoryInput, got %d\", m.phase)\n121\t\t}\n122\t\tif m.envs == nil {\n123\t\t\tt.Error(\"envs should be cached (non-nil)\")\n124\t\t}\n125\t}\n126\t\n127\t// --- advancing from directory phase ---\n128\t\n129\tfunc TestUpdate_EnterOnDir_NoEnvs_GoesToError(t *testing.T) {\n130\t\tm := pressEnter(New())                                                     // → dir\n131\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})   // cache: empty\n132\t\tm = pressEnter(m)                                                          // confirm dir\n133\t\tif m.phase != phaseError {\n134\t\t\tt.Errorf(\"expected phaseError, got %d\", m.phase)\n135\t\t}\n136\t}\n137\t\n138\tfunc TestUpdate_EnterOnDir_OneEnv_GoesToSetupConfig(t *testing.T) {\n139\t\tm := pressEnter(New())                                                                    // → dir\n140\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}}) // cache: one\n141\t\tm = pressEnter(m)                                                                         // confirm dir\n142\t\tif m.phase != phaseSetupConfig {\n143\t\t\tt.Errorf(\"expected phaseSetupConfig, got %d\", m.phase)\n144\t\t}\n145\t}\n146\t\n147\tfunc TestUpdate_EnterOnDir_MultipleEnvs_GoesToSelection(t *testing.T) {\n148\t\tm := pressEnter(New()) // → dir\n149\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{\n150\t\t\tmakeDetectedEnv(\"DDEV\"),\n151\t\t\tmakeDetectedEnv(\"Warden\"),\n152\t\t}})\n153\t\tm = pressEnter(m) // confirm dir\n154\t\tif m.phase != phaseSelection {\n155\t\t\tt.Errorf(\"expected phaseSelection, got %d\", m.phase)\n156\t\t}\n157\t}\n158\t\n159\tfunc TestUpdate_EnterOnDir_StillDetecting_GoesToDetecting(t *testing.T) {\n160\t\tm := pressEnter(New()) // → dir (envs still nil)\n161\t\tm = pressEnter(m)      // confirm dir without cached envs\n162\t\tif m.phase != phaseDetecting {\n163\t\t\tt.Errorf(\"expected phaseDetecting, got %d\", m.phase)\n164\t\t}\n165\t}\n166\t\n167\t// --- install done ---\n168\t\n169\tfunc TestUpdate_InstallDone_GoesToOpenBrowser(t *testing.T) {\n170\t\tm := sendMsg(New(), installDoneMsg{err: nil})\n171\t\tif m.phase != phaseOpenBrowser {\n172\t\t\tt.Errorf(\"expected phaseOpenBrowser, got %d\", m.phase)\n173\t\t}\n174\t}\n175\t\n176\tfunc TestUpdate_InstallDone_WithError_GoesToInstallDone(t *testing.T) {\n177\t\tm := sendMsg(New(), installDoneMsg{err: fmt.Errorf(\"something failed\")})\n178\t\tif m.phase != phaseInstallDone {\n179\t\t\tt.Errorf(\"expected phaseInstallDone, got %d\", m.phase)\n180\t\t}\n181\t}\n182\t\n183\t// --- selection phase cursor ---\n184\t\n185\tfunc TestUpdate_SelectionCursorMovement(t *testing.T) {\n186\t\tm := New()\n187\t\tm.phase = phaseSelection\n188\t\tm.envs = []detector.DetectedEnvironment{\n189\t\t\tmakeDetectedEnv(\"DDEV\"),\n190\t\t\tmakeDetectedEnv(\"Warden\"),\n191\t\t}\n192\t\tm.cursor = 0\n193\t\n194\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n195\t\tif m.cursor != 1 {\n196\t\t\tt.Errorf(\"expected cursor 1 after down, got %d\", m.cursor)\n197\t\t}\n198\t\n199\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n200\t\tif m.cursor != 0 {\n201\t\t\tt.Errorf(\"expected cursor 0 after up, got %d\", m.cursor)\n202\t\t}\n203\t}\n204\t\n205\tfunc TestUpdate_SelectionCursor_DoesNotGoOutOfBounds(t *testing.T) {\n206\t\tm := New()\n207\t\tm.phase = phaseSelection\n208\t\tm.envs = []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}\n209\t\tm.cursor = 0\n210\t\n211\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n212\t\tif m.cursor != 0 {\n213\t\t\tt.Errorf(\"cursor should stay at 0 at end of list, got %d\", m.cursor)\n214\t\t}\n215\t\n216\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n217\t\tif m.cursor != 0 {\n218\t\t\tt.Errorf(\"cursor should stay at 0 at start of list, got %d\", m.cursor)\n219\t\t}\n220\t}\n221\t\n222\t// --- view content ---\n223\t\n224\t// TestView_SelectionShowsNameAndVersion verifies that the selection screen\n225\t// includes both the environment name and version (acceptance criterion 2).\n226\tfunc TestView_SelectionShowsNameAndVersion(t *testing.T) {\n227\t\tm := New()\n228\t\tm.phase = phaseSelection\n229\t\tm.envs = []detector.DetectedEnvironment{\n230\t\t\t{\n231\t\t\t\tEnv:      detector.Environment{Name: \"DDEV\", Version: \"1.23.4\"},\n232\t\t\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: \"DDEV\", InstallURL: \"https://ddev.example.com\"}},\n233\t\t\t},\n234\t\t}\n235\t\tview := m.View()\n236\t\tif !contains(view, \"DDEV\") {\n237\t\t\tt.Error(\"selection view should contain environment name 'DDEV'\")\n238\t\t}\n239\t\tif !contains(view, \"1.23.4\") {\n240\t\t\tt.Error(\"selection view should contain environment version '1.23.4'\")\n241\t\t}\n242\t}\n243\t\n244\t// TestView_ErrorShowsInstallLinks verifies that the error phase shows\n245\t// links for each known environment (acceptance criterion 5).\n246\tfunc TestView_ErrorShowsInstallLinks(t *testing.T) {\n247\t\tm := New()\n248\t\tm.phase = phaseError\n249\t\tview := m.View()\n250\t\tfor _, info := range detector.AllDetectorInfos() {\n251\t\t\tif !contains(view, info.InstallURL) {\n252\t\t\t\tt.Errorf(\"error view should contain install URL %q for %q\", info.InstallURL, info.Name)\n253\t\t\t}\n254\t\t}\n255\t}\n256\t\n257\t// TestView_DetectingPhaseShowsSpinner verifies that the detecting phase\n258\t// renders spinner output (acceptance criterion 6).\n259\tfunc TestView_DetectingPhaseShowsSpinner(t *testing.T) {\n260\t\tm := New()\n261\t\tm.phase = phaseDetecting\n262\t\tview := m.View()\n263\t\tif !contains(view, \"Detecting\") {\n264\t\t\tt.Error(\"detecting phase view should contain 'Detecting'\")\n265\t\t}\n266\t}\n267\t\n268\t// --- admin credentials form (US-003) ---\n269\t\n270\t// advanceToSetupConfig drives the model through name → dir → setup config using a mock env.\n271\tfunc advanceToSetupConfig(t *testing.T) Model {\n272\t\tt.Helper()\n273\t\tm := pressEnter(New()) // name → dir\n274\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}})\n275\t\tm = pressEnter(m) // dir → setup config\n276\t\tif m.phase != phaseSetupConfig {\n277\t\t\tt.Fatalf(\"expected phaseSetupConfig, got %d\", m.phase)\n278\t\t}\n279\t\treturn m\n280\t}\n281\t\n282\t// TestSetupConfig_HasAllFiveFields verifies the setup form view renders all five\n283\t// required admin credential field labels.\n284\tfunc TestSetupConfig_HasAllFiveFields(t *testing.T) {\n285\t\tm := advanceToSetupConfig(t)\n286\t\tview := m.View()\n287\t\tfor _, want := range []string{\"Admin user\", \"Admin password\", \"Admin email\", \"Admin firstname\", \"Admin lastname\"} {\n288\t\t\tif !contains(view, want) {\n289\t\t\t\tt.Errorf(\"setup config view missing field label %q\", want)\n290\t\t\t}\n291\t\t}\n292\t}\n293\t\n294\t// TestSetupConfig_DefaultsPreFilled verifies that all five admin fields have\n295\t// sensible (non-empty) default values after initSetupInputs.\n296\tfunc TestSetupConfig_DefaultsPreFilled(t *testing.T) {\n297\t\tm := advanceToSetupConfig(t)\n298\t\tfor i, f := range setupFieldDefs {\n299\t\t\tval := m.setupInputs[i].Value()\n300\t\t\tif val == \"\" {\n301\t\t\t\tt.Errorf(\"field %q should have a non-empty default, got empty string\", f.label)\n302\t\t\t}\n303\t\t}\n304\t}\n305\t\n306\t// TestSetupConfig_TabAdvancesField verifies Tab moves focus to the next field.\n307\tfunc TestSetupConfig_TabAdvancesField(t *testing.T) {\n308\t\tm := advanceToSetupConfig(t)\n309\t\t// Start at field 0 (admin user)\n310\t\tif m.setupFocus != 0 {\n311\t\t\tt.Fatalf(\"expected setupFocus 0, got %d\", m.setupFocus)\n312\t\t}\n313\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n314\t\tif m.inTogglePhase || m.setupFocus != 1 {\n315\t\t\tt.Errorf(\"Tab should move focus to field 1; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n316\t\t}\n317\t}\n318\t\n319\t// TestSetupConfig_ShiftTabGoesBack verifies Shift+Tab moves focus to the previous field.\n320\tfunc TestSetupConfig_ShiftTabGoesBack(t *testing.T) {\n321\t\tm := advanceToSetupConfig(t)\n322\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab}) // → field 1\n323\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyShiftTab})\n324\t\tif m.inTogglePhase || m.setupFocus != 0 {\n325\t\t\tt.Errorf(\"Shift+Tab should move back to field 0; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n326\t\t}\n327\t}\n328\t\n329\t// TestSetupConfig_ValidationRejectsEmpty verifies that clearing a field and\n330\t// pressing Enter on the last field triggers a validation error.\n331\tfunc TestSetupConfig_ValidationRejectsEmpty(t *testing.T) {\n332\t\tm := advanceToSetupConfig(t)\n333\t\t// Clear the admin user field (index 0)\n334\t\tm.setupInputs[0].SetValue(\"\")\n335\t\t// Navigate to the last admin field then to the last toggle and submit\n336\t\t// by pressing Enter on the last field in the form.\n337\t\t// Simulate being on the last hyva toggle (absPos == totalFields-1) with enter.\n338\t\t// Easier: set absPos to last and send enter directly via pressing tab many times.\n339\t\ttotalFields := len(m.setupInputs) + 2 // +2 for toggles\n340\t\tfor i := 0; i < totalFields-1; i++ {\n341\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n342\t\t}\n343\t\t// Now at the last field; press Enter → should trigger validation\n344\t\tm = pressEnter(m)\n345\t\tif m.setupError == \"\" {\n346\t\t\tt.Error(\"expected a setupError after submitting with an empty required field, got none\")\n347\t\t}\n348\t\tif m.phase == phaseSetupPreview {\n349\t\t\tt.Error(\"should not advance to phaseSetupPreview when validation fails\")\n350\t\t}\n351\t}\n352\t\n353\t// --- sample data toggle (US-004) ---\n354\t\n355\t// TestSampleData_DefaultIsOff verifies that the sample data toggle is off by default.\n356\tfunc TestSampleData_DefaultIsOff(t *testing.T) {\n357\t\tm := advanceToSetupConfig(t)\n358\t\tif m.installSampleData {\n359\t\t\tt.Error(\"installSampleData should be false by default\")\n360\t\t}\n361\t}\n362\t\n363\t// TestSampleData_ToggledBySpace verifies that pressing space on the sample data\n364\t// toggle switches it on, and pressing space again switches it off.\n365\tfunc TestSampleData_ToggledBySpace(t *testing.T) {\n366\t\tm := advanceToSetupConfig(t)\n367\t\n368\t\t// Tab through all admin fields to reach the sample data toggle\n369\t\tfor i := 0; i < len(setupFieldDefs); i++ {\n370\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n371\t\t}\n372\t\t// Now at sample data toggle (absPos == len(setupInputs))\n373\t\tif !m.inTogglePhase || m.toggleFocus != -2 {\n374\t\t\tt.Fatalf(\"expected focus on sample data toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n375\t\t}\n376\t\n377\t\t// Press space: should enable sample data\n378\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n379\t\tif !m.installSampleData {\n380\t\t\tt.Error(\"space should enable installSampleData\")\n381\t\t}\n382\t\n383\t\t// Press space again: should disable sample data\n384\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n385\t\tif m.installSampleData {\n386\t\t\tt.Error(\"second space should disable installSampleData\")\n387\t\t}\n388\t}\n389\t\n390\t// TestSampleData_ViewContainsToggle verifies the setup form renders the sample data toggle.\n391\tfunc TestSampleData_ViewContainsToggle(t *testing.T) {\n392\t\tm := advanceToSetupConfig(t)\n393\t\tview := m.View()\n394\t\tif !contains(view, \"Install sample data\") {\n395\t\t\tt.Error(\"setup config view should contain 'Install sample data' toggle\")\n396\t\t}\n397\t}\n398\t\n399\t// TestSampleData_ViewShowsChecked verifies the toggle renders as [x] when enabled.\n400\tfunc TestSampleData_ViewShowsChecked(t *testing.T) {\n401\t\tm := advanceToSetupConfig(t)\n402\t\tm.installSampleData = true\n403\t\tview := m.View()\n404\t\tif !contains(view, \"[x]\") {\n405\t\t\tt.Error(\"view should show [x] when installSampleData is true\")\n406\t\t}\n407\t}\n408\t\n409\t// --- Hyvä theme toggle (US-005) ---\n410\t\n411\t// navigateToHyvaToggle tabs through all admin fields and the sample data toggle\n412\t// to land on the Hyvä toggle.\n413\tfunc navigateToHyvaToggle(m Model) Model {\n414\t\t// len(setupFieldDefs) tabs → sample data toggle; one more → Hyvä toggle\n415\t\tfor i := 0; i < len(setupFieldDefs)+1; i++ {\n416\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n417\t\t}\n418\t\treturn m\n419\t}\n420\t\n421\t// TestHyva_DefaultIsOff verifies that the Hyvä toggle is off by default.\n422\tfunc TestHyva_DefaultIsOff(t *testing.T) {\n423\t\tm := advanceToSetupConfig(t)\n424\t\tif m.installHyva {\n425\t\t\tt.Error(\"installHyva should be false by default\")\n426\t\t}\n427\t}\n428\t\n429\t// TestHyva_ToggledBySpace verifies that pressing space on the Hyvä toggle\n430\t// enables it, and pressing space again disables it.\n431\tfunc TestHyva_ToggledBySpace(t *testing.T) {\n432\t\tm := advanceToSetupConfig(t)\n433\t\tm = navigateToHyvaToggle(m)\n434\t\n435\t\tif !m.inTogglePhase || m.toggleFocus != -1 {\n436\t\t\tt.Fatalf(\"expected focus on Hyvä toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n437\t\t}\n438\t\n439\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n440\t\tif !m.installHyva {\n441\t\t\tt.Error(\"space should enable installHyva\")\n442\t\t}\n443\t\n444\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n445\t\tif m.installHyva {\n446\t\t\tt.Error(\"second space should disable installHyva\")\n447\t\t}\n448\t}\n449\t\n450\t// TestHyva_ViewContainsToggle verifies the setup form renders the Hyvä toggle.\n451\tfunc TestHyva_ViewContainsToggle(t *testing.T) {\n452\t\tm := advanceToSetupConfig(t)\n453\t\tview := m.View()\n454\t\tif !contains(view, \"Install Hyv\") {\n455\t\t\tt.Error(\"setup config view should contain 'Install Hyvä' toggle label\")\n456\t\t}\n457\t}\n458\t\n459\t// TestHyva_ViewShowsChecked verifies the toggle renders as [x] when Hyvä is enabled.\n460\tfunc TestHyva_ViewShowsChecked(t *testing.T) {\n461\t\tm := advanceToSetupConfig(t)\n462\t\tm.installHyva = true\n463\t\tview := m.View()\n464\t\tif !contains(view, \"[x]\") {\n465\t\t\tt.Error(\"view should show [x] when installHyva is true\")\n466\t\t}\n467\t}\n468\t\n469\t// TestHyva_CredentialFieldsHiddenByDefault verifies that Hyvä repo/token fields\n470\t// are not shown when the toggle is off (AC2).\n471\tfunc TestHyva_CredentialFieldsHiddenByDefault(t *testing.T) {\n472\t\tm := advanceToSetupConfig(t)\n473\t\tview := m.View()\n474\t\tif contains(view, \"Repo URL\") {\n475\t\t\tt.Error(\"'Repo URL' field should not appear when installHyva is false\")\n476\t\t}\n477\t\tif contains(view, \"Auth token\") {\n478\t\t\tt.Error(\"'Auth token' field should not appear when installHyva is false\")\n479\t\t}\n480\t}\n481\t\n482\t// TestHyva_CredentialFieldsAppearsWhenEnabled verifies that enabling the toggle\n483\t// shows the Hyvä repo URL and auth token fields (AC2).\n484\tfunc TestHyva_CredentialFieldsAppearsWhenEnabled(t *testing.T) {\n485\t\tm := advanceToSetupConfig(t)\n486\t\tm.installHyva = true\n487\t\tview := m.View()\n488\t\tif !contains(view, \"Repo URL\") {\n489\t\t\tt.Error(\"'Repo URL' field should appear when installHyva is true\")\n490\t\t}\n491\t\tif !contains(view, \"Auth token\") {\n492\t\t\tt.Error(\"'Auth token' field should appear when installHyva is true\")\n493\t\t}\n494\t}\n495\t\n496\t// --- setup:install command preview (US-006) ---\n497\t\n498\t// advanceToSetupPreview drives the model through name → dir → setup config → preview.\n499\tfunc advanceToSetupPreview(t *testing.T) Model {\n500\t\tt.Helper()\n501\t\tm := advanceToSetupConfig(t)\n502\t\t// Navigate to the last field (Hyvä toggle) and press Enter to submit the form.\n503\t\ttotalFields := len(m.setupInputs) + 2 // +2 for sample data + hyvä toggles\n504\t\tfor i := 0; i < totalFields-1; i++ {\n505\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n506\t\t}\n507\t\tm = pressEnter(m) // submit form → phaseSetupPreview\n508\t\tif m.phase != phaseSetupPreview {\n509\t\t\tt.Fatalf(\"expected phaseSetupPreview, got %d\", m.phase)\n510\t\t}\n511\t\treturn m\n512\t}\n513\t\n514\t// TestPreview_ShowsSetupInstallCommand verifies the preview screen renders the\n515\t// bin/magento setup:install command prefix.\n516\tfunc TestPreview_ShowsSetupInstallCommand(t *testing.T) {\n517\t\tm := advanceToSetupPreview(t)\n518\t\tview := m.View()\n519\t\tif !contains(view, \"setup:install\") {\n520\t\t\tt.Error(\"preview view should contain 'setup:install'\")\n521\t\t}\n522\t}\n523\t\n524\t// TestPreview_ShowsAllFlags verifies that all flags returned by SetupInstallFlags\n525\t// appear in the preview view.\n526\tfunc TestPreview_ShowsAllFlags(t *testing.T) {\n527\t\tm := advanceToSetupPreview(t)\n528\t\tview := m.View()\n529\t\tfor _, flag := range m.selected.Detector.SetupInstallFlags(&m.installCfg) {\n530\t\t\tif !contains(view, flag.Flag) {\n531\t\t\t\tt.Errorf(\"preview view should contain flag %q\", flag.Flag)\n532\t\t\t}\n533\t\t}\n534\t}\n535\t\n536\t// TestPreview_EditableValuesAppear verifies that editable (user-supplied) values\n537\t// appear in the preview view.\n538\tfunc TestPreview_EditableValuesAppear(t *testing.T) {\n539\t\tm := advanceToSetupPreview(t)\n540\t\tview := m.View()\n541\t\t// The admin user default is \"admin\"; it should appear as an editable value.\n542\t\tif !contains(view, m.installCfg.AdminUser) {\n543\t\t\tt.Errorf(\"preview view should show editable admin user value %q\", m.installCfg.AdminUser)\n544\t\t}\n545\t}\n546\t\n547\t// TestPreview_ScrollsWithArrowKeys verifies that up/down arrow keys change previewScroll.\n548\tfunc TestPreview_ScrollsWithArrowKeys(t *testing.T) {\n549\t\tm := advanceToSetupPreview(t)\n550\t\t// Set window height so there is room to scroll.\n551\t\tm.windowHeight = 5\n552\t\n553\t\tinitial := m.previewScroll\n554\t\n555\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n556\t\tif m.previewScroll == initial {\n557\t\t\t// It's possible all lines fit in the window; just verify no panic occurred.\n558\t\t\t// Skip if the command has fewer lines than the window.\n559\t\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n560\t\t\tmaxVisible := m.windowHeight - 10\n561\t\t\tif maxVisible < 3 {\n562\t\t\t\tmaxVisible = 3\n563\t\t\t}\n564\t\t\tif totalLines <= maxVisible {\n565\t\t\t\tt.Skip(\"not enough lines to scroll; skipping\")\n566\t\t\t}\n567\t\t\tt.Errorf(\"down arrow should increase previewScroll (was %d, still %d)\", initial, m.previewScroll)\n568\t\t}\n569\t\n570\t\t// Scroll back up\n571\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n572\t\tif m.previewScroll != initial {\n573\t\t\tt.Errorf(\"up arrow should decrease previewScroll back to %d, got %d\", initial, m.previewScroll)\n574\t\t}\n575\t}\n576\t\n577\t// TestPreview_UpArrowDoesNotGoNegative verifies that previewScroll stays >= 0.\n578\tfunc TestPreview_UpArrowDoesNotGoNegative(t *testing.T) {\n579\t\tm := advanceToSetupPreview(t)\n580\t\tm.previewScroll = 0\n581\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n582\t\tif m.previewScroll < 0 {\n583\t\t\tt.Errorf(\"previewScroll should not go negative, got %d\", m.previewScroll)\n584\t\t}\n585\t}\n586\t\n587\t// TestPreview_BackspaceGoesBackToSetupConfig verifies that pressing Backspace\n588\t// returns to the admin credentials form.\n589\tfunc TestPreview_BackspaceGoesBackToSetupConfig(t *testing.T) {\n590\t\tm := advanceToSetupPreview(t)\n591\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyBackspace})\n592\t\tif m.phase != phaseSetupConfig {\n593\t\t\tt.Errorf(\"Backspace should return to phaseSetupConfig, got %d\", m.phase)\n594\t\t}\n595\t}\n596\t\n597\t// TestPreview_EnterThenSudoCachedAdvancesToInstall verifies that pressing Enter on\n598\t// the preview screen and receiving the sudoCachedMsg transitions to phaseInstalling.\n599\tfunc TestPreview_EnterThenSudoCachedAdvancesToInstall(t *testing.T) {\n600\t\tm := advanceToSetupPreview(t)\n601\t\t// Enter schedules sudo -v via tea.ExecProcess (a Cmd, not a phase change).\n602\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyEnter})\n603\t\t// Simulate sudo completing successfully.\n604\t\tm = sendMsg(m, sudoCachedMsg{err: nil})\n605\t\tif m.phase != phaseInstalling {\n606\t\t\tt.Errorf(\"after Enter + sudoCachedMsg, expected phaseInstalling, got %d\", m.phase)\n607\t\t}\n608\t}\n609\t\n610\tfunc contains(s, substr string) bool {\n611\t\treturn len(s) >= len(substr) && (s == substr || len(substr) == 0 ||\n612\t\t\tfunc() bool {\n613\t\t\t\tfor i := 0; i <= len(s)-len(substr); i++ {\n614\t\t\t\t\tif s[i:i+len(substr)] == substr {\n615\t\t\t\t\t\treturn true\n616\t\t\t\t\t}\n617\t\t\t\t}\n618\t\t\t\treturn false\n619\t\t\t}())\n620\t}\n621\t"}]},"parent_tool_use_id":null,"session_id":"258e2b76-815d-4c27-8bd0-a6a296178c24","uuid":"82b192da-9658-4c8e-afbf-4697af466728","timestamp":"2026-04-14T19:33:49.721Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/tui/tui_test.go","content":"package tui\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\ttea \"github.com/charmbracelet/bubbletea\"\n\t\"github.com/mage-os/mage-os-install/internal/detector\"\n)\n\n// mockDetector satisfies the detector.Detector interface for tests.\ntype mockDetector struct {\n\tinfo       detector.DetectorInfo\n\tenv        *detector.Environment\n\tinstallErr error\n}\n\nfunc (d *mockDetector) Info() detector.DetectorInfo            { return d.info }\nfunc (d *mockDetector) Steps() []detector.Step                 { return nil }\nfunc (d *mockDetector) PrepareSteps(_ *detector.Config)        {}\nfunc (d *mockDetector) Detect() (*detector.Environment, error) { return d.env, nil }\nfunc (d *mockDetector) Install(cfg *detector.Config) error     { return d.installErr }\nfunc (d *mockDetector) SetupInstallFlags(cfg *detector.Config) []detector.SetupFlag {\n\treturn []detector.SetupFlag{\n\t\t{Flag: \"--db-host\", Value: \"db\", Editable: false},\n\t\t{Flag: \"--admin-user\", Value: cfg.AdminUser, Editable: true},\n\t\t{Flag: \"--admin-password\", Value: cfg.AdminPassword, Editable: true},\n\t}\n}\nfunc (d *mockDetector) SetupCommandPrefix() string { return \"mock exec bin/magento setup:install\" }\nfunc (d *mockDetector) BaseURL(projectName string) string {\n\treturn \"https://\" + projectName + \".test\"\n}\n\n// sendMsg sends a message into the model and returns the updated model.\n// The returned tea.Cmd is discarded — no side-effects run during tests.\nfunc sendMsg(m Model, msg tea.Msg) Model {\n\tnewModel, _ := m.Update(msg)\n\treturn newModel.(Model)\n}\n\nfunc pressEnter(m Model) Model {\n\treturn sendMsg(m, tea.KeyMsg{Type: tea.KeyEnter})\n}\n\n// makeDetectedEnv builds a DetectedEnvironment backed by a mockDetector.\nfunc makeDetectedEnv(name string) detector.DetectedEnvironment {\n\treturn detector.DetectedEnvironment{\n\t\tEnv:      detector.Environment{Name: name, Version: \"1.0.0\"},\n\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: name, InstallURL: \"https://example.com\"}},\n\t}\n}\n\n// --- initial state ---\n\nfunc TestNew_StartsInNameInputPhase(t *testing.T) {\n\tm := New()\n\tif m.phase != phaseNameInput {\n\t\tt.Errorf(\"expected phaseNameInput, got %d\", m.phase)\n\t}\n}\n\nfunc TestNew_NameInputMatchesOriginalName(t *testing.T) {\n\tm := New()\n\tif m.nameInput.Value() == \"\" {\n\t\tt.Error(\"nameInput should have a non-empty default\")\n\t}\n\tif m.nameInput.Value() != m.originalName {\n\t\tt.Errorf(\"nameInput.Value() %q should equal originalName %q\", m.nameInput.Value(), m.originalName)\n\t}\n}\n\n// --- name → directory phase ---\n\nfunc TestUpdate_EnterOnNameGoesToDirectoryPhase(t *testing.T) {\n\tm := pressEnter(New())\n\tif m.phase != phaseDirectoryInput {\n\t\tt.Errorf(\"expected phaseDirectoryInput, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_DirDefault_WhenNameUnchanged_IsCurrentDir(t *testing.T) {\n\tm := pressEnter(New()) // name → dir\n\twd, _ := os.Getwd()\n\tif m.dirInput.Value() != wd {\n\t\tt.Errorf(\"expected dir %q, got %q\", wd, m.dirInput.Value())\n\t}\n}\n\nfunc TestUpdate_DirDefault_WhenNameChanged_IsCwdPlusName(t *testing.T) {\n\tm := New()\n\tm.originalName = \"original\"\n\tm.nameInput.SetValue(\"my-custom-project\")\n\tm = pressEnter(m) // name → dir\n\twd, _ := os.Getwd()\n\texpected := filepath.Join(wd, \"my-custom-project\")\n\tif m.dirInput.Value() != expected {\n\t\tt.Errorf(\"expected dir %q, got %q\", expected, m.dirInput.Value())\n\t}\n}\n\n// --- detection caching during input phases ---\n\nfunc TestUpdate_DetectionCachedDuringNameInput(t *testing.T) {\n\tm := sendMsg(New(), detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n\tif m.phase != phaseNameInput {\n\t\tt.Errorf(\"phase should stay phaseNameInput, got %d\", m.phase)\n\t}\n\tif m.envs == nil {\n\t\tt.Error(\"envs should be cached (non-nil)\")\n\t}\n}\n\nfunc TestUpdate_DetectionCachedDuringDirInput(t *testing.T) {\n\tm := pressEnter(New()) // go to dir phase\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n\tif m.phase != phaseDirectoryInput {\n\t\tt.Errorf(\"phase should stay phaseDirectoryInput, got %d\", m.phase)\n\t}\n\tif m.envs == nil {\n\t\tt.Error(\"envs should be cached (non-nil)\")\n\t}\n}\n\n// --- advancing from directory phase ---\n\nfunc TestUpdate_EnterOnDir_NoEnvs_GoesToError(t *testing.T) {\n\tm := pressEnter(New())                                                     // → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})   // cache: empty\n\tm = pressEnter(m)                                                          // confirm dir\n\tif m.phase != phaseError {\n\t\tt.Errorf(\"expected phaseError, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_EnterOnDir_OneEnv_GoesToSetupConfig(t *testing.T) {\n\tm := pressEnter(New())                                                                    // → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}}) // cache: one\n\tm = pressEnter(m)                                                                         // confirm dir\n\tif m.phase != phaseSetupConfig {\n\t\tt.Errorf(\"expected phaseSetupConfig, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_EnterOnDir_MultipleEnvs_GoesToSelection(t *testing.T) {\n\tm := pressEnter(New()) // → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{\n\t\tmakeDetectedEnv(\"DDEV\"),\n\t\tmakeDetectedEnv(\"Warden\"),\n\t}})\n\tm = pressEnter(m) // confirm dir\n\tif m.phase != phaseSelection {\n\t\tt.Errorf(\"expected phaseSelection, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_EnterOnDir_StillDetecting_GoesToDetecting(t *testing.T) {\n\tm := pressEnter(New()) // → dir (envs still nil)\n\tm = pressEnter(m)      // confirm dir without cached envs\n\tif m.phase != phaseDetecting {\n\t\tt.Errorf(\"expected phaseDetecting, got %d\", m.phase)\n\t}\n}\n\n// --- install done ---\n\nfunc TestUpdate_InstallDone_GoesToOpenBrowser(t *testing.T) {\n\tm := sendMsg(New(), installDoneMsg{err: nil})\n\tif m.phase != phaseOpenBrowser {\n\t\tt.Errorf(\"expected phaseOpenBrowser, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_InstallDone_WithError_GoesToInstallDone(t *testing.T) {\n\tm := sendMsg(New(), installDoneMsg{err: fmt.Errorf(\"something failed\")})\n\tif m.phase != phaseInstallDone {\n\t\tt.Errorf(\"expected phaseInstallDone, got %d\", m.phase)\n\t}\n}\n\n// --- selection phase cursor ---\n\nfunc TestUpdate_SelectionCursorMovement(t *testing.T) {\n\tm := New()\n\tm.phase = phaseSelection\n\tm.envs = []detector.DetectedEnvironment{\n\t\tmakeDetectedEnv(\"DDEV\"),\n\t\tmakeDetectedEnv(\"Warden\"),\n\t}\n\tm.cursor = 0\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n\tif m.cursor != 1 {\n\t\tt.Errorf(\"expected cursor 1 after down, got %d\", m.cursor)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"expected cursor 0 after up, got %d\", m.cursor)\n\t}\n}\n\nfunc TestUpdate_SelectionCursor_DoesNotGoOutOfBounds(t *testing.T) {\n\tm := New()\n\tm.phase = phaseSelection\n\tm.envs = []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}\n\tm.cursor = 0\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"cursor should stay at 0 at end of list, got %d\", m.cursor)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"cursor should stay at 0 at start of list, got %d\", m.cursor)\n\t}\n}\n\n// --- view content ---\n\n// TestView_SelectionShowsNameAndVersion verifies that the selection screen\n// includes both the environment name and version (acceptance criterion 2).\nfunc TestView_SelectionShowsNameAndVersion(t *testing.T) {\n\tm := New()\n\tm.phase = phaseSelection\n\tm.envs = []detector.DetectedEnvironment{\n\t\t{\n\t\t\tEnv:      detector.Environment{Name: \"DDEV\", Version: \"1.23.4\"},\n\t\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: \"DDEV\", InstallURL: \"https://ddev.example.com\"}},\n\t\t},\n\t}\n\tview := m.View()\n\tif !contains(view, \"DDEV\") {\n\t\tt.Error(\"selection view should contain environment name 'DDEV'\")\n\t}\n\tif !contains(view, \"1.23.4\") {\n\t\tt.Error(\"selection view should contain environment version '1.23.4'\")\n\t}\n}\n\n// TestView_ErrorShowsInstallLinks verifies that the error phase shows\n// links for each known environment (acceptance criterion 5).\nfunc TestView_ErrorShowsInstallLinks(t *testing.T) {\n\tm := New()\n\tm.phase = phaseError\n\tview := m.View()\n\tfor _, info := range detector.AllDetectorInfos() {\n\t\tif !contains(view, info.InstallURL) {\n\t\t\tt.Errorf(\"error view should contain install URL %q for %q\", info.InstallURL, info.Name)\n\t\t}\n\t}\n}\n\n// TestView_DetectingPhaseShowsSpinner verifies that the detecting phase\n// renders spinner output (acceptance criterion 6).\nfunc TestView_DetectingPhaseShowsSpinner(t *testing.T) {\n\tm := New()\n\tm.phase = phaseDetecting\n\tview := m.View()\n\tif !contains(view, \"Detecting\") {\n\t\tt.Error(\"detecting phase view should contain 'Detecting'\")\n\t}\n}\n\n// --- admin credentials form (US-003) ---\n\n// advanceToSetupConfig drives the model through name → dir → setup config using a mock env.\nfunc advanceToSetupConfig(t *testing.T) Model {\n\tt.Helper()\n\tm := pressEnter(New()) // name → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}})\n\tm = pressEnter(m) // dir → setup config\n\tif m.phase != phaseSetupConfig {\n\t\tt.Fatalf(\"expected phaseSetupConfig, got %d\", m.phase)\n\t}\n\treturn m\n}\n\n// TestSetupConfig_HasAllFiveFields verifies the setup form view renders all five\n// required admin credential field labels.\nfunc TestSetupConfig_HasAllFiveFields(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tfor _, want := range []string{\"Admin user\", \"Admin password\", \"Admin email\", \"Admin firstname\", \"Admin lastname\"} {\n\t\tif !contains(view, want) {\n\t\t\tt.Errorf(\"setup config view missing field label %q\", want)\n\t\t}\n\t}\n}\n\n// TestSetupConfig_DefaultsPreFilled verifies that all five admin fields have\n// sensible (non-empty) default values after initSetupInputs.\nfunc TestSetupConfig_DefaultsPreFilled(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tfor i, f := range setupFieldDefs {\n\t\tval := m.setupInputs[i].Value()\n\t\tif val == \"\" {\n\t\t\tt.Errorf(\"field %q should have a non-empty default, got empty string\", f.label)\n\t\t}\n\t}\n}\n\n// TestSetupConfig_TabAdvancesField verifies Tab moves focus to the next field.\nfunc TestSetupConfig_TabAdvancesField(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\t// Start at field 0 (admin user)\n\tif m.setupFocus != 0 {\n\t\tt.Fatalf(\"expected setupFocus 0, got %d\", m.setupFocus)\n\t}\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\tif m.inTogglePhase || m.setupFocus != 1 {\n\t\tt.Errorf(\"Tab should move focus to field 1; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n\t}\n}\n\n// TestSetupConfig_ShiftTabGoesBack verifies Shift+Tab moves focus to the previous field.\nfunc TestSetupConfig_ShiftTabGoesBack(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab}) // → field 1\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyShiftTab})\n\tif m.inTogglePhase || m.setupFocus != 0 {\n\t\tt.Errorf(\"Shift+Tab should move back to field 0; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n\t}\n}\n\n// TestSetupConfig_ValidationRejectsEmpty verifies that clearing a field and\n// pressing Enter on the last field triggers a validation error.\nfunc TestSetupConfig_ValidationRejectsEmpty(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\t// Clear the admin user field (index 0)\n\tm.setupInputs[0].SetValue(\"\")\n\t// Navigate to the last admin field then to the last toggle and submit\n\t// by pressing Enter on the last field in the form.\n\t// Simulate being on the last hyva toggle (absPos == totalFields-1) with enter.\n\t// Easier: set absPos to last and send enter directly via pressing tab many times.\n\ttotalFields := len(m.setupInputs) + 2 // +2 for toggles\n\tfor i := 0; i < totalFields-1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\t// Now at the last field; press Enter → should trigger validation\n\tm = pressEnter(m)\n\tif m.setupError == \"\" {\n\t\tt.Error(\"expected a setupError after submitting with an empty required field, got none\")\n\t}\n\tif m.phase == phaseSetupPreview {\n\t\tt.Error(\"should not advance to phaseSetupPreview when validation fails\")\n\t}\n}\n\n// --- sample data toggle (US-004) ---\n\n// TestSampleData_DefaultIsOff verifies that the sample data toggle is off by default.\nfunc TestSampleData_DefaultIsOff(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tif m.installSampleData {\n\t\tt.Error(\"installSampleData should be false by default\")\n\t}\n}\n\n// TestSampleData_ToggledBySpace verifies that pressing space on the sample data\n// toggle switches it on, and pressing space again switches it off.\nfunc TestSampleData_ToggledBySpace(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\n\t// Tab through all admin fields to reach the sample data toggle\n\tfor i := 0; i < len(setupFieldDefs); i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\t// Now at sample data toggle (absPos == len(setupInputs))\n\tif !m.inTogglePhase || m.toggleFocus != -2 {\n\t\tt.Fatalf(\"expected focus on sample data toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n\t}\n\n\t// Press space: should enable sample data\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif !m.installSampleData {\n\t\tt.Error(\"space should enable installSampleData\")\n\t}\n\n\t// Press space again: should disable sample data\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif m.installSampleData {\n\t\tt.Error(\"second space should disable installSampleData\")\n\t}\n}\n\n// TestSampleData_ViewContainsToggle verifies the setup form renders the sample data toggle.\nfunc TestSampleData_ViewContainsToggle(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif !contains(view, \"Install sample data\") {\n\t\tt.Error(\"setup config view should contain 'Install sample data' toggle\")\n\t}\n}\n\n// TestSampleData_ViewShowsChecked verifies the toggle renders as [x] when enabled.\nfunc TestSampleData_ViewShowsChecked(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installSampleData = true\n\tview := m.View()\n\tif !contains(view, \"[x]\") {\n\t\tt.Error(\"view should show [x] when installSampleData is true\")\n\t}\n}\n\n// --- Hyvä theme toggle (US-005) ---\n\n// navigateToHyvaToggle tabs through all admin fields and the sample data toggle\n// to land on the Hyvä toggle.\nfunc navigateToHyvaToggle(m Model) Model {\n\t// len(setupFieldDefs) tabs → sample data toggle; one more → Hyvä toggle\n\tfor i := 0; i < len(setupFieldDefs)+1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\treturn m\n}\n\n// TestHyva_DefaultIsOff verifies that the Hyvä toggle is off by default.\nfunc TestHyva_DefaultIsOff(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tif m.installHyva {\n\t\tt.Error(\"installHyva should be false by default\")\n\t}\n}\n\n// TestHyva_ToggledBySpace verifies that pressing space on the Hyvä toggle\n// enables it, and pressing space again disables it.\nfunc TestHyva_ToggledBySpace(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm = navigateToHyvaToggle(m)\n\n\tif !m.inTogglePhase || m.toggleFocus != -1 {\n\t\tt.Fatalf(\"expected focus on Hyvä toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif !m.installHyva {\n\t\tt.Error(\"space should enable installHyva\")\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif m.installHyva {\n\t\tt.Error(\"second space should disable installHyva\")\n\t}\n}\n\n// TestHyva_ViewContainsToggle verifies the setup form renders the Hyvä toggle.\nfunc TestHyva_ViewContainsToggle(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif !contains(view, \"Install Hyv\") {\n\t\tt.Error(\"setup config view should contain 'Install Hyvä' toggle label\")\n\t}\n}\n\n// TestHyva_ViewShowsChecked verifies the toggle renders as [x] when Hyvä is enabled.\nfunc TestHyva_ViewShowsChecked(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installHyva = true\n\tview := m.View()\n\tif !contains(view, \"[x]\") {\n\t\tt.Error(\"view should show [x] when installHyva is true\")\n\t}\n}\n\n// TestHyva_CredentialFieldsHiddenByDefault verifies that Hyvä repo/token fields\n// are not shown when the toggle is off (AC2).\nfunc TestHyva_CredentialFieldsHiddenByDefault(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif contains(view, \"Repo URL\") {\n\t\tt.Error(\"'Repo URL' field should not appear when installHyva is false\")\n\t}\n\tif contains(view, \"Auth token\") {\n\t\tt.Error(\"'Auth token' field should not appear when installHyva is false\")\n\t}\n}\n\n// TestHyva_CredentialFieldsAppearsWhenEnabled verifies that enabling the toggle\n// shows the Hyvä repo URL and auth token fields (AC2).\nfunc TestHyva_CredentialFieldsAppearsWhenEnabled(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installHyva = true\n\tview := m.View()\n\tif !contains(view, \"Repo URL\") {\n\t\tt.Error(\"'Repo URL' field should appear when installHyva is true\")\n\t}\n\tif !contains(view, \"Auth token\") {\n\t\tt.Error(\"'Auth token' field should appear when installHyva is true\")\n\t}\n}\n\n// --- setup:install command preview (US-006) ---\n\n// advanceToSetupPreview drives the model through name → dir → setup config → preview.\nfunc advanceToSetupPreview(t *testing.T) Model {\n\tt.Helper()\n\tm := advanceToSetupConfig(t)\n\t// Navigate to the last field (Hyvä toggle) and press Enter to submit the form.\n\ttotalFields := len(m.setupInputs) + 2 // +2 for sample data + hyvä toggles\n\tfor i := 0; i < totalFields-1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\tm = pressEnter(m) // submit form → phaseSetupPreview\n\tif m.phase != phaseSetupPreview {\n\t\tt.Fatalf(\"expected phaseSetupPreview, got %d\", m.phase)\n\t}\n\treturn m\n}\n\n// TestPreview_ShowsSetupInstallCommand verifies the preview screen renders the\n// bin/magento setup:install command prefix.\nfunc TestPreview_ShowsSetupInstallCommand(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tview := m.View()\n\tif !contains(view, \"setup:install\") {\n\t\tt.Error(\"preview view should contain 'setup:install'\")\n\t}\n}\n\n// TestPreview_ShowsAllFlags verifies that all flags returned by SetupInstallFlags\n// appear in the preview view.\nfunc TestPreview_ShowsAllFlags(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tview := m.View()\n\tfor _, flag := range m.selected.Detector.SetupInstallFlags(&m.installCfg) {\n\t\tif !contains(view, flag.Flag) {\n\t\t\tt.Errorf(\"preview view should contain flag %q\", flag.Flag)\n\t\t}\n\t}\n}\n\n// TestPreview_EditableValuesAppear verifies that editable (user-supplied) values\n// appear in the preview view.\nfunc TestPreview_EditableValuesAppear(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tview := m.View()\n\t// The admin user default is \"admin\"; it should appear as an editable value.\n\tif !contains(view, m.installCfg.AdminUser) {\n\t\tt.Errorf(\"preview view should show editable admin user value %q\", m.installCfg.AdminUser)\n\t}\n}\n\n// TestPreview_ScrollsWithArrowKeys verifies that up/down arrow keys change previewScroll.\nfunc TestPreview_ScrollsWithArrowKeys(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\t// Set window height so there is room to scroll.\n\tm.windowHeight = 5\n\n\tinitial := m.previewScroll\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n\tif m.previewScroll == initial {\n\t\t// It's possible all lines fit in the window; just verify no panic occurred.\n\t\t// Skip if the command has fewer lines than the window.\n\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n\t\tmaxVisible := m.windowHeight - 10\n\t\tif maxVisible < 3 {\n\t\t\tmaxVisible = 3\n\t\t}\n\t\tif totalLines <= maxVisible {\n\t\t\tt.Skip(\"not enough lines to scroll; skipping\")\n\t\t}\n\t\tt.Errorf(\"down arrow should increase previewScroll (was %d, still %d)\", initial, m.previewScroll)\n\t}\n\n\t// Scroll back up\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.previewScroll != initial {\n\t\tt.Errorf(\"up arrow should decrease previewScroll back to %d, got %d\", initial, m.previewScroll)\n\t}\n}\n\n// TestPreview_UpArrowDoesNotGoNegative verifies that previewScroll stays >= 0.\nfunc TestPreview_UpArrowDoesNotGoNegative(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tm.previewScroll = 0\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.previewScroll < 0 {\n\t\tt.Errorf(\"previewScroll should not go negative, got %d\", m.previewScroll)\n\t}\n}\n\n// TestPreview_BackspaceGoesBackToSetupConfig verifies that pressing Backspace\n// returns to the admin credentials form.\nfunc TestPreview_BackspaceGoesBackToSetupConfig(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyBackspace})\n\tif m.phase != phaseSetupConfig {\n\t\tt.Errorf(\"Backspace should return to phaseSetupConfig, got %d\", m.phase)\n\t}\n}\n\n// TestPreview_EnterThenSudoCachedAdvancesToInstall verifies that pressing Enter on\n// the preview screen and receiving the sudoCachedMsg transitions to phaseInstalling.\nfunc TestPreview_EnterThenSudoCachedAdvancesToInstall(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\t// Enter schedules sudo -v via tea.ExecProcess (a Cmd, not a phase change).\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyEnter})\n\t// Simulate sudo completing successfully.\n\tm = sendMsg(m, sudoCachedMsg{err: nil})\n\tif m.phase != phaseInstalling {\n\t\tt.Errorf(\"after Enter + sudoCachedMsg, expected phaseInstalling, got %d\", m.phase)\n\t}\n}\n\nfunc contains(s, substr string) bool {\n\treturn len(s) >= len(substr) && (s == substr || len(substr) == 0 ||\n\t\tfunc() bool {\n\t\t\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\t\t\tif s[i:i+len(substr)] == substr {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t}())\n}\n","numLines":621,"startLine":1,"totalLines":621}}}
