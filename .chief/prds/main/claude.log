{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F3sKx8VZqp1YKHa3fAyvuQ","type":"tool_result","content":"1\tpackage tui\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"os/exec\"\n7\t\t\"path/filepath\"\n8\t\t\"runtime\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/charmbracelet/bubbles/spinner\"\n12\t\t\"github.com/charmbracelet/bubbles/textinput\"\n13\t\ttea \"github.com/charmbracelet/bubbletea\"\n14\t\t\"github.com/charmbracelet/lipgloss\"\n15\t\t\"github.com/mage-os/mage-os-install/internal/detector\"\n16\t)\n17\t\n18\ttype phase int\n19\t\n20\tconst (\n21\t\tphaseNameInput phase = iota\n22\t\tphaseDirectoryInput\n23\t\tphaseDetecting\n24\t\tphaseSelection\n25\t\tphaseSetupConfig  // admin credentials form\n26\t\tphaseSetupPreview // full command preview before running\n27\t\tphaseInstalling\n28\t\tphaseOpenBrowser // ask whether to open the site after install\n29\t\tphaseInstallDone\n30\t\tphaseError\n31\t)\n32\t\n33\t// detectionDoneMsg is sent when environment detection completes.\n34\ttype detectionDoneMsg struct {\n35\t\tenvs []detector.DetectedEnvironment\n36\t}\n37\t\n38\t// installDoneMsg is sent when installation completes.\n39\ttype installDoneMsg struct {\n40\t\terr error\n41\t}\n42\t\n43\t// logMsg carries a single line of installer output.\n44\ttype logMsg string\n45\t\n46\t// stepStartMsg is sent when an installation step begins.\n47\ttype stepStartMsg struct{ index int }\n48\t\n49\t// sudoCachedMsg is sent after sudo -v completes (caching credentials).\n50\ttype sudoCachedMsg struct{ err error }\n51\t\n52\t// stepDoneMsg is sent when an installation step completes successfully.\n53\ttype stepDoneMsg struct{ index int }\n54\t\n55\ttype stepStatus int\n56\t\n57\tconst (\n58\t\tstepPending stepStatus = iota\n59\t\tstepRunning\n60\t\tstepDone\n61\t\tstepFailed\n62\t)\n63\t\n64\ttype installStep struct {\n65\t\tname   string\n66\t\tstatus stepStatus\n67\t}\n68\t\n69\t// Model is the main bubbletea model for the installer TUI.\n70\ttype Model struct {\n71\t\tphase         phase\n72\t\tspinner       spinner.Model\n73\t\tnameInput     textinput.Model\n74\t\toriginalName  string // the default seeded into nameInput, used to compute the dir default\n75\t\tdirInput      textinput.Model\n76\t\tenvs          []detector.DetectedEnvironment\n77\t\tcursor        int\n78\t\tselected      *detector.DetectedEnvironment\n79\t\tsetupInputs   []textinput.Model\n80\t\tsetupFocus    int\n81\t\tsetupError    string\n82\t\tinstallCfg    detector.Config\n83\t\tpreviewScroll int\n84\t\twindowHeight  int\n85\t\twindowWidth   int\n86\t\tlogCh         <-chan tea.Msg\n87\t\tlogLines      []string\n88\t\tinstallSteps  []installStep\n89\t\tinstallErr    error\n90\t\tbrowserOpened bool\n91\t\n92\t\t// Optional feature toggles and Hyvä credentials\n93\t\tinstallSampleData bool\n94\t\tinstallHyva       bool\n95\t\thyvaInputs        []textinput.Model\n96\t\t// toggleFocus tracks which toggle/section has focus:\n97\t\t//   -2 = sample data toggle\n98\t\t//   -1 = hyva toggle\n99\t\t//   0+ = hyva input field index\n100\t\ttoggleFocus    int\n101\t\tinTogglePhase  bool // true when focus is in the toggle/hyva section (not admin fields)\n102\t}\n103\t\n104\t// currentDirName returns the base name of the working directory.\n105\tfunc currentDirName() string {\n106\t\tif wd, err := os.Getwd(); err == nil {\n107\t\t\treturn filepath.Base(wd)\n108\t\t}\n109\t\treturn \"my-project\"\n110\t}\n111\t\n112\t// New creates the initial TUI model.\n113\tfunc New() Model {\n114\t\ts := spinner.New()\n115\t\ts.Spinner = spinner.Dot\n116\t\ts.Style = spinnerStyle\n117\t\n118\t\tdefaultName := currentDirName()\n119\t\n120\t\tti := textinput.New()\n121\t\tti.SetValue(defaultName)\n122\t\tti.Focus()\n123\t\tti.CharLimit = 64\n124\t\n125\t\treturn Model{\n126\t\t\tphase:        phaseNameInput,\n127\t\t\tspinner:      s,\n128\t\t\tnameInput:    ti,\n129\t\t\toriginalName: defaultName,\n130\t\t}\n131\t}\n132\t\n133\tfunc (m Model) Init() tea.Cmd {\n134\t\t// Start detection in the background immediately so results are ready\n135\t\t// by the time the user confirms the project name.\n136\t\treturn tea.Batch(m.spinner.Tick, detectEnvironments, textinput.Blink)\n137\t}\n138\t\n139\tfunc detectEnvironments() tea.Msg {\n140\t\treturn detectionDoneMsg{envs: detector.DetectAll()}\n141\t}\n142\t\n143\t// defaultDirectory returns the install directory based on whether the user\n144\t// changed the project name from the default.\n145\tfunc (m *Model) defaultDirectory() string {\n146\t\twd, err := os.Getwd()\n147\t\tif err != nil {\n148\t\t\twd = \".\"\n149\t\t}\n150\t\tif m.nameInput.Value() == m.originalName {\n151\t\t\treturn wd\n152\t\t}\n153\t\treturn filepath.Join(wd, m.nameInput.Value())\n154\t}\n155\t\n156\t// enterDirectoryPhase transitions to the directory input phase,\n157\t// pre-filling the input with the computed default.\n158\tfunc (m *Model) enterDirectoryPhase() tea.Cmd {\n159\t\tdi := textinput.New()\n160\t\tdi.SetValue(m.defaultDirectory())\n161\t\tdi.Focus()\n162\t\tdi.CharLimit = 256\n163\t\tm.dirInput = di\n164\t\tm.phase = phaseDirectoryInput\n165\t\treturn textinput.Blink\n166\t}\n167\t\n168\t// initInstallSteps loads the step list from the selected detector.\n169\tfunc (m *Model) initInstallSteps() {\n170\t\tm.installSteps = nil\n171\t\tfor _, s := range m.selected.Detector.Steps() {\n172\t\t\tm.installSteps = append(m.installSteps, installStep{name: s.Name, status: stepPending})\n173\t\t}\n174\t}\n175\t\n176\t// setupFieldDefs defines the user-editable fields shown in the Mage-OS setup form.\n177\tvar setupFieldDefs = []struct {\n178\t\tlabel string\n179\t\techo  textinput.EchoMode\n180\t}{\n181\t\t{label: \"Admin user\", echo: textinput.EchoNormal},\n182\t\t{label: \"Admin password\", echo: textinput.EchoPassword},\n183\t\t{label: \"Admin email\", echo: textinput.EchoNormal},\n184\t\t{label: \"Admin firstname\", echo: textinput.EchoNormal},\n185\t\t{label: \"Admin lastname\", echo: textinput.EchoNormal},\n186\t}\n187\t\n188\tvar setupFieldDefaults = []string{\"admin\", \"Admin123!\", \"admin@example.com\", \"Admin\", \"User\"}\n189\t\n190\t// hyvaFieldDefs defines the Hyvä credential fields.\n191\tvar hyvaFieldDefs = []struct {\n192\t\tlabel string\n193\t\techo  textinput.EchoMode\n194\t}{\n195\t\t{label: \"Repo URL\", echo: textinput.EchoNormal},\n196\t\t{label: \"Auth token\", echo: textinput.EchoPassword},\n197\t}\n198\t\n199\t// initSetupInputs creates fresh text inputs for the Mage-OS setup form.\n200\tfunc (m *Model) initSetupInputs() {\n201\t\tm.setupInputs = make([]textinput.Model, len(setupFieldDefs))\n202\t\tfor i, f := range setupFieldDefs {\n203\t\t\tti := textinput.New()\n204\t\t\tti.SetValue(setupFieldDefaults[i])\n205\t\t\tti.EchoMode = f.echo\n206\t\t\tti.CharLimit = 128\n207\t\t\tif i == 0 {\n208\t\t\t\tti.Focus()\n209\t\t\t}\n210\t\t\tm.setupInputs[i] = ti\n211\t\t}\n212\t\tm.setupFocus = 0\n213\t\n214\t\t// Initialize toggles and Hyvä inputs\n215\t\tm.installSampleData = false\n216\t\tm.installHyva = false\n217\t\tm.inTogglePhase = false\n218\t\tm.toggleFocus = -2 // sample data toggle\n219\t\tm.hyvaInputs = make([]textinput.Model, len(hyvaFieldDefs))\n220\t\tfor i, f := range hyvaFieldDefs {\n221\t\t\tti := textinput.New()\n222\t\t\tti.EchoMode = f.echo\n223\t\t\tti.CharLimit = 256\n224\t\t\tm.hyvaInputs[i] = ti\n225\t\t}\n226\t}\n227\t\n228\t// focusSetupInput focuses the input at index and blurs all others.\n229\tfunc (m *Model) focusSetupInput(index int) {\n230\t\tfor i := range m.setupInputs {\n231\t\t\tif i == index {\n232\t\t\t\tm.setupInputs[i].Focus()\n233\t\t\t} else {\n234\t\t\t\tm.setupInputs[i].Blur()\n235\t\t\t}\n236\t\t}\n237\t\tm.setupFocus = index\n238\t}\n239\t\n240\t// focusAbsolutePos sets focus based on absolute position across all form fields.\n241\t// Layout: [admin fields...] [sampledata toggle] [hyva toggle] [hyva fields if enabled...]\n242\tfunc (m *Model) focusAbsolutePos(pos int) {\n243\t\t// Blur everything\n244\t\tfor i := range m.setupInputs {\n245\t\t\tm.setupInputs[i].Blur()\n246\t\t}\n247\t\tfor i := range m.hyvaInputs {\n248\t\t\tm.hyvaInputs[i].Blur()\n249\t\t}\n250\t\n251\t\tsampleDataPos := len(m.setupInputs)\n252\t\thyvaTogglePos := sampleDataPos + 1\n253\t\n254\t\tif pos < sampleDataPos {\n255\t\t\t// Admin field\n256\t\t\tm.inTogglePhase = false\n257\t\t\tm.setupFocus = pos\n258\t\t\tm.setupInputs[pos].Focus()\n259\t\t} else if pos == sampleDataPos {\n260\t\t\t// Sample data toggle\n261\t\t\tm.inTogglePhase = true\n262\t\t\tm.toggleFocus = -2\n263\t\t} else if pos == hyvaTogglePos {\n264\t\t\t// Hyva toggle\n265\t\t\tm.inTogglePhase = true\n266\t\t\tm.toggleFocus = -1\n267\t\t} else {\n268\t\t\t// Hyva input field\n269\t\t\tm.inTogglePhase = true\n270\t\t\tm.toggleFocus = pos - hyvaTogglePos - 1\n271\t\t\tif m.toggleFocus < len(m.hyvaInputs) {\n272\t\t\t\tm.hyvaInputs[m.toggleFocus].Focus()\n273\t\t\t}\n274\t\t}\n275\t}\n276\t\n277\t// buildInstallConfig builds a Config from the current form and input values.\n278\tfunc (m *Model) buildInstallConfig() detector.Config {\n279\t\tcfg := detector.Config{\n280\t\t\tProjectName:       m.nameInput.Value(),\n281\t\t\tDirectory:         m.dirInput.Value(),\n282\t\t\tAdminUser:         m.setupInputs[0].Value(),\n283\t\t\tAdminPassword:     m.setupInputs[1].Value(),\n284\t\t\tAdminEmail:        m.setupInputs[2].Value(),\n285\t\t\tAdminFirstname:    m.setupInputs[3].Value(),\n286\t\t\tAdminLastname:     m.setupInputs[4].Value(),\n287\t\t\tInstallSampleData: m.installSampleData,\n288\t\t\tInstallHyva:       m.installHyva,\n289\t\t}\n290\t\tif m.installHyva {\n291\t\t\tcfg.HyvaRepoURL = m.hyvaInputs[0].Value()\n292\t\t\tcfg.HyvaAuthToken = m.hyvaInputs[1].Value()\n293\t\t}\n294\t\treturn cfg\n295\t}\n296\t\n297\t// advanceFromDetection moves the model to the correct phase based on\n298\t// how many environments were detected. The caller must have already\n299\t// populated m.envs.\n300\tfunc (m *Model) advanceFromDetection() tea.Cmd {\n301\t\tswitch len(m.envs) {\n302\t\tcase 0:\n303\t\t\tm.phase = phaseError\n304\t\tcase 1:\n305\t\t\tm.selected = &m.envs[0]\n306\t\t\tm.initSetupInputs()\n307\t\t\tm.phase = phaseSetupConfig\n308\t\t\treturn textinput.Blink\n309\t\tdefault:\n310\t\t\tm.phase = phaseSelection\n311\t\t}\n312\t\treturn nil\n313\t}\n314\t\n315\tfunc runInstall(d detector.Detector, cfg detector.Config) (<-chan tea.Msg, tea.Cmd) {\n316\t\tch := make(chan tea.Msg, 1000)\n317\t\n318\t\tgo func() {\n319\t\t\tif err := os.MkdirAll(cfg.Directory, 0755); err != nil {\n320\t\t\t\tch <- installDoneMsg{err: fmt.Errorf(\"could not create directory %s: %w\", cfg.Directory, err)}\n321\t\t\t\treturn\n322\t\t\t}\n323\t\t\tcfg.Log = func(line string) { ch <- logMsg(line) }\n324\t\t\tcfg.OnStepStart = func(i int) { ch <- stepStartMsg{index: i} }\n325\t\t\tcfg.OnStepDone = func(i int) { ch <- stepDoneMsg{index: i} }\n326\t\t\tch <- installDoneMsg{err: d.Install(&cfg)}\n327\t\t}()\n328\t\n329\t\treturn ch, waitForLog(ch)\n330\t}\n331\t\n332\t// waitForLog returns a Cmd that reads the next message from the log channel.\n333\tfunc waitForLog(ch <-chan tea.Msg) tea.Cmd {\n334\t\treturn func() tea.Msg {\n335\t\t\treturn <-ch\n336\t\t}\n337\t}\n338\t\n339\t// openBrowser opens url in the default system browser without blocking.\n340\tfunc openBrowser(url string) error {\n341\t\tvar cmd *exec.Cmd\n342\t\tswitch runtime.GOOS {\n343\t\tcase \"darwin\":\n344\t\t\tcmd = exec.Command(\"open\", url)\n345\t\tcase \"linux\":\n346\t\t\tcmd = exec.Command(\"xdg-open\", url)\n347\t\tcase \"windows\":\n348\t\t\tcmd = exec.Command(\"rundll32\", \"url.dll,FileProtocolHandler\", url)\n349\t\tdefault:\n350\t\t\treturn fmt.Errorf(\"unsupported platform: %s\", runtime.GOOS)\n351\t\t}\n352\t\treturn cmd.Start()\n353\t}\n354\t\n355\tfunc (m Model) Update(msg tea.Msg) (tea.Model, tea.Cmd) {\n356\t\tswitch msg := msg.(type) {\n357\t\tcase tea.KeyMsg:\n358\t\t\tswitch msg.String() {\n359\t\t\tcase \"ctrl+c\", \"q\":\n360\t\t\t\treturn m, tea.Quit\n361\t\t\t}\n362\t\n363\t\tcase tea.WindowSizeMsg:\n364\t\t\tm.windowHeight = msg.Height\n365\t\t\tm.windowWidth = msg.Width\n366\t\t\treturn m, nil\n367\t\n368\t\tcase spinner.TickMsg:\n369\t\t\tvar cmd tea.Cmd\n370\t\t\tm.spinner, cmd = m.spinner.Update(msg)\n371\t\t\treturn m, cmd\n372\t\n373\t\tcase detectionDoneMsg:\n374\t\t\tm.envs = msg.envs\n375\t\t\t// Cache results while the user is still filling in the input steps;\n376\t\t\t// we'll advance when they confirm the directory.\n377\t\t\tif m.phase == phaseNameInput || m.phase == phaseDirectoryInput {\n378\t\t\t\treturn m, nil\n379\t\t\t}\n380\t\t\treturn m, m.advanceFromDetection()\n381\t\n382\t\tcase sudoCachedMsg:\n383\t\t\t// sudo credentials are now cached (or failed); proceed with install.\n384\t\t\tm.phase = phaseInstalling\n385\t\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n386\t\t\tm.logCh = ch\n387\t\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n388\t\n389\t\tcase logMsg:\n390\t\t\tm.logLines = append(m.logLines, string(msg))\n391\t\t\treturn m, waitForLog(m.logCh)\n392\t\n393\t\tcase stepStartMsg:\n394\t\t\tif msg.index < len(m.installSteps) {\n395\t\t\t\tm.installSteps[msg.index].status = stepRunning\n396\t\t\t}\n397\t\t\treturn m, waitForLog(m.logCh)\n398\t\n399\t\tcase stepDoneMsg:\n400\t\t\tif msg.index < len(m.installSteps) {\n401\t\t\t\tm.installSteps[msg.index].status = stepDone\n402\t\t\t}\n403\t\t\treturn m, waitForLog(m.logCh)\n404\t\n405\t\tcase installDoneMsg:\n406\t\t\tm.installErr = msg.err\n407\t\t\tif msg.err != nil {\n408\t\t\t\tfor i := range m.installSteps {\n409\t\t\t\t\tif m.installSteps[i].status == stepRunning {\n410\t\t\t\t\t\tm.installSteps[i].status = stepFailed\n411\t\t\t\t\t\tbreak\n412\t\t\t\t\t}\n413\t\t\t\t}\n414\t\t\t\tm.phase = phaseInstallDone\n415\t\t\t} else {\n416\t\t\t\tm.browserOpened = false\n417\t\t\t\tm.phase = phaseOpenBrowser\n418\t\t\t}\n419\t\t\treturn m, nil\n420\t\t}\n421\t\n422\t\t// Handle name-input phase\n423\t\tif m.phase == phaseNameInput {\n424\t\t\tswitch msg := msg.(type) {\n425\t\t\tcase tea.KeyMsg:\n426\t\t\t\tswitch msg.String() {\n427\t\t\t\tcase \"enter\":\n428\t\t\t\t\treturn m, m.enterDirectoryPhase()\n429\t\t\t\tdefault:\n430\t\t\t\t\tvar cmd tea.Cmd\n431\t\t\t\t\tm.nameInput, cmd = m.nameInput.Update(msg)\n432\t\t\t\t\treturn m, cmd\n433\t\t\t\t}\n434\t\t\t}\n435\t\t}\n436\t\n437\t\t// Handle directory-input phase\n438\t\tif m.phase == phaseDirectoryInput {\n439\t\t\tswitch msg := msg.(type) {\n440\t\t\tcase tea.KeyMsg:\n441\t\t\t\tswitch msg.String() {\n442\t\t\t\tcase \"enter\":\n443\t\t\t\t\t// Detection may already be done (envs cached) or still running.\n444\t\t\t\t\tif m.envs != nil {\n445\t\t\t\t\t\treturn m, m.advanceFromDetection()\n446\t\t\t\t\t}\n447\t\t\t\t\tm.phase = phaseDetecting\n448\t\t\t\t\treturn m, nil\n449\t\t\t\tdefault:\n450\t\t\t\t\tvar cmd tea.Cmd\n451\t\t\t\t\tm.dirInput, cmd = m.dirInput.Update(msg)\n452\t\t\t\t\treturn m, cmd\n453\t\t\t\t}\n454\t\t\t}\n455\t\t}\n456\t\n457\t\t// Handle selection-phase keys\n458\t\tif m.phase == phaseSelection {\n459\t\t\tswitch msg := msg.(type) {\n460\t\t\tcase tea.KeyMsg:\n461\t\t\t\tswitch msg.String() {\n462\t\t\t\tcase \"up\", \"k\":\n463\t\t\t\t\tif m.cursor > 0 {\n464\t\t\t\t\t\tm.cursor--\n465\t\t\t\t\t}\n466\t\t\t\tcase \"down\", \"j\":\n467\t\t\t\t\tif m.cursor < len(m.envs)-1 {\n468\t\t\t\t\t\tm.cursor++\n469\t\t\t\t\t}\n470\t\t\t\tcase \"enter\":\n471\t\t\t\t\tm.selected = &m.envs[m.cursor]\n472\t\t\t\t\tm.initSetupInputs()\n473\t\t\t\t\tm.phase = phaseSetupConfig\n474\t\t\t\t\treturn m, textinput.Blink\n475\t\t\t\t}\n476\t\t\t}\n477\t\t}\n478\t\n479\t\t// Handle setup config form\n480\t\tif m.phase == phaseSetupConfig {\n481\t\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n482\t\t\t\t// Total fields: admin fields + sample data toggle + hyva toggle + (hyva fields if enabled)\n483\t\t\t\ttotalFields := len(m.setupInputs) + 2 // +2 for both toggles\n484\t\t\t\tif m.installHyva {\n485\t\t\t\t\ttotalFields += len(m.hyvaInputs)\n486\t\t\t\t}\n487\t\n488\t\t\t\t// Calculate current absolute position\n489\t\t\t\tabsPos := m.setupFocus\n490\t\t\t\tif m.inTogglePhase {\n491\t\t\t\t\tswitch {\n492\t\t\t\t\tcase m.toggleFocus == -2: // sample data toggle\n493\t\t\t\t\t\tabsPos = len(m.setupInputs)\n494\t\t\t\t\tcase m.toggleFocus == -1: // hyva toggle\n495\t\t\t\t\t\tabsPos = len(m.setupInputs) + 1\n496\t\t\t\t\tdefault: // hyva input field\n497\t\t\t\t\t\tabsPos = len(m.setupInputs) + 2 + m.toggleFocus\n498\t\t\t\t\t}\n499\t\t\t\t}\n500\t\n501\t\t\t\tswitch keyMsg.String() {\n502\t\t\t\tcase \"tab\", \"down\":\n503\t\t\t\t\tnewPos := absPos + 1\n504\t\t\t\t\tif newPos >= totalFields {\n505\t\t\t\t\t\tnewPos = 0\n506\t\t\t\t\t}\n507\t\t\t\t\tm.focusAbsolutePos(newPos)\n508\t\t\t\t\treturn m, textinput.Blink\n509\t\t\t\tcase \"shift+tab\", \"up\":\n510\t\t\t\t\tnewPos := absPos - 1\n511\t\t\t\t\tif newPos < 0 {\n512\t\t\t\t\t\tnewPos = totalFields - 1\n513\t\t\t\t\t}\n514\t\t\t\t\tm.focusAbsolutePos(newPos)\n515\t\t\t\t\treturn m, textinput.Blink\n516\t\t\t\tcase \"enter\":\n517\t\t\t\t\t// On toggles, Enter advances to the next field (use Space to toggle)\n518\t\t\t\t\tif m.inTogglePhase && (m.toggleFocus == -2 || m.toggleFocus == -1) {\n519\t\t\t\t\t\t// If this toggle is the last field, submit\n520\t\t\t\t\t\tif absPos == totalFields-1 {\n521\t\t\t\t\t\t\t// fall through to submit logic below\n522\t\t\t\t\t\t} else {\n523\t\t\t\t\t\t\tm.focusAbsolutePos(absPos + 1)\n524\t\t\t\t\t\t\treturn m, textinput.Blink\n525\t\t\t\t\t\t}\n526\t\t\t\t\t}\n527\t\t\t\t\t// On the last field, submit\n528\t\t\t\t\tif absPos == totalFields-1 {\n529\t\t\t\t\t\t// Validate admin fields\n530\t\t\t\t\t\tfor i, f := range setupFieldDefs {\n531\t\t\t\t\t\t\tif strings.TrimSpace(m.setupInputs[i].Value()) == \"\" {\n532\t\t\t\t\t\t\t\tm.setupError = f.label + \" is required\"\n533\t\t\t\t\t\t\t\tm.focusAbsolutePos(i)\n534\t\t\t\t\t\t\t\treturn m, textinput.Blink\n535\t\t\t\t\t\t\t}\n536\t\t\t\t\t\t}\n537\t\t\t\t\t\t// Validate Hyva fields if enabled\n538\t\t\t\t\t\tif m.installHyva {\n539\t\t\t\t\t\t\tfor i, f := range hyvaFieldDefs {\n540\t\t\t\t\t\t\t\tif strings.TrimSpace(m.hyvaInputs[i].Value()) == \"\" {\n541\t\t\t\t\t\t\t\t\tm.setupError = \"Hyvä \" + f.label + \" is required\"\n542\t\t\t\t\t\t\t\t\tm.focusAbsolutePos(len(m.setupInputs) + 2 + i)\n543\t\t\t\t\t\t\t\t\treturn m, textinput.Blink\n544\t\t\t\t\t\t\t\t}\n545\t\t\t\t\t\t\t}\n546\t\t\t\t\t\t}\n547\t\t\t\t\t\tm.setupError = \"\"\n548\t\t\t\t\t\tm.installCfg = m.buildInstallConfig()\n549\t\t\t\t\t\tm.selected.Detector.PrepareSteps(&m.installCfg)\n550\t\t\t\t\t\tm.previewScroll = 0\n551\t\t\t\t\t\tm.phase = phaseSetupPreview\n552\t\t\t\t\t\treturn m, nil\n553\t\t\t\t\t}\n554\t\t\t\t\t// Move to next field\n555\t\t\t\t\tm.focusAbsolutePos(absPos + 1)\n556\t\t\t\t\treturn m, textinput.Blink\n557\t\t\t\tcase \" \":\n558\t\t\t\t\t// Space on toggles\n559\t\t\t\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n560\t\t\t\t\t\tm.installSampleData = !m.installSampleData\n561\t\t\t\t\t\treturn m, nil\n562\t\t\t\t\t}\n563\t\t\t\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n564\t\t\t\t\t\tm.installHyva = !m.installHyva\n565\t\t\t\t\t\treturn m, nil\n566\t\t\t\t\t}\n567\t\t\t\t\t// Fall through to default for text input\n568\t\t\t\t\tfallthrough\n569\t\t\t\tdefault:\n570\t\t\t\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n571\t\t\t\t\t\tvar cmd tea.Cmd\n572\t\t\t\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n573\t\t\t\t\t\treturn m, cmd\n574\t\t\t\t\t}\n575\t\t\t\t\tif !m.inTogglePhase {\n576\t\t\t\t\t\tvar cmd tea.Cmd\n577\t\t\t\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n578\t\t\t\t\t\treturn m, cmd\n579\t\t\t\t\t}\n580\t\t\t\t}\n581\t\t\t}\n582\t\t\t// Forward non-key messages (e.g. blink) to focused input\n583\t\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n584\t\t\t\tvar cmd tea.Cmd\n585\t\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n586\t\t\t\treturn m, cmd\n587\t\t\t}\n588\t\t\tif !m.inTogglePhase {\n589\t\t\t\tvar cmd tea.Cmd\n590\t\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n591\t\t\t\treturn m, cmd\n592\t\t\t}\n593\t\t}\n594\t\n595\t\t// Handle setup preview\n596\t\tif m.phase == phaseSetupPreview {\n597\t\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n598\t\t\t\tswitch keyMsg.String() {\n599\t\t\t\tcase \"up\", \"k\":\n600\t\t\t\t\tif m.previewScroll > 0 {\n601\t\t\t\t\t\tm.previewScroll--\n602\t\t\t\t\t}\n603\t\t\t\tcase \"down\", \"j\":\n604\t\t\t\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n605\t\t\t\t\tmaxVisible := m.windowHeight - 10\n606\t\t\t\t\tif maxVisible < 3 {\n607\t\t\t\t\t\tmaxVisible = 3\n608\t\t\t\t\t}\n609\t\t\t\t\tif maxScroll := totalLines - maxVisible; m.previewScroll < maxScroll {\n610\t\t\t\t\t\tm.previewScroll++\n611\t\t\t\t\t}\n612\t\t\t\tcase \"enter\":\n613\t\t\t\t\tm.initInstallSteps()\n614\t\t\t\t\t// Cache sudo credentials before starting the install so that\n615\t\t\t\t\t// commands like \"ddev start\" (which modifies /etc/hosts) can\n616\t\t\t\t\t// use sudo without prompting inside the TUI.\n617\t\t\t\t\tc := exec.Command(\"sudo\", \"-v\")\n618\t\t\t\t\treturn m, tea.ExecProcess(c, func(err error) tea.Msg {\n619\t\t\t\t\t\treturn sudoCachedMsg{err: err}\n620\t\t\t\t\t})\n621\t\t\t\tcase \"b\", \"esc\":\n622\t\t\t\t\tm.phase = phaseSetupConfig\n623\t\t\t\t\treturn m, textinput.Blink\n624\t\t\t\t}\n625\t\t\t}\n626\t\t}\n627\t\n628\t\tif m.phase == phaseOpenBrowser {\n629\t\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n630\t\t\t\tswitch keyMsg.String() {\n631\t\t\t\tcase \"y\":\n632\t\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n633\t\t\t\t\t_ = openBrowser(url)\n634\t\t\t\t\tm.browserOpened = true\n635\t\t\t\t\tm.phase = phaseInstallDone\n636\t\t\t\t\treturn m, nil\n637\t\t\t\tcase \"n\", \"enter\", \"esc\":\n638\t\t\t\t\tm.phase = phaseInstallDone\n639\t\t\t\t\treturn m, nil\n640\t\t\t\t}\n641\t\t\t}\n642\t\t}\n643\t\n644\t\tif m.phase == phaseInstallDone || m.phase == phaseError {\n645\t\t\tif msg, ok := msg.(tea.KeyMsg); ok {\n646\t\t\t\tswitch msg.String() {\n647\t\t\t\tcase \"r\":\n648\t\t\t\t\tif m.phase == phaseInstallDone && m.installErr != nil {\n649\t\t\t\t\t\t// Find the failed step so we can resume from there.\n650\t\t\t\t\t\tfailedIdx := 0\n651\t\t\t\t\t\tfor i := range m.installSteps {\n652\t\t\t\t\t\t\tif m.installSteps[i].status == stepFailed {\n653\t\t\t\t\t\t\t\tfailedIdx = i\n654\t\t\t\t\t\t\t\tbreak\n655\t\t\t\t\t\t\t}\n656\t\t\t\t\t\t}\n657\t\t\t\t\t\t// Keep completed steps green; reset failed + pending to pending.\n658\t\t\t\t\t\tfor i := range m.installSteps {\n659\t\t\t\t\t\t\tif m.installSteps[i].status != stepDone {\n660\t\t\t\t\t\t\t\tm.installSteps[i].status = stepPending\n661\t\t\t\t\t\t\t}\n662\t\t\t\t\t\t}\n663\t\t\t\t\t\tm.logLines = nil\n664\t\t\t\t\t\tm.installErr = nil\n665\t\t\t\t\t\tm.installCfg.StartFromStep = failedIdx\n666\t\t\t\t\t\tm.phase = phaseInstalling\n667\t\t\t\t\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n668\t\t\t\t\t\tm.logCh = ch\n669\t\t\t\t\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n670\t\t\t\t\t}\n671\t\t\t\tcase \"enter\", \"q\", \"esc\":\n672\t\t\t\t\treturn m, tea.Quit\n673\t\t\t\t}\n674\t\t\t}\n675\t\t}\n676\t\n677\t\treturn m, nil\n678\t}\n679\t\n680\tfunc (m Model) View() string {\n681\t\tvar b strings.Builder\n682\t\n683\t\tb.WriteString(bannerStyle.Render(banner))\n684\t\tb.WriteString(\"\\n\")\n685\t\tb.WriteString(titleStyle.Render(\"Mage-OS Installer\"))\n686\t\tb.WriteString(\"\\n\\n\")\n687\t\n688\t\tswitch m.phase {\n689\t\tcase phaseNameInput:\n690\t\t\tb.WriteString(\"Project name:\\n\\n\")\n691\t\t\tb.WriteString(m.nameInput.View())\n692\t\t\tb.WriteString(\"\\n\\n\")\n693\t\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n694\t\n695\t\tcase phaseDirectoryInput:\n696\t\t\tb.WriteString(\"Install directory:\\n\\n\")\n697\t\t\tb.WriteString(m.dirInput.View())\n698\t\t\tb.WriteString(\"\\n\\n\")\n699\t\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n700\t\n701\t\tcase phaseDetecting:\n702\t\t\tb.WriteString(fmt.Sprintf(\"%s Detecting development environments...\\n\", m.spinner.View()))\n703\t\n704\t\tcase phaseSelection:\n705\t\t\tb.WriteString(\"Multiple environments detected. Please select one:\\n\\n\")\n706\t\t\tfor i, env := range m.envs {\n707\t\t\t\tlabel := fmt.Sprintf(\"%s (%s)\", env.Env.Name, env.Env.Version)\n708\t\t\t\tif i == m.cursor {\n709\t\t\t\t\tb.WriteString(selectedItemStyle.Render(\"▸ \" + label))\n710\t\t\t\t} else {\n711\t\t\t\t\tb.WriteString(itemStyle.Render(\"  \" + label))\n712\t\t\t\t}\n713\t\t\t\tb.WriteString(\"\\n\")\n714\t\t\t}\n715\t\t\tb.WriteString(\"\\n\")\n716\t\t\tb.WriteString(dimStyle.Render(\"↑/↓ to move, enter to select, q to quit\"))\n717\t\n718\t\tcase phaseSetupConfig:\n719\t\t\tb.WriteString(\"Configure Mage-OS:\\n\\n\")\n720\t\t\tconst labelWidth = 18\n721\t\t\tfor i, f := range setupFieldDefs {\n722\t\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, f.label))\n723\t\t\t\tb.WriteString(m.setupInputs[i].View())\n724\t\t\t\tb.WriteString(\"\\n\")\n725\t\t\t}\n726\t\t\tb.WriteString(\"\\n\")\n727\t\t\t// Sample data toggle\n728\t\t\tsdCheckbox := \"[ ]\"\n729\t\t\tif m.installSampleData {\n730\t\t\t\tsdCheckbox = \"[x]\"\n731\t\t\t}\n732\t\t\tsdStyle := dimStyle\n733\t\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n734\t\t\t\tsdStyle = selectedItemStyle\n735\t\t\t}\n736\t\t\tb.WriteString(sdStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install sample data\", sdCheckbox)))\n737\t\t\tb.WriteString(\"\\n\")\n738\t\t\tb.WriteString(dimStyle.Render(\"                      Adds demo products, categories, and customers so you can\"))\n739\t\t\tb.WriteString(\"\\n\")\n740\t\t\tb.WriteString(dimStyle.Render(\"                      explore a fully populated store right away. Recommended\"))\n741\t\t\tb.WriteString(\"\\n\")\n742\t\t\tb.WriteString(dimStyle.Render(\"                      for your first install to see how everything works.\"))\n743\t\t\tb.WriteString(\"\\n\\n\")\n744\t\t\t// Hyva toggle\n745\t\t\thyvaCheckbox := \"[ ]\"\n746\t\t\tif m.installHyva {\n747\t\t\t\thyvaCheckbox = \"[x]\"\n748\t\t\t}\n749\t\t\thyvaStyle := dimStyle\n750\t\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n751\t\t\t\thyvaStyle = selectedItemStyle\n752\t\t\t}\n753\t\t\tb.WriteString(hyvaStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install Hyvä\", hyvaCheckbox)))\n754\t\t\tb.WriteString(\"\\n\")\n755\t\t\tb.WriteString(dimStyle.Render(\"                      Hyvä is a modern, fast frontend theme that replaces the\"))\n756\t\t\tb.WriteString(\"\\n\")\n757\t\t\tb.WriteString(dimStyle.Render(\"                      default Luma theme. It uses Tailwind CSS and Alpine.js,\"))\n758\t\t\tb.WriteString(\"\\n\")\n759\t\t\tb.WriteString(dimStyle.Render(\"                      making frontend development much more enjoyable.\"))\n760\t\t\tb.WriteString(\"\\n\")\n761\t\t\tb.WriteString(dimStyle.Render(\"                      ⚠ Hyvä requires a (free) license. Register at hyva.io and have\"))\n762\t\t\tb.WriteString(\"\\n\")\n763\t\t\tb.WriteString(dimStyle.Render(\"                      your repo URL and auth token ready before continuing.\"))\n764\t\t\tb.WriteString(\"\\n\")\n765\t\t\t// Hyva credential fields (shown only when enabled)\n766\t\t\tif m.installHyva {\n767\t\t\t\tfor i, f := range hyvaFieldDefs {\n768\t\t\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, \"    \"+f.label))\n769\t\t\t\t\tb.WriteString(m.hyvaInputs[i].View())\n770\t\t\t\t\tb.WriteString(\"\\n\")\n771\t\t\t\t}\n772\t\t\t}\n773\t\t\tb.WriteString(\"\\n\")\n774\t\t\tif m.setupError != \"\" {\n775\t\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \"+m.setupError) + \"\\n\\n\")\n776\t\t\t}\n777\t\t\tb.WriteString(dimStyle.Render(\"Tab/↑↓/Enter to move · Space to toggle options · Enter to review command · ctrl+c to quit\"))\n778\t\n779\t\tcase phaseSetupPreview:\n780\t\t\tb.WriteString(\"Review the setup command:\\n\\n\")\n781\t\t\tflags := m.selected.Detector.SetupInstallFlags(&m.installCfg)\n782\t\t\tvar lines []string\n783\t\t\tlines = append(lines, m.selected.Detector.SetupCommandPrefix()+\" \\\\\")\n784\t\t\tfor i, f := range flags {\n785\t\t\t\tsuffix := dimStyle.Render(\" \\\\\")\n786\t\t\t\tif i == len(flags)-1 {\n787\t\t\t\t\tsuffix = \"\"\n788\t\t\t\t}\n789\t\t\t\tvar line string\n790\t\t\t\tif f.Editable {\n791\t\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\") + highlightStyle.Render(f.Value) + suffix\n792\t\t\t\t} else {\n793\t\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\"+f.Value) + suffix\n794\t\t\t\t}\n795\t\t\t\tlines = append(lines, line)\n796\t\t\t}\n797\t\t\tmaxVisible := m.windowHeight - 10\n798\t\t\tif maxVisible < 5 {\n799\t\t\t\tmaxVisible = 5\n800\t\t\t}\n801\t\t\tstart := m.previewScroll\n802\t\t\tif start >= len(lines) {\n803\t\t\t\tstart = max(0, len(lines)-1)\n804\t\t\t}\n805\t\t\tend := start + maxVisible\n806\t\t\tif end > len(lines) {\n807\t\t\t\tend = len(lines)\n808\t\t\t}\n809\t\t\tfor _, line := range lines[start:end] {\n810\t\t\t\tb.WriteString(line + \"\\n\")\n811\t\t\t}\n812\t\t\tb.WriteString(\"\\n\")\n813\t\t\tb.WriteString(dimStyle.Render(\"↑/↓ to scroll · Enter to run · b to go back\"))\n814\t\n815\t\tcase phaseInstalling:\n816\t\t\tb.WriteString(fmt.Sprintf(\"%s Installing %s...\\n\", m.spinner.View(), m.selected.Env.Name))\n817\t\t\tb.WriteString(\"\\n\")\n818\t\t\tfor _, step := range m.installSteps {\n819\t\t\t\tswitch step.status {\n820\t\t\t\tcase stepDone:\n821\t\t\t\t\tb.WriteString(successStyle.Render(\"  ✓ \" + step.name))\n822\t\t\t\tcase stepRunning:\n823\t\t\t\t\tb.WriteString(selectedItemStyle.Render(\"  ▸ \" + step.name + \"...\"))\n824\t\t\t\tcase stepFailed:\n825\t\t\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \" + step.name))\n826\t\t\t\tdefault:\n827\t\t\t\t\tb.WriteString(dimStyle.Render(\"  • \" + step.name))\n828\t\t\t\t}\n829\t\t\t\tb.WriteString(\"\\n\")\n830\t\t\t}\n831\t\t\tif len(m.logLines) > 0 {\n832\t\t\t\t// Compute available height for the log box.\n833\t\t\t\t// Header: 8 (banner) + 1 (blank) + 1 (title) + 2 (blank) +\n834\t\t\t\t//         1 (installing line) + 1 (blank) + N (steps) = 14 + N\n835\t\t\t\t// Box border adds 2 rows; log box also has MarginTop(1).\n836\t\t\t\twh := m.windowHeight\n837\t\t\t\tif wh <= 0 {\n838\t\t\t\t\twh = 24\n839\t\t\t\t}\n840\t\t\t\theaderLines := 14 + len(m.installSteps)\n841\t\t\t\t// 2 for box borders, 1 for margin top\n842\t\t\t\tinnerHeight := wh - headerLines - 3\n843\t\t\t\tif innerHeight < 3 {\n844\t\t\t\t\tinnerHeight = 3\n845\t\t\t\t}\n846\t\n847\t\t\t\tww := m.windowWidth\n848\t\t\t\tif ww <= 0 {\n849\t\t\t\t\tww = 80\n850\t\t\t\t}\n851\t\t\t\t// 4 accounts for the border (2) + padding (2)\n852\t\t\t\tinnerWidth := ww - 4\n853\t\t\t\tif innerWidth < 40 {\n854\t\t\t\t\tinnerWidth = 40\n855\t\t\t\t}\n856\t\n857\t\t\t\tstart := len(m.logLines) - innerHeight\n858\t\t\t\tif start < 0 {\n859\t\t\t\t\tstart = 0\n860\t\t\t\t}\n861\t\t\t\tstyle := logBoxStyle.Width(innerWidth).Height(innerHeight)\n862\t\t\t\tb.WriteString(style.Render(strings.Join(m.logLines[start:], \"\\n\")))\n863\t\t\t\tb.WriteString(\"\\n\")\n864\t\t\t}\n865\t\n866\t\tcase phaseOpenBrowser:\n867\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n868\t\t\tlines := []string{\n869\t\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n870\t\t\t\t\"\",\n871\t\t\t\t\"Open \" + highlightStyle.Render(url) + \" in your browser?\",\n872\t\t\t\t\"\",\n873\t\t\t\tdimStyle.Render(\"y to open · n/enter to skip\"),\n874\t\t\t}\n875\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n876\t\t\tb.WriteString(\"\\n\")\n877\t\n878\t\tcase phaseInstallDone:\n879\t\t\tif m.installErr != nil {\n880\t\t\t\tlines := []string{\n881\t\t\t\t\terrorStyle.Render(\"✗ Installation failed!\"),\n882\t\t\t\t\t\"\",\n883\t\t\t\t\tm.installErr.Error(),\n884\t\t\t\t}\n885\t\t\t\tif len(m.logLines) > 0 {\n886\t\t\t\t\tconst maxLines = 10\n887\t\t\t\t\tstart := len(m.logLines) - maxLines\n888\t\t\t\t\tif start < 0 {\n889\t\t\t\t\t\tstart = 0\n890\t\t\t\t\t}\n891\t\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Last output:\"))\n892\t\t\t\t\tfor _, line := range m.logLines[start:] {\n893\t\t\t\t\t\tlines = append(lines, dimStyle.Render(line))\n894\t\t\t\t\t}\n895\t\t\t\t}\n896\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press r to retry, enter/q to exit.\"))\n897\t\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n898\t\t\t} else {\n899\t\t\t\tlines := []string{\n900\t\t\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n901\t\t\t\t}\n902\t\t\t\tif m.browserOpened {\n903\t\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n904\t\t\t\t\tlines = append(lines, \"\", \"Opened \"+highlightStyle.Render(url)+\" in your browser.\")\n905\t\t\t\t}\n906\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press enter to exit.\"))\n907\t\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n908\t\t\t}\n909\t\t\tb.WriteString(\"\\n\")\n910\t\n911\t\tcase phaseError:\n912\t\t\tlines := []string{\n913\t\t\t\terrorStyle.Render(\"No supported environments found!\"),\n914\t\t\t\t\"\",\n915\t\t\t\t\"Please install one of the following:\",\n916\t\t\t\t\"\",\n917\t\t\t}\n918\t\t\tfor _, info := range detector.AllDetectorInfos() {\n919\t\t\t\tlines = append(lines, \"  \"+selectedItemStyle.Render(info.Name)+\"  \"+info.InstallURL)\n920\t\t\t}\n921\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press q to quit.\"))\n922\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n923\t\t\tb.WriteString(\"\\n\")\n924\t\t}\n925\t\n926\t\treturn b.String()\n927\t}\n928\t"}]},"parent_tool_use_id":null,"session_id":"93d16013-c824-4dee-a909-af38c9b89b17","uuid":"f82ca82b-9f6b-46d1-84d9-73d87e1ddb81","timestamp":"2026-04-14T19:23:42.625Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/tui/tui.go","content":"package tui\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strings\"\n\n\t\"github.com/charmbracelet/bubbles/spinner\"\n\t\"github.com/charmbracelet/bubbles/textinput\"\n\ttea \"github.com/charmbracelet/bubbletea\"\n\t\"github.com/charmbracelet/lipgloss\"\n\t\"github.com/mage-os/mage-os-install/internal/detector\"\n)\n\ntype phase int\n\nconst (\n\tphaseNameInput phase = iota\n\tphaseDirectoryInput\n\tphaseDetecting\n\tphaseSelection\n\tphaseSetupConfig  // admin credentials form\n\tphaseSetupPreview // full command preview before running\n\tphaseInstalling\n\tphaseOpenBrowser // ask whether to open the site after install\n\tphaseInstallDone\n\tphaseError\n)\n\n// detectionDoneMsg is sent when environment detection completes.\ntype detectionDoneMsg struct {\n\tenvs []detector.DetectedEnvironment\n}\n\n// installDoneMsg is sent when installation completes.\ntype installDoneMsg struct {\n\terr error\n}\n\n// logMsg carries a single line of installer output.\ntype logMsg string\n\n// stepStartMsg is sent when an installation step begins.\ntype stepStartMsg struct{ index int }\n\n// sudoCachedMsg is sent after sudo -v completes (caching credentials).\ntype sudoCachedMsg struct{ err error }\n\n// stepDoneMsg is sent when an installation step completes successfully.\ntype stepDoneMsg struct{ index int }\n\ntype stepStatus int\n\nconst (\n\tstepPending stepStatus = iota\n\tstepRunning\n\tstepDone\n\tstepFailed\n)\n\ntype installStep struct {\n\tname   string\n\tstatus stepStatus\n}\n\n// Model is the main bubbletea model for the installer TUI.\ntype Model struct {\n\tphase         phase\n\tspinner       spinner.Model\n\tnameInput     textinput.Model\n\toriginalName  string // the default seeded into nameInput, used to compute the dir default\n\tdirInput      textinput.Model\n\tenvs          []detector.DetectedEnvironment\n\tcursor        int\n\tselected      *detector.DetectedEnvironment\n\tsetupInputs   []textinput.Model\n\tsetupFocus    int\n\tsetupError    string\n\tinstallCfg    detector.Config\n\tpreviewScroll int\n\twindowHeight  int\n\twindowWidth   int\n\tlogCh         <-chan tea.Msg\n\tlogLines      []string\n\tinstallSteps  []installStep\n\tinstallErr    error\n\tbrowserOpened bool\n\n\t// Optional feature toggles and Hyvä credentials\n\tinstallSampleData bool\n\tinstallHyva       bool\n\thyvaInputs        []textinput.Model\n\t// toggleFocus tracks which toggle/section has focus:\n\t//   -2 = sample data toggle\n\t//   -1 = hyva toggle\n\t//   0+ = hyva input field index\n\ttoggleFocus    int\n\tinTogglePhase  bool // true when focus is in the toggle/hyva section (not admin fields)\n}\n\n// currentDirName returns the base name of the working directory.\nfunc currentDirName() string {\n\tif wd, err := os.Getwd(); err == nil {\n\t\treturn filepath.Base(wd)\n\t}\n\treturn \"my-project\"\n}\n\n// New creates the initial TUI model.\nfunc New() Model {\n\ts := spinner.New()\n\ts.Spinner = spinner.Dot\n\ts.Style = spinnerStyle\n\n\tdefaultName := currentDirName()\n\n\tti := textinput.New()\n\tti.SetValue(defaultName)\n\tti.Focus()\n\tti.CharLimit = 64\n\n\treturn Model{\n\t\tphase:        phaseNameInput,\n\t\tspinner:      s,\n\t\tnameInput:    ti,\n\t\toriginalName: defaultName,\n\t}\n}\n\nfunc (m Model) Init() tea.Cmd {\n\t// Start detection in the background immediately so results are ready\n\t// by the time the user confirms the project name.\n\treturn tea.Batch(m.spinner.Tick, detectEnvironments, textinput.Blink)\n}\n\nfunc detectEnvironments() tea.Msg {\n\treturn detectionDoneMsg{envs: detector.DetectAll()}\n}\n\n// defaultDirectory returns the install directory based on whether the user\n// changed the project name from the default.\nfunc (m *Model) defaultDirectory() string {\n\twd, err := os.Getwd()\n\tif err != nil {\n\t\twd = \".\"\n\t}\n\tif m.nameInput.Value() == m.originalName {\n\t\treturn wd\n\t}\n\treturn filepath.Join(wd, m.nameInput.Value())\n}\n\n// enterDirectoryPhase transitions to the directory input phase,\n// pre-filling the input with the computed default.\nfunc (m *Model) enterDirectoryPhase() tea.Cmd {\n\tdi := textinput.New()\n\tdi.SetValue(m.defaultDirectory())\n\tdi.Focus()\n\tdi.CharLimit = 256\n\tm.dirInput = di\n\tm.phase = phaseDirectoryInput\n\treturn textinput.Blink\n}\n\n// initInstallSteps loads the step list from the selected detector.\nfunc (m *Model) initInstallSteps() {\n\tm.installSteps = nil\n\tfor _, s := range m.selected.Detector.Steps() {\n\t\tm.installSteps = append(m.installSteps, installStep{name: s.Name, status: stepPending})\n\t}\n}\n\n// setupFieldDefs defines the user-editable fields shown in the Mage-OS setup form.\nvar setupFieldDefs = []struct {\n\tlabel string\n\techo  textinput.EchoMode\n}{\n\t{label: \"Admin user\", echo: textinput.EchoNormal},\n\t{label: \"Admin password\", echo: textinput.EchoPassword},\n\t{label: \"Admin email\", echo: textinput.EchoNormal},\n\t{label: \"Admin firstname\", echo: textinput.EchoNormal},\n\t{label: \"Admin lastname\", echo: textinput.EchoNormal},\n}\n\nvar setupFieldDefaults = []string{\"admin\", \"Admin123!\", \"admin@example.com\", \"Admin\", \"User\"}\n\n// hyvaFieldDefs defines the Hyvä credential fields.\nvar hyvaFieldDefs = []struct {\n\tlabel string\n\techo  textinput.EchoMode\n}{\n\t{label: \"Repo URL\", echo: textinput.EchoNormal},\n\t{label: \"Auth token\", echo: textinput.EchoPassword},\n}\n\n// initSetupInputs creates fresh text inputs for the Mage-OS setup form.\nfunc (m *Model) initSetupInputs() {\n\tm.setupInputs = make([]textinput.Model, len(setupFieldDefs))\n\tfor i, f := range setupFieldDefs {\n\t\tti := textinput.New()\n\t\tti.SetValue(setupFieldDefaults[i])\n\t\tti.EchoMode = f.echo\n\t\tti.CharLimit = 128\n\t\tif i == 0 {\n\t\t\tti.Focus()\n\t\t}\n\t\tm.setupInputs[i] = ti\n\t}\n\tm.setupFocus = 0\n\n\t// Initialize toggles and Hyvä inputs\n\tm.installSampleData = false\n\tm.installHyva = false\n\tm.inTogglePhase = false\n\tm.toggleFocus = -2 // sample data toggle\n\tm.hyvaInputs = make([]textinput.Model, len(hyvaFieldDefs))\n\tfor i, f := range hyvaFieldDefs {\n\t\tti := textinput.New()\n\t\tti.EchoMode = f.echo\n\t\tti.CharLimit = 256\n\t\tm.hyvaInputs[i] = ti\n\t}\n}\n\n// focusSetupInput focuses the input at index and blurs all others.\nfunc (m *Model) focusSetupInput(index int) {\n\tfor i := range m.setupInputs {\n\t\tif i == index {\n\t\t\tm.setupInputs[i].Focus()\n\t\t} else {\n\t\t\tm.setupInputs[i].Blur()\n\t\t}\n\t}\n\tm.setupFocus = index\n}\n\n// focusAbsolutePos sets focus based on absolute position across all form fields.\n// Layout: [admin fields...] [sampledata toggle] [hyva toggle] [hyva fields if enabled...]\nfunc (m *Model) focusAbsolutePos(pos int) {\n\t// Blur everything\n\tfor i := range m.setupInputs {\n\t\tm.setupInputs[i].Blur()\n\t}\n\tfor i := range m.hyvaInputs {\n\t\tm.hyvaInputs[i].Blur()\n\t}\n\n\tsampleDataPos := len(m.setupInputs)\n\thyvaTogglePos := sampleDataPos + 1\n\n\tif pos < sampleDataPos {\n\t\t// Admin field\n\t\tm.inTogglePhase = false\n\t\tm.setupFocus = pos\n\t\tm.setupInputs[pos].Focus()\n\t} else if pos == sampleDataPos {\n\t\t// Sample data toggle\n\t\tm.inTogglePhase = true\n\t\tm.toggleFocus = -2\n\t} else if pos == hyvaTogglePos {\n\t\t// Hyva toggle\n\t\tm.inTogglePhase = true\n\t\tm.toggleFocus = -1\n\t} else {\n\t\t// Hyva input field\n\t\tm.inTogglePhase = true\n\t\tm.toggleFocus = pos - hyvaTogglePos - 1\n\t\tif m.toggleFocus < len(m.hyvaInputs) {\n\t\t\tm.hyvaInputs[m.toggleFocus].Focus()\n\t\t}\n\t}\n}\n\n// buildInstallConfig builds a Config from the current form and input values.\nfunc (m *Model) buildInstallConfig() detector.Config {\n\tcfg := detector.Config{\n\t\tProjectName:       m.nameInput.Value(),\n\t\tDirectory:         m.dirInput.Value(),\n\t\tAdminUser:         m.setupInputs[0].Value(),\n\t\tAdminPassword:     m.setupInputs[1].Value(),\n\t\tAdminEmail:        m.setupInputs[2].Value(),\n\t\tAdminFirstname:    m.setupInputs[3].Value(),\n\t\tAdminLastname:     m.setupInputs[4].Value(),\n\t\tInstallSampleData: m.installSampleData,\n\t\tInstallHyva:       m.installHyva,\n\t}\n\tif m.installHyva {\n\t\tcfg.HyvaRepoURL = m.hyvaInputs[0].Value()\n\t\tcfg.HyvaAuthToken = m.hyvaInputs[1].Value()\n\t}\n\treturn cfg\n}\n\n// advanceFromDetection moves the model to the correct phase based on\n// how many environments were detected. The caller must have already\n// populated m.envs.\nfunc (m *Model) advanceFromDetection() tea.Cmd {\n\tswitch len(m.envs) {\n\tcase 0:\n\t\tm.phase = phaseError\n\tcase 1:\n\t\tm.selected = &m.envs[0]\n\t\tm.initSetupInputs()\n\t\tm.phase = phaseSetupConfig\n\t\treturn textinput.Blink\n\tdefault:\n\t\tm.phase = phaseSelection\n\t}\n\treturn nil\n}\n\nfunc runInstall(d detector.Detector, cfg detector.Config) (<-chan tea.Msg, tea.Cmd) {\n\tch := make(chan tea.Msg, 1000)\n\n\tgo func() {\n\t\tif err := os.MkdirAll(cfg.Directory, 0755); err != nil {\n\t\t\tch <- installDoneMsg{err: fmt.Errorf(\"could not create directory %s: %w\", cfg.Directory, err)}\n\t\t\treturn\n\t\t}\n\t\tcfg.Log = func(line string) { ch <- logMsg(line) }\n\t\tcfg.OnStepStart = func(i int) { ch <- stepStartMsg{index: i} }\n\t\tcfg.OnStepDone = func(i int) { ch <- stepDoneMsg{index: i} }\n\t\tch <- installDoneMsg{err: d.Install(&cfg)}\n\t}()\n\n\treturn ch, waitForLog(ch)\n}\n\n// waitForLog returns a Cmd that reads the next message from the log channel.\nfunc waitForLog(ch <-chan tea.Msg) tea.Cmd {\n\treturn func() tea.Msg {\n\t\treturn <-ch\n\t}\n}\n\n// openBrowser opens url in the default system browser without blocking.\nfunc openBrowser(url string) error {\n\tvar cmd *exec.Cmd\n\tswitch runtime.GOOS {\n\tcase \"darwin\":\n\t\tcmd = exec.Command(\"open\", url)\n\tcase \"linux\":\n\t\tcmd = exec.Command(\"xdg-open\", url)\n\tcase \"windows\":\n\t\tcmd = exec.Command(\"rundll32\", \"url.dll,FileProtocolHandler\", url)\n\tdefault:\n\t\treturn fmt.Errorf(\"unsupported platform: %s\", runtime.GOOS)\n\t}\n\treturn cmd.Start()\n}\n\nfunc (m Model) Update(msg tea.Msg) (tea.Model, tea.Cmd) {\n\tswitch msg := msg.(type) {\n\tcase tea.KeyMsg:\n\t\tswitch msg.String() {\n\t\tcase \"ctrl+c\", \"q\":\n\t\t\treturn m, tea.Quit\n\t\t}\n\n\tcase tea.WindowSizeMsg:\n\t\tm.windowHeight = msg.Height\n\t\tm.windowWidth = msg.Width\n\t\treturn m, nil\n\n\tcase spinner.TickMsg:\n\t\tvar cmd tea.Cmd\n\t\tm.spinner, cmd = m.spinner.Update(msg)\n\t\treturn m, cmd\n\n\tcase detectionDoneMsg:\n\t\tm.envs = msg.envs\n\t\t// Cache results while the user is still filling in the input steps;\n\t\t// we'll advance when they confirm the directory.\n\t\tif m.phase == phaseNameInput || m.phase == phaseDirectoryInput {\n\t\t\treturn m, nil\n\t\t}\n\t\treturn m, m.advanceFromDetection()\n\n\tcase sudoCachedMsg:\n\t\t// sudo credentials are now cached (or failed); proceed with install.\n\t\tm.phase = phaseInstalling\n\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n\t\tm.logCh = ch\n\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n\n\tcase logMsg:\n\t\tm.logLines = append(m.logLines, string(msg))\n\t\treturn m, waitForLog(m.logCh)\n\n\tcase stepStartMsg:\n\t\tif msg.index < len(m.installSteps) {\n\t\t\tm.installSteps[msg.index].status = stepRunning\n\t\t}\n\t\treturn m, waitForLog(m.logCh)\n\n\tcase stepDoneMsg:\n\t\tif msg.index < len(m.installSteps) {\n\t\t\tm.installSteps[msg.index].status = stepDone\n\t\t}\n\t\treturn m, waitForLog(m.logCh)\n\n\tcase installDoneMsg:\n\t\tm.installErr = msg.err\n\t\tif msg.err != nil {\n\t\t\tfor i := range m.installSteps {\n\t\t\t\tif m.installSteps[i].status == stepRunning {\n\t\t\t\t\tm.installSteps[i].status = stepFailed\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tm.phase = phaseInstallDone\n\t\t} else {\n\t\t\tm.browserOpened = false\n\t\t\tm.phase = phaseOpenBrowser\n\t\t}\n\t\treturn m, nil\n\t}\n\n\t// Handle name-input phase\n\tif m.phase == phaseNameInput {\n\t\tswitch msg := msg.(type) {\n\t\tcase tea.KeyMsg:\n\t\t\tswitch msg.String() {\n\t\t\tcase \"enter\":\n\t\t\t\treturn m, m.enterDirectoryPhase()\n\t\t\tdefault:\n\t\t\t\tvar cmd tea.Cmd\n\t\t\t\tm.nameInput, cmd = m.nameInput.Update(msg)\n\t\t\t\treturn m, cmd\n\t\t\t}\n\t\t}\n\t}\n\n\t// Handle directory-input phase\n\tif m.phase == phaseDirectoryInput {\n\t\tswitch msg := msg.(type) {\n\t\tcase tea.KeyMsg:\n\t\t\tswitch msg.String() {\n\t\t\tcase \"enter\":\n\t\t\t\t// Detection may already be done (envs cached) or still running.\n\t\t\t\tif m.envs != nil {\n\t\t\t\t\treturn m, m.advanceFromDetection()\n\t\t\t\t}\n\t\t\t\tm.phase = phaseDetecting\n\t\t\t\treturn m, nil\n\t\t\tdefault:\n\t\t\t\tvar cmd tea.Cmd\n\t\t\t\tm.dirInput, cmd = m.dirInput.Update(msg)\n\t\t\t\treturn m, cmd\n\t\t\t}\n\t\t}\n\t}\n\n\t// Handle selection-phase keys\n\tif m.phase == phaseSelection {\n\t\tswitch msg := msg.(type) {\n\t\tcase tea.KeyMsg:\n\t\t\tswitch msg.String() {\n\t\t\tcase \"up\", \"k\":\n\t\t\t\tif m.cursor > 0 {\n\t\t\t\t\tm.cursor--\n\t\t\t\t}\n\t\t\tcase \"down\", \"j\":\n\t\t\t\tif m.cursor < len(m.envs)-1 {\n\t\t\t\t\tm.cursor++\n\t\t\t\t}\n\t\t\tcase \"enter\":\n\t\t\t\tm.selected = &m.envs[m.cursor]\n\t\t\t\tm.initSetupInputs()\n\t\t\t\tm.phase = phaseSetupConfig\n\t\t\t\treturn m, textinput.Blink\n\t\t\t}\n\t\t}\n\t}\n\n\t// Handle setup config form\n\tif m.phase == phaseSetupConfig {\n\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n\t\t\t// Total fields: admin fields + sample data toggle + hyva toggle + (hyva fields if enabled)\n\t\t\ttotalFields := len(m.setupInputs) + 2 // +2 for both toggles\n\t\t\tif m.installHyva {\n\t\t\t\ttotalFields += len(m.hyvaInputs)\n\t\t\t}\n\n\t\t\t// Calculate current absolute position\n\t\t\tabsPos := m.setupFocus\n\t\t\tif m.inTogglePhase {\n\t\t\t\tswitch {\n\t\t\t\tcase m.toggleFocus == -2: // sample data toggle\n\t\t\t\t\tabsPos = len(m.setupInputs)\n\t\t\t\tcase m.toggleFocus == -1: // hyva toggle\n\t\t\t\t\tabsPos = len(m.setupInputs) + 1\n\t\t\t\tdefault: // hyva input field\n\t\t\t\t\tabsPos = len(m.setupInputs) + 2 + m.toggleFocus\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch keyMsg.String() {\n\t\t\tcase \"tab\", \"down\":\n\t\t\t\tnewPos := absPos + 1\n\t\t\t\tif newPos >= totalFields {\n\t\t\t\t\tnewPos = 0\n\t\t\t\t}\n\t\t\t\tm.focusAbsolutePos(newPos)\n\t\t\t\treturn m, textinput.Blink\n\t\t\tcase \"shift+tab\", \"up\":\n\t\t\t\tnewPos := absPos - 1\n\t\t\t\tif newPos < 0 {\n\t\t\t\t\tnewPos = totalFields - 1\n\t\t\t\t}\n\t\t\t\tm.focusAbsolutePos(newPos)\n\t\t\t\treturn m, textinput.Blink\n\t\t\tcase \"enter\":\n\t\t\t\t// On toggles, Enter advances to the next field (use Space to toggle)\n\t\t\t\tif m.inTogglePhase && (m.toggleFocus == -2 || m.toggleFocus == -1) {\n\t\t\t\t\t// If this toggle is the last field, submit\n\t\t\t\t\tif absPos == totalFields-1 {\n\t\t\t\t\t\t// fall through to submit logic below\n\t\t\t\t\t} else {\n\t\t\t\t\t\tm.focusAbsolutePos(absPos + 1)\n\t\t\t\t\t\treturn m, textinput.Blink\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// On the last field, submit\n\t\t\t\tif absPos == totalFields-1 {\n\t\t\t\t\t// Validate admin fields\n\t\t\t\t\tfor i, f := range setupFieldDefs {\n\t\t\t\t\t\tif strings.TrimSpace(m.setupInputs[i].Value()) == \"\" {\n\t\t\t\t\t\t\tm.setupError = f.label + \" is required\"\n\t\t\t\t\t\t\tm.focusAbsolutePos(i)\n\t\t\t\t\t\t\treturn m, textinput.Blink\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t// Validate Hyva fields if enabled\n\t\t\t\t\tif m.installHyva {\n\t\t\t\t\t\tfor i, f := range hyvaFieldDefs {\n\t\t\t\t\t\t\tif strings.TrimSpace(m.hyvaInputs[i].Value()) == \"\" {\n\t\t\t\t\t\t\t\tm.setupError = \"Hyvä \" + f.label + \" is required\"\n\t\t\t\t\t\t\t\tm.focusAbsolutePos(len(m.setupInputs) + 2 + i)\n\t\t\t\t\t\t\t\treturn m, textinput.Blink\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\tm.setupError = \"\"\n\t\t\t\t\tm.installCfg = m.buildInstallConfig()\n\t\t\t\t\tm.selected.Detector.PrepareSteps(&m.installCfg)\n\t\t\t\t\tm.previewScroll = 0\n\t\t\t\t\tm.phase = phaseSetupPreview\n\t\t\t\t\treturn m, nil\n\t\t\t\t}\n\t\t\t\t// Move to next field\n\t\t\t\tm.focusAbsolutePos(absPos + 1)\n\t\t\t\treturn m, textinput.Blink\n\t\t\tcase \" \":\n\t\t\t\t// Space on toggles\n\t\t\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n\t\t\t\t\tm.installSampleData = !m.installSampleData\n\t\t\t\t\treturn m, nil\n\t\t\t\t}\n\t\t\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n\t\t\t\t\tm.installHyva = !m.installHyva\n\t\t\t\t\treturn m, nil\n\t\t\t\t}\n\t\t\t\t// Fall through to default for text input\n\t\t\t\tfallthrough\n\t\t\tdefault:\n\t\t\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n\t\t\t\t\tvar cmd tea.Cmd\n\t\t\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n\t\t\t\t\treturn m, cmd\n\t\t\t\t}\n\t\t\t\tif !m.inTogglePhase {\n\t\t\t\t\tvar cmd tea.Cmd\n\t\t\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n\t\t\t\t\treturn m, cmd\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\t// Forward non-key messages (e.g. blink) to focused input\n\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n\t\t\tvar cmd tea.Cmd\n\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n\t\t\treturn m, cmd\n\t\t}\n\t\tif !m.inTogglePhase {\n\t\t\tvar cmd tea.Cmd\n\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n\t\t\treturn m, cmd\n\t\t}\n\t}\n\n\t// Handle setup preview\n\tif m.phase == phaseSetupPreview {\n\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n\t\t\tswitch keyMsg.String() {\n\t\t\tcase \"up\", \"k\":\n\t\t\t\tif m.previewScroll > 0 {\n\t\t\t\t\tm.previewScroll--\n\t\t\t\t}\n\t\t\tcase \"down\", \"j\":\n\t\t\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n\t\t\t\tmaxVisible := m.windowHeight - 10\n\t\t\t\tif maxVisible < 3 {\n\t\t\t\t\tmaxVisible = 3\n\t\t\t\t}\n\t\t\t\tif maxScroll := totalLines - maxVisible; m.previewScroll < maxScroll {\n\t\t\t\t\tm.previewScroll++\n\t\t\t\t}\n\t\t\tcase \"enter\":\n\t\t\t\tm.initInstallSteps()\n\t\t\t\t// Cache sudo credentials before starting the install so that\n\t\t\t\t// commands like \"ddev start\" (which modifies /etc/hosts) can\n\t\t\t\t// use sudo without prompting inside the TUI.\n\t\t\t\tc := exec.Command(\"sudo\", \"-v\")\n\t\t\t\treturn m, tea.ExecProcess(c, func(err error) tea.Msg {\n\t\t\t\t\treturn sudoCachedMsg{err: err}\n\t\t\t\t})\n\t\t\tcase \"b\", \"esc\":\n\t\t\t\tm.phase = phaseSetupConfig\n\t\t\t\treturn m, textinput.Blink\n\t\t\t}\n\t\t}\n\t}\n\n\tif m.phase == phaseOpenBrowser {\n\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n\t\t\tswitch keyMsg.String() {\n\t\t\tcase \"y\":\n\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n\t\t\t\t_ = openBrowser(url)\n\t\t\t\tm.browserOpened = true\n\t\t\t\tm.phase = phaseInstallDone\n\t\t\t\treturn m, nil\n\t\t\tcase \"n\", \"enter\", \"esc\":\n\t\t\t\tm.phase = phaseInstallDone\n\t\t\t\treturn m, nil\n\t\t\t}\n\t\t}\n\t}\n\n\tif m.phase == phaseInstallDone || m.phase == phaseError {\n\t\tif msg, ok := msg.(tea.KeyMsg); ok {\n\t\t\tswitch msg.String() {\n\t\t\tcase \"r\":\n\t\t\t\tif m.phase == phaseInstallDone && m.installErr != nil {\n\t\t\t\t\t// Find the failed step so we can resume from there.\n\t\t\t\t\tfailedIdx := 0\n\t\t\t\t\tfor i := range m.installSteps {\n\t\t\t\t\t\tif m.installSteps[i].status == stepFailed {\n\t\t\t\t\t\t\tfailedIdx = i\n\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t// Keep completed steps green; reset failed + pending to pending.\n\t\t\t\t\tfor i := range m.installSteps {\n\t\t\t\t\t\tif m.installSteps[i].status != stepDone {\n\t\t\t\t\t\t\tm.installSteps[i].status = stepPending\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\tm.logLines = nil\n\t\t\t\t\tm.installErr = nil\n\t\t\t\t\tm.installCfg.StartFromStep = failedIdx\n\t\t\t\t\tm.phase = phaseInstalling\n\t\t\t\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n\t\t\t\t\tm.logCh = ch\n\t\t\t\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n\t\t\t\t}\n\t\t\tcase \"enter\", \"q\", \"esc\":\n\t\t\t\treturn m, tea.Quit\n\t\t\t}\n\t\t}\n\t}\n\n\treturn m, nil\n}\n\nfunc (m Model) View() string {\n\tvar b strings.Builder\n\n\tb.WriteString(bannerStyle.Render(banner))\n\tb.WriteString(\"\\n\")\n\tb.WriteString(titleStyle.Render(\"Mage-OS Installer\"))\n\tb.WriteString(\"\\n\\n\")\n\n\tswitch m.phase {\n\tcase phaseNameInput:\n\t\tb.WriteString(\"Project name:\\n\\n\")\n\t\tb.WriteString(m.nameInput.View())\n\t\tb.WriteString(\"\\n\\n\")\n\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n\n\tcase phaseDirectoryInput:\n\t\tb.WriteString(\"Install directory:\\n\\n\")\n\t\tb.WriteString(m.dirInput.View())\n\t\tb.WriteString(\"\\n\\n\")\n\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n\n\tcase phaseDetecting:\n\t\tb.WriteString(fmt.Sprintf(\"%s Detecting development environments...\\n\", m.spinner.View()))\n\n\tcase phaseSelection:\n\t\tb.WriteString(\"Multiple environments detected. Please select one:\\n\\n\")\n\t\tfor i, env := range m.envs {\n\t\t\tlabel := fmt.Sprintf(\"%s (%s)\", env.Env.Name, env.Env.Version)\n\t\t\tif i == m.cursor {\n\t\t\t\tb.WriteString(selectedItemStyle.Render(\"▸ \" + label))\n\t\t\t} else {\n\t\t\t\tb.WriteString(itemStyle.Render(\"  \" + label))\n\t\t\t}\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"↑/↓ to move, enter to select, q to quit\"))\n\n\tcase phaseSetupConfig:\n\t\tb.WriteString(\"Configure Mage-OS:\\n\\n\")\n\t\tconst labelWidth = 18\n\t\tfor i, f := range setupFieldDefs {\n\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, f.label))\n\t\t\tb.WriteString(m.setupInputs[i].View())\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\t// Sample data toggle\n\t\tsdCheckbox := \"[ ]\"\n\t\tif m.installSampleData {\n\t\t\tsdCheckbox = \"[x]\"\n\t\t}\n\t\tsdStyle := dimStyle\n\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n\t\t\tsdStyle = selectedItemStyle\n\t\t}\n\t\tb.WriteString(sdStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install sample data\", sdCheckbox)))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      Adds demo products, categories, and customers so you can\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      explore a fully populated store right away. Recommended\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      for your first install to see how everything works.\"))\n\t\tb.WriteString(\"\\n\\n\")\n\t\t// Hyva toggle\n\t\thyvaCheckbox := \"[ ]\"\n\t\tif m.installHyva {\n\t\t\thyvaCheckbox = \"[x]\"\n\t\t}\n\t\thyvaStyle := dimStyle\n\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n\t\t\thyvaStyle = selectedItemStyle\n\t\t}\n\t\tb.WriteString(hyvaStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install Hyvä\", hyvaCheckbox)))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      Hyvä is a modern, fast frontend theme that replaces the\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      default Luma theme. It uses Tailwind CSS and Alpine.js,\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      making frontend development much more enjoyable.\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      ⚠ Hyvä requires a (free) license. Register at hyva.io and have\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      your repo URL and auth token ready before continuing.\"))\n\t\tb.WriteString(\"\\n\")\n\t\t// Hyva credential fields (shown only when enabled)\n\t\tif m.installHyva {\n\t\t\tfor i, f := range hyvaFieldDefs {\n\t\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, \"    \"+f.label))\n\t\t\t\tb.WriteString(m.hyvaInputs[i].View())\n\t\t\t\tb.WriteString(\"\\n\")\n\t\t\t}\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\tif m.setupError != \"\" {\n\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \"+m.setupError) + \"\\n\\n\")\n\t\t}\n\t\tb.WriteString(dimStyle.Render(\"Tab/↑↓/Enter to move · Space to toggle options · Enter to review command · ctrl+c to quit\"))\n\n\tcase phaseSetupPreview:\n\t\tb.WriteString(\"Review the setup command:\\n\\n\")\n\t\tflags := m.selected.Detector.SetupInstallFlags(&m.installCfg)\n\t\tvar lines []string\n\t\tlines = append(lines, m.selected.Detector.SetupCommandPrefix()+\" \\\\\")\n\t\tfor i, f := range flags {\n\t\t\tsuffix := dimStyle.Render(\" \\\\\")\n\t\t\tif i == len(flags)-1 {\n\t\t\t\tsuffix = \"\"\n\t\t\t}\n\t\t\tvar line string\n\t\t\tif f.Editable {\n\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\") + highlightStyle.Render(f.Value) + suffix\n\t\t\t} else {\n\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\"+f.Value) + suffix\n\t\t\t}\n\t\t\tlines = append(lines, line)\n\t\t}\n\t\tmaxVisible := m.windowHeight - 10\n\t\tif maxVisible < 5 {\n\t\t\tmaxVisible = 5\n\t\t}\n\t\tstart := m.previewScroll\n\t\tif start >= len(lines) {\n\t\t\tstart = max(0, len(lines)-1)\n\t\t}\n\t\tend := start + maxVisible\n\t\tif end > len(lines) {\n\t\t\tend = len(lines)\n\t\t}\n\t\tfor _, line := range lines[start:end] {\n\t\t\tb.WriteString(line + \"\\n\")\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"↑/↓ to scroll · Enter to run · b to go back\"))\n\n\tcase phaseInstalling:\n\t\tb.WriteString(fmt.Sprintf(\"%s Installing %s...\\n\", m.spinner.View(), m.selected.Env.Name))\n\t\tb.WriteString(\"\\n\")\n\t\tfor _, step := range m.installSteps {\n\t\t\tswitch step.status {\n\t\t\tcase stepDone:\n\t\t\t\tb.WriteString(successStyle.Render(\"  ✓ \" + step.name))\n\t\t\tcase stepRunning:\n\t\t\t\tb.WriteString(selectedItemStyle.Render(\"  ▸ \" + step.name + \"...\"))\n\t\t\tcase stepFailed:\n\t\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \" + step.name))\n\t\t\tdefault:\n\t\t\t\tb.WriteString(dimStyle.Render(\"  • \" + step.name))\n\t\t\t}\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\t\tif len(m.logLines) > 0 {\n\t\t\t// Compute available height for the log box.\n\t\t\t// Header: 8 (banner) + 1 (blank) + 1 (title) + 2 (blank) +\n\t\t\t//         1 (installing line) + 1 (blank) + N (steps) = 14 + N\n\t\t\t// Box border adds 2 rows; log box also has MarginTop(1).\n\t\t\twh := m.windowHeight\n\t\t\tif wh <= 0 {\n\t\t\t\twh = 24\n\t\t\t}\n\t\t\theaderLines := 14 + len(m.installSteps)\n\t\t\t// 2 for box borders, 1 for margin top\n\t\t\tinnerHeight := wh - headerLines - 3\n\t\t\tif innerHeight < 3 {\n\t\t\t\tinnerHeight = 3\n\t\t\t}\n\n\t\t\tww := m.windowWidth\n\t\t\tif ww <= 0 {\n\t\t\t\tww = 80\n\t\t\t}\n\t\t\t// 4 accounts for the border (2) + padding (2)\n\t\t\tinnerWidth := ww - 4\n\t\t\tif innerWidth < 40 {\n\t\t\t\tinnerWidth = 40\n\t\t\t}\n\n\t\t\tstart := len(m.logLines) - innerHeight\n\t\t\tif start < 0 {\n\t\t\t\tstart = 0\n\t\t\t}\n\t\t\tstyle := logBoxStyle.Width(innerWidth).Height(innerHeight)\n\t\t\tb.WriteString(style.Render(strings.Join(m.logLines[start:], \"\\n\")))\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\n\tcase phaseOpenBrowser:\n\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n\t\tlines := []string{\n\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n\t\t\t\"\",\n\t\t\t\"Open \" + highlightStyle.Render(url) + \" in your browser?\",\n\t\t\t\"\",\n\t\t\tdimStyle.Render(\"y to open · n/enter to skip\"),\n\t\t}\n\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\tb.WriteString(\"\\n\")\n\n\tcase phaseInstallDone:\n\t\tif m.installErr != nil {\n\t\t\tlines := []string{\n\t\t\t\terrorStyle.Render(\"✗ Installation failed!\"),\n\t\t\t\t\"\",\n\t\t\t\tm.installErr.Error(),\n\t\t\t}\n\t\t\tif len(m.logLines) > 0 {\n\t\t\t\tconst maxLines = 10\n\t\t\t\tstart := len(m.logLines) - maxLines\n\t\t\t\tif start < 0 {\n\t\t\t\t\tstart = 0\n\t\t\t\t}\n\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Last output:\"))\n\t\t\t\tfor _, line := range m.logLines[start:] {\n\t\t\t\t\tlines = append(lines, dimStyle.Render(line))\n\t\t\t\t}\n\t\t\t}\n\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press r to retry, enter/q to exit.\"))\n\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\t} else {\n\t\t\tlines := []string{\n\t\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n\t\t\t}\n\t\t\tif m.browserOpened {\n\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n\t\t\t\tlines = append(lines, \"\", \"Opened \"+highlightStyle.Render(url)+\" in your browser.\")\n\t\t\t}\n\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press enter to exit.\"))\n\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\n\tcase phaseError:\n\t\tlines := []string{\n\t\t\terrorStyle.Render(\"No supported environments found!\"),\n\t\t\t\"\",\n\t\t\t\"Please install one of the following:\",\n\t\t\t\"\",\n\t\t}\n\t\tfor _, info := range detector.AllDetectorInfos() {\n\t\t\tlines = append(lines, \"  \"+selectedItemStyle.Render(info.Name)+\"  \"+info.InstallURL)\n\t\t}\n\t\tlines = append(lines, \"\", dimStyle.Render(\"Press q to quit.\"))\n\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\tb.WriteString(\"\\n\")\n\t}\n\n\treturn b.String()\n}\n","numLines":928,"startLine":1,"totalLines":928}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ACxvynWkuBqMH5BC91CJHM","type":"tool_result","content":"1\tpackage detector\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/tls\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"net/http\"\n10\t\t\"os\"\n11\t\t\"os/exec\"\n12\t\t\"strings\"\n13\t\t\"time\"\n14\t)\n15\t\n16\t// DdevDetector checks for the DDEV development environment.\n17\ttype DdevDetector struct {\n18\t\t// primaryURL is populated after ddev start by querying ddev describe.\n19\t\tprimaryURL string\n20\t\t// steps is the list of installation steps, built dynamically based on config.\n21\t\tsteps []Step\n22\t}\n23\t\n24\tfunc (d *DdevDetector) Info() DetectorInfo {\n25\t\treturn DetectorInfo{\n26\t\t\tName:       \"DDEV\",\n27\t\t\tInstallURL: \"https://ddev.readthedocs.io/en/stable/\",\n28\t\t}\n29\t}\n30\t\n31\tfunc (d *DdevDetector) Steps() []Step {\n32\t\treturn d.steps\n33\t}\n34\t\n35\tfunc (d *DdevDetector) PrepareSteps(config *Config) {\n36\t\td.buildSteps(config)\n37\t}\n38\t\n39\tfunc (d *DdevDetector) buildSteps(config *Config) {\n40\t\td.steps = []Step{\n41\t\t\t{Name: \"Configure DDEV project\"},\n42\t\t\t{Name: \"Install OpenSearch addon\"},\n43\t\t\t{Name: \"Install Redis addon\"},\n44\t\t\t{Name: \"Install Cron addon\"},\n45\t\t\t{Name: \"Install RabbitMQ addon\"},\n46\t\t\t{Name: \"Start DDEV\"},\n47\t\t\t{Name: \"Apply RabbitMQ config\"},\n48\t\t\t{Name: \"Create Mage-OS project\"},\n49\t\t\t{Name: \"Copy project files\"},\n50\t\t\t{Name: \"Create composer home directory\"},\n51\t\t\t{Name: \"Copy auth.json\"},\n52\t\t\t{Name: \"Install Mage-OS\"},\n53\t\t}\n54\t\tif config != nil && config.InstallSampleData {\n55\t\t\td.steps = append(d.steps, Step{Name: \"Install sample data\"})\n56\t\t}\n57\t\tif config != nil && config.InstallHyva {\n58\t\t\td.steps = append(d.steps,\n59\t\t\t\tStep{Name: \"Configure Hyvä repository\"},\n60\t\t\t\tStep{Name: \"Install Hyvä theme\"},\n61\t\t\t\tStep{Name: \"Enable Hyvä modules\"},\n62\t\t\t)\n63\t\t}\n64\t\td.steps = append(d.steps, Step{Name: \"Verify installation\"})\n65\t}\n66\t\n67\tfunc (d *DdevDetector) SetupCommandPrefix() string {\n68\t\treturn \"ddev exec bin/magento setup:install\"\n69\t}\n70\t\n71\tfunc (d *DdevDetector) BaseURL(projectName string) string {\n72\t\tif d.primaryURL != \"\" {\n73\t\t\treturn d.primaryURL\n74\t\t}\n75\t\treturn \"https://\" + projectName + \".ddev.site\"\n76\t}\n77\t\n78\t// SetupInstallFlags returns the full ordered list of flags for bin/magento setup:install.\n79\tfunc (d *DdevDetector) SetupInstallFlags(config *Config) []SetupFlag {\n80\t\treturn []SetupFlag{\n81\t\t\t{Flag: \"--backend-frontname\", Value: \"admin\"},\n82\t\t\t{Flag: \"--amqp-host\", Value: \"rabbitmq\"},\n83\t\t\t{Flag: \"--amqp-port\", Value: \"5672\"},\n84\t\t\t{Flag: \"--amqp-user\", Value: \"rabbitmq\"},\n85\t\t\t{Flag: \"--amqp-password\", Value: \"rabbitmq\"},\n86\t\t\t{Flag: \"--db-host\", Value: \"db\"},\n87\t\t\t{Flag: \"--db-name\", Value: \"db\"},\n88\t\t\t{Flag: \"--db-user\", Value: \"db\"},\n89\t\t\t{Flag: \"--db-password\", Value: \"db\"},\n90\t\t\t{Flag: \"--search-engine\", Value: \"opensearch\"},\n91\t\t\t{Flag: \"--opensearch-host\", Value: \"opensearch\"},\n92\t\t\t{Flag: \"--opensearch-port\", Value: \"9200\"},\n93\t\t\t{Flag: \"--opensearch-index-prefix\", Value: \"magento2\"},\n94\t\t\t{Flag: \"--opensearch-enable-auth\", Value: \"0\"},\n95\t\t\t{Flag: \"--opensearch-timeout\", Value: \"15\"},\n96\t\t\t{Flag: \"--http-cache-hosts\", Value: \"varnish:80\"},\n97\t\t\t{Flag: \"--session-save\", Value: \"redis\"},\n98\t\t\t{Flag: \"--session-save-redis-host\", Value: \"redis\"},\n99\t\t\t{Flag: \"--session-save-redis-port\", Value: \"6379\"},\n100\t\t\t{Flag: \"--session-save-redis-db\", Value: \"2\"},\n101\t\t\t{Flag: \"--session-save-redis-max-concurrency\", Value: \"20\"},\n102\t\t\t{Flag: \"--cache-backend\", Value: \"redis\"},\n103\t\t\t{Flag: \"--cache-backend-redis-server\", Value: \"redis\"},\n104\t\t\t{Flag: \"--cache-backend-redis-db\", Value: \"0\"},\n105\t\t\t{Flag: \"--cache-backend-redis-port\", Value: \"6379\"},\n106\t\t\t{Flag: \"--page-cache\", Value: \"redis\"},\n107\t\t\t{Flag: \"--page-cache-redis-server\", Value: \"redis\"},\n108\t\t\t{Flag: \"--page-cache-redis-db\", Value: \"1\"},\n109\t\t\t{Flag: \"--page-cache-redis-port\", Value: \"6379\"},\n110\t\t\t{Flag: \"--base-url\", Value: d.BaseURL(config.ProjectName)},\n111\t\t\t{Flag: \"--timezone\", Value: \"Europe/Amsterdam\"},\n112\t\t\t{Flag: \"--currency\", Value: \"EUR\"},\n113\t\t\t{Flag: \"--admin-user\", Value: config.AdminUser, Editable: true},\n114\t\t\t{Flag: \"--admin-password\", Value: config.AdminPassword, Editable: true},\n115\t\t\t{Flag: \"--admin-email\", Value: config.AdminEmail, Editable: true},\n116\t\t\t{Flag: \"--admin-firstname\", Value: config.AdminFirstname, Editable: true},\n117\t\t\t{Flag: \"--admin-lastname\", Value: config.AdminLastname, Editable: true},\n118\t\t\t{Flag: \"--use-rewrites\", Value: \"1\"},\n119\t\t}\n120\t}\n121\t\n122\tfunc (d *DdevDetector) Install(config *Config) error {\n123\t\td.buildSteps(config)\n124\t\n125\t\tsteps := [][]string{\n126\t\t\t{\n127\t\t\t\t\"ddev\", \"config\",\n128\t\t\t\t\"--project-name=\" + config.ProjectName,\n129\t\t\t\t\"--docroot=pub\",\n130\t\t\t\t\"--project-type=magento2\",\n131\t\t\t\t\"--database=mysql:8.0\",\n132\t\t\t\t\"--composer-version=2.2\",\n133\t\t\t},\n134\t\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-opensearch\"},\n135\t\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-redis\"},\n136\t\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-cron\"},\n137\t\t\t{\"ddev\", \"add-on\", \"get\", \"b13/ddev-rabbitmq\"},\n138\t\t\t{\"ddev\", \"start\"},\n139\t\t\t{\"ddev\", \"rabbitmq\", \"apply\"},\n140\t\t\t{\n141\t\t\t\t\"ddev\", \"exec\", \"composer\", \"create-project\",\n142\t\t\t\t\"--repository-url=https://repo.mage-os.org/\",\n143\t\t\t\t\"mage-os/project-community-edition\",\n144\t\t\t\t\"/tmp/mage-os-project\",\n145\t\t\t},\n146\t\t\t{\n147\t\t\t\t\"ddev\", \"exec\", \"bash\", \"-c\",\n148\t\t\t\t\"cp -a /tmp/mage-os-project/. /var/www/html/\",\n149\t\t\t},\n150\t\t\t{\"ddev\", \"exec\", \"mkdir\", \"-p\", \"/var/www/html/var/composer_home/\"},\n151\t\t}\n152\t\n153\t\tfor i, args := range steps {\n154\t\t\tif i < config.StartFromStep {\n155\t\t\t\tcontinue\n156\t\t\t}\n157\t\t\tstepStart(config, i)\n158\t\t\tlogf(config, \"▸ %s\", strings.Join(args, \" \"))\n159\t\t\tif err := runInDir(config.Directory, config.Log, args[0], args[1:]...); err != nil {\n160\t\t\t\treturn fmt.Errorf(\"step %q failed: %w\", strings.Join(args, \" \"), err)\n161\t\t\t}\n162\t\t\tstepDone(config, i)\n163\t\t}\n164\t\n165\t\t// After ddev start, query the actual primary URL so we use\n166\t\t// the correct domain (e.g. .ddev.site) for Magento's base-url.\n167\t\tif url, err := ddevPrimaryURL(config.Directory); err == nil {\n168\t\t\td.primaryURL = url\n169\t\t\tlogf(config, \"▸ Detected primary URL: %s\", url)\n170\t\t}\n171\t\n172\t\tauthIdx := len(steps)\n173\t\tif authIdx >= config.StartFromStep {\n174\t\t\tstepStart(config, authIdx)\n175\t\t\tif err := copyAuthJSON(config); err != nil {\n176\t\t\t\treturn err\n177\t\t\t}\n178\t\t\tstepDone(config, authIdx)\n179\t\t}\n180\t\n181\t\tmagentoIdx := len(steps) + 1\n182\t\tif magentoIdx >= config.StartFromStep {\n183\t\t\tstepStart(config, magentoIdx)\n184\t\t\tlogf(config, \"▸ ddev exec bin/magento setup:install\")\n185\t\t\tsetupArgs := []string{\"exec\", \"bin/magento\", \"setup:install\"}\n186\t\t\tfor _, f := range d.SetupInstallFlags(config) {\n187\t\t\t\tsetupArgs = append(setupArgs, f.Flag+\"=\"+f.Value)\n188\t\t\t}\n189\t\t\tif err := runInDir(config.Directory, config.Log, \"ddev\", setupArgs...); err != nil {\n190\t\t\t\treturn fmt.Errorf(\"setup:install failed: %w\", err)\n191\t\t\t}\n192\t\t\tstepDone(config, magentoIdx)\n193\t\t}\n194\t\n195\t\tnextIdx := magentoIdx + 1\n196\t\n197\t\tif config.InstallSampleData {\n198\t\t\tsampleDataIdx := nextIdx\n199\t\t\tif sampleDataIdx >= config.StartFromStep {\n200\t\t\t\tstepStart(config, sampleDataIdx)\n201\t\t\t\tlogf(config, \"▸ Deploying sample data\")\n202\t\t\t\tif err := runInDir(config.Directory, config.Log,\n203\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"sampledata:deploy\"); err != nil {\n204\t\t\t\t\treturn fmt.Errorf(\"sampledata:deploy failed: %w\", err)\n205\t\t\t\t}\n206\t\t\t\t// If no Hyvä, run setup:upgrade + cache:flush now.\n207\t\t\t\t// If Hyvä is also enabled, setup:upgrade runs in the Hyvä enable step.\n208\t\t\t\tif !config.InstallHyva {\n209\t\t\t\t\tif err := runInDir(config.Directory, config.Log,\n210\t\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n211\t\t\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n212\t\t\t\t\t}\n213\t\t\t\t\tif err := runInDir(config.Directory, config.Log,\n214\t\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n215\t\t\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n216\t\t\t\t\t}\n217\t\t\t\t}\n218\t\t\t\tstepDone(config, sampleDataIdx)\n219\t\t\t}\n220\t\t\tnextIdx++\n221\t\t}\n222\t\n223\t\tif config.InstallHyva {\n224\t\t\thyvaRepoIdx := nextIdx\n225\t\t\tif hyvaRepoIdx >= config.StartFromStep {\n226\t\t\t\tstepStart(config, hyvaRepoIdx)\n227\t\t\t\tlogf(config, \"▸ Configuring Hyvä Private Packagist repository\")\n228\t\t\t\tif err := runInDir(config.Directory, config.Log,\n229\t\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"repositories.private-packagist\",\n230\t\t\t\t\t\"composer\", config.HyvaRepoURL); err != nil {\n231\t\t\t\t\treturn fmt.Errorf(\"configure Hyvä repository failed: %w\", err)\n232\t\t\t\t}\n233\t\t\t\tif err := runInDir(config.Directory, config.Log,\n234\t\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"--auth\",\n235\t\t\t\t\t\"http-basic.\"+extractHost(config.HyvaRepoURL),\n236\t\t\t\t\t\"token\", config.HyvaAuthToken); err != nil {\n237\t\t\t\t\treturn fmt.Errorf(\"configure Hyvä auth failed: %w\", err)\n238\t\t\t\t}\n239\t\t\t\tstepDone(config, hyvaRepoIdx)\n240\t\t\t}\n241\t\t\tnextIdx++\n242\t\n243\t\t\thyvaInstallIdx := nextIdx\n244\t\t\tif hyvaInstallIdx >= config.StartFromStep {\n245\t\t\t\tstepStart(config, hyvaInstallIdx)\n246\t\t\t\tlogf(config, \"▸ Installing Hyvä theme\")\n247\t\t\t\tif err := runInDir(config.Directory, config.Log,\n248\t\t\t\t\t\"ddev\", \"exec\", \"composer\", \"require\", \"hyva-themes/magento2-default-theme\"); err != nil {\n249\t\t\t\t\treturn fmt.Errorf(\"install Hyvä theme failed: %w\", err)\n250\t\t\t\t}\n251\t\t\t\tstepDone(config, hyvaInstallIdx)\n252\t\t\t}\n253\t\t\tnextIdx++\n254\t\n255\t\t\thyvaEnableIdx := nextIdx\n256\t\t\tif hyvaEnableIdx >= config.StartFromStep {\n257\t\t\t\tstepStart(config, hyvaEnableIdx)\n258\t\t\t\tlogf(config, \"▸ Enabling Hyvä modules and setting up theme\")\n259\t\t\t\tif err := runInDir(config.Directory, config.Log,\n260\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"module:enable\", \"--all\"); err != nil {\n261\t\t\t\t\treturn fmt.Errorf(\"enable Hyvä modules failed: %w\", err)\n262\t\t\t\t}\n263\t\t\t\tif err := runInDir(config.Directory, config.Log,\n264\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n265\t\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n266\t\t\t\t}\n267\t\t\t\t// Look up the Hyvä theme ID and set it as default\n268\t\t\t\tlogf(config, \"▸ Setting Hyvä as default storefront theme\")\n269\t\t\t\tthemeID, err := ddevQueryThemeID(config.Directory, \"Hyva/default\")\n270\t\t\t\tif err != nil {\n271\t\t\t\t\treturn fmt.Errorf(\"could not find Hyvä theme ID: %w\", err)\n272\t\t\t\t}\n273\t\t\t\tlogf(config, \"▸ Hyvä theme ID: %s\", themeID)\n274\t\t\t\tif err := runInDir(config.Directory, config.Log,\n275\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"config:set\", \"design/theme/theme_id\", themeID); err != nil {\n276\t\t\t\t\treturn fmt.Errorf(\"set Hyvä theme failed: %w\", err)\n277\t\t\t\t}\n278\t\t\t\tif err := runInDir(config.Directory, config.Log,\n279\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n280\t\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n281\t\t\t\t}\n282\t\t\t\tstepDone(config, hyvaEnableIdx)\n283\t\t\t}\n284\t\t}\n285\t\n286\t\t// verifyInstallation is always the last step regardless of optional steps.\n287\t\tverifyIdx := len(d.steps) - 1\n288\t\tif verifyIdx >= config.StartFromStep {\n289\t\t\tstepStart(config, verifyIdx)\n290\t\t\tbaseURL := d.BaseURL(config.ProjectName)\n291\t\t\tlogf(config, \"▸ Verifying store at %s\", baseURL)\n292\t\t\tif err := verifyInstallation(baseURL, config.Log); err != nil {\n293\t\t\t\treturn fmt.Errorf(\"installation verification failed: %w\", err)\n294\t\t\t}\n295\t\t\tstepDone(config, verifyIdx)\n296\t\t}\n297\t\n298\t\treturn nil\n299\t}\n300\t\n301\t// verifyInstallation makes an HTTP GET request to baseURL and checks that the\n302\t// response returns HTTP 200 and includes the \"x-dist: Mage-OS\" header.\n303\t// DDEV uses self-signed TLS certificates, so TLS verification is skipped.\n304\tfunc verifyInstallation(baseURL string, logFn func(string)) error {\n305\t\tclient := &http.Client{\n306\t\t\tTimeout: 30 * time.Second,\n307\t\t\tTransport: &http.Transport{\n308\t\t\t\tTLSClientConfig: &tls.Config{InsecureSkipVerify: true}, //nolint:gosec\n309\t\t\t},\n310\t\t}\n311\t\n312\t\tresp, err := client.Get(baseURL) //nolint:noctx\n313\t\tif err != nil {\n314\t\t\treturn fmt.Errorf(\"HTTP request to %s failed: %w\", baseURL, err)\n315\t\t}\n316\t\tdefer resp.Body.Close()\n317\t\n318\t\tif resp.StatusCode != http.StatusOK {\n319\t\t\treturn fmt.Errorf(\"expected HTTP 200 from %s, got %d\", baseURL, resp.StatusCode)\n320\t\t}\n321\t\n322\t\tdist := resp.Header.Get(\"x-dist\")\n323\t\tif !strings.Contains(dist, \"Mage-OS\") {\n324\t\t\treturn fmt.Errorf(\"expected x-dist header to contain 'Mage-OS', got %q\", dist)\n325\t\t}\n326\t\n327\t\tif logFn != nil {\n328\t\t\tlogFn(fmt.Sprintf(\"▸ Verified: %s → HTTP 200, x-dist: %s\", baseURL, dist))\n329\t\t}\n330\t\treturn nil\n331\t}\n332\t\n333\t// extractHost extracts the hostname from a URL string.\n334\tfunc extractHost(rawURL string) string {\n335\t\t// Strip protocol prefix\n336\t\thost := rawURL\n337\t\tif i := strings.Index(host, \"://\"); i >= 0 {\n338\t\t\thost = host[i+3:]\n339\t\t}\n340\t\t// Strip path\n341\t\tif i := strings.Index(host, \"/\"); i >= 0 {\n342\t\t\thost = host[:i]\n343\t\t}\n344\t\treturn host\n345\t}\n346\t\n347\t// logf sends a formatted message to config.Log if it is set.\n348\tfunc logf(config *Config, format string, args ...any) {\n349\t\tif config.Log != nil {\n350\t\t\tconfig.Log(fmt.Sprintf(format, args...))\n351\t\t}\n352\t}\n353\t\n354\tfunc stepStart(config *Config, index int) {\n355\t\tif config.OnStepStart != nil {\n356\t\t\tconfig.OnStepStart(index)\n357\t\t}\n358\t}\n359\t\n360\tfunc stepDone(config *Config, index int) {\n361\t\tif config.OnStepDone != nil {\n362\t\t\tconfig.OnStepDone(index)\n363\t\t}\n364\t}\n365\t\n366\t// runInDir runs a command in dir, streaming each output line to logFn.\n367\t// If logFn is nil the output is captured silently and included only in errors.\n368\tfunc runInDir(dir string, logFn func(string), name string, args ...string) error {\n369\t\tcmd := exec.Command(name, args...)\n370\t\tcmd.Dir = dir\n371\t\n372\t\tif logFn == nil {\n373\t\t\tout, err := cmd.CombinedOutput()\n374\t\t\tif err != nil {\n375\t\t\t\treturn fmt.Errorf(\"%w\\n%s\", err, strings.TrimSpace(string(out)))\n376\t\t\t}\n377\t\t\treturn nil\n378\t\t}\n379\t\n380\t\tpr, pw := io.Pipe()\n381\t\tcmd.Stdout = pw\n382\t\tcmd.Stderr = pw\n383\t\n384\t\tif err := cmd.Start(); err != nil {\n385\t\t\tpr.Close()\n386\t\t\tpw.Close()\n387\t\t\treturn err\n388\t\t}\n389\t\n390\t\tscanDone := make(chan struct{})\n391\t\tgo func() {\n392\t\t\tdefer close(scanDone)\n393\t\t\tscanner := bufio.NewScanner(pr)\n394\t\t\tfor scanner.Scan() {\n395\t\t\t\tlogFn(scanner.Text())\n396\t\t\t}\n397\t\t}()\n398\t\n399\t\terr := cmd.Wait()\n400\t\tpw.Close()\n401\t\t<-scanDone\n402\t\tpr.Close()\n403\t\n404\t\treturn err\n405\t}\n406\t\n407\t// copyAuthJSON copies ~/.composer/auth.json into the running DDEV web container.\n408\t// If the file does not exist it is silently skipped.\n409\tfunc copyAuthJSON(config *Config) error {\n410\t\thome, err := os.UserHomeDir()\n411\t\tif err != nil {\n412\t\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n413\t\t}\n414\t\n415\t\tauthSrc := home + \"/.composer/auth.json\"\n416\t\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n417\t\t\treturn nil // nothing to copy\n418\t\t}\n419\t\n420\t\tcontainerName, err := ddevWebContainerName(config.Directory)\n421\t\tif err != nil {\n422\t\t\treturn fmt.Errorf(\"could not get DDEV web container name: %w\", err)\n423\t\t}\n424\t\n425\t\tlogf(config, \"▸ docker cp auth.json → container\")\n426\t\tauthDst := containerName + \":/var/www/html/var/composer_home/auth.json\"\n427\t\treturn runInDir(config.Directory, config.Log, \"docker\", \"cp\", authSrc, authDst)\n428\t}\n429\t\n430\t// ddevDescribeOutput is the relevant subset of `ddev describe --json-output`.\n431\ttype ddevDescribeOutput struct {\n432\t\tRaw struct {\n433\t\t\tPrimaryURL string `json:\"primary_url\"`\n434\t\t\tServices   map[string]struct {\n435\t\t\t\tFullName string `json:\"full_name\"`\n436\t\t\t} `json:\"services\"`\n437\t\t} `json:\"raw\"`\n438\t}\n439\t\n440\t// ddevWebContainerName returns the full Docker container name for the web service.\n441\tfunc ddevWebContainerName(dir string) (string, error) {\n442\t\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n443\t\tcmd.Dir = dir\n444\t\tout, err := cmd.Output()\n445\t\tif err != nil {\n446\t\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n447\t\t}\n448\t\n449\t\tvar desc ddevDescribeOutput\n450\t\tif err := json.Unmarshal(out, &desc); err != nil {\n451\t\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n452\t\t}\n453\t\n454\t\tweb, ok := desc.Raw.Services[\"web\"]\n455\t\tif !ok || web.FullName == \"\" {\n456\t\t\treturn \"\", fmt.Errorf(\"web service not found in ddev describe output\")\n457\t\t}\n458\t\n459\t\treturn web.FullName, nil\n460\t}\n461\t\n462\t// ddevPrimaryURL returns the primary URL of the running ddev project.\n463\tfunc ddevPrimaryURL(dir string) (string, error) {\n464\t\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n465\t\tcmd.Dir = dir\n466\t\tout, err := cmd.Output()\n467\t\tif err != nil {\n468\t\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n469\t\t}\n470\t\n471\t\tvar desc ddevDescribeOutput\n472\t\tif err := json.Unmarshal(out, &desc); err != nil {\n473\t\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n474\t\t}\n475\t\n476\t\tif desc.Raw.PrimaryURL == \"\" {\n477\t\t\treturn \"\", fmt.Errorf(\"primary_url not found in ddev describe output\")\n478\t\t}\n479\t\n480\t\treturn desc.Raw.PrimaryURL, nil\n481\t}\n482\t\n483\t// ddevQueryThemeID queries the database via ddev mysql for the given theme path\n484\t// and returns its numeric ID as a string.\n485\tfunc ddevQueryThemeID(dir, themePath string) (string, error) {\n486\t\tcmd := exec.Command(\"ddev\", \"mysql\", \"-N\", \"-e\",\n487\t\t\tfmt.Sprintf(\"SELECT theme_id FROM theme WHERE theme_path='%s'\", themePath))\n488\t\tcmd.Dir = dir\n489\t\tout, err := cmd.Output()\n490\t\tif err != nil {\n491\t\t\treturn \"\", fmt.Errorf(\"ddev mysql query failed: %w\", err)\n492\t\t}\n493\t\tid := strings.TrimSpace(string(out))\n494\t\tif id == \"\" {\n495\t\t\treturn \"\", fmt.Errorf(\"theme %q not found in database\", themePath)\n496\t\t}\n497\t\treturn id, nil\n498\t}\n499\t\n500\tfunc (d *DdevDetector) Detect() (*Environment, error) {\n501\t\tpath, err := exec.LookPath(\"ddev\")\n502\t\tif err != nil {\n503\t\t\treturn nil, err\n504\t\t}\n505\t\n506\t\tversion := \"unknown\"\n507\t\tout, err := exec.Command(\"ddev\", \"version\", \"-j\").Output()\n508\t\tif err == nil {\n509\t\t\tversion = parseVersion(string(out), \"ddev\")\n510\t\t}\n511\t\tif version == \"unknown\" {\n512\t\t\tout, err = exec.Command(\"ddev\", \"version\").Output()\n513\t\t\tif err == nil {\n514\t\t\t\tversion = parseDdevVersionPlain(string(out))\n515\t\t\t}\n516\t\t}\n517\t\n518\t\treturn &Environment{\n519\t\t\tName:    \"DDEV\",\n520\t\t\tVersion: version,\n521\t\t\tCommand: path,\n522\t\t}, nil\n523\t}\n524\t\n525\tfunc parseDdevVersionPlain(output string) string {\n526\t\tfor _, line := range strings.Split(output, \"\\n\") {\n527\t\t\tline = strings.TrimSpace(line)\n528\t\t\tif strings.HasPrefix(line, \"DDEV version\") || strings.HasPrefix(line, \"ddev version\") {\n529\t\t\t\tparts := strings.Fields(line)\n530\t\t\t\tif len(parts) >= 3 {\n531\t\t\t\t\treturn strings.TrimRight(parts[len(parts)-1], \",\")\n532\t\t\t\t}\n533\t\t\t}\n534\t\t\tif strings.HasPrefix(line, \"version:\") {\n535\t\t\t\tparts := strings.Fields(line)\n536\t\t\t\tif len(parts) >= 2 {\n537\t\t\t\t\treturn parts[1]\n538\t\t\t\t}\n539\t\t\t}\n540\t\t}\n541\t\treturn \"unknown\"\n542\t}\n543\t"}]},"parent_tool_use_id":null,"session_id":"93d16013-c824-4dee-a909-af38c9b89b17","uuid":"a79ea342-ef33-4eb7-890f-9f3839fc8910","timestamp":"2026-04-14T19:23:42.694Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/detector/ddev.go","content":"package detector\n\nimport (\n\t\"bufio\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"strings\"\n\t\"time\"\n)\n\n// DdevDetector checks for the DDEV development environment.\ntype DdevDetector struct {\n\t// primaryURL is populated after ddev start by querying ddev describe.\n\tprimaryURL string\n\t// steps is the list of installation steps, built dynamically based on config.\n\tsteps []Step\n}\n\nfunc (d *DdevDetector) Info() DetectorInfo {\n\treturn DetectorInfo{\n\t\tName:       \"DDEV\",\n\t\tInstallURL: \"https://ddev.readthedocs.io/en/stable/\",\n\t}\n}\n\nfunc (d *DdevDetector) Steps() []Step {\n\treturn d.steps\n}\n\nfunc (d *DdevDetector) PrepareSteps(config *Config) {\n\td.buildSteps(config)\n}\n\nfunc (d *DdevDetector) buildSteps(config *Config) {\n\td.steps = []Step{\n\t\t{Name: \"Configure DDEV project\"},\n\t\t{Name: \"Install OpenSearch addon\"},\n\t\t{Name: \"Install Redis addon\"},\n\t\t{Name: \"Install Cron addon\"},\n\t\t{Name: \"Install RabbitMQ addon\"},\n\t\t{Name: \"Start DDEV\"},\n\t\t{Name: \"Apply RabbitMQ config\"},\n\t\t{Name: \"Create Mage-OS project\"},\n\t\t{Name: \"Copy project files\"},\n\t\t{Name: \"Create composer home directory\"},\n\t\t{Name: \"Copy auth.json\"},\n\t\t{Name: \"Install Mage-OS\"},\n\t}\n\tif config != nil && config.InstallSampleData {\n\t\td.steps = append(d.steps, Step{Name: \"Install sample data\"})\n\t}\n\tif config != nil && config.InstallHyva {\n\t\td.steps = append(d.steps,\n\t\t\tStep{Name: \"Configure Hyvä repository\"},\n\t\t\tStep{Name: \"Install Hyvä theme\"},\n\t\t\tStep{Name: \"Enable Hyvä modules\"},\n\t\t)\n\t}\n\td.steps = append(d.steps, Step{Name: \"Verify installation\"})\n}\n\nfunc (d *DdevDetector) SetupCommandPrefix() string {\n\treturn \"ddev exec bin/magento setup:install\"\n}\n\nfunc (d *DdevDetector) BaseURL(projectName string) string {\n\tif d.primaryURL != \"\" {\n\t\treturn d.primaryURL\n\t}\n\treturn \"https://\" + projectName + \".ddev.site\"\n}\n\n// SetupInstallFlags returns the full ordered list of flags for bin/magento setup:install.\nfunc (d *DdevDetector) SetupInstallFlags(config *Config) []SetupFlag {\n\treturn []SetupFlag{\n\t\t{Flag: \"--backend-frontname\", Value: \"admin\"},\n\t\t{Flag: \"--amqp-host\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--amqp-port\", Value: \"5672\"},\n\t\t{Flag: \"--amqp-user\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--amqp-password\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--db-host\", Value: \"db\"},\n\t\t{Flag: \"--db-name\", Value: \"db\"},\n\t\t{Flag: \"--db-user\", Value: \"db\"},\n\t\t{Flag: \"--db-password\", Value: \"db\"},\n\t\t{Flag: \"--search-engine\", Value: \"opensearch\"},\n\t\t{Flag: \"--opensearch-host\", Value: \"opensearch\"},\n\t\t{Flag: \"--opensearch-port\", Value: \"9200\"},\n\t\t{Flag: \"--opensearch-index-prefix\", Value: \"magento2\"},\n\t\t{Flag: \"--opensearch-enable-auth\", Value: \"0\"},\n\t\t{Flag: \"--opensearch-timeout\", Value: \"15\"},\n\t\t{Flag: \"--http-cache-hosts\", Value: \"varnish:80\"},\n\t\t{Flag: \"--session-save\", Value: \"redis\"},\n\t\t{Flag: \"--session-save-redis-host\", Value: \"redis\"},\n\t\t{Flag: \"--session-save-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--session-save-redis-db\", Value: \"2\"},\n\t\t{Flag: \"--session-save-redis-max-concurrency\", Value: \"20\"},\n\t\t{Flag: \"--cache-backend\", Value: \"redis\"},\n\t\t{Flag: \"--cache-backend-redis-server\", Value: \"redis\"},\n\t\t{Flag: \"--cache-backend-redis-db\", Value: \"0\"},\n\t\t{Flag: \"--cache-backend-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--page-cache\", Value: \"redis\"},\n\t\t{Flag: \"--page-cache-redis-server\", Value: \"redis\"},\n\t\t{Flag: \"--page-cache-redis-db\", Value: \"1\"},\n\t\t{Flag: \"--page-cache-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--base-url\", Value: d.BaseURL(config.ProjectName)},\n\t\t{Flag: \"--timezone\", Value: \"Europe/Amsterdam\"},\n\t\t{Flag: \"--currency\", Value: \"EUR\"},\n\t\t{Flag: \"--admin-user\", Value: config.AdminUser, Editable: true},\n\t\t{Flag: \"--admin-password\", Value: config.AdminPassword, Editable: true},\n\t\t{Flag: \"--admin-email\", Value: config.AdminEmail, Editable: true},\n\t\t{Flag: \"--admin-firstname\", Value: config.AdminFirstname, Editable: true},\n\t\t{Flag: \"--admin-lastname\", Value: config.AdminLastname, Editable: true},\n\t\t{Flag: \"--use-rewrites\", Value: \"1\"},\n\t}\n}\n\nfunc (d *DdevDetector) Install(config *Config) error {\n\td.buildSteps(config)\n\n\tsteps := [][]string{\n\t\t{\n\t\t\t\"ddev\", \"config\",\n\t\t\t\"--project-name=\" + config.ProjectName,\n\t\t\t\"--docroot=pub\",\n\t\t\t\"--project-type=magento2\",\n\t\t\t\"--database=mysql:8.0\",\n\t\t\t\"--composer-version=2.2\",\n\t\t},\n\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-opensearch\"},\n\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-redis\"},\n\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-cron\"},\n\t\t{\"ddev\", \"add-on\", \"get\", \"b13/ddev-rabbitmq\"},\n\t\t{\"ddev\", \"start\"},\n\t\t{\"ddev\", \"rabbitmq\", \"apply\"},\n\t\t{\n\t\t\t\"ddev\", \"exec\", \"composer\", \"create-project\",\n\t\t\t\"--repository-url=https://repo.mage-os.org/\",\n\t\t\t\"mage-os/project-community-edition\",\n\t\t\t\"/tmp/mage-os-project\",\n\t\t},\n\t\t{\n\t\t\t\"ddev\", \"exec\", \"bash\", \"-c\",\n\t\t\t\"cp -a /tmp/mage-os-project/. /var/www/html/\",\n\t\t},\n\t\t{\"ddev\", \"exec\", \"mkdir\", \"-p\", \"/var/www/html/var/composer_home/\"},\n\t}\n\n\tfor i, args := range steps {\n\t\tif i < config.StartFromStep {\n\t\t\tcontinue\n\t\t}\n\t\tstepStart(config, i)\n\t\tlogf(config, \"▸ %s\", strings.Join(args, \" \"))\n\t\tif err := runInDir(config.Directory, config.Log, args[0], args[1:]...); err != nil {\n\t\t\treturn fmt.Errorf(\"step %q failed: %w\", strings.Join(args, \" \"), err)\n\t\t}\n\t\tstepDone(config, i)\n\t}\n\n\t// After ddev start, query the actual primary URL so we use\n\t// the correct domain (e.g. .ddev.site) for Magento's base-url.\n\tif url, err := ddevPrimaryURL(config.Directory); err == nil {\n\t\td.primaryURL = url\n\t\tlogf(config, \"▸ Detected primary URL: %s\", url)\n\t}\n\n\tauthIdx := len(steps)\n\tif authIdx >= config.StartFromStep {\n\t\tstepStart(config, authIdx)\n\t\tif err := copyAuthJSON(config); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstepDone(config, authIdx)\n\t}\n\n\tmagentoIdx := len(steps) + 1\n\tif magentoIdx >= config.StartFromStep {\n\t\tstepStart(config, magentoIdx)\n\t\tlogf(config, \"▸ ddev exec bin/magento setup:install\")\n\t\tsetupArgs := []string{\"exec\", \"bin/magento\", \"setup:install\"}\n\t\tfor _, f := range d.SetupInstallFlags(config) {\n\t\t\tsetupArgs = append(setupArgs, f.Flag+\"=\"+f.Value)\n\t\t}\n\t\tif err := runInDir(config.Directory, config.Log, \"ddev\", setupArgs...); err != nil {\n\t\t\treturn fmt.Errorf(\"setup:install failed: %w\", err)\n\t\t}\n\t\tstepDone(config, magentoIdx)\n\t}\n\n\tnextIdx := magentoIdx + 1\n\n\tif config.InstallSampleData {\n\t\tsampleDataIdx := nextIdx\n\t\tif sampleDataIdx >= config.StartFromStep {\n\t\t\tstepStart(config, sampleDataIdx)\n\t\t\tlogf(config, \"▸ Deploying sample data\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"sampledata:deploy\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"sampledata:deploy failed: %w\", err)\n\t\t\t}\n\t\t\t// If no Hyvä, run setup:upgrade + cache:flush now.\n\t\t\t// If Hyvä is also enabled, setup:upgrade runs in the Hyvä enable step.\n\t\t\tif !config.InstallHyva {\n\t\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n\t\t\t\t}\n\t\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t\tstepDone(config, sampleDataIdx)\n\t\t}\n\t\tnextIdx++\n\t}\n\n\tif config.InstallHyva {\n\t\thyvaRepoIdx := nextIdx\n\t\tif hyvaRepoIdx >= config.StartFromStep {\n\t\t\tstepStart(config, hyvaRepoIdx)\n\t\t\tlogf(config, \"▸ Configuring Hyvä Private Packagist repository\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"repositories.private-packagist\",\n\t\t\t\t\"composer\", config.HyvaRepoURL); err != nil {\n\t\t\t\treturn fmt.Errorf(\"configure Hyvä repository failed: %w\", err)\n\t\t\t}\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"--auth\",\n\t\t\t\t\"http-basic.\"+extractHost(config.HyvaRepoURL),\n\t\t\t\t\"token\", config.HyvaAuthToken); err != nil {\n\t\t\t\treturn fmt.Errorf(\"configure Hyvä auth failed: %w\", err)\n\t\t\t}\n\t\t\tstepDone(config, hyvaRepoIdx)\n\t\t}\n\t\tnextIdx++\n\n\t\thyvaInstallIdx := nextIdx\n\t\tif hyvaInstallIdx >= config.StartFromStep {\n\t\t\tstepStart(config, hyvaInstallIdx)\n\t\t\tlogf(config, \"▸ Installing Hyvä theme\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"composer\", \"require\", \"hyva-themes/magento2-default-theme\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"install Hyvä theme failed: %w\", err)\n\t\t\t}\n\t\t\tstepDone(config, hyvaInstallIdx)\n\t\t}\n\t\tnextIdx++\n\n\t\thyvaEnableIdx := nextIdx\n\t\tif hyvaEnableIdx >= config.StartFromStep {\n\t\t\tstepStart(config, hyvaEnableIdx)\n\t\t\tlogf(config, \"▸ Enabling Hyvä modules and setting up theme\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"module:enable\", \"--all\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"enable Hyvä modules failed: %w\", err)\n\t\t\t}\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n\t\t\t}\n\t\t\t// Look up the Hyvä theme ID and set it as default\n\t\t\tlogf(config, \"▸ Setting Hyvä as default storefront theme\")\n\t\t\tthemeID, err := ddevQueryThemeID(config.Directory, \"Hyva/default\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"could not find Hyvä theme ID: %w\", err)\n\t\t\t}\n\t\t\tlogf(config, \"▸ Hyvä theme ID: %s\", themeID)\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"config:set\", \"design/theme/theme_id\", themeID); err != nil {\n\t\t\t\treturn fmt.Errorf(\"set Hyvä theme failed: %w\", err)\n\t\t\t}\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n\t\t\t}\n\t\t\tstepDone(config, hyvaEnableIdx)\n\t\t}\n\t}\n\n\t// verifyInstallation is always the last step regardless of optional steps.\n\tverifyIdx := len(d.steps) - 1\n\tif verifyIdx >= config.StartFromStep {\n\t\tstepStart(config, verifyIdx)\n\t\tbaseURL := d.BaseURL(config.ProjectName)\n\t\tlogf(config, \"▸ Verifying store at %s\", baseURL)\n\t\tif err := verifyInstallation(baseURL, config.Log); err != nil {\n\t\t\treturn fmt.Errorf(\"installation verification failed: %w\", err)\n\t\t}\n\t\tstepDone(config, verifyIdx)\n\t}\n\n\treturn nil\n}\n\n// verifyInstallation makes an HTTP GET request to baseURL and checks that the\n// response returns HTTP 200 and includes the \"x-dist: Mage-OS\" header.\n// DDEV uses self-signed TLS certificates, so TLS verification is skipped.\nfunc verifyInstallation(baseURL string, logFn func(string)) error {\n\tclient := &http.Client{\n\t\tTimeout: 30 * time.Second,\n\t\tTransport: &http.Transport{\n\t\t\tTLSClientConfig: &tls.Config{InsecureSkipVerify: true}, //nolint:gosec\n\t\t},\n\t}\n\n\tresp, err := client.Get(baseURL) //nolint:noctx\n\tif err != nil {\n\t\treturn fmt.Errorf(\"HTTP request to %s failed: %w\", baseURL, err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\treturn fmt.Errorf(\"expected HTTP 200 from %s, got %d\", baseURL, resp.StatusCode)\n\t}\n\n\tdist := resp.Header.Get(\"x-dist\")\n\tif !strings.Contains(dist, \"Mage-OS\") {\n\t\treturn fmt.Errorf(\"expected x-dist header to contain 'Mage-OS', got %q\", dist)\n\t}\n\n\tif logFn != nil {\n\t\tlogFn(fmt.Sprintf(\"▸ Verified: %s → HTTP 200, x-dist: %s\", baseURL, dist))\n\t}\n\treturn nil\n}\n\n// extractHost extracts the hostname from a URL string.\nfunc extractHost(rawURL string) string {\n\t// Strip protocol prefix\n\thost := rawURL\n\tif i := strings.Index(host, \"://\"); i >= 0 {\n\t\thost = host[i+3:]\n\t}\n\t// Strip path\n\tif i := strings.Index(host, \"/\"); i >= 0 {\n\t\thost = host[:i]\n\t}\n\treturn host\n}\n\n// logf sends a formatted message to config.Log if it is set.\nfunc logf(config *Config, format string, args ...any) {\n\tif config.Log != nil {\n\t\tconfig.Log(fmt.Sprintf(format, args...))\n\t}\n}\n\nfunc stepStart(config *Config, index int) {\n\tif config.OnStepStart != nil {\n\t\tconfig.OnStepStart(index)\n\t}\n}\n\nfunc stepDone(config *Config, index int) {\n\tif config.OnStepDone != nil {\n\t\tconfig.OnStepDone(index)\n\t}\n}\n\n// runInDir runs a command in dir, streaming each output line to logFn.\n// If logFn is nil the output is captured silently and included only in errors.\nfunc runInDir(dir string, logFn func(string), name string, args ...string) error {\n\tcmd := exec.Command(name, args...)\n\tcmd.Dir = dir\n\n\tif logFn == nil {\n\t\tout, err := cmd.CombinedOutput()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"%w\\n%s\", err, strings.TrimSpace(string(out)))\n\t\t}\n\t\treturn nil\n\t}\n\n\tpr, pw := io.Pipe()\n\tcmd.Stdout = pw\n\tcmd.Stderr = pw\n\n\tif err := cmd.Start(); err != nil {\n\t\tpr.Close()\n\t\tpw.Close()\n\t\treturn err\n\t}\n\n\tscanDone := make(chan struct{})\n\tgo func() {\n\t\tdefer close(scanDone)\n\t\tscanner := bufio.NewScanner(pr)\n\t\tfor scanner.Scan() {\n\t\t\tlogFn(scanner.Text())\n\t\t}\n\t}()\n\n\terr := cmd.Wait()\n\tpw.Close()\n\t<-scanDone\n\tpr.Close()\n\n\treturn err\n}\n\n// copyAuthJSON copies ~/.composer/auth.json into the running DDEV web container.\n// If the file does not exist it is silently skipped.\nfunc copyAuthJSON(config *Config) error {\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n\t}\n\n\tauthSrc := home + \"/.composer/auth.json\"\n\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n\t\treturn nil // nothing to copy\n\t}\n\n\tcontainerName, err := ddevWebContainerName(config.Directory)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not get DDEV web container name: %w\", err)\n\t}\n\n\tlogf(config, \"▸ docker cp auth.json → container\")\n\tauthDst := containerName + \":/var/www/html/var/composer_home/auth.json\"\n\treturn runInDir(config.Directory, config.Log, \"docker\", \"cp\", authSrc, authDst)\n}\n\n// ddevDescribeOutput is the relevant subset of `ddev describe --json-output`.\ntype ddevDescribeOutput struct {\n\tRaw struct {\n\t\tPrimaryURL string `json:\"primary_url\"`\n\t\tServices   map[string]struct {\n\t\t\tFullName string `json:\"full_name\"`\n\t\t} `json:\"services\"`\n\t} `json:\"raw\"`\n}\n\n// ddevWebContainerName returns the full Docker container name for the web service.\nfunc ddevWebContainerName(dir string) (string, error) {\n\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n\t}\n\n\tvar desc ddevDescribeOutput\n\tif err := json.Unmarshal(out, &desc); err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n\t}\n\n\tweb, ok := desc.Raw.Services[\"web\"]\n\tif !ok || web.FullName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"web service not found in ddev describe output\")\n\t}\n\n\treturn web.FullName, nil\n}\n\n// ddevPrimaryURL returns the primary URL of the running ddev project.\nfunc ddevPrimaryURL(dir string) (string, error) {\n\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n\t}\n\n\tvar desc ddevDescribeOutput\n\tif err := json.Unmarshal(out, &desc); err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n\t}\n\n\tif desc.Raw.PrimaryURL == \"\" {\n\t\treturn \"\", fmt.Errorf(\"primary_url not found in ddev describe output\")\n\t}\n\n\treturn desc.Raw.PrimaryURL, nil\n}\n\n// ddevQueryThemeID queries the database via ddev mysql for the given theme path\n// and returns its numeric ID as a string.\nfunc ddevQueryThemeID(dir, themePath string) (string, error) {\n\tcmd := exec.Command(\"ddev\", \"mysql\", \"-N\", \"-e\",\n\t\tfmt.Sprintf(\"SELECT theme_id FROM theme WHERE theme_path='%s'\", themePath))\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"ddev mysql query failed: %w\", err)\n\t}\n\tid := strings.TrimSpace(string(out))\n\tif id == \"\" {\n\t\treturn \"\", fmt.Errorf(\"theme %q not found in database\", themePath)\n\t}\n\treturn id, nil\n}\n\nfunc (d *DdevDetector) Detect() (*Environment, error) {\n\tpath, err := exec.LookPath(\"ddev\")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tversion := \"unknown\"\n\tout, err := exec.Command(\"ddev\", \"version\", \"-j\").Output()\n\tif err == nil {\n\t\tversion = parseVersion(string(out), \"ddev\")\n\t}\n\tif version == \"unknown\" {\n\t\tout, err = exec.Command(\"ddev\", \"version\").Output()\n\t\tif err == nil {\n\t\t\tversion = parseDdevVersionPlain(string(out))\n\t\t}\n\t}\n\n\treturn &Environment{\n\t\tName:    \"DDEV\",\n\t\tVersion: version,\n\t\tCommand: path,\n\t}, nil\n}\n\nfunc parseDdevVersionPlain(output string) string {\n\tfor _, line := range strings.Split(output, \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif strings.HasPrefix(line, \"DDEV version\") || strings.HasPrefix(line, \"ddev version\") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tif len(parts) >= 3 {\n\t\t\t\treturn strings.TrimRight(parts[len(parts)-1], \",\")\n\t\t\t}\n\t\t}\n\t\tif strings.HasPrefix(line, \"version:\") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tif len(parts) >= 2 {\n\t\t\t\treturn parts[1]\n\t\t\t}\n\t\t}\n\t}\n\treturn \"unknown\"\n}\n","numLines":543,"startLine":1,"totalLines":543}}}
