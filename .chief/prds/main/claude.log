{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013yiAJgifLFr3eqRD4AAsfo","type":"tool_result","content":"1\tpackage tui\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"path/filepath\"\n7\t\t\"testing\"\n8\t\n9\t\ttea \"github.com/charmbracelet/bubbletea\"\n10\t\t\"github.com/mage-os/mage-os-install/internal/detector\"\n11\t)\n12\t\n13\t// mockDetector satisfies the detector.Detector interface for tests.\n14\ttype mockDetector struct {\n15\t\tinfo       detector.DetectorInfo\n16\t\tenv        *detector.Environment\n17\t\tinstallErr error\n18\t}\n19\t\n20\tfunc (d *mockDetector) Info() detector.DetectorInfo            { return d.info }\n21\tfunc (d *mockDetector) Steps() []detector.Step                 { return nil }\n22\tfunc (d *mockDetector) PrepareSteps(_ *detector.Config)        {}\n23\tfunc (d *mockDetector) Detect() (*detector.Environment, error) { return d.env, nil }\n24\tfunc (d *mockDetector) Install(cfg *detector.Config) error     { return d.installErr }\n25\tfunc (d *mockDetector) SetupInstallFlags(_ *detector.Config) []detector.SetupFlag {\n26\t\treturn nil\n27\t}\n28\tfunc (d *mockDetector) SetupCommandPrefix() string  { return \"mock exec bin/magento setup:install\" }\n29\tfunc (d *mockDetector) BaseURL(projectName string) string {\n30\t\treturn \"https://\" + projectName + \".test\"\n31\t}\n32\t\n33\t// sendMsg sends a message into the model and returns the updated model.\n34\t// The returned tea.Cmd is discarded — no side-effects run during tests.\n35\tfunc sendMsg(m Model, msg tea.Msg) Model {\n36\t\tnewModel, _ := m.Update(msg)\n37\t\treturn newModel.(Model)\n38\t}\n39\t\n40\tfunc pressEnter(m Model) Model {\n41\t\treturn sendMsg(m, tea.KeyMsg{Type: tea.KeyEnter})\n42\t}\n43\t\n44\t// makeDetectedEnv builds a DetectedEnvironment backed by a mockDetector.\n45\tfunc makeDetectedEnv(name string) detector.DetectedEnvironment {\n46\t\treturn detector.DetectedEnvironment{\n47\t\t\tEnv:      detector.Environment{Name: name, Version: \"1.0.0\"},\n48\t\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: name, InstallURL: \"https://example.com\"}},\n49\t\t}\n50\t}\n51\t\n52\t// --- initial state ---\n53\t\n54\tfunc TestNew_StartsInNameInputPhase(t *testing.T) {\n55\t\tm := New()\n56\t\tif m.phase != phaseNameInput {\n57\t\t\tt.Errorf(\"expected phaseNameInput, got %d\", m.phase)\n58\t\t}\n59\t}\n60\t\n61\tfunc TestNew_NameInputMatchesOriginalName(t *testing.T) {\n62\t\tm := New()\n63\t\tif m.nameInput.Value() == \"\" {\n64\t\t\tt.Error(\"nameInput should have a non-empty default\")\n65\t\t}\n66\t\tif m.nameInput.Value() != m.originalName {\n67\t\t\tt.Errorf(\"nameInput.Value() %q should equal originalName %q\", m.nameInput.Value(), m.originalName)\n68\t\t}\n69\t}\n70\t\n71\t// --- name → directory phase ---\n72\t\n73\tfunc TestUpdate_EnterOnNameGoesToDirectoryPhase(t *testing.T) {\n74\t\tm := pressEnter(New())\n75\t\tif m.phase != phaseDirectoryInput {\n76\t\t\tt.Errorf(\"expected phaseDirectoryInput, got %d\", m.phase)\n77\t\t}\n78\t}\n79\t\n80\tfunc TestUpdate_DirDefault_WhenNameUnchanged_IsCurrentDir(t *testing.T) {\n81\t\tm := pressEnter(New()) // name → dir\n82\t\twd, _ := os.Getwd()\n83\t\tif m.dirInput.Value() != wd {\n84\t\t\tt.Errorf(\"expected dir %q, got %q\", wd, m.dirInput.Value())\n85\t\t}\n86\t}\n87\t\n88\tfunc TestUpdate_DirDefault_WhenNameChanged_IsCwdPlusName(t *testing.T) {\n89\t\tm := New()\n90\t\tm.originalName = \"original\"\n91\t\tm.nameInput.SetValue(\"my-custom-project\")\n92\t\tm = pressEnter(m) // name → dir\n93\t\twd, _ := os.Getwd()\n94\t\texpected := filepath.Join(wd, \"my-custom-project\")\n95\t\tif m.dirInput.Value() != expected {\n96\t\t\tt.Errorf(\"expected dir %q, got %q\", expected, m.dirInput.Value())\n97\t\t}\n98\t}\n99\t\n100\t// --- detection caching during input phases ---\n101\t\n102\tfunc TestUpdate_DetectionCachedDuringNameInput(t *testing.T) {\n103\t\tm := sendMsg(New(), detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n104\t\tif m.phase != phaseNameInput {\n105\t\t\tt.Errorf(\"phase should stay phaseNameInput, got %d\", m.phase)\n106\t\t}\n107\t\tif m.envs == nil {\n108\t\t\tt.Error(\"envs should be cached (non-nil)\")\n109\t\t}\n110\t}\n111\t\n112\tfunc TestUpdate_DetectionCachedDuringDirInput(t *testing.T) {\n113\t\tm := pressEnter(New()) // go to dir phase\n114\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n115\t\tif m.phase != phaseDirectoryInput {\n116\t\t\tt.Errorf(\"phase should stay phaseDirectoryInput, got %d\", m.phase)\n117\t\t}\n118\t\tif m.envs == nil {\n119\t\t\tt.Error(\"envs should be cached (non-nil)\")\n120\t\t}\n121\t}\n122\t\n123\t// --- advancing from directory phase ---\n124\t\n125\tfunc TestUpdate_EnterOnDir_NoEnvs_GoesToError(t *testing.T) {\n126\t\tm := pressEnter(New())                                                     // → dir\n127\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})   // cache: empty\n128\t\tm = pressEnter(m)                                                          // confirm dir\n129\t\tif m.phase != phaseError {\n130\t\t\tt.Errorf(\"expected phaseError, got %d\", m.phase)\n131\t\t}\n132\t}\n133\t\n134\tfunc TestUpdate_EnterOnDir_OneEnv_GoesToSetupConfig(t *testing.T) {\n135\t\tm := pressEnter(New())                                                                    // → dir\n136\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}}) // cache: one\n137\t\tm = pressEnter(m)                                                                         // confirm dir\n138\t\tif m.phase != phaseSetupConfig {\n139\t\t\tt.Errorf(\"expected phaseSetupConfig, got %d\", m.phase)\n140\t\t}\n141\t}\n142\t\n143\tfunc TestUpdate_EnterOnDir_MultipleEnvs_GoesToSelection(t *testing.T) {\n144\t\tm := pressEnter(New()) // → dir\n145\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{\n146\t\t\tmakeDetectedEnv(\"DDEV\"),\n147\t\t\tmakeDetectedEnv(\"Warden\"),\n148\t\t}})\n149\t\tm = pressEnter(m) // confirm dir\n150\t\tif m.phase != phaseSelection {\n151\t\t\tt.Errorf(\"expected phaseSelection, got %d\", m.phase)\n152\t\t}\n153\t}\n154\t\n155\tfunc TestUpdate_EnterOnDir_StillDetecting_GoesToDetecting(t *testing.T) {\n156\t\tm := pressEnter(New()) // → dir (envs still nil)\n157\t\tm = pressEnter(m)      // confirm dir without cached envs\n158\t\tif m.phase != phaseDetecting {\n159\t\t\tt.Errorf(\"expected phaseDetecting, got %d\", m.phase)\n160\t\t}\n161\t}\n162\t\n163\t// --- install done ---\n164\t\n165\tfunc TestUpdate_InstallDone_GoesToOpenBrowser(t *testing.T) {\n166\t\tm := sendMsg(New(), installDoneMsg{err: nil})\n167\t\tif m.phase != phaseOpenBrowser {\n168\t\t\tt.Errorf(\"expected phaseOpenBrowser, got %d\", m.phase)\n169\t\t}\n170\t}\n171\t\n172\tfunc TestUpdate_InstallDone_WithError_GoesToInstallDone(t *testing.T) {\n173\t\tm := sendMsg(New(), installDoneMsg{err: fmt.Errorf(\"something failed\")})\n174\t\tif m.phase != phaseInstallDone {\n175\t\t\tt.Errorf(\"expected phaseInstallDone, got %d\", m.phase)\n176\t\t}\n177\t}\n178\t\n179\t// --- selection phase cursor ---\n180\t\n181\tfunc TestUpdate_SelectionCursorMovement(t *testing.T) {\n182\t\tm := New()\n183\t\tm.phase = phaseSelection\n184\t\tm.envs = []detector.DetectedEnvironment{\n185\t\t\tmakeDetectedEnv(\"DDEV\"),\n186\t\t\tmakeDetectedEnv(\"Warden\"),\n187\t\t}\n188\t\tm.cursor = 0\n189\t\n190\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n191\t\tif m.cursor != 1 {\n192\t\t\tt.Errorf(\"expected cursor 1 after down, got %d\", m.cursor)\n193\t\t}\n194\t\n195\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n196\t\tif m.cursor != 0 {\n197\t\t\tt.Errorf(\"expected cursor 0 after up, got %d\", m.cursor)\n198\t\t}\n199\t}\n200\t\n201\tfunc TestUpdate_SelectionCursor_DoesNotGoOutOfBounds(t *testing.T) {\n202\t\tm := New()\n203\t\tm.phase = phaseSelection\n204\t\tm.envs = []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}\n205\t\tm.cursor = 0\n206\t\n207\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n208\t\tif m.cursor != 0 {\n209\t\t\tt.Errorf(\"cursor should stay at 0 at end of list, got %d\", m.cursor)\n210\t\t}\n211\t\n212\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n213\t\tif m.cursor != 0 {\n214\t\t\tt.Errorf(\"cursor should stay at 0 at start of list, got %d\", m.cursor)\n215\t\t}\n216\t}\n217\t\n218\t// --- view content ---\n219\t\n220\t// TestView_SelectionShowsNameAndVersion verifies that the selection screen\n221\t// includes both the environment name and version (acceptance criterion 2).\n222\tfunc TestView_SelectionShowsNameAndVersion(t *testing.T) {\n223\t\tm := New()\n224\t\tm.phase = phaseSelection\n225\t\tm.envs = []detector.DetectedEnvironment{\n226\t\t\t{\n227\t\t\t\tEnv:      detector.Environment{Name: \"DDEV\", Version: \"1.23.4\"},\n228\t\t\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: \"DDEV\", InstallURL: \"https://ddev.example.com\"}},\n229\t\t\t},\n230\t\t}\n231\t\tview := m.View()\n232\t\tif !contains(view, \"DDEV\") {\n233\t\t\tt.Error(\"selection view should contain environment name 'DDEV'\")\n234\t\t}\n235\t\tif !contains(view, \"1.23.4\") {\n236\t\t\tt.Error(\"selection view should contain environment version '1.23.4'\")\n237\t\t}\n238\t}\n239\t\n240\t// TestView_ErrorShowsInstallLinks verifies that the error phase shows\n241\t// links for each known environment (acceptance criterion 5).\n242\tfunc TestView_ErrorShowsInstallLinks(t *testing.T) {\n243\t\tm := New()\n244\t\tm.phase = phaseError\n245\t\tview := m.View()\n246\t\tfor _, info := range detector.AllDetectorInfos() {\n247\t\t\tif !contains(view, info.InstallURL) {\n248\t\t\t\tt.Errorf(\"error view should contain install URL %q for %q\", info.InstallURL, info.Name)\n249\t\t\t}\n250\t\t}\n251\t}\n252\t\n253\t// TestView_DetectingPhaseShowsSpinner verifies that the detecting phase\n254\t// renders spinner output (acceptance criterion 6).\n255\tfunc TestView_DetectingPhaseShowsSpinner(t *testing.T) {\n256\t\tm := New()\n257\t\tm.phase = phaseDetecting\n258\t\tview := m.View()\n259\t\tif !contains(view, \"Detecting\") {\n260\t\t\tt.Error(\"detecting phase view should contain 'Detecting'\")\n261\t\t}\n262\t}\n263\t\n264\t// --- admin credentials form (US-003) ---\n265\t\n266\t// advanceToSetupConfig drives the model through name → dir → setup config using a mock env.\n267\tfunc advanceToSetupConfig(t *testing.T) Model {\n268\t\tt.Helper()\n269\t\tm := pressEnter(New()) // name → dir\n270\t\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}})\n271\t\tm = pressEnter(m) // dir → setup config\n272\t\tif m.phase != phaseSetupConfig {\n273\t\t\tt.Fatalf(\"expected phaseSetupConfig, got %d\", m.phase)\n274\t\t}\n275\t\treturn m\n276\t}\n277\t\n278\t// TestSetupConfig_HasAllFiveFields verifies the setup form view renders all five\n279\t// required admin credential field labels.\n280\tfunc TestSetupConfig_HasAllFiveFields(t *testing.T) {\n281\t\tm := advanceToSetupConfig(t)\n282\t\tview := m.View()\n283\t\tfor _, want := range []string{\"Admin user\", \"Admin password\", \"Admin email\", \"Admin firstname\", \"Admin lastname\"} {\n284\t\t\tif !contains(view, want) {\n285\t\t\t\tt.Errorf(\"setup config view missing field label %q\", want)\n286\t\t\t}\n287\t\t}\n288\t}\n289\t\n290\t// TestSetupConfig_DefaultsPreFilled verifies that all five admin fields have\n291\t// sensible (non-empty) default values after initSetupInputs.\n292\tfunc TestSetupConfig_DefaultsPreFilled(t *testing.T) {\n293\t\tm := advanceToSetupConfig(t)\n294\t\tfor i, f := range setupFieldDefs {\n295\t\t\tval := m.setupInputs[i].Value()\n296\t\t\tif val == \"\" {\n297\t\t\t\tt.Errorf(\"field %q should have a non-empty default, got empty string\", f.label)\n298\t\t\t}\n299\t\t}\n300\t}\n301\t\n302\t// TestSetupConfig_TabAdvancesField verifies Tab moves focus to the next field.\n303\tfunc TestSetupConfig_TabAdvancesField(t *testing.T) {\n304\t\tm := advanceToSetupConfig(t)\n305\t\t// Start at field 0 (admin user)\n306\t\tif m.setupFocus != 0 {\n307\t\t\tt.Fatalf(\"expected setupFocus 0, got %d\", m.setupFocus)\n308\t\t}\n309\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n310\t\tif m.inTogglePhase || m.setupFocus != 1 {\n311\t\t\tt.Errorf(\"Tab should move focus to field 1; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n312\t\t}\n313\t}\n314\t\n315\t// TestSetupConfig_ShiftTabGoesBack verifies Shift+Tab moves focus to the previous field.\n316\tfunc TestSetupConfig_ShiftTabGoesBack(t *testing.T) {\n317\t\tm := advanceToSetupConfig(t)\n318\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab}) // → field 1\n319\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyShiftTab})\n320\t\tif m.inTogglePhase || m.setupFocus != 0 {\n321\t\t\tt.Errorf(\"Shift+Tab should move back to field 0; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n322\t\t}\n323\t}\n324\t\n325\t// TestSetupConfig_ValidationRejectsEmpty verifies that clearing a field and\n326\t// pressing Enter on the last field triggers a validation error.\n327\tfunc TestSetupConfig_ValidationRejectsEmpty(t *testing.T) {\n328\t\tm := advanceToSetupConfig(t)\n329\t\t// Clear the admin user field (index 0)\n330\t\tm.setupInputs[0].SetValue(\"\")\n331\t\t// Navigate to the last admin field then to the last toggle and submit\n332\t\t// by pressing Enter on the last field in the form.\n333\t\t// Simulate being on the last hyva toggle (absPos == totalFields-1) with enter.\n334\t\t// Easier: set absPos to last and send enter directly via pressing tab many times.\n335\t\ttotalFields := len(m.setupInputs) + 2 // +2 for toggles\n336\t\tfor i := 0; i < totalFields-1; i++ {\n337\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n338\t\t}\n339\t\t// Now at the last field; press Enter → should trigger validation\n340\t\tm = pressEnter(m)\n341\t\tif m.setupError == \"\" {\n342\t\t\tt.Error(\"expected a setupError after submitting with an empty required field, got none\")\n343\t\t}\n344\t\tif m.phase == phaseSetupPreview {\n345\t\t\tt.Error(\"should not advance to phaseSetupPreview when validation fails\")\n346\t\t}\n347\t}\n348\t\n349\t// --- sample data toggle (US-004) ---\n350\t\n351\t// TestSampleData_DefaultIsOff verifies that the sample data toggle is off by default.\n352\tfunc TestSampleData_DefaultIsOff(t *testing.T) {\n353\t\tm := advanceToSetupConfig(t)\n354\t\tif m.installSampleData {\n355\t\t\tt.Error(\"installSampleData should be false by default\")\n356\t\t}\n357\t}\n358\t\n359\t// TestSampleData_ToggledBySpace verifies that pressing space on the sample data\n360\t// toggle switches it on, and pressing space again switches it off.\n361\tfunc TestSampleData_ToggledBySpace(t *testing.T) {\n362\t\tm := advanceToSetupConfig(t)\n363\t\n364\t\t// Tab through all admin fields to reach the sample data toggle\n365\t\tfor i := 0; i < len(setupFieldDefs); i++ {\n366\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n367\t\t}\n368\t\t// Now at sample data toggle (absPos == len(setupInputs))\n369\t\tif !m.inTogglePhase || m.toggleFocus != -2 {\n370\t\t\tt.Fatalf(\"expected focus on sample data toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n371\t\t}\n372\t\n373\t\t// Press space: should enable sample data\n374\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n375\t\tif !m.installSampleData {\n376\t\t\tt.Error(\"space should enable installSampleData\")\n377\t\t}\n378\t\n379\t\t// Press space again: should disable sample data\n380\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n381\t\tif m.installSampleData {\n382\t\t\tt.Error(\"second space should disable installSampleData\")\n383\t\t}\n384\t}\n385\t\n386\t// TestSampleData_ViewContainsToggle verifies the setup form renders the sample data toggle.\n387\tfunc TestSampleData_ViewContainsToggle(t *testing.T) {\n388\t\tm := advanceToSetupConfig(t)\n389\t\tview := m.View()\n390\t\tif !contains(view, \"Install sample data\") {\n391\t\t\tt.Error(\"setup config view should contain 'Install sample data' toggle\")\n392\t\t}\n393\t}\n394\t\n395\t// TestSampleData_ViewShowsChecked verifies the toggle renders as [x] when enabled.\n396\tfunc TestSampleData_ViewShowsChecked(t *testing.T) {\n397\t\tm := advanceToSetupConfig(t)\n398\t\tm.installSampleData = true\n399\t\tview := m.View()\n400\t\tif !contains(view, \"[x]\") {\n401\t\t\tt.Error(\"view should show [x] when installSampleData is true\")\n402\t\t}\n403\t}\n404\t\n405\t// --- Hyvä theme toggle (US-005) ---\n406\t\n407\t// navigateToHyvaToggle tabs through all admin fields and the sample data toggle\n408\t// to land on the Hyvä toggle.\n409\tfunc navigateToHyvaToggle(m Model) Model {\n410\t\t// len(setupFieldDefs) tabs → sample data toggle; one more → Hyvä toggle\n411\t\tfor i := 0; i < len(setupFieldDefs)+1; i++ {\n412\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n413\t\t}\n414\t\treturn m\n415\t}\n416\t\n417\t// TestHyva_DefaultIsOff verifies that the Hyvä toggle is off by default.\n418\tfunc TestHyva_DefaultIsOff(t *testing.T) {\n419\t\tm := advanceToSetupConfig(t)\n420\t\tif m.installHyva {\n421\t\t\tt.Error(\"installHyva should be false by default\")\n422\t\t}\n423\t}\n424\t\n425\t// TestHyva_ToggledBySpace verifies that pressing space on the Hyvä toggle\n426\t// enables it, and pressing space again disables it.\n427\tfunc TestHyva_ToggledBySpace(t *testing.T) {\n428\t\tm := advanceToSetupConfig(t)\n429\t\tm = navigateToHyvaToggle(m)\n430\t\n431\t\tif !m.inTogglePhase || m.toggleFocus != -1 {\n432\t\t\tt.Fatalf(\"expected focus on Hyvä toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n433\t\t}\n434\t\n435\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n436\t\tif !m.installHyva {\n437\t\t\tt.Error(\"space should enable installHyva\")\n438\t\t}\n439\t\n440\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n441\t\tif m.installHyva {\n442\t\t\tt.Error(\"second space should disable installHyva\")\n443\t\t}\n444\t}\n445\t\n446\t// TestHyva_ViewContainsToggle verifies the setup form renders the Hyvä toggle.\n447\tfunc TestHyva_ViewContainsToggle(t *testing.T) {\n448\t\tm := advanceToSetupConfig(t)\n449\t\tview := m.View()\n450\t\tif !contains(view, \"Install Hyv\") {\n451\t\t\tt.Error(\"setup config view should contain 'Install Hyvä' toggle label\")\n452\t\t}\n453\t}\n454\t\n455\t// TestHyva_ViewShowsChecked verifies the toggle renders as [x] when Hyvä is enabled.\n456\tfunc TestHyva_ViewShowsChecked(t *testing.T) {\n457\t\tm := advanceToSetupConfig(t)\n458\t\tm.installHyva = true\n459\t\tview := m.View()\n460\t\tif !contains(view, \"[x]\") {\n461\t\t\tt.Error(\"view should show [x] when installHyva is true\")\n462\t\t}\n463\t}\n464\t\n465\t// TestHyva_CredentialFieldsHiddenByDefault verifies that Hyvä repo/token fields\n466\t// are not shown when the toggle is off (AC2).\n467\tfunc TestHyva_CredentialFieldsHiddenByDefault(t *testing.T) {\n468\t\tm := advanceToSetupConfig(t)\n469\t\tview := m.View()\n470\t\tif contains(view, \"Repo URL\") {\n471\t\t\tt.Error(\"'Repo URL' field should not appear when installHyva is false\")\n472\t\t}\n473\t\tif contains(view, \"Auth token\") {\n474\t\t\tt.Error(\"'Auth token' field should not appear when installHyva is false\")\n475\t\t}\n476\t}\n477\t\n478\t// TestHyva_CredentialFieldsAppearsWhenEnabled verifies that enabling the toggle\n479\t// shows the Hyvä repo URL and auth token fields (AC2).\n480\tfunc TestHyva_CredentialFieldsAppearsWhenEnabled(t *testing.T) {\n481\t\tm := advanceToSetupConfig(t)\n482\t\tm.installHyva = true\n483\t\tview := m.View()\n484\t\tif !contains(view, \"Repo URL\") {\n485\t\t\tt.Error(\"'Repo URL' field should appear when installHyva is true\")\n486\t\t}\n487\t\tif !contains(view, \"Auth token\") {\n488\t\t\tt.Error(\"'Auth token' field should appear when installHyva is true\")\n489\t\t}\n490\t}\n491\t\n492\tfunc contains(s, substr string) bool {\n493\t\treturn len(s) >= len(substr) && (s == substr || len(substr) == 0 ||\n494\t\t\tfunc() bool {\n495\t\t\t\tfor i := 0; i <= len(s)-len(substr); i++ {\n496\t\t\t\t\tif s[i:i+len(substr)] == substr {\n497\t\t\t\t\t\treturn true\n498\t\t\t\t\t}\n499\t\t\t\t}\n500\t\t\t\treturn false\n501\t\t\t}())\n502\t}\n503\t"}]},"parent_tool_use_id":null,"session_id":"27dbe6f2-4344-4ebd-9988-c8a54cc5d7bc","uuid":"af2412b8-1c3d-41f8-8db3-f212a2f10bff","timestamp":"2026-04-14T19:31:24.211Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/tui/tui_test.go","content":"package tui\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\ttea \"github.com/charmbracelet/bubbletea\"\n\t\"github.com/mage-os/mage-os-install/internal/detector\"\n)\n\n// mockDetector satisfies the detector.Detector interface for tests.\ntype mockDetector struct {\n\tinfo       detector.DetectorInfo\n\tenv        *detector.Environment\n\tinstallErr error\n}\n\nfunc (d *mockDetector) Info() detector.DetectorInfo            { return d.info }\nfunc (d *mockDetector) Steps() []detector.Step                 { return nil }\nfunc (d *mockDetector) PrepareSteps(_ *detector.Config)        {}\nfunc (d *mockDetector) Detect() (*detector.Environment, error) { return d.env, nil }\nfunc (d *mockDetector) Install(cfg *detector.Config) error     { return d.installErr }\nfunc (d *mockDetector) SetupInstallFlags(_ *detector.Config) []detector.SetupFlag {\n\treturn nil\n}\nfunc (d *mockDetector) SetupCommandPrefix() string  { return \"mock exec bin/magento setup:install\" }\nfunc (d *mockDetector) BaseURL(projectName string) string {\n\treturn \"https://\" + projectName + \".test\"\n}\n\n// sendMsg sends a message into the model and returns the updated model.\n// The returned tea.Cmd is discarded — no side-effects run during tests.\nfunc sendMsg(m Model, msg tea.Msg) Model {\n\tnewModel, _ := m.Update(msg)\n\treturn newModel.(Model)\n}\n\nfunc pressEnter(m Model) Model {\n\treturn sendMsg(m, tea.KeyMsg{Type: tea.KeyEnter})\n}\n\n// makeDetectedEnv builds a DetectedEnvironment backed by a mockDetector.\nfunc makeDetectedEnv(name string) detector.DetectedEnvironment {\n\treturn detector.DetectedEnvironment{\n\t\tEnv:      detector.Environment{Name: name, Version: \"1.0.0\"},\n\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: name, InstallURL: \"https://example.com\"}},\n\t}\n}\n\n// --- initial state ---\n\nfunc TestNew_StartsInNameInputPhase(t *testing.T) {\n\tm := New()\n\tif m.phase != phaseNameInput {\n\t\tt.Errorf(\"expected phaseNameInput, got %d\", m.phase)\n\t}\n}\n\nfunc TestNew_NameInputMatchesOriginalName(t *testing.T) {\n\tm := New()\n\tif m.nameInput.Value() == \"\" {\n\t\tt.Error(\"nameInput should have a non-empty default\")\n\t}\n\tif m.nameInput.Value() != m.originalName {\n\t\tt.Errorf(\"nameInput.Value() %q should equal originalName %q\", m.nameInput.Value(), m.originalName)\n\t}\n}\n\n// --- name → directory phase ---\n\nfunc TestUpdate_EnterOnNameGoesToDirectoryPhase(t *testing.T) {\n\tm := pressEnter(New())\n\tif m.phase != phaseDirectoryInput {\n\t\tt.Errorf(\"expected phaseDirectoryInput, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_DirDefault_WhenNameUnchanged_IsCurrentDir(t *testing.T) {\n\tm := pressEnter(New()) // name → dir\n\twd, _ := os.Getwd()\n\tif m.dirInput.Value() != wd {\n\t\tt.Errorf(\"expected dir %q, got %q\", wd, m.dirInput.Value())\n\t}\n}\n\nfunc TestUpdate_DirDefault_WhenNameChanged_IsCwdPlusName(t *testing.T) {\n\tm := New()\n\tm.originalName = \"original\"\n\tm.nameInput.SetValue(\"my-custom-project\")\n\tm = pressEnter(m) // name → dir\n\twd, _ := os.Getwd()\n\texpected := filepath.Join(wd, \"my-custom-project\")\n\tif m.dirInput.Value() != expected {\n\t\tt.Errorf(\"expected dir %q, got %q\", expected, m.dirInput.Value())\n\t}\n}\n\n// --- detection caching during input phases ---\n\nfunc TestUpdate_DetectionCachedDuringNameInput(t *testing.T) {\n\tm := sendMsg(New(), detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n\tif m.phase != phaseNameInput {\n\t\tt.Errorf(\"phase should stay phaseNameInput, got %d\", m.phase)\n\t}\n\tif m.envs == nil {\n\t\tt.Error(\"envs should be cached (non-nil)\")\n\t}\n}\n\nfunc TestUpdate_DetectionCachedDuringDirInput(t *testing.T) {\n\tm := pressEnter(New()) // go to dir phase\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})\n\tif m.phase != phaseDirectoryInput {\n\t\tt.Errorf(\"phase should stay phaseDirectoryInput, got %d\", m.phase)\n\t}\n\tif m.envs == nil {\n\t\tt.Error(\"envs should be cached (non-nil)\")\n\t}\n}\n\n// --- advancing from directory phase ---\n\nfunc TestUpdate_EnterOnDir_NoEnvs_GoesToError(t *testing.T) {\n\tm := pressEnter(New())                                                     // → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{}})   // cache: empty\n\tm = pressEnter(m)                                                          // confirm dir\n\tif m.phase != phaseError {\n\t\tt.Errorf(\"expected phaseError, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_EnterOnDir_OneEnv_GoesToSetupConfig(t *testing.T) {\n\tm := pressEnter(New())                                                                    // → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}}) // cache: one\n\tm = pressEnter(m)                                                                         // confirm dir\n\tif m.phase != phaseSetupConfig {\n\t\tt.Errorf(\"expected phaseSetupConfig, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_EnterOnDir_MultipleEnvs_GoesToSelection(t *testing.T) {\n\tm := pressEnter(New()) // → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{\n\t\tmakeDetectedEnv(\"DDEV\"),\n\t\tmakeDetectedEnv(\"Warden\"),\n\t}})\n\tm = pressEnter(m) // confirm dir\n\tif m.phase != phaseSelection {\n\t\tt.Errorf(\"expected phaseSelection, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_EnterOnDir_StillDetecting_GoesToDetecting(t *testing.T) {\n\tm := pressEnter(New()) // → dir (envs still nil)\n\tm = pressEnter(m)      // confirm dir without cached envs\n\tif m.phase != phaseDetecting {\n\t\tt.Errorf(\"expected phaseDetecting, got %d\", m.phase)\n\t}\n}\n\n// --- install done ---\n\nfunc TestUpdate_InstallDone_GoesToOpenBrowser(t *testing.T) {\n\tm := sendMsg(New(), installDoneMsg{err: nil})\n\tif m.phase != phaseOpenBrowser {\n\t\tt.Errorf(\"expected phaseOpenBrowser, got %d\", m.phase)\n\t}\n}\n\nfunc TestUpdate_InstallDone_WithError_GoesToInstallDone(t *testing.T) {\n\tm := sendMsg(New(), installDoneMsg{err: fmt.Errorf(\"something failed\")})\n\tif m.phase != phaseInstallDone {\n\t\tt.Errorf(\"expected phaseInstallDone, got %d\", m.phase)\n\t}\n}\n\n// --- selection phase cursor ---\n\nfunc TestUpdate_SelectionCursorMovement(t *testing.T) {\n\tm := New()\n\tm.phase = phaseSelection\n\tm.envs = []detector.DetectedEnvironment{\n\t\tmakeDetectedEnv(\"DDEV\"),\n\t\tmakeDetectedEnv(\"Warden\"),\n\t}\n\tm.cursor = 0\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n\tif m.cursor != 1 {\n\t\tt.Errorf(\"expected cursor 1 after down, got %d\", m.cursor)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"expected cursor 0 after up, got %d\", m.cursor)\n\t}\n}\n\nfunc TestUpdate_SelectionCursor_DoesNotGoOutOfBounds(t *testing.T) {\n\tm := New()\n\tm.phase = phaseSelection\n\tm.envs = []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}\n\tm.cursor = 0\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"cursor should stay at 0 at end of list, got %d\", m.cursor)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"cursor should stay at 0 at start of list, got %d\", m.cursor)\n\t}\n}\n\n// --- view content ---\n\n// TestView_SelectionShowsNameAndVersion verifies that the selection screen\n// includes both the environment name and version (acceptance criterion 2).\nfunc TestView_SelectionShowsNameAndVersion(t *testing.T) {\n\tm := New()\n\tm.phase = phaseSelection\n\tm.envs = []detector.DetectedEnvironment{\n\t\t{\n\t\t\tEnv:      detector.Environment{Name: \"DDEV\", Version: \"1.23.4\"},\n\t\t\tDetector: &mockDetector{info: detector.DetectorInfo{Name: \"DDEV\", InstallURL: \"https://ddev.example.com\"}},\n\t\t},\n\t}\n\tview := m.View()\n\tif !contains(view, \"DDEV\") {\n\t\tt.Error(\"selection view should contain environment name 'DDEV'\")\n\t}\n\tif !contains(view, \"1.23.4\") {\n\t\tt.Error(\"selection view should contain environment version '1.23.4'\")\n\t}\n}\n\n// TestView_ErrorShowsInstallLinks verifies that the error phase shows\n// links for each known environment (acceptance criterion 5).\nfunc TestView_ErrorShowsInstallLinks(t *testing.T) {\n\tm := New()\n\tm.phase = phaseError\n\tview := m.View()\n\tfor _, info := range detector.AllDetectorInfos() {\n\t\tif !contains(view, info.InstallURL) {\n\t\t\tt.Errorf(\"error view should contain install URL %q for %q\", info.InstallURL, info.Name)\n\t\t}\n\t}\n}\n\n// TestView_DetectingPhaseShowsSpinner verifies that the detecting phase\n// renders spinner output (acceptance criterion 6).\nfunc TestView_DetectingPhaseShowsSpinner(t *testing.T) {\n\tm := New()\n\tm.phase = phaseDetecting\n\tview := m.View()\n\tif !contains(view, \"Detecting\") {\n\t\tt.Error(\"detecting phase view should contain 'Detecting'\")\n\t}\n}\n\n// --- admin credentials form (US-003) ---\n\n// advanceToSetupConfig drives the model through name → dir → setup config using a mock env.\nfunc advanceToSetupConfig(t *testing.T) Model {\n\tt.Helper()\n\tm := pressEnter(New()) // name → dir\n\tm = sendMsg(m, detectionDoneMsg{envs: []detector.DetectedEnvironment{makeDetectedEnv(\"DDEV\")}})\n\tm = pressEnter(m) // dir → setup config\n\tif m.phase != phaseSetupConfig {\n\t\tt.Fatalf(\"expected phaseSetupConfig, got %d\", m.phase)\n\t}\n\treturn m\n}\n\n// TestSetupConfig_HasAllFiveFields verifies the setup form view renders all five\n// required admin credential field labels.\nfunc TestSetupConfig_HasAllFiveFields(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tfor _, want := range []string{\"Admin user\", \"Admin password\", \"Admin email\", \"Admin firstname\", \"Admin lastname\"} {\n\t\tif !contains(view, want) {\n\t\t\tt.Errorf(\"setup config view missing field label %q\", want)\n\t\t}\n\t}\n}\n\n// TestSetupConfig_DefaultsPreFilled verifies that all five admin fields have\n// sensible (non-empty) default values after initSetupInputs.\nfunc TestSetupConfig_DefaultsPreFilled(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tfor i, f := range setupFieldDefs {\n\t\tval := m.setupInputs[i].Value()\n\t\tif val == \"\" {\n\t\t\tt.Errorf(\"field %q should have a non-empty default, got empty string\", f.label)\n\t\t}\n\t}\n}\n\n// TestSetupConfig_TabAdvancesField verifies Tab moves focus to the next field.\nfunc TestSetupConfig_TabAdvancesField(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\t// Start at field 0 (admin user)\n\tif m.setupFocus != 0 {\n\t\tt.Fatalf(\"expected setupFocus 0, got %d\", m.setupFocus)\n\t}\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\tif m.inTogglePhase || m.setupFocus != 1 {\n\t\tt.Errorf(\"Tab should move focus to field 1; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n\t}\n}\n\n// TestSetupConfig_ShiftTabGoesBack verifies Shift+Tab moves focus to the previous field.\nfunc TestSetupConfig_ShiftTabGoesBack(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab}) // → field 1\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyShiftTab})\n\tif m.inTogglePhase || m.setupFocus != 0 {\n\t\tt.Errorf(\"Shift+Tab should move back to field 0; inTogglePhase=%v setupFocus=%d\", m.inTogglePhase, m.setupFocus)\n\t}\n}\n\n// TestSetupConfig_ValidationRejectsEmpty verifies that clearing a field and\n// pressing Enter on the last field triggers a validation error.\nfunc TestSetupConfig_ValidationRejectsEmpty(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\t// Clear the admin user field (index 0)\n\tm.setupInputs[0].SetValue(\"\")\n\t// Navigate to the last admin field then to the last toggle and submit\n\t// by pressing Enter on the last field in the form.\n\t// Simulate being on the last hyva toggle (absPos == totalFields-1) with enter.\n\t// Easier: set absPos to last and send enter directly via pressing tab many times.\n\ttotalFields := len(m.setupInputs) + 2 // +2 for toggles\n\tfor i := 0; i < totalFields-1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\t// Now at the last field; press Enter → should trigger validation\n\tm = pressEnter(m)\n\tif m.setupError == \"\" {\n\t\tt.Error(\"expected a setupError after submitting with an empty required field, got none\")\n\t}\n\tif m.phase == phaseSetupPreview {\n\t\tt.Error(\"should not advance to phaseSetupPreview when validation fails\")\n\t}\n}\n\n// --- sample data toggle (US-004) ---\n\n// TestSampleData_DefaultIsOff verifies that the sample data toggle is off by default.\nfunc TestSampleData_DefaultIsOff(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tif m.installSampleData {\n\t\tt.Error(\"installSampleData should be false by default\")\n\t}\n}\n\n// TestSampleData_ToggledBySpace verifies that pressing space on the sample data\n// toggle switches it on, and pressing space again switches it off.\nfunc TestSampleData_ToggledBySpace(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\n\t// Tab through all admin fields to reach the sample data toggle\n\tfor i := 0; i < len(setupFieldDefs); i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\t// Now at sample data toggle (absPos == len(setupInputs))\n\tif !m.inTogglePhase || m.toggleFocus != -2 {\n\t\tt.Fatalf(\"expected focus on sample data toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n\t}\n\n\t// Press space: should enable sample data\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif !m.installSampleData {\n\t\tt.Error(\"space should enable installSampleData\")\n\t}\n\n\t// Press space again: should disable sample data\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif m.installSampleData {\n\t\tt.Error(\"second space should disable installSampleData\")\n\t}\n}\n\n// TestSampleData_ViewContainsToggle verifies the setup form renders the sample data toggle.\nfunc TestSampleData_ViewContainsToggle(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif !contains(view, \"Install sample data\") {\n\t\tt.Error(\"setup config view should contain 'Install sample data' toggle\")\n\t}\n}\n\n// TestSampleData_ViewShowsChecked verifies the toggle renders as [x] when enabled.\nfunc TestSampleData_ViewShowsChecked(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installSampleData = true\n\tview := m.View()\n\tif !contains(view, \"[x]\") {\n\t\tt.Error(\"view should show [x] when installSampleData is true\")\n\t}\n}\n\n// --- Hyvä theme toggle (US-005) ---\n\n// navigateToHyvaToggle tabs through all admin fields and the sample data toggle\n// to land on the Hyvä toggle.\nfunc navigateToHyvaToggle(m Model) Model {\n\t// len(setupFieldDefs) tabs → sample data toggle; one more → Hyvä toggle\n\tfor i := 0; i < len(setupFieldDefs)+1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\treturn m\n}\n\n// TestHyva_DefaultIsOff verifies that the Hyvä toggle is off by default.\nfunc TestHyva_DefaultIsOff(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tif m.installHyva {\n\t\tt.Error(\"installHyva should be false by default\")\n\t}\n}\n\n// TestHyva_ToggledBySpace verifies that pressing space on the Hyvä toggle\n// enables it, and pressing space again disables it.\nfunc TestHyva_ToggledBySpace(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm = navigateToHyvaToggle(m)\n\n\tif !m.inTogglePhase || m.toggleFocus != -1 {\n\t\tt.Fatalf(\"expected focus on Hyvä toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif !m.installHyva {\n\t\tt.Error(\"space should enable installHyva\")\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif m.installHyva {\n\t\tt.Error(\"second space should disable installHyva\")\n\t}\n}\n\n// TestHyva_ViewContainsToggle verifies the setup form renders the Hyvä toggle.\nfunc TestHyva_ViewContainsToggle(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif !contains(view, \"Install Hyv\") {\n\t\tt.Error(\"setup config view should contain 'Install Hyvä' toggle label\")\n\t}\n}\n\n// TestHyva_ViewShowsChecked verifies the toggle renders as [x] when Hyvä is enabled.\nfunc TestHyva_ViewShowsChecked(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installHyva = true\n\tview := m.View()\n\tif !contains(view, \"[x]\") {\n\t\tt.Error(\"view should show [x] when installHyva is true\")\n\t}\n}\n\n// TestHyva_CredentialFieldsHiddenByDefault verifies that Hyvä repo/token fields\n// are not shown when the toggle is off (AC2).\nfunc TestHyva_CredentialFieldsHiddenByDefault(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif contains(view, \"Repo URL\") {\n\t\tt.Error(\"'Repo URL' field should not appear when installHyva is false\")\n\t}\n\tif contains(view, \"Auth token\") {\n\t\tt.Error(\"'Auth token' field should not appear when installHyva is false\")\n\t}\n}\n\n// TestHyva_CredentialFieldsAppearsWhenEnabled verifies that enabling the toggle\n// shows the Hyvä repo URL and auth token fields (AC2).\nfunc TestHyva_CredentialFieldsAppearsWhenEnabled(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installHyva = true\n\tview := m.View()\n\tif !contains(view, \"Repo URL\") {\n\t\tt.Error(\"'Repo URL' field should appear when installHyva is true\")\n\t}\n\tif !contains(view, \"Auth token\") {\n\t\tt.Error(\"'Auth token' field should appear when installHyva is true\")\n\t}\n}\n\nfunc contains(s, substr string) bool {\n\treturn len(s) >= len(substr) && (s == substr || len(substr) == 0 ||\n\t\tfunc() bool {\n\t\t\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\t\t\tif s[i:i+len(substr)] == substr {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t}())\n}\n","numLines":503,"startLine":1,"totalLines":503}}}
