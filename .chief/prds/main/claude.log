{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UfweE791amgGrBtbaSUh7E","type":"tool_result","content":"1\tpackage tui\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"os/exec\"\n7\t\t\"path/filepath\"\n8\t\t\"runtime\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/charmbracelet/bubbles/spinner\"\n12\t\t\"github.com/charmbracelet/bubbles/textinput\"\n13\t\ttea \"github.com/charmbracelet/bubbletea\"\n14\t\t\"github.com/charmbracelet/lipgloss\"\n15\t\t\"github.com/mage-os/mage-os-install/internal/detector\"\n16\t)\n17\t\n18\ttype phase int\n19\t\n20\tconst (\n21\t\tphaseNameInput phase = iota\n22\t\tphaseDirectoryInput\n23\t\tphaseDetecting\n24\t\tphaseSelection\n25\t\tphaseSetupConfig  // admin credentials form\n26\t\tphaseSetupPreview // full command preview before running\n27\t\tphaseInstalling\n28\t\tphaseOpenBrowser // ask whether to open the site after install\n29\t\tphaseInstallDone\n30\t\tphaseError\n31\t)\n32\t\n33\t// detectionDoneMsg is sent when environment detection completes.\n34\ttype detectionDoneMsg struct {\n35\t\tenvs []detector.DetectedEnvironment\n36\t}\n37\t\n38\t// installDoneMsg is sent when installation completes.\n39\ttype installDoneMsg struct {\n40\t\terr error\n41\t}\n42\t\n43\t// logMsg carries a single line of installer output.\n44\ttype logMsg string\n45\t\n46\t// stepStartMsg is sent when an installation step begins.\n47\ttype stepStartMsg struct{ index int }\n48\t\n49\t// sudoCachedMsg is sent after sudo -v completes (caching credentials).\n50\ttype sudoCachedMsg struct{ err error }\n51\t\n52\t// stepDoneMsg is sent when an installation step completes successfully.\n53\ttype stepDoneMsg struct{ index int }\n54\t\n55\ttype stepStatus int\n56\t\n57\tconst (\n58\t\tstepPending stepStatus = iota\n59\t\tstepRunning\n60\t\tstepDone\n61\t\tstepFailed\n62\t)\n63\t\n64\ttype installStep struct {\n65\t\tname   string\n66\t\tstatus stepStatus\n67\t}\n68\t\n69\t// Model is the main bubbletea model for the installer TUI.\n70\ttype Model struct {\n71\t\tphase         phase\n72\t\tspinner       spinner.Model\n73\t\tnameInput     textinput.Model\n74\t\toriginalName  string // the default seeded into nameInput, used to compute the dir default\n75\t\tdirInput      textinput.Model\n76\t\tenvs          []detector.DetectedEnvironment\n77\t\tcursor        int\n78\t\tselected      *detector.DetectedEnvironment\n79\t\tsetupInputs   []textinput.Model\n80\t\tsetupFocus    int\n81\t\tsetupError    string\n82\t\tinstallCfg    detector.Config\n83\t\tpreviewScroll int\n84\t\twindowHeight  int\n85\t\twindowWidth   int\n86\t\tlogCh         <-chan tea.Msg\n87\t\tlogLines      []string\n88\t\tinstallSteps  []installStep\n89\t\tinstallErr    error\n90\t\tbrowserOpened bool\n91\t\n92\t\t// Optional feature toggles and Hyvä credentials\n93\t\tinstallSampleData bool\n94\t\tinstallHyva       bool\n95\t\thyvaInputs        []textinput.Model\n96\t\t// toggleFocus tracks which toggle/section has focus:\n97\t\t//   -2 = sample data toggle\n98\t\t//   -1 = hyva toggle\n99\t\t//   0+ = hyva input field index\n100\t\ttoggleFocus    int\n101\t\tinTogglePhase  bool // true when focus is in the toggle/hyva section (not admin fields)\n102\t}\n103\t\n104\t// currentDirName returns the base name of the working directory.\n105\tfunc currentDirName() string {\n106\t\tif wd, err := os.Getwd(); err == nil {\n107\t\t\treturn filepath.Base(wd)\n108\t\t}\n109\t\treturn \"my-project\"\n110\t}\n111\t\n112\t// New creates the initial TUI model.\n113\tfunc New() Model {\n114\t\ts := spinner.New()\n115\t\ts.Spinner = spinner.Dot\n116\t\ts.Style = spinnerStyle\n117\t\n118\t\tdefaultName := currentDirName()\n119\t\n120\t\tti := textinput.New()\n121\t\tti.SetValue(defaultName)\n122\t\tti.Focus()\n123\t\tti.CharLimit = 64\n124\t\n125\t\treturn Model{\n126\t\t\tphase:        phaseNameInput,\n127\t\t\tspinner:      s,\n128\t\t\tnameInput:    ti,\n129\t\t\toriginalName: defaultName,\n130\t\t}\n131\t}\n132\t\n133\tfunc (m Model) Init() tea.Cmd {\n134\t\t// Start detection in the background immediately so results are ready\n135\t\t// by the time the user confirms the project name.\n136\t\treturn tea.Batch(m.spinner.Tick, detectEnvironments, textinput.Blink)\n137\t}\n138\t\n139\tfunc detectEnvironments() tea.Msg {\n140\t\treturn detectionDoneMsg{envs: detector.DetectAll()}\n141\t}\n142\t\n143\t// defaultDirectory returns the install directory based on whether the user\n144\t// changed the project name from the default.\n145\tfunc (m *Model) defaultDirectory() string {\n146\t\twd, err := os.Getwd()\n147\t\tif err != nil {\n148\t\t\twd = \".\"\n149\t\t}\n150\t\tif m.nameInput.Value() == m.originalName {\n151\t\t\treturn wd\n152\t\t}\n153\t\treturn filepath.Join(wd, m.nameInput.Value())\n154\t}\n155\t\n156\t// enterDirectoryPhase transitions to the directory input phase,\n157\t// pre-filling the input with the computed default.\n158\tfunc (m *Model) enterDirectoryPhase() tea.Cmd {\n159\t\tdi := textinput.New()\n160\t\tdi.SetValue(m.defaultDirectory())\n161\t\tdi.Focus()\n162\t\tdi.CharLimit = 256\n163\t\tm.dirInput = di\n164\t\tm.phase = phaseDirectoryInput\n165\t\treturn textinput.Blink\n166\t}\n167\t\n168\t// initInstallSteps loads the step list from the selected detector.\n169\tfunc (m *Model) initInstallSteps() {\n170\t\tm.installSteps = nil\n171\t\tfor _, s := range m.selected.Detector.Steps() {\n172\t\t\tm.installSteps = append(m.installSteps, installStep{name: s.Name, status: stepPending})\n173\t\t}\n174\t}\n175\t\n176\t// setupFieldDefs defines the user-editable fields shown in the Mage-OS setup form.\n177\tvar setupFieldDefs = []struct {\n178\t\tlabel string\n179\t\techo  textinput.EchoMode\n180\t}{\n181\t\t{label: \"Admin user\", echo: textinput.EchoNormal},\n182\t\t{label: \"Admin password\", echo: textinput.EchoPassword},\n183\t\t{label: \"Admin email\", echo: textinput.EchoNormal},\n184\t\t{label: \"Admin firstname\", echo: textinput.EchoNormal},\n185\t\t{label: \"Admin lastname\", echo: textinput.EchoNormal},\n186\t}\n187\t\n188\tvar setupFieldDefaults = []string{\"admin\", \"\", \"\", \"Admin\", \"User\"}\n189\t\n190\t// hyvaFieldDefs defines the Hyvä credential fields.\n191\tvar hyvaFieldDefs = []struct {\n192\t\tlabel string\n193\t\techo  textinput.EchoMode\n194\t}{\n195\t\t{label: \"Repo URL\", echo: textinput.EchoNormal},\n196\t\t{label: \"Auth token\", echo: textinput.EchoPassword},\n197\t}\n198\t\n199\t// initSetupInputs creates fresh text inputs for the Mage-OS setup form.\n200\tfunc (m *Model) initSetupInputs() {\n201\t\tm.setupInputs = make([]textinput.Model, len(setupFieldDefs))\n202\t\tfor i, f := range setupFieldDefs {\n203\t\t\tti := textinput.New()\n204\t\t\tti.SetValue(setupFieldDefaults[i])\n205\t\t\tti.EchoMode = f.echo\n206\t\t\tti.CharLimit = 128\n207\t\t\tif i == 0 {\n208\t\t\t\tti.Focus()\n209\t\t\t}\n210\t\t\tm.setupInputs[i] = ti\n211\t\t}\n212\t\tm.setupFocus = 0\n213\t\n214\t\t// Initialize toggles and Hyvä inputs\n215\t\tm.installSampleData = false\n216\t\tm.installHyva = false\n217\t\tm.inTogglePhase = false\n218\t\tm.toggleFocus = -2 // sample data toggle\n219\t\tm.hyvaInputs = make([]textinput.Model, len(hyvaFieldDefs))\n220\t\tfor i, f := range hyvaFieldDefs {\n221\t\t\tti := textinput.New()\n222\t\t\tti.EchoMode = f.echo\n223\t\t\tti.CharLimit = 256\n224\t\t\tm.hyvaInputs[i] = ti\n225\t\t}\n226\t}\n227\t\n228\t// focusSetupInput focuses the input at index and blurs all others.\n229\tfunc (m *Model) focusSetupInput(index int) {\n230\t\tfor i := range m.setupInputs {\n231\t\t\tif i == index {\n232\t\t\t\tm.setupInputs[i].Focus()\n233\t\t\t} else {\n234\t\t\t\tm.setupInputs[i].Blur()\n235\t\t\t}\n236\t\t}\n237\t\tm.setupFocus = index\n238\t}\n239\t\n240\t// focusAbsolutePos sets focus based on absolute position across all form fields.\n241\t// Layout: [admin fields...] [sampledata toggle] [hyva toggle] [hyva fields if enabled...]\n242\tfunc (m *Model) focusAbsolutePos(pos int) {\n243\t\t// Blur everything\n244\t\tfor i := range m.setupInputs {\n245\t\t\tm.setupInputs[i].Blur()\n246\t\t}\n247\t\tfor i := range m.hyvaInputs {\n248\t\t\tm.hyvaInputs[i].Blur()\n249\t\t}\n250\t\n251\t\tsampleDataPos := len(m.setupInputs)\n252\t\thyvaTogglePos := sampleDataPos + 1\n253\t\n254\t\tif pos < sampleDataPos {\n255\t\t\t// Admin field\n256\t\t\tm.inTogglePhase = false\n257\t\t\tm.setupFocus = pos\n258\t\t\tm.setupInputs[pos].Focus()\n259\t\t} else if pos == sampleDataPos {\n260\t\t\t// Sample data toggle\n261\t\t\tm.inTogglePhase = true\n262\t\t\tm.toggleFocus = -2\n263\t\t} else if pos == hyvaTogglePos {\n264\t\t\t// Hyva toggle\n265\t\t\tm.inTogglePhase = true\n266\t\t\tm.toggleFocus = -1\n267\t\t} else {\n268\t\t\t// Hyva input field\n269\t\t\tm.inTogglePhase = true\n270\t\t\tm.toggleFocus = pos - hyvaTogglePos - 1\n271\t\t\tif m.toggleFocus < len(m.hyvaInputs) {\n272\t\t\t\tm.hyvaInputs[m.toggleFocus].Focus()\n273\t\t\t}\n274\t\t}\n275\t}\n276\t\n277\t// buildInstallConfig builds a Config from the current form and input values.\n278\tfunc (m *Model) buildInstallConfig() detector.Config {\n279\t\tcfg := detector.Config{\n280\t\t\tProjectName:       m.nameInput.Value(),\n281\t\t\tDirectory:         m.dirInput.Value(),\n282\t\t\tAdminUser:         m.setupInputs[0].Value(),\n283\t\t\tAdminPassword:     m.setupInputs[1].Value(),\n284\t\t\tAdminEmail:        m.setupInputs[2].Value(),\n285\t\t\tAdminFirstname:    m.setupInputs[3].Value(),\n286\t\t\tAdminLastname:     m.setupInputs[4].Value(),\n287\t\t\tInstallSampleData: m.installSampleData,\n288\t\t\tInstallHyva:       m.installHyva,\n289\t\t}\n290\t\tif m.installHyva {\n291\t\t\tcfg.HyvaRepoURL = m.hyvaInputs[0].Value()\n292\t\t\tcfg.HyvaAuthToken = m.hyvaInputs[1].Value()\n293\t\t}\n294\t\treturn cfg\n295\t}\n296\t\n297\t// advanceFromDetection moves the model to the correct phase based on\n298\t// how many environments were detected. The caller must have already\n299\t// populated m.envs.\n300\tfunc (m *Model) advanceFromDetection() tea.Cmd {\n301\t\tswitch len(m.envs) {\n302\t\tcase 0:\n303\t\t\tm.phase = phaseError\n304\t\tcase 1:\n305\t\t\tm.selected = &m.envs[0]\n306\t\t\tm.initSetupInputs()\n307\t\t\tm.phase = phaseSetupConfig\n308\t\t\treturn textinput.Blink\n309\t\tdefault:\n310\t\t\tm.phase = phaseSelection\n311\t\t}\n312\t\treturn nil\n313\t}\n314\t\n315\tfunc runInstall(d detector.Detector, cfg detector.Config) (<-chan tea.Msg, tea.Cmd) {\n316\t\tch := make(chan tea.Msg, 1000)\n317\t\n318\t\tgo func() {\n319\t\t\tif err := os.MkdirAll(cfg.Directory, 0755); err != nil {\n320\t\t\t\tch <- installDoneMsg{err: fmt.Errorf(\"could not create directory %s: %w\", cfg.Directory, err)}\n321\t\t\t\treturn\n322\t\t\t}\n323\t\t\tcfg.Log = func(line string) { ch <- logMsg(line) }\n324\t\t\tcfg.OnStepStart = func(i int) { ch <- stepStartMsg{index: i} }\n325\t\t\tcfg.OnStepDone = func(i int) { ch <- stepDoneMsg{index: i} }\n326\t\t\tch <- installDoneMsg{err: d.Install(&cfg)}\n327\t\t}()\n328\t\n329\t\treturn ch, waitForLog(ch)\n330\t}\n331\t\n332\t// waitForLog returns a Cmd that reads the next message from the log channel.\n333\tfunc waitForLog(ch <-chan tea.Msg) tea.Cmd {\n334\t\treturn func() tea.Msg {\n335\t\t\treturn <-ch\n336\t\t}\n337\t}\n338\t\n339\t// openBrowser opens url in the default system browser without blocking.\n340\tfunc openBrowser(url string) error {\n341\t\tvar cmd *exec.Cmd\n342\t\tswitch runtime.GOOS {\n343\t\tcase \"darwin\":\n344\t\t\tcmd = exec.Command(\"open\", url)\n345\t\tcase \"linux\":\n346\t\t\tcmd = exec.Command(\"xdg-open\", url)\n347\t\tcase \"windows\":\n348\t\t\tcmd = exec.Command(\"rundll32\", \"url.dll,FileProtocolHandler\", url)\n349\t\tdefault:\n350\t\t\treturn fmt.Errorf(\"unsupported platform: %s\", runtime.GOOS)\n351\t\t}\n352\t\treturn cmd.Start()\n353\t}\n354\t\n355\tfunc (m Model) Update(msg tea.Msg) (tea.Model, tea.Cmd) {\n356\t\tswitch msg := msg.(type) {\n357\t\tcase tea.KeyMsg:\n358\t\t\tswitch msg.String() {\n359\t\t\tcase \"ctrl+c\", \"q\":\n360\t\t\t\treturn m, tea.Quit\n361\t\t\t}\n362\t\n363\t\tcase tea.WindowSizeMsg:\n364\t\t\tm.windowHeight = msg.Height\n365\t\t\tm.windowWidth = msg.Width\n366\t\t\treturn m, nil\n367\t\n368\t\tcase spinner.TickMsg:\n369\t\t\tvar cmd tea.Cmd\n370\t\t\tm.spinner, cmd = m.spinner.Update(msg)\n371\t\t\treturn m, cmd\n372\t\n373\t\tcase detectionDoneMsg:\n374\t\t\tm.envs = msg.envs\n375\t\t\t// Cache results while the user is still filling in the input steps;\n376\t\t\t// we'll advance when they confirm the directory.\n377\t\t\tif m.phase == phaseNameInput || m.phase == phaseDirectoryInput {\n378\t\t\t\treturn m, nil\n379\t\t\t}\n380\t\t\treturn m, m.advanceFromDetection()\n381\t\n382\t\tcase sudoCachedMsg:\n383\t\t\t// sudo credentials are now cached (or failed); proceed with install.\n384\t\t\tm.phase = phaseInstalling\n385\t\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n386\t\t\tm.logCh = ch\n387\t\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n388\t\n389\t\tcase logMsg:\n390\t\t\tm.logLines = append(m.logLines, string(msg))\n391\t\t\treturn m, waitForLog(m.logCh)\n392\t\n393\t\tcase stepStartMsg:\n394\t\t\tif msg.index < len(m.installSteps) {\n395\t\t\t\tm.installSteps[msg.index].status = stepRunning\n396\t\t\t}\n397\t\t\treturn m, waitForLog(m.logCh)\n398\t\n399\t\tcase stepDoneMsg:\n400\t\t\tif msg.index < len(m.installSteps) {\n401\t\t\t\tm.installSteps[msg.index].status = stepDone\n402\t\t\t}\n403\t\t\treturn m, waitForLog(m.logCh)\n404\t\n405\t\tcase installDoneMsg:\n406\t\t\tm.installErr = msg.err\n407\t\t\tif msg.err != nil {\n408\t\t\t\tfor i := range m.installSteps {\n409\t\t\t\t\tif m.installSteps[i].status == stepRunning {\n410\t\t\t\t\t\tm.installSteps[i].status = stepFailed\n411\t\t\t\t\t\tbreak\n412\t\t\t\t\t}\n413\t\t\t\t}\n414\t\t\t\tm.phase = phaseInstallDone\n415\t\t\t} else {\n416\t\t\t\tm.browserOpened = false\n417\t\t\t\tm.phase = phaseOpenBrowser\n418\t\t\t}\n419\t\t\treturn m, nil\n420\t\t}\n421\t\n422\t\t// Handle name-input phase\n423\t\tif m.phase == phaseNameInput {\n424\t\t\tswitch msg := msg.(type) {\n425\t\t\tcase tea.KeyMsg:\n426\t\t\t\tswitch msg.String() {\n427\t\t\t\tcase \"enter\":\n428\t\t\t\t\treturn m, m.enterDirectoryPhase()\n429\t\t\t\tdefault:\n430\t\t\t\t\tvar cmd tea.Cmd\n431\t\t\t\t\tm.nameInput, cmd = m.nameInput.Update(msg)\n432\t\t\t\t\treturn m, cmd\n433\t\t\t\t}\n434\t\t\t}\n435\t\t}\n436\t\n437\t\t// Handle directory-input phase\n438\t\tif m.phase == phaseDirectoryInput {\n439\t\t\tswitch msg := msg.(type) {\n440\t\t\tcase tea.KeyMsg:\n441\t\t\t\tswitch msg.String() {\n442\t\t\t\tcase \"enter\":\n443\t\t\t\t\t// Detection may already be done (envs cached) or still running.\n444\t\t\t\t\tif m.envs != nil {\n445\t\t\t\t\t\treturn m, m.advanceFromDetection()\n446\t\t\t\t\t}\n447\t\t\t\t\tm.phase = phaseDetecting\n448\t\t\t\t\treturn m, nil\n449\t\t\t\tdefault:\n450\t\t\t\t\tvar cmd tea.Cmd\n451\t\t\t\t\tm.dirInput, cmd = m.dirInput.Update(msg)\n452\t\t\t\t\treturn m, cmd\n453\t\t\t\t}\n454\t\t\t}\n455\t\t}\n456\t\n457\t\t// Handle selection-phase keys\n458\t\tif m.phase == phaseSelection {\n459\t\t\tswitch msg := msg.(type) {\n460\t\t\tcase tea.KeyMsg:\n461\t\t\t\tswitch msg.String() {\n462\t\t\t\tcase \"up\", \"k\":\n463\t\t\t\t\tif m.cursor > 0 {\n464\t\t\t\t\t\tm.cursor--\n465\t\t\t\t\t}\n466\t\t\t\tcase \"down\", \"j\":\n467\t\t\t\t\tif m.cursor < len(m.envs)-1 {\n468\t\t\t\t\t\tm.cursor++\n469\t\t\t\t\t}\n470\t\t\t\tcase \"enter\":\n471\t\t\t\t\tm.selected = &m.envs[m.cursor]\n472\t\t\t\t\tm.initSetupInputs()\n473\t\t\t\t\tm.phase = phaseSetupConfig\n474\t\t\t\t\treturn m, textinput.Blink\n475\t\t\t\t}\n476\t\t\t}\n477\t\t}\n478\t\n479\t\t// Handle setup config form\n480\t\tif m.phase == phaseSetupConfig {\n481\t\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n482\t\t\t\t// Total fields: admin fields + sample data toggle + hyva toggle + (hyva fields if enabled)\n483\t\t\t\ttotalFields := len(m.setupInputs) + 2 // +2 for both toggles\n484\t\t\t\tif m.installHyva {\n485\t\t\t\t\ttotalFields += len(m.hyvaInputs)\n486\t\t\t\t}\n487\t\n488\t\t\t\t// Calculate current absolute position\n489\t\t\t\tabsPos := m.setupFocus\n490\t\t\t\tif m.inTogglePhase {\n491\t\t\t\t\tswitch {\n492\t\t\t\t\tcase m.toggleFocus == -2: // sample data toggle\n493\t\t\t\t\t\tabsPos = len(m.setupInputs)\n494\t\t\t\t\tcase m.toggleFocus == -1: // hyva toggle\n495\t\t\t\t\t\tabsPos = len(m.setupInputs) + 1\n496\t\t\t\t\tdefault: // hyva input field\n497\t\t\t\t\t\tabsPos = len(m.setupInputs) + 2 + m.toggleFocus\n498\t\t\t\t\t}\n499\t\t\t\t}\n500\t\n501\t\t\t\tswitch keyMsg.String() {\n502\t\t\t\tcase \"tab\", \"down\":\n503\t\t\t\t\tnewPos := absPos + 1\n504\t\t\t\t\tif newPos >= totalFields {\n505\t\t\t\t\t\tnewPos = 0\n506\t\t\t\t\t}\n507\t\t\t\t\tm.focusAbsolutePos(newPos)\n508\t\t\t\t\treturn m, textinput.Blink\n509\t\t\t\tcase \"shift+tab\", \"up\":\n510\t\t\t\t\tnewPos := absPos - 1\n511\t\t\t\t\tif newPos < 0 {\n512\t\t\t\t\t\tnewPos = totalFields - 1\n513\t\t\t\t\t}\n514\t\t\t\t\tm.focusAbsolutePos(newPos)\n515\t\t\t\t\treturn m, textinput.Blink\n516\t\t\t\tcase \"enter\":\n517\t\t\t\t\t// On toggles, Enter advances to the next field (use Space to toggle)\n518\t\t\t\t\tif m.inTogglePhase && (m.toggleFocus == -2 || m.toggleFocus == -1) {\n519\t\t\t\t\t\t// If this toggle is the last field, submit\n520\t\t\t\t\t\tif absPos == totalFields-1 {\n521\t\t\t\t\t\t\t// fall through to submit logic below\n522\t\t\t\t\t\t} else {\n523\t\t\t\t\t\t\tm.focusAbsolutePos(absPos + 1)\n524\t\t\t\t\t\t\treturn m, textinput.Blink\n525\t\t\t\t\t\t}\n526\t\t\t\t\t}\n527\t\t\t\t\t// On the last field, submit\n528\t\t\t\t\tif absPos == totalFields-1 {\n529\t\t\t\t\t\t// Validate admin fields\n530\t\t\t\t\t\tfor i, f := range setupFieldDefs {\n531\t\t\t\t\t\t\tif strings.TrimSpace(m.setupInputs[i].Value()) == \"\" {\n532\t\t\t\t\t\t\t\tm.setupError = f.label + \" is required\"\n533\t\t\t\t\t\t\t\tm.focusAbsolutePos(i)\n534\t\t\t\t\t\t\t\treturn m, textinput.Blink\n535\t\t\t\t\t\t\t}\n536\t\t\t\t\t\t}\n537\t\t\t\t\t\t// Validate Hyva fields if enabled\n538\t\t\t\t\t\tif m.installHyva {\n539\t\t\t\t\t\t\tfor i, f := range hyvaFieldDefs {\n540\t\t\t\t\t\t\t\tif strings.TrimSpace(m.hyvaInputs[i].Value()) == \"\" {\n541\t\t\t\t\t\t\t\t\tm.setupError = \"Hyvä \" + f.label + \" is required\"\n542\t\t\t\t\t\t\t\t\tm.focusAbsolutePos(len(m.setupInputs) + 2 + i)\n543\t\t\t\t\t\t\t\t\treturn m, textinput.Blink\n544\t\t\t\t\t\t\t\t}\n545\t\t\t\t\t\t\t}\n546\t\t\t\t\t\t}\n547\t\t\t\t\t\tm.setupError = \"\"\n548\t\t\t\t\t\tm.installCfg = m.buildInstallConfig()\n549\t\t\t\t\t\tm.selected.Detector.PrepareSteps(&m.installCfg)\n550\t\t\t\t\t\tm.previewScroll = 0\n551\t\t\t\t\t\tm.phase = phaseSetupPreview\n552\t\t\t\t\t\treturn m, nil\n553\t\t\t\t\t}\n554\t\t\t\t\t// Move to next field\n555\t\t\t\t\tm.focusAbsolutePos(absPos + 1)\n556\t\t\t\t\treturn m, textinput.Blink\n557\t\t\t\tcase \" \":\n558\t\t\t\t\t// Space on toggles\n559\t\t\t\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n560\t\t\t\t\t\tm.installSampleData = !m.installSampleData\n561\t\t\t\t\t\treturn m, nil\n562\t\t\t\t\t}\n563\t\t\t\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n564\t\t\t\t\t\tm.installHyva = !m.installHyva\n565\t\t\t\t\t\treturn m, nil\n566\t\t\t\t\t}\n567\t\t\t\t\t// Fall through to default for text input\n568\t\t\t\t\tfallthrough\n569\t\t\t\tdefault:\n570\t\t\t\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n571\t\t\t\t\t\tvar cmd tea.Cmd\n572\t\t\t\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n573\t\t\t\t\t\treturn m, cmd\n574\t\t\t\t\t}\n575\t\t\t\t\tif !m.inTogglePhase {\n576\t\t\t\t\t\tvar cmd tea.Cmd\n577\t\t\t\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n578\t\t\t\t\t\treturn m, cmd\n579\t\t\t\t\t}\n580\t\t\t\t}\n581\t\t\t}\n582\t\t\t// Forward non-key messages (e.g. blink) to focused input\n583\t\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n584\t\t\t\tvar cmd tea.Cmd\n585\t\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n586\t\t\t\treturn m, cmd\n587\t\t\t}\n588\t\t\tif !m.inTogglePhase {\n589\t\t\t\tvar cmd tea.Cmd\n590\t\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n591\t\t\t\treturn m, cmd\n592\t\t\t}\n593\t\t}\n594\t\n595\t\t// Handle setup preview\n596\t\tif m.phase == phaseSetupPreview {\n597\t\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n598\t\t\t\tswitch keyMsg.String() {\n599\t\t\t\tcase \"up\", \"k\":\n600\t\t\t\t\tif m.previewScroll > 0 {\n601\t\t\t\t\t\tm.previewScroll--\n602\t\t\t\t\t}\n603\t\t\t\tcase \"down\", \"j\":\n604\t\t\t\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n605\t\t\t\t\tmaxVisible := m.windowHeight - 10\n606\t\t\t\t\tif maxVisible < 3 {\n607\t\t\t\t\t\tmaxVisible = 3\n608\t\t\t\t\t}\n609\t\t\t\t\tif maxScroll := totalLines - maxVisible; m.previewScroll < maxScroll {\n610\t\t\t\t\t\tm.previewScroll++\n611\t\t\t\t\t}\n612\t\t\t\tcase \"enter\":\n613\t\t\t\t\tm.initInstallSteps()\n614\t\t\t\t\t// Cache sudo credentials before starting the install so that\n615\t\t\t\t\t// commands like \"ddev start\" (which modifies /etc/hosts) can\n616\t\t\t\t\t// use sudo without prompting inside the TUI.\n617\t\t\t\t\tc := exec.Command(\"sudo\", \"-v\")\n618\t\t\t\t\treturn m, tea.ExecProcess(c, func(err error) tea.Msg {\n619\t\t\t\t\t\treturn sudoCachedMsg{err: err}\n620\t\t\t\t\t})\n621\t\t\t\tcase \"b\", \"esc\":\n622\t\t\t\t\tm.phase = phaseSetupConfig\n623\t\t\t\t\treturn m, textinput.Blink\n624\t\t\t\t}\n625\t\t\t}\n626\t\t}\n627\t\n628\t\tif m.phase == phaseOpenBrowser {\n629\t\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n630\t\t\t\tswitch keyMsg.String() {\n631\t\t\t\tcase \"y\":\n632\t\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n633\t\t\t\t\t_ = openBrowser(url)\n634\t\t\t\t\tm.browserOpened = true\n635\t\t\t\t\tm.phase = phaseInstallDone\n636\t\t\t\t\treturn m, nil\n637\t\t\t\tcase \"n\", \"enter\", \"esc\":\n638\t\t\t\t\tm.phase = phaseInstallDone\n639\t\t\t\t\treturn m, nil\n640\t\t\t\t}\n641\t\t\t}\n642\t\t}\n643\t\n644\t\tif m.phase == phaseInstallDone || m.phase == phaseError {\n645\t\t\tif msg, ok := msg.(tea.KeyMsg); ok {\n646\t\t\t\tswitch msg.String() {\n647\t\t\t\tcase \"r\":\n648\t\t\t\t\tif m.phase == phaseInstallDone && m.installErr != nil {\n649\t\t\t\t\t\t// Find the failed step so we can resume from there.\n650\t\t\t\t\t\tfailedIdx := 0\n651\t\t\t\t\t\tfor i := range m.installSteps {\n652\t\t\t\t\t\t\tif m.installSteps[i].status == stepFailed {\n653\t\t\t\t\t\t\t\tfailedIdx = i\n654\t\t\t\t\t\t\t\tbreak\n655\t\t\t\t\t\t\t}\n656\t\t\t\t\t\t}\n657\t\t\t\t\t\t// Keep completed steps green; reset failed + pending to pending.\n658\t\t\t\t\t\tfor i := range m.installSteps {\n659\t\t\t\t\t\t\tif m.installSteps[i].status != stepDone {\n660\t\t\t\t\t\t\t\tm.installSteps[i].status = stepPending\n661\t\t\t\t\t\t\t}\n662\t\t\t\t\t\t}\n663\t\t\t\t\t\tm.logLines = nil\n664\t\t\t\t\t\tm.installErr = nil\n665\t\t\t\t\t\tm.installCfg.StartFromStep = failedIdx\n666\t\t\t\t\t\tm.phase = phaseInstalling\n667\t\t\t\t\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n668\t\t\t\t\t\tm.logCh = ch\n669\t\t\t\t\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n670\t\t\t\t\t}\n671\t\t\t\tcase \"enter\", \"q\", \"esc\":\n672\t\t\t\t\treturn m, tea.Quit\n673\t\t\t\t}\n674\t\t\t}\n675\t\t}\n676\t\n677\t\treturn m, nil\n678\t}\n679\t\n680\tfunc (m Model) View() string {\n681\t\tvar b strings.Builder\n682\t\n683\t\tb.WriteString(bannerStyle.Render(banner))\n684\t\tb.WriteString(\"\\n\")\n685\t\tb.WriteString(titleStyle.Render(\"Mage-OS Installer\"))\n686\t\tb.WriteString(\"\\n\\n\")\n687\t\n688\t\tswitch m.phase {\n689\t\tcase phaseNameInput:\n690\t\t\tb.WriteString(\"Project name:\\n\\n\")\n691\t\t\tb.WriteString(m.nameInput.View())\n692\t\t\tb.WriteString(\"\\n\\n\")\n693\t\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n694\t\n695\t\tcase phaseDirectoryInput:\n696\t\t\tb.WriteString(\"Install directory:\\n\\n\")\n697\t\t\tb.WriteString(m.dirInput.View())\n698\t\t\tb.WriteString(\"\\n\\n\")\n699\t\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n700\t\n701\t\tcase phaseDetecting:\n702\t\t\tb.WriteString(fmt.Sprintf(\"%s Detecting development environments...\\n\", m.spinner.View()))\n703\t\n704\t\tcase phaseSelection:\n705\t\t\tb.WriteString(\"Multiple environments detected. Please select one:\\n\\n\")\n706\t\t\tfor i, env := range m.envs {\n707\t\t\t\tlabel := fmt.Sprintf(\"%s (%s)\", env.Env.Name, env.Env.Version)\n708\t\t\t\tif i == m.cursor {\n709\t\t\t\t\tb.WriteString(selectedItemStyle.Render(\"▸ \" + label))\n710\t\t\t\t} else {\n711\t\t\t\t\tb.WriteString(itemStyle.Render(\"  \" + label))\n712\t\t\t\t}\n713\t\t\t\tb.WriteString(\"\\n\")\n714\t\t\t}\n715\t\t\tb.WriteString(\"\\n\")\n716\t\t\tb.WriteString(dimStyle.Render(\"↑/↓ to move, enter to select, q to quit\"))\n717\t\n718\t\tcase phaseSetupConfig:\n719\t\t\tb.WriteString(\"Configure Mage-OS:\\n\\n\")\n720\t\t\tconst labelWidth = 18\n721\t\t\tfor i, f := range setupFieldDefs {\n722\t\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, f.label))\n723\t\t\t\tb.WriteString(m.setupInputs[i].View())\n724\t\t\t\tb.WriteString(\"\\n\")\n725\t\t\t}\n726\t\t\tb.WriteString(\"\\n\")\n727\t\t\t// Sample data toggle\n728\t\t\tsdCheckbox := \"[ ]\"\n729\t\t\tif m.installSampleData {\n730\t\t\t\tsdCheckbox = \"[x]\"\n731\t\t\t}\n732\t\t\tsdStyle := dimStyle\n733\t\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n734\t\t\t\tsdStyle = selectedItemStyle\n735\t\t\t}\n736\t\t\tb.WriteString(sdStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install sample data\", sdCheckbox)))\n737\t\t\tb.WriteString(\"\\n\")\n738\t\t\tb.WriteString(dimStyle.Render(\"                      Adds demo products, categories, and customers so you can\"))\n739\t\t\tb.WriteString(\"\\n\")\n740\t\t\tb.WriteString(dimStyle.Render(\"                      explore a fully populated store right away. Recommended\"))\n741\t\t\tb.WriteString(\"\\n\")\n742\t\t\tb.WriteString(dimStyle.Render(\"                      for your first install to see how everything works.\"))\n743\t\t\tb.WriteString(\"\\n\\n\")\n744\t\t\t// Hyva toggle\n745\t\t\thyvaCheckbox := \"[ ]\"\n746\t\t\tif m.installHyva {\n747\t\t\t\thyvaCheckbox = \"[x]\"\n748\t\t\t}\n749\t\t\thyvaStyle := dimStyle\n750\t\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n751\t\t\t\thyvaStyle = selectedItemStyle\n752\t\t\t}\n753\t\t\tb.WriteString(hyvaStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install Hyvä\", hyvaCheckbox)))\n754\t\t\tb.WriteString(\"\\n\")\n755\t\t\tb.WriteString(dimStyle.Render(\"                      Hyvä is a modern, fast frontend theme that replaces the\"))\n756\t\t\tb.WriteString(\"\\n\")\n757\t\t\tb.WriteString(dimStyle.Render(\"                      default Luma theme. It uses Tailwind CSS and Alpine.js,\"))\n758\t\t\tb.WriteString(\"\\n\")\n759\t\t\tb.WriteString(dimStyle.Render(\"                      making frontend development much more enjoyable.\"))\n760\t\t\tb.WriteString(\"\\n\")\n761\t\t\tb.WriteString(dimStyle.Render(\"                      ⚠ Hyvä requires a (free) license. Register at hyva.io and have\"))\n762\t\t\tb.WriteString(\"\\n\")\n763\t\t\tb.WriteString(dimStyle.Render(\"                      your repo URL and auth token ready before continuing.\"))\n764\t\t\tb.WriteString(\"\\n\")\n765\t\t\t// Hyva credential fields (shown only when enabled)\n766\t\t\tif m.installHyva {\n767\t\t\t\tfor i, f := range hyvaFieldDefs {\n768\t\t\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, \"    \"+f.label))\n769\t\t\t\t\tb.WriteString(m.hyvaInputs[i].View())\n770\t\t\t\t\tb.WriteString(\"\\n\")\n771\t\t\t\t}\n772\t\t\t}\n773\t\t\tb.WriteString(\"\\n\")\n774\t\t\tif m.setupError != \"\" {\n775\t\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \"+m.setupError) + \"\\n\\n\")\n776\t\t\t}\n777\t\t\tb.WriteString(dimStyle.Render(\"Tab/↑↓/Enter to move · Space to toggle options · Enter to review command · ctrl+c to quit\"))\n778\t\n779\t\tcase phaseSetupPreview:\n780\t\t\tb.WriteString(\"Review the setup command:\\n\\n\")\n781\t\t\tflags := m.selected.Detector.SetupInstallFlags(&m.installCfg)\n782\t\t\tvar lines []string\n783\t\t\tlines = append(lines, m.selected.Detector.SetupCommandPrefix()+\" \\\\\")\n784\t\t\tfor i, f := range flags {\n785\t\t\t\tsuffix := dimStyle.Render(\" \\\\\")\n786\t\t\t\tif i == len(flags)-1 {\n787\t\t\t\t\tsuffix = \"\"\n788\t\t\t\t}\n789\t\t\t\tvar line string\n790\t\t\t\tif f.Editable {\n791\t\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\") + highlightStyle.Render(f.Value) + suffix\n792\t\t\t\t} else {\n793\t\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\"+f.Value) + suffix\n794\t\t\t\t}\n795\t\t\t\tlines = append(lines, line)\n796\t\t\t}\n797\t\t\tmaxVisible := m.windowHeight - 10\n798\t\t\tif maxVisible < 5 {\n799\t\t\t\tmaxVisible = 5\n800\t\t\t}\n801\t\t\tstart := m.previewScroll\n802\t\t\tif start >= len(lines) {\n803\t\t\t\tstart = max(0, len(lines)-1)\n804\t\t\t}\n805\t\t\tend := start + maxVisible\n806\t\t\tif end > len(lines) {\n807\t\t\t\tend = len(lines)\n808\t\t\t}\n809\t\t\tfor _, line := range lines[start:end] {\n810\t\t\t\tb.WriteString(line + \"\\n\")\n811\t\t\t}\n812\t\t\tb.WriteString(\"\\n\")\n813\t\t\tb.WriteString(dimStyle.Render(\"↑/↓ to scroll · Enter to run · b to go back\"))\n814\t\n815\t\tcase phaseInstalling:\n816\t\t\tb.WriteString(fmt.Sprintf(\"%s Installing %s...\\n\", m.spinner.View(), m.selected.Env.Name))\n817\t\t\tb.WriteString(\"\\n\")\n818\t\t\tfor _, step := range m.installSteps {\n819\t\t\t\tswitch step.status {\n820\t\t\t\tcase stepDone:\n821\t\t\t\t\tb.WriteString(successStyle.Render(\"  ✓ \" + step.name))\n822\t\t\t\tcase stepRunning:\n823\t\t\t\t\tb.WriteString(selectedItemStyle.Render(\"  ▸ \" + step.name + \"...\"))\n824\t\t\t\tcase stepFailed:\n825\t\t\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \" + step.name))\n826\t\t\t\tdefault:\n827\t\t\t\t\tb.WriteString(dimStyle.Render(\"  • \" + step.name))\n828\t\t\t\t}\n829\t\t\t\tb.WriteString(\"\\n\")\n830\t\t\t}\n831\t\t\tif len(m.logLines) > 0 {\n832\t\t\t\t// Compute available height for the log box.\n833\t\t\t\t// Header: 8 (banner) + 1 (blank) + 1 (title) + 2 (blank) +\n834\t\t\t\t//         1 (installing line) + 1 (blank) + N (steps) = 14 + N\n835\t\t\t\t// Box border adds 2 rows; log box also has MarginTop(1).\n836\t\t\t\twh := m.windowHeight\n837\t\t\t\tif wh <= 0 {\n838\t\t\t\t\twh = 24\n839\t\t\t\t}\n840\t\t\t\theaderLines := 14 + len(m.installSteps)\n841\t\t\t\t// 2 for box borders, 1 for margin top\n842\t\t\t\tinnerHeight := wh - headerLines - 3\n843\t\t\t\tif innerHeight < 3 {\n844\t\t\t\t\tinnerHeight = 3\n845\t\t\t\t}\n846\t\n847\t\t\t\tww := m.windowWidth\n848\t\t\t\tif ww <= 0 {\n849\t\t\t\t\tww = 80\n850\t\t\t\t}\n851\t\t\t\t// 4 accounts for the border (2) + padding (2)\n852\t\t\t\tinnerWidth := ww - 4\n853\t\t\t\tif innerWidth < 40 {\n854\t\t\t\t\tinnerWidth = 40\n855\t\t\t\t}\n856\t\n857\t\t\t\tstart := len(m.logLines) - innerHeight\n858\t\t\t\tif start < 0 {\n859\t\t\t\t\tstart = 0\n860\t\t\t\t}\n861\t\t\t\tstyle := logBoxStyle.Width(innerWidth).Height(innerHeight)\n862\t\t\t\tb.WriteString(style.Render(strings.Join(m.logLines[start:], \"\\n\")))\n863\t\t\t\tb.WriteString(\"\\n\")\n864\t\t\t}\n865\t\n866\t\tcase phaseOpenBrowser:\n867\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n868\t\t\tlines := []string{\n869\t\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n870\t\t\t\t\"\",\n871\t\t\t\t\"Open \" + highlightStyle.Render(url) + \" in your browser?\",\n872\t\t\t\t\"\",\n873\t\t\t\tdimStyle.Render(\"y to open · n/enter to skip\"),\n874\t\t\t}\n875\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n876\t\t\tb.WriteString(\"\\n\")\n877\t\n878\t\tcase phaseInstallDone:\n879\t\t\tif m.installErr != nil {\n880\t\t\t\tlines := []string{\n881\t\t\t\t\terrorStyle.Render(\"✗ Installation failed!\"),\n882\t\t\t\t\t\"\",\n883\t\t\t\t\tm.installErr.Error(),\n884\t\t\t\t}\n885\t\t\t\tif len(m.logLines) > 0 {\n886\t\t\t\t\tconst maxLines = 10\n887\t\t\t\t\tstart := len(m.logLines) - maxLines\n888\t\t\t\t\tif start < 0 {\n889\t\t\t\t\t\tstart = 0\n890\t\t\t\t\t}\n891\t\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Last output:\"))\n892\t\t\t\t\tfor _, line := range m.logLines[start:] {\n893\t\t\t\t\t\tlines = append(lines, dimStyle.Render(line))\n894\t\t\t\t\t}\n895\t\t\t\t}\n896\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press r to retry, enter/q to exit.\"))\n897\t\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n898\t\t\t} else {\n899\t\t\t\tlines := []string{\n900\t\t\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n901\t\t\t\t}\n902\t\t\t\tif m.browserOpened {\n903\t\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n904\t\t\t\t\tlines = append(lines, \"\", \"Opened \"+highlightStyle.Render(url)+\" in your browser.\")\n905\t\t\t\t}\n906\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press enter to exit.\"))\n907\t\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n908\t\t\t}\n909\t\t\tb.WriteString(\"\\n\")\n910\t\n911\t\tcase phaseError:\n912\t\t\tlines := []string{\n913\t\t\t\terrorStyle.Render(\"No supported environments found!\"),\n914\t\t\t\t\"\",\n915\t\t\t\t\"Please install one of the following:\",\n916\t\t\t\t\"\",\n917\t\t\t}\n918\t\t\tfor _, info := range detector.AllDetectorInfos() {\n919\t\t\t\tlines = append(lines, \"  \"+selectedItemStyle.Render(info.Name)+\"  \"+info.InstallURL)\n920\t\t\t}\n921\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press q to quit.\"))\n922\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n923\t\t\tb.WriteString(\"\\n\")\n924\t\t}\n925\t\n926\t\treturn b.String()\n927\t}\n928\t"}]},"parent_tool_use_id":null,"session_id":"4a3c2ef1-9c01-442f-932f-75a160395f83","uuid":"4a9c9d68-ccf0-4ac6-89e2-edd7544fbd1c","timestamp":"2026-04-14T19:11:56.214Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/tui/tui.go","content":"package tui\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strings\"\n\n\t\"github.com/charmbracelet/bubbles/spinner\"\n\t\"github.com/charmbracelet/bubbles/textinput\"\n\ttea \"github.com/charmbracelet/bubbletea\"\n\t\"github.com/charmbracelet/lipgloss\"\n\t\"github.com/mage-os/mage-os-install/internal/detector\"\n)\n\ntype phase int\n\nconst (\n\tphaseNameInput phase = iota\n\tphaseDirectoryInput\n\tphaseDetecting\n\tphaseSelection\n\tphaseSetupConfig  // admin credentials form\n\tphaseSetupPreview // full command preview before running\n\tphaseInstalling\n\tphaseOpenBrowser // ask whether to open the site after install\n\tphaseInstallDone\n\tphaseError\n)\n\n// detectionDoneMsg is sent when environment detection completes.\ntype detectionDoneMsg struct {\n\tenvs []detector.DetectedEnvironment\n}\n\n// installDoneMsg is sent when installation completes.\ntype installDoneMsg struct {\n\terr error\n}\n\n// logMsg carries a single line of installer output.\ntype logMsg string\n\n// stepStartMsg is sent when an installation step begins.\ntype stepStartMsg struct{ index int }\n\n// sudoCachedMsg is sent after sudo -v completes (caching credentials).\ntype sudoCachedMsg struct{ err error }\n\n// stepDoneMsg is sent when an installation step completes successfully.\ntype stepDoneMsg struct{ index int }\n\ntype stepStatus int\n\nconst (\n\tstepPending stepStatus = iota\n\tstepRunning\n\tstepDone\n\tstepFailed\n)\n\ntype installStep struct {\n\tname   string\n\tstatus stepStatus\n}\n\n// Model is the main bubbletea model for the installer TUI.\ntype Model struct {\n\tphase         phase\n\tspinner       spinner.Model\n\tnameInput     textinput.Model\n\toriginalName  string // the default seeded into nameInput, used to compute the dir default\n\tdirInput      textinput.Model\n\tenvs          []detector.DetectedEnvironment\n\tcursor        int\n\tselected      *detector.DetectedEnvironment\n\tsetupInputs   []textinput.Model\n\tsetupFocus    int\n\tsetupError    string\n\tinstallCfg    detector.Config\n\tpreviewScroll int\n\twindowHeight  int\n\twindowWidth   int\n\tlogCh         <-chan tea.Msg\n\tlogLines      []string\n\tinstallSteps  []installStep\n\tinstallErr    error\n\tbrowserOpened bool\n\n\t// Optional feature toggles and Hyvä credentials\n\tinstallSampleData bool\n\tinstallHyva       bool\n\thyvaInputs        []textinput.Model\n\t// toggleFocus tracks which toggle/section has focus:\n\t//   -2 = sample data toggle\n\t//   -1 = hyva toggle\n\t//   0+ = hyva input field index\n\ttoggleFocus    int\n\tinTogglePhase  bool // true when focus is in the toggle/hyva section (not admin fields)\n}\n\n// currentDirName returns the base name of the working directory.\nfunc currentDirName() string {\n\tif wd, err := os.Getwd(); err == nil {\n\t\treturn filepath.Base(wd)\n\t}\n\treturn \"my-project\"\n}\n\n// New creates the initial TUI model.\nfunc New() Model {\n\ts := spinner.New()\n\ts.Spinner = spinner.Dot\n\ts.Style = spinnerStyle\n\n\tdefaultName := currentDirName()\n\n\tti := textinput.New()\n\tti.SetValue(defaultName)\n\tti.Focus()\n\tti.CharLimit = 64\n\n\treturn Model{\n\t\tphase:        phaseNameInput,\n\t\tspinner:      s,\n\t\tnameInput:    ti,\n\t\toriginalName: defaultName,\n\t}\n}\n\nfunc (m Model) Init() tea.Cmd {\n\t// Start detection in the background immediately so results are ready\n\t// by the time the user confirms the project name.\n\treturn tea.Batch(m.spinner.Tick, detectEnvironments, textinput.Blink)\n}\n\nfunc detectEnvironments() tea.Msg {\n\treturn detectionDoneMsg{envs: detector.DetectAll()}\n}\n\n// defaultDirectory returns the install directory based on whether the user\n// changed the project name from the default.\nfunc (m *Model) defaultDirectory() string {\n\twd, err := os.Getwd()\n\tif err != nil {\n\t\twd = \".\"\n\t}\n\tif m.nameInput.Value() == m.originalName {\n\t\treturn wd\n\t}\n\treturn filepath.Join(wd, m.nameInput.Value())\n}\n\n// enterDirectoryPhase transitions to the directory input phase,\n// pre-filling the input with the computed default.\nfunc (m *Model) enterDirectoryPhase() tea.Cmd {\n\tdi := textinput.New()\n\tdi.SetValue(m.defaultDirectory())\n\tdi.Focus()\n\tdi.CharLimit = 256\n\tm.dirInput = di\n\tm.phase = phaseDirectoryInput\n\treturn textinput.Blink\n}\n\n// initInstallSteps loads the step list from the selected detector.\nfunc (m *Model) initInstallSteps() {\n\tm.installSteps = nil\n\tfor _, s := range m.selected.Detector.Steps() {\n\t\tm.installSteps = append(m.installSteps, installStep{name: s.Name, status: stepPending})\n\t}\n}\n\n// setupFieldDefs defines the user-editable fields shown in the Mage-OS setup form.\nvar setupFieldDefs = []struct {\n\tlabel string\n\techo  textinput.EchoMode\n}{\n\t{label: \"Admin user\", echo: textinput.EchoNormal},\n\t{label: \"Admin password\", echo: textinput.EchoPassword},\n\t{label: \"Admin email\", echo: textinput.EchoNormal},\n\t{label: \"Admin firstname\", echo: textinput.EchoNormal},\n\t{label: \"Admin lastname\", echo: textinput.EchoNormal},\n}\n\nvar setupFieldDefaults = []string{\"admin\", \"\", \"\", \"Admin\", \"User\"}\n\n// hyvaFieldDefs defines the Hyvä credential fields.\nvar hyvaFieldDefs = []struct {\n\tlabel string\n\techo  textinput.EchoMode\n}{\n\t{label: \"Repo URL\", echo: textinput.EchoNormal},\n\t{label: \"Auth token\", echo: textinput.EchoPassword},\n}\n\n// initSetupInputs creates fresh text inputs for the Mage-OS setup form.\nfunc (m *Model) initSetupInputs() {\n\tm.setupInputs = make([]textinput.Model, len(setupFieldDefs))\n\tfor i, f := range setupFieldDefs {\n\t\tti := textinput.New()\n\t\tti.SetValue(setupFieldDefaults[i])\n\t\tti.EchoMode = f.echo\n\t\tti.CharLimit = 128\n\t\tif i == 0 {\n\t\t\tti.Focus()\n\t\t}\n\t\tm.setupInputs[i] = ti\n\t}\n\tm.setupFocus = 0\n\n\t// Initialize toggles and Hyvä inputs\n\tm.installSampleData = false\n\tm.installHyva = false\n\tm.inTogglePhase = false\n\tm.toggleFocus = -2 // sample data toggle\n\tm.hyvaInputs = make([]textinput.Model, len(hyvaFieldDefs))\n\tfor i, f := range hyvaFieldDefs {\n\t\tti := textinput.New()\n\t\tti.EchoMode = f.echo\n\t\tti.CharLimit = 256\n\t\tm.hyvaInputs[i] = ti\n\t}\n}\n\n// focusSetupInput focuses the input at index and blurs all others.\nfunc (m *Model) focusSetupInput(index int) {\n\tfor i := range m.setupInputs {\n\t\tif i == index {\n\t\t\tm.setupInputs[i].Focus()\n\t\t} else {\n\t\t\tm.setupInputs[i].Blur()\n\t\t}\n\t}\n\tm.setupFocus = index\n}\n\n// focusAbsolutePos sets focus based on absolute position across all form fields.\n// Layout: [admin fields...] [sampledata toggle] [hyva toggle] [hyva fields if enabled...]\nfunc (m *Model) focusAbsolutePos(pos int) {\n\t// Blur everything\n\tfor i := range m.setupInputs {\n\t\tm.setupInputs[i].Blur()\n\t}\n\tfor i := range m.hyvaInputs {\n\t\tm.hyvaInputs[i].Blur()\n\t}\n\n\tsampleDataPos := len(m.setupInputs)\n\thyvaTogglePos := sampleDataPos + 1\n\n\tif pos < sampleDataPos {\n\t\t// Admin field\n\t\tm.inTogglePhase = false\n\t\tm.setupFocus = pos\n\t\tm.setupInputs[pos].Focus()\n\t} else if pos == sampleDataPos {\n\t\t// Sample data toggle\n\t\tm.inTogglePhase = true\n\t\tm.toggleFocus = -2\n\t} else if pos == hyvaTogglePos {\n\t\t// Hyva toggle\n\t\tm.inTogglePhase = true\n\t\tm.toggleFocus = -1\n\t} else {\n\t\t// Hyva input field\n\t\tm.inTogglePhase = true\n\t\tm.toggleFocus = pos - hyvaTogglePos - 1\n\t\tif m.toggleFocus < len(m.hyvaInputs) {\n\t\t\tm.hyvaInputs[m.toggleFocus].Focus()\n\t\t}\n\t}\n}\n\n// buildInstallConfig builds a Config from the current form and input values.\nfunc (m *Model) buildInstallConfig() detector.Config {\n\tcfg := detector.Config{\n\t\tProjectName:       m.nameInput.Value(),\n\t\tDirectory:         m.dirInput.Value(),\n\t\tAdminUser:         m.setupInputs[0].Value(),\n\t\tAdminPassword:     m.setupInputs[1].Value(),\n\t\tAdminEmail:        m.setupInputs[2].Value(),\n\t\tAdminFirstname:    m.setupInputs[3].Value(),\n\t\tAdminLastname:     m.setupInputs[4].Value(),\n\t\tInstallSampleData: m.installSampleData,\n\t\tInstallHyva:       m.installHyva,\n\t}\n\tif m.installHyva {\n\t\tcfg.HyvaRepoURL = m.hyvaInputs[0].Value()\n\t\tcfg.HyvaAuthToken = m.hyvaInputs[1].Value()\n\t}\n\treturn cfg\n}\n\n// advanceFromDetection moves the model to the correct phase based on\n// how many environments were detected. The caller must have already\n// populated m.envs.\nfunc (m *Model) advanceFromDetection() tea.Cmd {\n\tswitch len(m.envs) {\n\tcase 0:\n\t\tm.phase = phaseError\n\tcase 1:\n\t\tm.selected = &m.envs[0]\n\t\tm.initSetupInputs()\n\t\tm.phase = phaseSetupConfig\n\t\treturn textinput.Blink\n\tdefault:\n\t\tm.phase = phaseSelection\n\t}\n\treturn nil\n}\n\nfunc runInstall(d detector.Detector, cfg detector.Config) (<-chan tea.Msg, tea.Cmd) {\n\tch := make(chan tea.Msg, 1000)\n\n\tgo func() {\n\t\tif err := os.MkdirAll(cfg.Directory, 0755); err != nil {\n\t\t\tch <- installDoneMsg{err: fmt.Errorf(\"could not create directory %s: %w\", cfg.Directory, err)}\n\t\t\treturn\n\t\t}\n\t\tcfg.Log = func(line string) { ch <- logMsg(line) }\n\t\tcfg.OnStepStart = func(i int) { ch <- stepStartMsg{index: i} }\n\t\tcfg.OnStepDone = func(i int) { ch <- stepDoneMsg{index: i} }\n\t\tch <- installDoneMsg{err: d.Install(&cfg)}\n\t}()\n\n\treturn ch, waitForLog(ch)\n}\n\n// waitForLog returns a Cmd that reads the next message from the log channel.\nfunc waitForLog(ch <-chan tea.Msg) tea.Cmd {\n\treturn func() tea.Msg {\n\t\treturn <-ch\n\t}\n}\n\n// openBrowser opens url in the default system browser without blocking.\nfunc openBrowser(url string) error {\n\tvar cmd *exec.Cmd\n\tswitch runtime.GOOS {\n\tcase \"darwin\":\n\t\tcmd = exec.Command(\"open\", url)\n\tcase \"linux\":\n\t\tcmd = exec.Command(\"xdg-open\", url)\n\tcase \"windows\":\n\t\tcmd = exec.Command(\"rundll32\", \"url.dll,FileProtocolHandler\", url)\n\tdefault:\n\t\treturn fmt.Errorf(\"unsupported platform: %s\", runtime.GOOS)\n\t}\n\treturn cmd.Start()\n}\n\nfunc (m Model) Update(msg tea.Msg) (tea.Model, tea.Cmd) {\n\tswitch msg := msg.(type) {\n\tcase tea.KeyMsg:\n\t\tswitch msg.String() {\n\t\tcase \"ctrl+c\", \"q\":\n\t\t\treturn m, tea.Quit\n\t\t}\n\n\tcase tea.WindowSizeMsg:\n\t\tm.windowHeight = msg.Height\n\t\tm.windowWidth = msg.Width\n\t\treturn m, nil\n\n\tcase spinner.TickMsg:\n\t\tvar cmd tea.Cmd\n\t\tm.spinner, cmd = m.spinner.Update(msg)\n\t\treturn m, cmd\n\n\tcase detectionDoneMsg:\n\t\tm.envs = msg.envs\n\t\t// Cache results while the user is still filling in the input steps;\n\t\t// we'll advance when they confirm the directory.\n\t\tif m.phase == phaseNameInput || m.phase == phaseDirectoryInput {\n\t\t\treturn m, nil\n\t\t}\n\t\treturn m, m.advanceFromDetection()\n\n\tcase sudoCachedMsg:\n\t\t// sudo credentials are now cached (or failed); proceed with install.\n\t\tm.phase = phaseInstalling\n\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n\t\tm.logCh = ch\n\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n\n\tcase logMsg:\n\t\tm.logLines = append(m.logLines, string(msg))\n\t\treturn m, waitForLog(m.logCh)\n\n\tcase stepStartMsg:\n\t\tif msg.index < len(m.installSteps) {\n\t\t\tm.installSteps[msg.index].status = stepRunning\n\t\t}\n\t\treturn m, waitForLog(m.logCh)\n\n\tcase stepDoneMsg:\n\t\tif msg.index < len(m.installSteps) {\n\t\t\tm.installSteps[msg.index].status = stepDone\n\t\t}\n\t\treturn m, waitForLog(m.logCh)\n\n\tcase installDoneMsg:\n\t\tm.installErr = msg.err\n\t\tif msg.err != nil {\n\t\t\tfor i := range m.installSteps {\n\t\t\t\tif m.installSteps[i].status == stepRunning {\n\t\t\t\t\tm.installSteps[i].status = stepFailed\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tm.phase = phaseInstallDone\n\t\t} else {\n\t\t\tm.browserOpened = false\n\t\t\tm.phase = phaseOpenBrowser\n\t\t}\n\t\treturn m, nil\n\t}\n\n\t// Handle name-input phase\n\tif m.phase == phaseNameInput {\n\t\tswitch msg := msg.(type) {\n\t\tcase tea.KeyMsg:\n\t\t\tswitch msg.String() {\n\t\t\tcase \"enter\":\n\t\t\t\treturn m, m.enterDirectoryPhase()\n\t\t\tdefault:\n\t\t\t\tvar cmd tea.Cmd\n\t\t\t\tm.nameInput, cmd = m.nameInput.Update(msg)\n\t\t\t\treturn m, cmd\n\t\t\t}\n\t\t}\n\t}\n\n\t// Handle directory-input phase\n\tif m.phase == phaseDirectoryInput {\n\t\tswitch msg := msg.(type) {\n\t\tcase tea.KeyMsg:\n\t\t\tswitch msg.String() {\n\t\t\tcase \"enter\":\n\t\t\t\t// Detection may already be done (envs cached) or still running.\n\t\t\t\tif m.envs != nil {\n\t\t\t\t\treturn m, m.advanceFromDetection()\n\t\t\t\t}\n\t\t\t\tm.phase = phaseDetecting\n\t\t\t\treturn m, nil\n\t\t\tdefault:\n\t\t\t\tvar cmd tea.Cmd\n\t\t\t\tm.dirInput, cmd = m.dirInput.Update(msg)\n\t\t\t\treturn m, cmd\n\t\t\t}\n\t\t}\n\t}\n\n\t// Handle selection-phase keys\n\tif m.phase == phaseSelection {\n\t\tswitch msg := msg.(type) {\n\t\tcase tea.KeyMsg:\n\t\t\tswitch msg.String() {\n\t\t\tcase \"up\", \"k\":\n\t\t\t\tif m.cursor > 0 {\n\t\t\t\t\tm.cursor--\n\t\t\t\t}\n\t\t\tcase \"down\", \"j\":\n\t\t\t\tif m.cursor < len(m.envs)-1 {\n\t\t\t\t\tm.cursor++\n\t\t\t\t}\n\t\t\tcase \"enter\":\n\t\t\t\tm.selected = &m.envs[m.cursor]\n\t\t\t\tm.initSetupInputs()\n\t\t\t\tm.phase = phaseSetupConfig\n\t\t\t\treturn m, textinput.Blink\n\t\t\t}\n\t\t}\n\t}\n\n\t// Handle setup config form\n\tif m.phase == phaseSetupConfig {\n\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n\t\t\t// Total fields: admin fields + sample data toggle + hyva toggle + (hyva fields if enabled)\n\t\t\ttotalFields := len(m.setupInputs) + 2 // +2 for both toggles\n\t\t\tif m.installHyva {\n\t\t\t\ttotalFields += len(m.hyvaInputs)\n\t\t\t}\n\n\t\t\t// Calculate current absolute position\n\t\t\tabsPos := m.setupFocus\n\t\t\tif m.inTogglePhase {\n\t\t\t\tswitch {\n\t\t\t\tcase m.toggleFocus == -2: // sample data toggle\n\t\t\t\t\tabsPos = len(m.setupInputs)\n\t\t\t\tcase m.toggleFocus == -1: // hyva toggle\n\t\t\t\t\tabsPos = len(m.setupInputs) + 1\n\t\t\t\tdefault: // hyva input field\n\t\t\t\t\tabsPos = len(m.setupInputs) + 2 + m.toggleFocus\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch keyMsg.String() {\n\t\t\tcase \"tab\", \"down\":\n\t\t\t\tnewPos := absPos + 1\n\t\t\t\tif newPos >= totalFields {\n\t\t\t\t\tnewPos = 0\n\t\t\t\t}\n\t\t\t\tm.focusAbsolutePos(newPos)\n\t\t\t\treturn m, textinput.Blink\n\t\t\tcase \"shift+tab\", \"up\":\n\t\t\t\tnewPos := absPos - 1\n\t\t\t\tif newPos < 0 {\n\t\t\t\t\tnewPos = totalFields - 1\n\t\t\t\t}\n\t\t\t\tm.focusAbsolutePos(newPos)\n\t\t\t\treturn m, textinput.Blink\n\t\t\tcase \"enter\":\n\t\t\t\t// On toggles, Enter advances to the next field (use Space to toggle)\n\t\t\t\tif m.inTogglePhase && (m.toggleFocus == -2 || m.toggleFocus == -1) {\n\t\t\t\t\t// If this toggle is the last field, submit\n\t\t\t\t\tif absPos == totalFields-1 {\n\t\t\t\t\t\t// fall through to submit logic below\n\t\t\t\t\t} else {\n\t\t\t\t\t\tm.focusAbsolutePos(absPos + 1)\n\t\t\t\t\t\treturn m, textinput.Blink\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// On the last field, submit\n\t\t\t\tif absPos == totalFields-1 {\n\t\t\t\t\t// Validate admin fields\n\t\t\t\t\tfor i, f := range setupFieldDefs {\n\t\t\t\t\t\tif strings.TrimSpace(m.setupInputs[i].Value()) == \"\" {\n\t\t\t\t\t\t\tm.setupError = f.label + \" is required\"\n\t\t\t\t\t\t\tm.focusAbsolutePos(i)\n\t\t\t\t\t\t\treturn m, textinput.Blink\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t// Validate Hyva fields if enabled\n\t\t\t\t\tif m.installHyva {\n\t\t\t\t\t\tfor i, f := range hyvaFieldDefs {\n\t\t\t\t\t\t\tif strings.TrimSpace(m.hyvaInputs[i].Value()) == \"\" {\n\t\t\t\t\t\t\t\tm.setupError = \"Hyvä \" + f.label + \" is required\"\n\t\t\t\t\t\t\t\tm.focusAbsolutePos(len(m.setupInputs) + 2 + i)\n\t\t\t\t\t\t\t\treturn m, textinput.Blink\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\tm.setupError = \"\"\n\t\t\t\t\tm.installCfg = m.buildInstallConfig()\n\t\t\t\t\tm.selected.Detector.PrepareSteps(&m.installCfg)\n\t\t\t\t\tm.previewScroll = 0\n\t\t\t\t\tm.phase = phaseSetupPreview\n\t\t\t\t\treturn m, nil\n\t\t\t\t}\n\t\t\t\t// Move to next field\n\t\t\t\tm.focusAbsolutePos(absPos + 1)\n\t\t\t\treturn m, textinput.Blink\n\t\t\tcase \" \":\n\t\t\t\t// Space on toggles\n\t\t\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n\t\t\t\t\tm.installSampleData = !m.installSampleData\n\t\t\t\t\treturn m, nil\n\t\t\t\t}\n\t\t\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n\t\t\t\t\tm.installHyva = !m.installHyva\n\t\t\t\t\treturn m, nil\n\t\t\t\t}\n\t\t\t\t// Fall through to default for text input\n\t\t\t\tfallthrough\n\t\t\tdefault:\n\t\t\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n\t\t\t\t\tvar cmd tea.Cmd\n\t\t\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n\t\t\t\t\treturn m, cmd\n\t\t\t\t}\n\t\t\t\tif !m.inTogglePhase {\n\t\t\t\t\tvar cmd tea.Cmd\n\t\t\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n\t\t\t\t\treturn m, cmd\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\t// Forward non-key messages (e.g. blink) to focused input\n\t\tif m.inTogglePhase && m.toggleFocus >= 0 {\n\t\t\tvar cmd tea.Cmd\n\t\t\tm.hyvaInputs[m.toggleFocus], cmd = m.hyvaInputs[m.toggleFocus].Update(msg)\n\t\t\treturn m, cmd\n\t\t}\n\t\tif !m.inTogglePhase {\n\t\t\tvar cmd tea.Cmd\n\t\t\tm.setupInputs[m.setupFocus], cmd = m.setupInputs[m.setupFocus].Update(msg)\n\t\t\treturn m, cmd\n\t\t}\n\t}\n\n\t// Handle setup preview\n\tif m.phase == phaseSetupPreview {\n\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n\t\t\tswitch keyMsg.String() {\n\t\t\tcase \"up\", \"k\":\n\t\t\t\tif m.previewScroll > 0 {\n\t\t\t\t\tm.previewScroll--\n\t\t\t\t}\n\t\t\tcase \"down\", \"j\":\n\t\t\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n\t\t\t\tmaxVisible := m.windowHeight - 10\n\t\t\t\tif maxVisible < 3 {\n\t\t\t\t\tmaxVisible = 3\n\t\t\t\t}\n\t\t\t\tif maxScroll := totalLines - maxVisible; m.previewScroll < maxScroll {\n\t\t\t\t\tm.previewScroll++\n\t\t\t\t}\n\t\t\tcase \"enter\":\n\t\t\t\tm.initInstallSteps()\n\t\t\t\t// Cache sudo credentials before starting the install so that\n\t\t\t\t// commands like \"ddev start\" (which modifies /etc/hosts) can\n\t\t\t\t// use sudo without prompting inside the TUI.\n\t\t\t\tc := exec.Command(\"sudo\", \"-v\")\n\t\t\t\treturn m, tea.ExecProcess(c, func(err error) tea.Msg {\n\t\t\t\t\treturn sudoCachedMsg{err: err}\n\t\t\t\t})\n\t\t\tcase \"b\", \"esc\":\n\t\t\t\tm.phase = phaseSetupConfig\n\t\t\t\treturn m, textinput.Blink\n\t\t\t}\n\t\t}\n\t}\n\n\tif m.phase == phaseOpenBrowser {\n\t\tif keyMsg, ok := msg.(tea.KeyMsg); ok {\n\t\t\tswitch keyMsg.String() {\n\t\t\tcase \"y\":\n\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n\t\t\t\t_ = openBrowser(url)\n\t\t\t\tm.browserOpened = true\n\t\t\t\tm.phase = phaseInstallDone\n\t\t\t\treturn m, nil\n\t\t\tcase \"n\", \"enter\", \"esc\":\n\t\t\t\tm.phase = phaseInstallDone\n\t\t\t\treturn m, nil\n\t\t\t}\n\t\t}\n\t}\n\n\tif m.phase == phaseInstallDone || m.phase == phaseError {\n\t\tif msg, ok := msg.(tea.KeyMsg); ok {\n\t\t\tswitch msg.String() {\n\t\t\tcase \"r\":\n\t\t\t\tif m.phase == phaseInstallDone && m.installErr != nil {\n\t\t\t\t\t// Find the failed step so we can resume from there.\n\t\t\t\t\tfailedIdx := 0\n\t\t\t\t\tfor i := range m.installSteps {\n\t\t\t\t\t\tif m.installSteps[i].status == stepFailed {\n\t\t\t\t\t\t\tfailedIdx = i\n\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t// Keep completed steps green; reset failed + pending to pending.\n\t\t\t\t\tfor i := range m.installSteps {\n\t\t\t\t\t\tif m.installSteps[i].status != stepDone {\n\t\t\t\t\t\t\tm.installSteps[i].status = stepPending\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\tm.logLines = nil\n\t\t\t\t\tm.installErr = nil\n\t\t\t\t\tm.installCfg.StartFromStep = failedIdx\n\t\t\t\t\tm.phase = phaseInstalling\n\t\t\t\t\tch, cmd := runInstall(m.selected.Detector, m.installCfg)\n\t\t\t\t\tm.logCh = ch\n\t\t\t\t\treturn m, tea.Batch(m.spinner.Tick, cmd)\n\t\t\t\t}\n\t\t\tcase \"enter\", \"q\", \"esc\":\n\t\t\t\treturn m, tea.Quit\n\t\t\t}\n\t\t}\n\t}\n\n\treturn m, nil\n}\n\nfunc (m Model) View() string {\n\tvar b strings.Builder\n\n\tb.WriteString(bannerStyle.Render(banner))\n\tb.WriteString(\"\\n\")\n\tb.WriteString(titleStyle.Render(\"Mage-OS Installer\"))\n\tb.WriteString(\"\\n\\n\")\n\n\tswitch m.phase {\n\tcase phaseNameInput:\n\t\tb.WriteString(\"Project name:\\n\\n\")\n\t\tb.WriteString(m.nameInput.View())\n\t\tb.WriteString(\"\\n\\n\")\n\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n\n\tcase phaseDirectoryInput:\n\t\tb.WriteString(\"Install directory:\\n\\n\")\n\t\tb.WriteString(m.dirInput.View())\n\t\tb.WriteString(\"\\n\\n\")\n\t\tb.WriteString(dimStyle.Render(\"Enter to confirm, ctrl+c to quit\"))\n\n\tcase phaseDetecting:\n\t\tb.WriteString(fmt.Sprintf(\"%s Detecting development environments...\\n\", m.spinner.View()))\n\n\tcase phaseSelection:\n\t\tb.WriteString(\"Multiple environments detected. Please select one:\\n\\n\")\n\t\tfor i, env := range m.envs {\n\t\t\tlabel := fmt.Sprintf(\"%s (%s)\", env.Env.Name, env.Env.Version)\n\t\t\tif i == m.cursor {\n\t\t\t\tb.WriteString(selectedItemStyle.Render(\"▸ \" + label))\n\t\t\t} else {\n\t\t\t\tb.WriteString(itemStyle.Render(\"  \" + label))\n\t\t\t}\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"↑/↓ to move, enter to select, q to quit\"))\n\n\tcase phaseSetupConfig:\n\t\tb.WriteString(\"Configure Mage-OS:\\n\\n\")\n\t\tconst labelWidth = 18\n\t\tfor i, f := range setupFieldDefs {\n\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, f.label))\n\t\t\tb.WriteString(m.setupInputs[i].View())\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\t// Sample data toggle\n\t\tsdCheckbox := \"[ ]\"\n\t\tif m.installSampleData {\n\t\t\tsdCheckbox = \"[x]\"\n\t\t}\n\t\tsdStyle := dimStyle\n\t\tif m.inTogglePhase && m.toggleFocus == -2 {\n\t\t\tsdStyle = selectedItemStyle\n\t\t}\n\t\tb.WriteString(sdStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install sample data\", sdCheckbox)))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      Adds demo products, categories, and customers so you can\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      explore a fully populated store right away. Recommended\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      for your first install to see how everything works.\"))\n\t\tb.WriteString(\"\\n\\n\")\n\t\t// Hyva toggle\n\t\thyvaCheckbox := \"[ ]\"\n\t\tif m.installHyva {\n\t\t\thyvaCheckbox = \"[x]\"\n\t\t}\n\t\thyvaStyle := dimStyle\n\t\tif m.inTogglePhase && m.toggleFocus == -1 {\n\t\t\thyvaStyle = selectedItemStyle\n\t\t}\n\t\tb.WriteString(hyvaStyle.Render(fmt.Sprintf(\"  %-*s  %s\", labelWidth, \"Install Hyvä\", hyvaCheckbox)))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      Hyvä is a modern, fast frontend theme that replaces the\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      default Luma theme. It uses Tailwind CSS and Alpine.js,\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      making frontend development much more enjoyable.\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      ⚠ Hyvä requires a (free) license. Register at hyva.io and have\"))\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"                      your repo URL and auth token ready before continuing.\"))\n\t\tb.WriteString(\"\\n\")\n\t\t// Hyva credential fields (shown only when enabled)\n\t\tif m.installHyva {\n\t\t\tfor i, f := range hyvaFieldDefs {\n\t\t\t\tb.WriteString(fmt.Sprintf(\"  %-*s  \", labelWidth, \"    \"+f.label))\n\t\t\t\tb.WriteString(m.hyvaInputs[i].View())\n\t\t\t\tb.WriteString(\"\\n\")\n\t\t\t}\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\tif m.setupError != \"\" {\n\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \"+m.setupError) + \"\\n\\n\")\n\t\t}\n\t\tb.WriteString(dimStyle.Render(\"Tab/↑↓/Enter to move · Space to toggle options · Enter to review command · ctrl+c to quit\"))\n\n\tcase phaseSetupPreview:\n\t\tb.WriteString(\"Review the setup command:\\n\\n\")\n\t\tflags := m.selected.Detector.SetupInstallFlags(&m.installCfg)\n\t\tvar lines []string\n\t\tlines = append(lines, m.selected.Detector.SetupCommandPrefix()+\" \\\\\")\n\t\tfor i, f := range flags {\n\t\t\tsuffix := dimStyle.Render(\" \\\\\")\n\t\t\tif i == len(flags)-1 {\n\t\t\t\tsuffix = \"\"\n\t\t\t}\n\t\t\tvar line string\n\t\t\tif f.Editable {\n\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\") + highlightStyle.Render(f.Value) + suffix\n\t\t\t} else {\n\t\t\t\tline = \"  \" + dimStyle.Render(f.Flag+\"=\"+f.Value) + suffix\n\t\t\t}\n\t\t\tlines = append(lines, line)\n\t\t}\n\t\tmaxVisible := m.windowHeight - 10\n\t\tif maxVisible < 5 {\n\t\t\tmaxVisible = 5\n\t\t}\n\t\tstart := m.previewScroll\n\t\tif start >= len(lines) {\n\t\t\tstart = max(0, len(lines)-1)\n\t\t}\n\t\tend := start + maxVisible\n\t\tif end > len(lines) {\n\t\t\tend = len(lines)\n\t\t}\n\t\tfor _, line := range lines[start:end] {\n\t\t\tb.WriteString(line + \"\\n\")\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\t\tb.WriteString(dimStyle.Render(\"↑/↓ to scroll · Enter to run · b to go back\"))\n\n\tcase phaseInstalling:\n\t\tb.WriteString(fmt.Sprintf(\"%s Installing %s...\\n\", m.spinner.View(), m.selected.Env.Name))\n\t\tb.WriteString(\"\\n\")\n\t\tfor _, step := range m.installSteps {\n\t\t\tswitch step.status {\n\t\t\tcase stepDone:\n\t\t\t\tb.WriteString(successStyle.Render(\"  ✓ \" + step.name))\n\t\t\tcase stepRunning:\n\t\t\t\tb.WriteString(selectedItemStyle.Render(\"  ▸ \" + step.name + \"...\"))\n\t\t\tcase stepFailed:\n\t\t\t\tb.WriteString(errorStyle.Render(\"  ✗ \" + step.name))\n\t\t\tdefault:\n\t\t\t\tb.WriteString(dimStyle.Render(\"  • \" + step.name))\n\t\t\t}\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\t\tif len(m.logLines) > 0 {\n\t\t\t// Compute available height for the log box.\n\t\t\t// Header: 8 (banner) + 1 (blank) + 1 (title) + 2 (blank) +\n\t\t\t//         1 (installing line) + 1 (blank) + N (steps) = 14 + N\n\t\t\t// Box border adds 2 rows; log box also has MarginTop(1).\n\t\t\twh := m.windowHeight\n\t\t\tif wh <= 0 {\n\t\t\t\twh = 24\n\t\t\t}\n\t\t\theaderLines := 14 + len(m.installSteps)\n\t\t\t// 2 for box borders, 1 for margin top\n\t\t\tinnerHeight := wh - headerLines - 3\n\t\t\tif innerHeight < 3 {\n\t\t\t\tinnerHeight = 3\n\t\t\t}\n\n\t\t\tww := m.windowWidth\n\t\t\tif ww <= 0 {\n\t\t\t\tww = 80\n\t\t\t}\n\t\t\t// 4 accounts for the border (2) + padding (2)\n\t\t\tinnerWidth := ww - 4\n\t\t\tif innerWidth < 40 {\n\t\t\t\tinnerWidth = 40\n\t\t\t}\n\n\t\t\tstart := len(m.logLines) - innerHeight\n\t\t\tif start < 0 {\n\t\t\t\tstart = 0\n\t\t\t}\n\t\t\tstyle := logBoxStyle.Width(innerWidth).Height(innerHeight)\n\t\t\tb.WriteString(style.Render(strings.Join(m.logLines[start:], \"\\n\")))\n\t\t\tb.WriteString(\"\\n\")\n\t\t}\n\n\tcase phaseOpenBrowser:\n\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n\t\tlines := []string{\n\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n\t\t\t\"\",\n\t\t\t\"Open \" + highlightStyle.Render(url) + \" in your browser?\",\n\t\t\t\"\",\n\t\t\tdimStyle.Render(\"y to open · n/enter to skip\"),\n\t\t}\n\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\tb.WriteString(\"\\n\")\n\n\tcase phaseInstallDone:\n\t\tif m.installErr != nil {\n\t\t\tlines := []string{\n\t\t\t\terrorStyle.Render(\"✗ Installation failed!\"),\n\t\t\t\t\"\",\n\t\t\t\tm.installErr.Error(),\n\t\t\t}\n\t\t\tif len(m.logLines) > 0 {\n\t\t\t\tconst maxLines = 10\n\t\t\t\tstart := len(m.logLines) - maxLines\n\t\t\t\tif start < 0 {\n\t\t\t\t\tstart = 0\n\t\t\t\t}\n\t\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Last output:\"))\n\t\t\t\tfor _, line := range m.logLines[start:] {\n\t\t\t\t\tlines = append(lines, dimStyle.Render(line))\n\t\t\t\t}\n\t\t\t}\n\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press r to retry, enter/q to exit.\"))\n\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\t} else {\n\t\t\tlines := []string{\n\t\t\t\tsuccessStyle.Render(\"✓ \" + m.selected.Env.Name + \" installed successfully!\"),\n\t\t\t}\n\t\t\tif m.browserOpened {\n\t\t\t\turl := m.selected.Detector.BaseURL(m.installCfg.ProjectName)\n\t\t\t\tlines = append(lines, \"\", \"Opened \"+highlightStyle.Render(url)+\" in your browser.\")\n\t\t\t}\n\t\t\tlines = append(lines, \"\", dimStyle.Render(\"Press enter to exit.\"))\n\t\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\t}\n\t\tb.WriteString(\"\\n\")\n\n\tcase phaseError:\n\t\tlines := []string{\n\t\t\terrorStyle.Render(\"No supported environments found!\"),\n\t\t\t\"\",\n\t\t\t\"Please install one of the following:\",\n\t\t\t\"\",\n\t\t}\n\t\tfor _, info := range detector.AllDetectorInfos() {\n\t\t\tlines = append(lines, \"  \"+selectedItemStyle.Render(info.Name)+\"  \"+info.InstallURL)\n\t\t}\n\t\tlines = append(lines, \"\", dimStyle.Render(\"Press q to quit.\"))\n\t\tb.WriteString(boxStyle.Render(lipgloss.JoinVertical(lipgloss.Left, lines...)))\n\t\tb.WriteString(\"\\n\")\n\t}\n\n\treturn b.String()\n}\n","numLines":928,"startLine":1,"totalLines":928}}}
