{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UChiTQS1fZaqWeTWDzoBQ6","type":"tool_result","content":"1\tpackage detector\n2\t\n3\t// Environment represents a detected development environment.\n4\ttype Environment struct {\n5\t\tName    string\n6\t\tVersion string\n7\t\tCommand string\n8\t}\n9\t\n10\t// DetectorInfo holds static metadata about a detector (used for install hints).\n11\ttype DetectorInfo struct {\n12\t\tName       string\n13\t\tInstallURL string\n14\t}\n15\t\n16\t// Step represents a single named installation step.\n17\ttype Step struct {\n18\t\tName string\n19\t}\n20\t\n21\t// SetupFlag represents one --flag=value argument for bin/magento setup:install.\n22\ttype SetupFlag struct {\n23\t\tFlag     string\n24\t\tValue    string\n25\t\tEditable bool // shown highlighted in the command preview\n26\t}\n27\t\n28\t// Detector checks for a specific development environment.\n29\ttype Detector interface {\n30\t\tInfo() DetectorInfo\n31\t\tSteps() []Step\n32\t\t// PrepareSteps builds the step list based on the given config.\n33\t\t// Must be called before Steps() to get accurate results.\n34\t\tPrepareSteps(config *Config)\n35\t\tDetect() (*Environment, error)\n36\t\tInstall(config *Config) error\n37\t\t// SetupInstallFlags returns the ordered list of flags for bin/magento setup:install.\n38\t\tSetupInstallFlags(config *Config) []SetupFlag\n39\t\t// SetupCommandPrefix returns the command prefix shown in the setup preview\n40\t\t// (e.g. \"ddev exec bin/magento setup:install\").\n41\t\tSetupCommandPrefix() string\n42\t\t// BaseURL returns the base URL for the installed Magento site.\n43\t\tBaseURL(projectName string) string\n44\t}\n45\t\n46\tfunc allDetectors() []Detector {\n47\t\treturn []Detector{\n48\t\t\t&DdevDetector{},\n49\t\t\t&WardenDetector{},\n50\t\t}\n51\t}\n52\t\n53\t// AllDetectorInfos returns static info for every known detector.\n54\tfunc AllDetectorInfos() []DetectorInfo {\n55\t\tvar infos []DetectorInfo\n56\t\tfor _, d := range allDetectors() {\n57\t\t\tinfos = append(infos, d.Info())\n58\t\t}\n59\t\treturn infos\n60\t}\n61\t\n62\t// DetectedEnvironment pairs a detected Environment with the Detector that found it.\n63\ttype DetectedEnvironment struct {\n64\t\tEnv      Environment\n65\t\tDetector Detector\n66\t}\n67\t\n68\t// DetectAll runs all known detectors and returns available environments.\n69\tfunc DetectAll() []DetectedEnvironment {\n70\t\tvar results []DetectedEnvironment\n71\t\tfor _, d := range allDetectors() {\n72\t\t\tenv, err := d.Detect()\n73\t\t\tif err == nil && env != nil {\n74\t\t\t\tresults = append(results, DetectedEnvironment{Env: *env, Detector: d})\n75\t\t\t}\n76\t\t}\n77\t\treturn results\n78\t}\n79\t"}]},"parent_tool_use_id":null,"session_id":"a125b2b2-af62-4392-8396-7f4a588a5ae5","uuid":"44581ebb-089f-486d-90ac-4aab26377774","timestamp":"2026-04-14T19:21:25.888Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/detector/detector.go","content":"package detector\n\n// Environment represents a detected development environment.\ntype Environment struct {\n\tName    string\n\tVersion string\n\tCommand string\n}\n\n// DetectorInfo holds static metadata about a detector (used for install hints).\ntype DetectorInfo struct {\n\tName       string\n\tInstallURL string\n}\n\n// Step represents a single named installation step.\ntype Step struct {\n\tName string\n}\n\n// SetupFlag represents one --flag=value argument for bin/magento setup:install.\ntype SetupFlag struct {\n\tFlag     string\n\tValue    string\n\tEditable bool // shown highlighted in the command preview\n}\n\n// Detector checks for a specific development environment.\ntype Detector interface {\n\tInfo() DetectorInfo\n\tSteps() []Step\n\t// PrepareSteps builds the step list based on the given config.\n\t// Must be called before Steps() to get accurate results.\n\tPrepareSteps(config *Config)\n\tDetect() (*Environment, error)\n\tInstall(config *Config) error\n\t// SetupInstallFlags returns the ordered list of flags for bin/magento setup:install.\n\tSetupInstallFlags(config *Config) []SetupFlag\n\t// SetupCommandPrefix returns the command prefix shown in the setup preview\n\t// (e.g. \"ddev exec bin/magento setup:install\").\n\tSetupCommandPrefix() string\n\t// BaseURL returns the base URL for the installed Magento site.\n\tBaseURL(projectName string) string\n}\n\nfunc allDetectors() []Detector {\n\treturn []Detector{\n\t\t&DdevDetector{},\n\t\t&WardenDetector{},\n\t}\n}\n\n// AllDetectorInfos returns static info for every known detector.\nfunc AllDetectorInfos() []DetectorInfo {\n\tvar infos []DetectorInfo\n\tfor _, d := range allDetectors() {\n\t\tinfos = append(infos, d.Info())\n\t}\n\treturn infos\n}\n\n// DetectedEnvironment pairs a detected Environment with the Detector that found it.\ntype DetectedEnvironment struct {\n\tEnv      Environment\n\tDetector Detector\n}\n\n// DetectAll runs all known detectors and returns available environments.\nfunc DetectAll() []DetectedEnvironment {\n\tvar results []DetectedEnvironment\n\tfor _, d := range allDetectors() {\n\t\tenv, err := d.Detect()\n\t\tif err == nil && env != nil {\n\t\t\tresults = append(results, DetectedEnvironment{Env: *env, Detector: d})\n\t\t}\n\t}\n\treturn results\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P9xAK2UobRzjTLTmt8rUSu","type":"tool_result","content":"1\tpackage detector\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/tls\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"net/http\"\n10\t\t\"os\"\n11\t\t\"os/exec\"\n12\t\t\"strings\"\n13\t\t\"time\"\n14\t)\n15\t\n16\t// DdevDetector checks for the DDEV development environment.\n17\ttype DdevDetector struct {\n18\t\t// primaryURL is populated after ddev start by querying ddev describe.\n19\t\tprimaryURL string\n20\t\t// steps is the list of installation steps, built dynamically based on config.\n21\t\tsteps []Step\n22\t}\n23\t\n24\tfunc (d *DdevDetector) Info() DetectorInfo {\n25\t\treturn DetectorInfo{\n26\t\t\tName:       \"DDEV\",\n27\t\t\tInstallURL: \"https://ddev.readthedocs.io/en/stable/\",\n28\t\t}\n29\t}\n30\t\n31\tfunc (d *DdevDetector) Steps() []Step {\n32\t\treturn d.steps\n33\t}\n34\t\n35\tfunc (d *DdevDetector) PrepareSteps(config *Config) {\n36\t\td.buildSteps(config)\n37\t}\n38\t\n39\tfunc (d *DdevDetector) buildSteps(config *Config) {\n40\t\td.steps = []Step{\n41\t\t\t{Name: \"Configure DDEV project\"},\n42\t\t\t{Name: \"Install OpenSearch addon\"},\n43\t\t\t{Name: \"Install Redis addon\"},\n44\t\t\t{Name: \"Install Cron addon\"},\n45\t\t\t{Name: \"Install RabbitMQ addon\"},\n46\t\t\t{Name: \"Start DDEV\"},\n47\t\t\t{Name: \"Apply RabbitMQ config\"},\n48\t\t\t{Name: \"Create Mage-OS project\"},\n49\t\t\t{Name: \"Copy project files\"},\n50\t\t\t{Name: \"Create composer home directory\"},\n51\t\t\t{Name: \"Copy auth.json\"},\n52\t\t\t{Name: \"Install Mage-OS\"},\n53\t\t}\n54\t\tif config != nil && config.InstallSampleData {\n55\t\t\td.steps = append(d.steps, Step{Name: \"Install sample data\"})\n56\t\t}\n57\t\tif config != nil && config.InstallHyva {\n58\t\t\td.steps = append(d.steps,\n59\t\t\t\tStep{Name: \"Configure Hyvä repository\"},\n60\t\t\t\tStep{Name: \"Install Hyvä theme\"},\n61\t\t\t\tStep{Name: \"Enable Hyvä modules\"},\n62\t\t\t)\n63\t\t}\n64\t\td.steps = append(d.steps, Step{Name: \"Verify installation\"})\n65\t}\n66\t\n67\tfunc (d *DdevDetector) SetupCommandPrefix() string {\n68\t\treturn \"ddev exec bin/magento setup:install\"\n69\t}\n70\t\n71\tfunc (d *DdevDetector) BaseURL(projectName string) string {\n72\t\tif d.primaryURL != \"\" {\n73\t\t\treturn d.primaryURL\n74\t\t}\n75\t\treturn \"https://\" + projectName + \".ddev.site\"\n76\t}\n77\t\n78\t// SetupInstallFlags returns the full ordered list of flags for bin/magento setup:install.\n79\tfunc (d *DdevDetector) SetupInstallFlags(config *Config) []SetupFlag {\n80\t\treturn []SetupFlag{\n81\t\t\t{Flag: \"--backend-frontname\", Value: \"admin\"},\n82\t\t\t{Flag: \"--amqp-host\", Value: \"rabbitmq\"},\n83\t\t\t{Flag: \"--amqp-port\", Value: \"5672\"},\n84\t\t\t{Flag: \"--amqp-user\", Value: \"rabbitmq\"},\n85\t\t\t{Flag: \"--amqp-password\", Value: \"rabbitmq\"},\n86\t\t\t{Flag: \"--db-host\", Value: \"db\"},\n87\t\t\t{Flag: \"--db-name\", Value: \"db\"},\n88\t\t\t{Flag: \"--db-user\", Value: \"db\"},\n89\t\t\t{Flag: \"--db-password\", Value: \"db\"},\n90\t\t\t{Flag: \"--search-engine\", Value: \"opensearch\"},\n91\t\t\t{Flag: \"--opensearch-host\", Value: \"opensearch\"},\n92\t\t\t{Flag: \"--opensearch-port\", Value: \"9200\"},\n93\t\t\t{Flag: \"--opensearch-index-prefix\", Value: \"magento2\"},\n94\t\t\t{Flag: \"--opensearch-enable-auth\", Value: \"0\"},\n95\t\t\t{Flag: \"--opensearch-timeout\", Value: \"15\"},\n96\t\t\t{Flag: \"--http-cache-hosts\", Value: \"varnish:80\"},\n97\t\t\t{Flag: \"--session-save\", Value: \"redis\"},\n98\t\t\t{Flag: \"--session-save-redis-host\", Value: \"redis\"},\n99\t\t\t{Flag: \"--session-save-redis-port\", Value: \"6379\"},\n100\t\t\t{Flag: \"--session-save-redis-db\", Value: \"2\"},\n101\t\t\t{Flag: \"--session-save-redis-max-concurrency\", Value: \"20\"},\n102\t\t\t{Flag: \"--cache-backend\", Value: \"redis\"},\n103\t\t\t{Flag: \"--cache-backend-redis-server\", Value: \"redis\"},\n104\t\t\t{Flag: \"--cache-backend-redis-db\", Value: \"0\"},\n105\t\t\t{Flag: \"--cache-backend-redis-port\", Value: \"6379\"},\n106\t\t\t{Flag: \"--page-cache\", Value: \"redis\"},\n107\t\t\t{Flag: \"--page-cache-redis-server\", Value: \"redis\"},\n108\t\t\t{Flag: \"--page-cache-redis-db\", Value: \"1\"},\n109\t\t\t{Flag: \"--page-cache-redis-port\", Value: \"6379\"},\n110\t\t\t{Flag: \"--base-url\", Value: d.BaseURL(config.ProjectName)},\n111\t\t\t{Flag: \"--timezone\", Value: \"Europe/Amsterdam\"},\n112\t\t\t{Flag: \"--currency\", Value: \"EUR\"},\n113\t\t\t{Flag: \"--admin-user\", Value: config.AdminUser, Editable: true},\n114\t\t\t{Flag: \"--admin-password\", Value: config.AdminPassword, Editable: true},\n115\t\t\t{Flag: \"--admin-email\", Value: config.AdminEmail, Editable: true},\n116\t\t\t{Flag: \"--admin-firstname\", Value: config.AdminFirstname, Editable: true},\n117\t\t\t{Flag: \"--admin-lastname\", Value: config.AdminLastname, Editable: true},\n118\t\t\t{Flag: \"--use-rewrites\", Value: \"1\"},\n119\t\t}\n120\t}\n121\t\n122\tfunc (d *DdevDetector) Install(config *Config) error {\n123\t\td.buildSteps(config)\n124\t\n125\t\tsteps := [][]string{\n126\t\t\t{\n127\t\t\t\t\"ddev\", \"config\",\n128\t\t\t\t\"--project-name=\" + config.ProjectName,\n129\t\t\t\t\"--docroot=pub\",\n130\t\t\t\t\"--project-type=magento2\",\n131\t\t\t\t\"--database=mysql:8.0\",\n132\t\t\t\t\"--composer-version=2.2\",\n133\t\t\t},\n134\t\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-opensearch\"},\n135\t\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-redis\"},\n136\t\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-cron\"},\n137\t\t\t{\"ddev\", \"add-on\", \"get\", \"b13/ddev-rabbitmq\"},\n138\t\t\t{\"ddev\", \"start\"},\n139\t\t\t{\"ddev\", \"rabbitmq\", \"apply\"},\n140\t\t\t{\n141\t\t\t\t\"ddev\", \"exec\", \"composer\", \"create-project\",\n142\t\t\t\t\"--repository-url=https://repo.mage-os.org/\",\n143\t\t\t\t\"mage-os/project-community-edition\",\n144\t\t\t\t\"/tmp/mage-os-project\",\n145\t\t\t},\n146\t\t\t{\n147\t\t\t\t\"ddev\", \"exec\", \"bash\", \"-c\",\n148\t\t\t\t\"cp -a /tmp/mage-os-project/. /var/www/html/\",\n149\t\t\t},\n150\t\t\t{\"ddev\", \"exec\", \"mkdir\", \"-p\", \"/var/www/html/var/composer_home/\"},\n151\t\t}\n152\t\n153\t\tfor i, args := range steps {\n154\t\t\tif i < config.StartFromStep {\n155\t\t\t\tcontinue\n156\t\t\t}\n157\t\t\tstepStart(config, i)\n158\t\t\tlogf(config, \"▸ %s\", strings.Join(args, \" \"))\n159\t\t\tif err := runInDir(config.Directory, config.Log, args[0], args[1:]...); err != nil {\n160\t\t\t\treturn fmt.Errorf(\"step %q failed: %w\", strings.Join(args, \" \"), err)\n161\t\t\t}\n162\t\t\tstepDone(config, i)\n163\t\t}\n164\t\n165\t\t// After ddev start, query the actual primary URL so we use\n166\t\t// the correct domain (e.g. .ddev.site) for Magento's base-url.\n167\t\tif url, err := ddevPrimaryURL(config.Directory); err == nil {\n168\t\t\td.primaryURL = url\n169\t\t\tlogf(config, \"▸ Detected primary URL: %s\", url)\n170\t\t}\n171\t\n172\t\tauthIdx := len(steps)\n173\t\tif authIdx >= config.StartFromStep {\n174\t\t\tstepStart(config, authIdx)\n175\t\t\tif err := copyAuthJSON(config); err != nil {\n176\t\t\t\treturn err\n177\t\t\t}\n178\t\t\tstepDone(config, authIdx)\n179\t\t}\n180\t\n181\t\tmagentoIdx := len(steps) + 1\n182\t\tif magentoIdx >= config.StartFromStep {\n183\t\t\tstepStart(config, magentoIdx)\n184\t\t\tlogf(config, \"▸ ddev exec bin/magento setup:install\")\n185\t\t\tsetupArgs := []string{\"exec\", \"bin/magento\", \"setup:install\"}\n186\t\t\tfor _, f := range d.SetupInstallFlags(config) {\n187\t\t\t\tsetupArgs = append(setupArgs, f.Flag+\"=\"+f.Value)\n188\t\t\t}\n189\t\t\tif err := runInDir(config.Directory, config.Log, \"ddev\", setupArgs...); err != nil {\n190\t\t\t\treturn fmt.Errorf(\"setup:install failed: %w\", err)\n191\t\t\t}\n192\t\t\tstepDone(config, magentoIdx)\n193\t\t}\n194\t\n195\t\tnextIdx := magentoIdx + 1\n196\t\n197\t\tif config.InstallSampleData {\n198\t\t\tsampleDataIdx := nextIdx\n199\t\t\tif sampleDataIdx >= config.StartFromStep {\n200\t\t\t\tstepStart(config, sampleDataIdx)\n201\t\t\t\tlogf(config, \"▸ Deploying sample data\")\n202\t\t\t\tif err := runInDir(config.Directory, config.Log,\n203\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"sampledata:deploy\"); err != nil {\n204\t\t\t\t\treturn fmt.Errorf(\"sampledata:deploy failed: %w\", err)\n205\t\t\t\t}\n206\t\t\t\t// If no Hyvä, run setup:upgrade + cache:flush now.\n207\t\t\t\t// If Hyvä is also enabled, setup:upgrade runs in the Hyvä enable step.\n208\t\t\t\tif !config.InstallHyva {\n209\t\t\t\t\tif err := runInDir(config.Directory, config.Log,\n210\t\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n211\t\t\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n212\t\t\t\t\t}\n213\t\t\t\t\tif err := runInDir(config.Directory, config.Log,\n214\t\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n215\t\t\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n216\t\t\t\t\t}\n217\t\t\t\t}\n218\t\t\t\tstepDone(config, sampleDataIdx)\n219\t\t\t}\n220\t\t\tnextIdx++\n221\t\t}\n222\t\n223\t\tif config.InstallHyva {\n224\t\t\thyvaRepoIdx := nextIdx\n225\t\t\tif hyvaRepoIdx >= config.StartFromStep {\n226\t\t\t\tstepStart(config, hyvaRepoIdx)\n227\t\t\t\tlogf(config, \"▸ Configuring Hyvä Private Packagist repository\")\n228\t\t\t\tif err := runInDir(config.Directory, config.Log,\n229\t\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"repositories.private-packagist\",\n230\t\t\t\t\t\"composer\", config.HyvaRepoURL); err != nil {\n231\t\t\t\t\treturn fmt.Errorf(\"configure Hyvä repository failed: %w\", err)\n232\t\t\t\t}\n233\t\t\t\tif err := runInDir(config.Directory, config.Log,\n234\t\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"--auth\",\n235\t\t\t\t\t\"http-basic.\"+extractHost(config.HyvaRepoURL),\n236\t\t\t\t\t\"token\", config.HyvaAuthToken); err != nil {\n237\t\t\t\t\treturn fmt.Errorf(\"configure Hyvä auth failed: %w\", err)\n238\t\t\t\t}\n239\t\t\t\tstepDone(config, hyvaRepoIdx)\n240\t\t\t}\n241\t\t\tnextIdx++\n242\t\n243\t\t\thyvaInstallIdx := nextIdx\n244\t\t\tif hyvaInstallIdx >= config.StartFromStep {\n245\t\t\t\tstepStart(config, hyvaInstallIdx)\n246\t\t\t\tlogf(config, \"▸ Installing Hyvä theme\")\n247\t\t\t\tif err := runInDir(config.Directory, config.Log,\n248\t\t\t\t\t\"ddev\", \"exec\", \"composer\", \"require\", \"hyva-themes/magento2-default-theme\"); err != nil {\n249\t\t\t\t\treturn fmt.Errorf(\"install Hyvä theme failed: %w\", err)\n250\t\t\t\t}\n251\t\t\t\tstepDone(config, hyvaInstallIdx)\n252\t\t\t}\n253\t\t\tnextIdx++\n254\t\n255\t\t\thyvaEnableIdx := nextIdx\n256\t\t\tif hyvaEnableIdx >= config.StartFromStep {\n257\t\t\t\tstepStart(config, hyvaEnableIdx)\n258\t\t\t\tlogf(config, \"▸ Enabling Hyvä modules and setting up theme\")\n259\t\t\t\tif err := runInDir(config.Directory, config.Log,\n260\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"module:enable\", \"--all\"); err != nil {\n261\t\t\t\t\treturn fmt.Errorf(\"enable Hyvä modules failed: %w\", err)\n262\t\t\t\t}\n263\t\t\t\tif err := runInDir(config.Directory, config.Log,\n264\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n265\t\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n266\t\t\t\t}\n267\t\t\t\t// Look up the Hyvä theme ID and set it as default\n268\t\t\t\tlogf(config, \"▸ Setting Hyvä as default storefront theme\")\n269\t\t\t\tthemeID, err := ddevQueryThemeID(config.Directory, \"Hyva/default\")\n270\t\t\t\tif err != nil {\n271\t\t\t\t\treturn fmt.Errorf(\"could not find Hyvä theme ID: %w\", err)\n272\t\t\t\t}\n273\t\t\t\tlogf(config, \"▸ Hyvä theme ID: %s\", themeID)\n274\t\t\t\tif err := runInDir(config.Directory, config.Log,\n275\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"config:set\", \"design/theme/theme_id\", themeID); err != nil {\n276\t\t\t\t\treturn fmt.Errorf(\"set Hyvä theme failed: %w\", err)\n277\t\t\t\t}\n278\t\t\t\tif err := runInDir(config.Directory, config.Log,\n279\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n280\t\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n281\t\t\t\t}\n282\t\t\t\tstepDone(config, hyvaEnableIdx)\n283\t\t\t}\n284\t\t}\n285\t\n286\t\t// verifyInstallation is always the last step regardless of optional steps.\n287\t\tverifyIdx := len(d.steps) - 1\n288\t\tif verifyIdx >= config.StartFromStep {\n289\t\t\tstepStart(config, verifyIdx)\n290\t\t\tbaseURL := d.BaseURL(config.ProjectName)\n291\t\t\tlogf(config, \"▸ Verifying store at %s\", baseURL)\n292\t\t\tif err := verifyInstallation(baseURL, config.Log); err != nil {\n293\t\t\t\treturn fmt.Errorf(\"installation verification failed: %w\", err)\n294\t\t\t}\n295\t\t\tstepDone(config, verifyIdx)\n296\t\t}\n297\t\n298\t\treturn nil\n299\t}\n300\t\n301\t// verifyInstallation makes an HTTP GET request to baseURL and checks that the\n302\t// response returns HTTP 200 and includes the \"x-dist: Mage-OS\" header.\n303\t// DDEV uses self-signed TLS certificates, so TLS verification is skipped.\n304\tfunc verifyInstallation(baseURL string, logFn func(string)) error {\n305\t\tclient := &http.Client{\n306\t\t\tTimeout: 30 * time.Second,\n307\t\t\tTransport: &http.Transport{\n308\t\t\t\tTLSClientConfig: &tls.Config{InsecureSkipVerify: true}, //nolint:gosec\n309\t\t\t},\n310\t\t}\n311\t\n312\t\tresp, err := client.Get(baseURL) //nolint:noctx\n313\t\tif err != nil {\n314\t\t\treturn fmt.Errorf(\"HTTP request to %s failed: %w\", baseURL, err)\n315\t\t}\n316\t\tdefer resp.Body.Close()\n317\t\n318\t\tif resp.StatusCode != http.StatusOK {\n319\t\t\treturn fmt.Errorf(\"expected HTTP 200 from %s, got %d\", baseURL, resp.StatusCode)\n320\t\t}\n321\t\n322\t\tdist := resp.Header.Get(\"x-dist\")\n323\t\tif !strings.Contains(dist, \"Mage-OS\") {\n324\t\t\treturn fmt.Errorf(\"expected x-dist header to contain 'Mage-OS', got %q\", dist)\n325\t\t}\n326\t\n327\t\tif logFn != nil {\n328\t\t\tlogFn(fmt.Sprintf(\"▸ Verified: %s → HTTP 200, x-dist: %s\", baseURL, dist))\n329\t\t}\n330\t\treturn nil\n331\t}\n332\t\n333\t// extractHost extracts the hostname from a URL string.\n334\tfunc extractHost(rawURL string) string {\n335\t\t// Strip protocol prefix\n336\t\thost := rawURL\n337\t\tif i := strings.Index(host, \"://\"); i >= 0 {\n338\t\t\thost = host[i+3:]\n339\t\t}\n340\t\t// Strip path\n341\t\tif i := strings.Index(host, \"/\"); i >= 0 {\n342\t\t\thost = host[:i]\n343\t\t}\n344\t\treturn host\n345\t}\n346\t\n347\t// logf sends a formatted message to config.Log if it is set.\n348\tfunc logf(config *Config, format string, args ...any) {\n349\t\tif config.Log != nil {\n350\t\t\tconfig.Log(fmt.Sprintf(format, args...))\n351\t\t}\n352\t}\n353\t\n354\tfunc stepStart(config *Config, index int) {\n355\t\tif config.OnStepStart != nil {\n356\t\t\tconfig.OnStepStart(index)\n357\t\t}\n358\t}\n359\t\n360\tfunc stepDone(config *Config, index int) {\n361\t\tif config.OnStepDone != nil {\n362\t\t\tconfig.OnStepDone(index)\n363\t\t}\n364\t}\n365\t\n366\t// runInDir runs a command in dir, streaming each output line to logFn.\n367\t// If logFn is nil the output is captured silently and included only in errors.\n368\tfunc runInDir(dir string, logFn func(string), name string, args ...string) error {\n369\t\tcmd := exec.Command(name, args...)\n370\t\tcmd.Dir = dir\n371\t\n372\t\tif logFn == nil {\n373\t\t\tout, err := cmd.CombinedOutput()\n374\t\t\tif err != nil {\n375\t\t\t\treturn fmt.Errorf(\"%w\\n%s\", err, strings.TrimSpace(string(out)))\n376\t\t\t}\n377\t\t\treturn nil\n378\t\t}\n379\t\n380\t\tpr, pw := io.Pipe()\n381\t\tcmd.Stdout = pw\n382\t\tcmd.Stderr = pw\n383\t\n384\t\tif err := cmd.Start(); err != nil {\n385\t\t\tpr.Close()\n386\t\t\tpw.Close()\n387\t\t\treturn err\n388\t\t}\n389\t\n390\t\tscanDone := make(chan struct{})\n391\t\tgo func() {\n392\t\t\tdefer close(scanDone)\n393\t\t\tscanner := bufio.NewScanner(pr)\n394\t\t\tfor scanner.Scan() {\n395\t\t\t\tlogFn(scanner.Text())\n396\t\t\t}\n397\t\t}()\n398\t\n399\t\terr := cmd.Wait()\n400\t\tpw.Close()\n401\t\t<-scanDone\n402\t\tpr.Close()\n403\t\n404\t\treturn err\n405\t}\n406\t\n407\t// copyAuthJSON copies ~/.composer/auth.json into the running DDEV web container.\n408\t// If the file does not exist it is silently skipped.\n409\tfunc copyAuthJSON(config *Config) error {\n410\t\thome, err := os.UserHomeDir()\n411\t\tif err != nil {\n412\t\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n413\t\t}\n414\t\n415\t\tauthSrc := home + \"/.composer/auth.json\"\n416\t\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n417\t\t\treturn nil // nothing to copy\n418\t\t}\n419\t\n420\t\tcontainerName, err := ddevWebContainerName(config.Directory)\n421\t\tif err != nil {\n422\t\t\treturn fmt.Errorf(\"could not get DDEV web container name: %w\", err)\n423\t\t}\n424\t\n425\t\tlogf(config, \"▸ docker cp auth.json → container\")\n426\t\tauthDst := containerName + \":/var/www/html/var/composer_home/auth.json\"\n427\t\treturn runInDir(config.Directory, config.Log, \"docker\", \"cp\", authSrc, authDst)\n428\t}\n429\t\n430\t// ddevDescribeOutput is the relevant subset of `ddev describe --json-output`.\n431\ttype ddevDescribeOutput struct {\n432\t\tRaw struct {\n433\t\t\tPrimaryURL string `json:\"primary_url\"`\n434\t\t\tServices   map[string]struct {\n435\t\t\t\tFullName string `json:\"full_name\"`\n436\t\t\t} `json:\"services\"`\n437\t\t} `json:\"raw\"`\n438\t}\n439\t\n440\t// ddevWebContainerName returns the full Docker container name for the web service.\n441\tfunc ddevWebContainerName(dir string) (string, error) {\n442\t\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n443\t\tcmd.Dir = dir\n444\t\tout, err := cmd.Output()\n445\t\tif err != nil {\n446\t\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n447\t\t}\n448\t\n449\t\tvar desc ddevDescribeOutput\n450\t\tif err := json.Unmarshal(out, &desc); err != nil {\n451\t\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n452\t\t}\n453\t\n454\t\tweb, ok := desc.Raw.Services[\"web\"]\n455\t\tif !ok || web.FullName == \"\" {\n456\t\t\treturn \"\", fmt.Errorf(\"web service not found in ddev describe output\")\n457\t\t}\n458\t\n459\t\treturn web.FullName, nil\n460\t}\n461\t\n462\t// ddevPrimaryURL returns the primary URL of the running ddev project.\n463\tfunc ddevPrimaryURL(dir string) (string, error) {\n464\t\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n465\t\tcmd.Dir = dir\n466\t\tout, err := cmd.Output()\n467\t\tif err != nil {\n468\t\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n469\t\t}\n470\t\n471\t\tvar desc ddevDescribeOutput\n472\t\tif err := json.Unmarshal(out, &desc); err != nil {\n473\t\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n474\t\t}\n475\t\n476\t\tif desc.Raw.PrimaryURL == \"\" {\n477\t\t\treturn \"\", fmt.Errorf(\"primary_url not found in ddev describe output\")\n478\t\t}\n479\t\n480\t\treturn desc.Raw.PrimaryURL, nil\n481\t}\n482\t\n483\t// ddevQueryThemeID queries the database via ddev mysql for the given theme path\n484\t// and returns its numeric ID as a string.\n485\tfunc ddevQueryThemeID(dir, themePath string) (string, error) {\n486\t\tcmd := exec.Command(\"ddev\", \"mysql\", \"-N\", \"-e\",\n487\t\t\tfmt.Sprintf(\"SELECT theme_id FROM theme WHERE theme_path='%s'\", themePath))\n488\t\tcmd.Dir = dir\n489\t\tout, err := cmd.Output()\n490\t\tif err != nil {\n491\t\t\treturn \"\", fmt.Errorf(\"ddev mysql query failed: %w\", err)\n492\t\t}\n493\t\tid := strings.TrimSpace(string(out))\n494\t\tif id == \"\" {\n495\t\t\treturn \"\", fmt.Errorf(\"theme %q not found in database\", themePath)\n496\t\t}\n497\t\treturn id, nil\n498\t}\n499\t\n500\tfunc (d *DdevDetector) Detect() (*Environment, error) {\n501\t\tpath, err := exec.LookPath(\"ddev\")\n502\t\tif err != nil {\n503\t\t\treturn nil, err\n504\t\t}\n505\t\n506\t\tversion := \"unknown\"\n507\t\tout, err := exec.Command(\"ddev\", \"version\", \"-j\").Output()\n508\t\tif err == nil {\n509\t\t\tversion = parseVersion(string(out), \"ddev\")\n510\t\t}\n511\t\tif version == \"unknown\" {\n512\t\t\tout, err = exec.Command(\"ddev\", \"version\").Output()\n513\t\t\tif err == nil {\n514\t\t\t\tversion = parseDdevVersionPlain(string(out))\n515\t\t\t}\n516\t\t}\n517\t\n518\t\treturn &Environment{\n519\t\t\tName:    \"DDEV\",\n520\t\t\tVersion: version,\n521\t\t\tCommand: path,\n522\t\t}, nil\n523\t}\n524\t\n525\tfunc parseDdevVersionPlain(output string) string {\n526\t\tfor _, line := range strings.Split(output, \"\\n\") {\n527\t\t\tline = strings.TrimSpace(line)\n528\t\t\tif strings.HasPrefix(line, \"DDEV version\") || strings.HasPrefix(line, \"ddev version\") {\n529\t\t\t\tparts := strings.Fields(line)\n530\t\t\t\tif len(parts) >= 3 {\n531\t\t\t\t\treturn strings.TrimRight(parts[len(parts)-1], \",\")\n532\t\t\t\t}\n533\t\t\t}\n534\t\t\tif strings.HasPrefix(line, \"version:\") {\n535\t\t\t\tparts := strings.Fields(line)\n536\t\t\t\tif len(parts) >= 2 {\n537\t\t\t\t\treturn parts[1]\n538\t\t\t\t}\n539\t\t\t}\n540\t\t}\n541\t\treturn \"unknown\"\n542\t}\n543\t"}]},"parent_tool_use_id":null,"session_id":"a125b2b2-af62-4392-8396-7f4a588a5ae5","uuid":"a1e20c50-e3d3-40e6-837d-2cf58c262cf2","timestamp":"2026-04-14T19:21:25.941Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/detector/ddev.go","content":"package detector\n\nimport (\n\t\"bufio\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"strings\"\n\t\"time\"\n)\n\n// DdevDetector checks for the DDEV development environment.\ntype DdevDetector struct {\n\t// primaryURL is populated after ddev start by querying ddev describe.\n\tprimaryURL string\n\t// steps is the list of installation steps, built dynamically based on config.\n\tsteps []Step\n}\n\nfunc (d *DdevDetector) Info() DetectorInfo {\n\treturn DetectorInfo{\n\t\tName:       \"DDEV\",\n\t\tInstallURL: \"https://ddev.readthedocs.io/en/stable/\",\n\t}\n}\n\nfunc (d *DdevDetector) Steps() []Step {\n\treturn d.steps\n}\n\nfunc (d *DdevDetector) PrepareSteps(config *Config) {\n\td.buildSteps(config)\n}\n\nfunc (d *DdevDetector) buildSteps(config *Config) {\n\td.steps = []Step{\n\t\t{Name: \"Configure DDEV project\"},\n\t\t{Name: \"Install OpenSearch addon\"},\n\t\t{Name: \"Install Redis addon\"},\n\t\t{Name: \"Install Cron addon\"},\n\t\t{Name: \"Install RabbitMQ addon\"},\n\t\t{Name: \"Start DDEV\"},\n\t\t{Name: \"Apply RabbitMQ config\"},\n\t\t{Name: \"Create Mage-OS project\"},\n\t\t{Name: \"Copy project files\"},\n\t\t{Name: \"Create composer home directory\"},\n\t\t{Name: \"Copy auth.json\"},\n\t\t{Name: \"Install Mage-OS\"},\n\t}\n\tif config != nil && config.InstallSampleData {\n\t\td.steps = append(d.steps, Step{Name: \"Install sample data\"})\n\t}\n\tif config != nil && config.InstallHyva {\n\t\td.steps = append(d.steps,\n\t\t\tStep{Name: \"Configure Hyvä repository\"},\n\t\t\tStep{Name: \"Install Hyvä theme\"},\n\t\t\tStep{Name: \"Enable Hyvä modules\"},\n\t\t)\n\t}\n\td.steps = append(d.steps, Step{Name: \"Verify installation\"})\n}\n\nfunc (d *DdevDetector) SetupCommandPrefix() string {\n\treturn \"ddev exec bin/magento setup:install\"\n}\n\nfunc (d *DdevDetector) BaseURL(projectName string) string {\n\tif d.primaryURL != \"\" {\n\t\treturn d.primaryURL\n\t}\n\treturn \"https://\" + projectName + \".ddev.site\"\n}\n\n// SetupInstallFlags returns the full ordered list of flags for bin/magento setup:install.\nfunc (d *DdevDetector) SetupInstallFlags(config *Config) []SetupFlag {\n\treturn []SetupFlag{\n\t\t{Flag: \"--backend-frontname\", Value: \"admin\"},\n\t\t{Flag: \"--amqp-host\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--amqp-port\", Value: \"5672\"},\n\t\t{Flag: \"--amqp-user\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--amqp-password\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--db-host\", Value: \"db\"},\n\t\t{Flag: \"--db-name\", Value: \"db\"},\n\t\t{Flag: \"--db-user\", Value: \"db\"},\n\t\t{Flag: \"--db-password\", Value: \"db\"},\n\t\t{Flag: \"--search-engine\", Value: \"opensearch\"},\n\t\t{Flag: \"--opensearch-host\", Value: \"opensearch\"},\n\t\t{Flag: \"--opensearch-port\", Value: \"9200\"},\n\t\t{Flag: \"--opensearch-index-prefix\", Value: \"magento2\"},\n\t\t{Flag: \"--opensearch-enable-auth\", Value: \"0\"},\n\t\t{Flag: \"--opensearch-timeout\", Value: \"15\"},\n\t\t{Flag: \"--http-cache-hosts\", Value: \"varnish:80\"},\n\t\t{Flag: \"--session-save\", Value: \"redis\"},\n\t\t{Flag: \"--session-save-redis-host\", Value: \"redis\"},\n\t\t{Flag: \"--session-save-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--session-save-redis-db\", Value: \"2\"},\n\t\t{Flag: \"--session-save-redis-max-concurrency\", Value: \"20\"},\n\t\t{Flag: \"--cache-backend\", Value: \"redis\"},\n\t\t{Flag: \"--cache-backend-redis-server\", Value: \"redis\"},\n\t\t{Flag: \"--cache-backend-redis-db\", Value: \"0\"},\n\t\t{Flag: \"--cache-backend-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--page-cache\", Value: \"redis\"},\n\t\t{Flag: \"--page-cache-redis-server\", Value: \"redis\"},\n\t\t{Flag: \"--page-cache-redis-db\", Value: \"1\"},\n\t\t{Flag: \"--page-cache-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--base-url\", Value: d.BaseURL(config.ProjectName)},\n\t\t{Flag: \"--timezone\", Value: \"Europe/Amsterdam\"},\n\t\t{Flag: \"--currency\", Value: \"EUR\"},\n\t\t{Flag: \"--admin-user\", Value: config.AdminUser, Editable: true},\n\t\t{Flag: \"--admin-password\", Value: config.AdminPassword, Editable: true},\n\t\t{Flag: \"--admin-email\", Value: config.AdminEmail, Editable: true},\n\t\t{Flag: \"--admin-firstname\", Value: config.AdminFirstname, Editable: true},\n\t\t{Flag: \"--admin-lastname\", Value: config.AdminLastname, Editable: true},\n\t\t{Flag: \"--use-rewrites\", Value: \"1\"},\n\t}\n}\n\nfunc (d *DdevDetector) Install(config *Config) error {\n\td.buildSteps(config)\n\n\tsteps := [][]string{\n\t\t{\n\t\t\t\"ddev\", \"config\",\n\t\t\t\"--project-name=\" + config.ProjectName,\n\t\t\t\"--docroot=pub\",\n\t\t\t\"--project-type=magento2\",\n\t\t\t\"--database=mysql:8.0\",\n\t\t\t\"--composer-version=2.2\",\n\t\t},\n\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-opensearch\"},\n\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-redis\"},\n\t\t{\"ddev\", \"add-on\", \"get\", \"ddev/ddev-cron\"},\n\t\t{\"ddev\", \"add-on\", \"get\", \"b13/ddev-rabbitmq\"},\n\t\t{\"ddev\", \"start\"},\n\t\t{\"ddev\", \"rabbitmq\", \"apply\"},\n\t\t{\n\t\t\t\"ddev\", \"exec\", \"composer\", \"create-project\",\n\t\t\t\"--repository-url=https://repo.mage-os.org/\",\n\t\t\t\"mage-os/project-community-edition\",\n\t\t\t\"/tmp/mage-os-project\",\n\t\t},\n\t\t{\n\t\t\t\"ddev\", \"exec\", \"bash\", \"-c\",\n\t\t\t\"cp -a /tmp/mage-os-project/. /var/www/html/\",\n\t\t},\n\t\t{\"ddev\", \"exec\", \"mkdir\", \"-p\", \"/var/www/html/var/composer_home/\"},\n\t}\n\n\tfor i, args := range steps {\n\t\tif i < config.StartFromStep {\n\t\t\tcontinue\n\t\t}\n\t\tstepStart(config, i)\n\t\tlogf(config, \"▸ %s\", strings.Join(args, \" \"))\n\t\tif err := runInDir(config.Directory, config.Log, args[0], args[1:]...); err != nil {\n\t\t\treturn fmt.Errorf(\"step %q failed: %w\", strings.Join(args, \" \"), err)\n\t\t}\n\t\tstepDone(config, i)\n\t}\n\n\t// After ddev start, query the actual primary URL so we use\n\t// the correct domain (e.g. .ddev.site) for Magento's base-url.\n\tif url, err := ddevPrimaryURL(config.Directory); err == nil {\n\t\td.primaryURL = url\n\t\tlogf(config, \"▸ Detected primary URL: %s\", url)\n\t}\n\n\tauthIdx := len(steps)\n\tif authIdx >= config.StartFromStep {\n\t\tstepStart(config, authIdx)\n\t\tif err := copyAuthJSON(config); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstepDone(config, authIdx)\n\t}\n\n\tmagentoIdx := len(steps) + 1\n\tif magentoIdx >= config.StartFromStep {\n\t\tstepStart(config, magentoIdx)\n\t\tlogf(config, \"▸ ddev exec bin/magento setup:install\")\n\t\tsetupArgs := []string{\"exec\", \"bin/magento\", \"setup:install\"}\n\t\tfor _, f := range d.SetupInstallFlags(config) {\n\t\t\tsetupArgs = append(setupArgs, f.Flag+\"=\"+f.Value)\n\t\t}\n\t\tif err := runInDir(config.Directory, config.Log, \"ddev\", setupArgs...); err != nil {\n\t\t\treturn fmt.Errorf(\"setup:install failed: %w\", err)\n\t\t}\n\t\tstepDone(config, magentoIdx)\n\t}\n\n\tnextIdx := magentoIdx + 1\n\n\tif config.InstallSampleData {\n\t\tsampleDataIdx := nextIdx\n\t\tif sampleDataIdx >= config.StartFromStep {\n\t\t\tstepStart(config, sampleDataIdx)\n\t\t\tlogf(config, \"▸ Deploying sample data\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"sampledata:deploy\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"sampledata:deploy failed: %w\", err)\n\t\t\t}\n\t\t\t// If no Hyvä, run setup:upgrade + cache:flush now.\n\t\t\t// If Hyvä is also enabled, setup:upgrade runs in the Hyvä enable step.\n\t\t\tif !config.InstallHyva {\n\t\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n\t\t\t\t}\n\t\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t\tstepDone(config, sampleDataIdx)\n\t\t}\n\t\tnextIdx++\n\t}\n\n\tif config.InstallHyva {\n\t\thyvaRepoIdx := nextIdx\n\t\tif hyvaRepoIdx >= config.StartFromStep {\n\t\t\tstepStart(config, hyvaRepoIdx)\n\t\t\tlogf(config, \"▸ Configuring Hyvä Private Packagist repository\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"repositories.private-packagist\",\n\t\t\t\t\"composer\", config.HyvaRepoURL); err != nil {\n\t\t\t\treturn fmt.Errorf(\"configure Hyvä repository failed: %w\", err)\n\t\t\t}\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"composer\", \"config\", \"--auth\",\n\t\t\t\t\"http-basic.\"+extractHost(config.HyvaRepoURL),\n\t\t\t\t\"token\", config.HyvaAuthToken); err != nil {\n\t\t\t\treturn fmt.Errorf(\"configure Hyvä auth failed: %w\", err)\n\t\t\t}\n\t\t\tstepDone(config, hyvaRepoIdx)\n\t\t}\n\t\tnextIdx++\n\n\t\thyvaInstallIdx := nextIdx\n\t\tif hyvaInstallIdx >= config.StartFromStep {\n\t\t\tstepStart(config, hyvaInstallIdx)\n\t\t\tlogf(config, \"▸ Installing Hyvä theme\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"composer\", \"require\", \"hyva-themes/magento2-default-theme\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"install Hyvä theme failed: %w\", err)\n\t\t\t}\n\t\t\tstepDone(config, hyvaInstallIdx)\n\t\t}\n\t\tnextIdx++\n\n\t\thyvaEnableIdx := nextIdx\n\t\tif hyvaEnableIdx >= config.StartFromStep {\n\t\t\tstepStart(config, hyvaEnableIdx)\n\t\t\tlogf(config, \"▸ Enabling Hyvä modules and setting up theme\")\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"module:enable\", \"--all\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"enable Hyvä modules failed: %w\", err)\n\t\t\t}\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"setup:upgrade\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"setup:upgrade failed: %w\", err)\n\t\t\t}\n\t\t\t// Look up the Hyvä theme ID and set it as default\n\t\t\tlogf(config, \"▸ Setting Hyvä as default storefront theme\")\n\t\t\tthemeID, err := ddevQueryThemeID(config.Directory, \"Hyva/default\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"could not find Hyvä theme ID: %w\", err)\n\t\t\t}\n\t\t\tlogf(config, \"▸ Hyvä theme ID: %s\", themeID)\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"config:set\", \"design/theme/theme_id\", themeID); err != nil {\n\t\t\t\treturn fmt.Errorf(\"set Hyvä theme failed: %w\", err)\n\t\t\t}\n\t\t\tif err := runInDir(config.Directory, config.Log,\n\t\t\t\t\"ddev\", \"exec\", \"bin/magento\", \"cache:flush\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"cache:flush failed: %w\", err)\n\t\t\t}\n\t\t\tstepDone(config, hyvaEnableIdx)\n\t\t}\n\t}\n\n\t// verifyInstallation is always the last step regardless of optional steps.\n\tverifyIdx := len(d.steps) - 1\n\tif verifyIdx >= config.StartFromStep {\n\t\tstepStart(config, verifyIdx)\n\t\tbaseURL := d.BaseURL(config.ProjectName)\n\t\tlogf(config, \"▸ Verifying store at %s\", baseURL)\n\t\tif err := verifyInstallation(baseURL, config.Log); err != nil {\n\t\t\treturn fmt.Errorf(\"installation verification failed: %w\", err)\n\t\t}\n\t\tstepDone(config, verifyIdx)\n\t}\n\n\treturn nil\n}\n\n// verifyInstallation makes an HTTP GET request to baseURL and checks that the\n// response returns HTTP 200 and includes the \"x-dist: Mage-OS\" header.\n// DDEV uses self-signed TLS certificates, so TLS verification is skipped.\nfunc verifyInstallation(baseURL string, logFn func(string)) error {\n\tclient := &http.Client{\n\t\tTimeout: 30 * time.Second,\n\t\tTransport: &http.Transport{\n\t\t\tTLSClientConfig: &tls.Config{InsecureSkipVerify: true}, //nolint:gosec\n\t\t},\n\t}\n\n\tresp, err := client.Get(baseURL) //nolint:noctx\n\tif err != nil {\n\t\treturn fmt.Errorf(\"HTTP request to %s failed: %w\", baseURL, err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\treturn fmt.Errorf(\"expected HTTP 200 from %s, got %d\", baseURL, resp.StatusCode)\n\t}\n\n\tdist := resp.Header.Get(\"x-dist\")\n\tif !strings.Contains(dist, \"Mage-OS\") {\n\t\treturn fmt.Errorf(\"expected x-dist header to contain 'Mage-OS', got %q\", dist)\n\t}\n\n\tif logFn != nil {\n\t\tlogFn(fmt.Sprintf(\"▸ Verified: %s → HTTP 200, x-dist: %s\", baseURL, dist))\n\t}\n\treturn nil\n}\n\n// extractHost extracts the hostname from a URL string.\nfunc extractHost(rawURL string) string {\n\t// Strip protocol prefix\n\thost := rawURL\n\tif i := strings.Index(host, \"://\"); i >= 0 {\n\t\thost = host[i+3:]\n\t}\n\t// Strip path\n\tif i := strings.Index(host, \"/\"); i >= 0 {\n\t\thost = host[:i]\n\t}\n\treturn host\n}\n\n// logf sends a formatted message to config.Log if it is set.\nfunc logf(config *Config, format string, args ...any) {\n\tif config.Log != nil {\n\t\tconfig.Log(fmt.Sprintf(format, args...))\n\t}\n}\n\nfunc stepStart(config *Config, index int) {\n\tif config.OnStepStart != nil {\n\t\tconfig.OnStepStart(index)\n\t}\n}\n\nfunc stepDone(config *Config, index int) {\n\tif config.OnStepDone != nil {\n\t\tconfig.OnStepDone(index)\n\t}\n}\n\n// runInDir runs a command in dir, streaming each output line to logFn.\n// If logFn is nil the output is captured silently and included only in errors.\nfunc runInDir(dir string, logFn func(string), name string, args ...string) error {\n\tcmd := exec.Command(name, args...)\n\tcmd.Dir = dir\n\n\tif logFn == nil {\n\t\tout, err := cmd.CombinedOutput()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"%w\\n%s\", err, strings.TrimSpace(string(out)))\n\t\t}\n\t\treturn nil\n\t}\n\n\tpr, pw := io.Pipe()\n\tcmd.Stdout = pw\n\tcmd.Stderr = pw\n\n\tif err := cmd.Start(); err != nil {\n\t\tpr.Close()\n\t\tpw.Close()\n\t\treturn err\n\t}\n\n\tscanDone := make(chan struct{})\n\tgo func() {\n\t\tdefer close(scanDone)\n\t\tscanner := bufio.NewScanner(pr)\n\t\tfor scanner.Scan() {\n\t\t\tlogFn(scanner.Text())\n\t\t}\n\t}()\n\n\terr := cmd.Wait()\n\tpw.Close()\n\t<-scanDone\n\tpr.Close()\n\n\treturn err\n}\n\n// copyAuthJSON copies ~/.composer/auth.json into the running DDEV web container.\n// If the file does not exist it is silently skipped.\nfunc copyAuthJSON(config *Config) error {\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n\t}\n\n\tauthSrc := home + \"/.composer/auth.json\"\n\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n\t\treturn nil // nothing to copy\n\t}\n\n\tcontainerName, err := ddevWebContainerName(config.Directory)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not get DDEV web container name: %w\", err)\n\t}\n\n\tlogf(config, \"▸ docker cp auth.json → container\")\n\tauthDst := containerName + \":/var/www/html/var/composer_home/auth.json\"\n\treturn runInDir(config.Directory, config.Log, \"docker\", \"cp\", authSrc, authDst)\n}\n\n// ddevDescribeOutput is the relevant subset of `ddev describe --json-output`.\ntype ddevDescribeOutput struct {\n\tRaw struct {\n\t\tPrimaryURL string `json:\"primary_url\"`\n\t\tServices   map[string]struct {\n\t\t\tFullName string `json:\"full_name\"`\n\t\t} `json:\"services\"`\n\t} `json:\"raw\"`\n}\n\n// ddevWebContainerName returns the full Docker container name for the web service.\nfunc ddevWebContainerName(dir string) (string, error) {\n\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n\t}\n\n\tvar desc ddevDescribeOutput\n\tif err := json.Unmarshal(out, &desc); err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n\t}\n\n\tweb, ok := desc.Raw.Services[\"web\"]\n\tif !ok || web.FullName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"web service not found in ddev describe output\")\n\t}\n\n\treturn web.FullName, nil\n}\n\n// ddevPrimaryURL returns the primary URL of the running ddev project.\nfunc ddevPrimaryURL(dir string) (string, error) {\n\tcmd := exec.Command(\"ddev\", \"describe\", \"--json-output\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"ddev describe failed: %w\", err)\n\t}\n\n\tvar desc ddevDescribeOutput\n\tif err := json.Unmarshal(out, &desc); err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not parse ddev describe output: %w\", err)\n\t}\n\n\tif desc.Raw.PrimaryURL == \"\" {\n\t\treturn \"\", fmt.Errorf(\"primary_url not found in ddev describe output\")\n\t}\n\n\treturn desc.Raw.PrimaryURL, nil\n}\n\n// ddevQueryThemeID queries the database via ddev mysql for the given theme path\n// and returns its numeric ID as a string.\nfunc ddevQueryThemeID(dir, themePath string) (string, error) {\n\tcmd := exec.Command(\"ddev\", \"mysql\", \"-N\", \"-e\",\n\t\tfmt.Sprintf(\"SELECT theme_id FROM theme WHERE theme_path='%s'\", themePath))\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"ddev mysql query failed: %w\", err)\n\t}\n\tid := strings.TrimSpace(string(out))\n\tif id == \"\" {\n\t\treturn \"\", fmt.Errorf(\"theme %q not found in database\", themePath)\n\t}\n\treturn id, nil\n}\n\nfunc (d *DdevDetector) Detect() (*Environment, error) {\n\tpath, err := exec.LookPath(\"ddev\")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tversion := \"unknown\"\n\tout, err := exec.Command(\"ddev\", \"version\", \"-j\").Output()\n\tif err == nil {\n\t\tversion = parseVersion(string(out), \"ddev\")\n\t}\n\tif version == \"unknown\" {\n\t\tout, err = exec.Command(\"ddev\", \"version\").Output()\n\t\tif err == nil {\n\t\t\tversion = parseDdevVersionPlain(string(out))\n\t\t}\n\t}\n\n\treturn &Environment{\n\t\tName:    \"DDEV\",\n\t\tVersion: version,\n\t\tCommand: path,\n\t}, nil\n}\n\nfunc parseDdevVersionPlain(output string) string {\n\tfor _, line := range strings.Split(output, \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif strings.HasPrefix(line, \"DDEV version\") || strings.HasPrefix(line, \"ddev version\") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tif len(parts) >= 3 {\n\t\t\t\treturn strings.TrimRight(parts[len(parts)-1], \",\")\n\t\t\t}\n\t\t}\n\t\tif strings.HasPrefix(line, \"version:\") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tif len(parts) >= 2 {\n\t\t\t\treturn parts[1]\n\t\t\t}\n\t\t}\n\t}\n\treturn \"unknown\"\n}\n","numLines":543,"startLine":1,"totalLines":543}}}
