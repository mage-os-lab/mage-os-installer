{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01THHq6adPTTT1CqoonhwANq","type":"tool_result","content":"350\t\t\tt.Error(\"should not advance to phaseSetupPreview when validation fails\")\n351\t\t}\n352\t}\n353\t\n354\t// --- sample data toggle (US-004) ---\n355\t\n356\t// TestSampleData_DefaultIsOff verifies that the sample data toggle is off by default.\n357\tfunc TestSampleData_DefaultIsOff(t *testing.T) {\n358\t\tm := advanceToSetupConfig(t)\n359\t\tif m.installSampleData {\n360\t\t\tt.Error(\"installSampleData should be false by default\")\n361\t\t}\n362\t}\n363\t\n364\t// TestSampleData_ToggledBySpace verifies that pressing space on the sample data\n365\t// toggle switches it on, and pressing space again switches it off.\n366\tfunc TestSampleData_ToggledBySpace(t *testing.T) {\n367\t\tm := advanceToSetupConfig(t)\n368\t\n369\t\t// Tab through all admin fields to reach the sample data toggle\n370\t\tfor i := 0; i < len(setupFieldDefs); i++ {\n371\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n372\t\t}\n373\t\t// Now at sample data toggle (absPos == len(setupInputs))\n374\t\tif !m.inTogglePhase || m.toggleFocus != -2 {\n375\t\t\tt.Fatalf(\"expected focus on sample data toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n376\t\t}\n377\t\n378\t\t// Press space: should enable sample data\n379\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n380\t\tif !m.installSampleData {\n381\t\t\tt.Error(\"space should enable installSampleData\")\n382\t\t}\n383\t\n384\t\t// Press space again: should disable sample data\n385\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n386\t\tif m.installSampleData {\n387\t\t\tt.Error(\"second space should disable installSampleData\")\n388\t\t}\n389\t}\n390\t\n391\t// TestSampleData_ViewContainsToggle verifies the setup form renders the sample data toggle.\n392\tfunc TestSampleData_ViewContainsToggle(t *testing.T) {\n393\t\tm := advanceToSetupConfig(t)\n394\t\tview := m.View()\n395\t\tif !contains(view, \"Install sample data\") {\n396\t\t\tt.Error(\"setup config view should contain 'Install sample data' toggle\")\n397\t\t}\n398\t}\n399\t\n400\t// TestSampleData_ViewShowsChecked verifies the toggle renders as [x] when enabled.\n401\tfunc TestSampleData_ViewShowsChecked(t *testing.T) {\n402\t\tm := advanceToSetupConfig(t)\n403\t\tm.installSampleData = true\n404\t\tview := m.View()\n405\t\tif !contains(view, \"[x]\") {\n406\t\t\tt.Error(\"view should show [x] when installSampleData is true\")\n407\t\t}\n408\t}\n409\t\n410\t// --- Hyvä theme toggle (US-005) ---\n411\t\n412\t// navigateToHyvaToggle tabs through all admin fields and the sample data toggle\n413\t// to land on the Hyvä toggle.\n414\tfunc navigateToHyvaToggle(m Model) Model {\n415\t\t// len(setupFieldDefs) tabs → sample data toggle; one more → Hyvä toggle\n416\t\tfor i := 0; i < len(setupFieldDefs)+1; i++ {\n417\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n418\t\t}\n419\t\treturn m\n420\t}\n421\t\n422\t// TestHyva_DefaultIsOff verifies that the Hyvä toggle is off by default.\n423\tfunc TestHyva_DefaultIsOff(t *testing.T) {\n424\t\tm := advanceToSetupConfig(t)\n425\t\tif m.installHyva {\n426\t\t\tt.Error(\"installHyva should be false by default\")\n427\t\t}\n428\t}\n429\t\n430\t// TestHyva_ToggledBySpace verifies that pressing space on the Hyvä toggle\n431\t// enables it, and pressing space again disables it.\n432\tfunc TestHyva_ToggledBySpace(t *testing.T) {\n433\t\tm := advanceToSetupConfig(t)\n434\t\tm = navigateToHyvaToggle(m)\n435\t\n436\t\tif !m.inTogglePhase || m.toggleFocus != -1 {\n437\t\t\tt.Fatalf(\"expected focus on Hyvä toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n438\t\t}\n439\t\n440\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n441\t\tif !m.installHyva {\n442\t\t\tt.Error(\"space should enable installHyva\")\n443\t\t}\n444\t\n445\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n446\t\tif m.installHyva {\n447\t\t\tt.Error(\"second space should disable installHyva\")\n448\t\t}\n449\t}\n450\t\n451\t// TestHyva_ViewContainsToggle verifies the setup form renders the Hyvä toggle.\n452\tfunc TestHyva_ViewContainsToggle(t *testing.T) {\n453\t\tm := advanceToSetupConfig(t)\n454\t\tview := m.View()\n455\t\tif !contains(view, \"Install Hyv\") {\n456\t\t\tt.Error(\"setup config view should contain 'Install Hyvä' toggle label\")\n457\t\t}\n458\t}\n459\t\n460\t// TestHyva_ViewShowsChecked verifies the toggle renders as [x] when Hyvä is enabled.\n461\tfunc TestHyva_ViewShowsChecked(t *testing.T) {\n462\t\tm := advanceToSetupConfig(t)\n463\t\tm.installHyva = true\n464\t\tview := m.View()\n465\t\tif !contains(view, \"[x]\") {\n466\t\t\tt.Error(\"view should show [x] when installHyva is true\")\n467\t\t}\n468\t}\n469\t\n470\t// TestHyva_CredentialFieldsHiddenByDefault verifies that Hyvä repo/token fields\n471\t// are not shown when the toggle is off (AC2).\n472\tfunc TestHyva_CredentialFieldsHiddenByDefault(t *testing.T) {\n473\t\tm := advanceToSetupConfig(t)\n474\t\tview := m.View()\n475\t\tif contains(view, \"Repo URL\") {\n476\t\t\tt.Error(\"'Repo URL' field should not appear when installHyva is false\")\n477\t\t}\n478\t\tif contains(view, \"Auth token\") {\n479\t\t\tt.Error(\"'Auth token' field should not appear when installHyva is false\")\n480\t\t}\n481\t}\n482\t\n483\t// TestHyva_CredentialFieldsAppearsWhenEnabled verifies that enabling the toggle\n484\t// shows the Hyvä repo URL and auth token fields (AC2).\n485\tfunc TestHyva_CredentialFieldsAppearsWhenEnabled(t *testing.T) {\n486\t\tm := advanceToSetupConfig(t)\n487\t\tm.installHyva = true\n488\t\tview := m.View()\n489\t\tif !contains(view, \"Repo URL\") {\n490\t\t\tt.Error(\"'Repo URL' field should appear when installHyva is true\")\n491\t\t}\n492\t\tif !contains(view, \"Auth token\") {\n493\t\t\tt.Error(\"'Auth token' field should appear when installHyva is true\")\n494\t\t}\n495\t}\n496\t\n497\t// --- setup:install command preview (US-006) ---\n498\t\n499\t// advanceToSetupPreview drives the model through name → dir → setup config → preview.\n500\tfunc advanceToSetupPreview(t *testing.T) Model {\n501\t\tt.Helper()\n502\t\tm := advanceToSetupConfig(t)\n503\t\t// Navigate to the last field (Hyvä toggle) and press Enter to submit the form.\n504\t\ttotalFields := len(m.setupInputs) + 2 // +2 for sample data + hyvä toggles\n505\t\tfor i := 0; i < totalFields-1; i++ {\n506\t\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n507\t\t}\n508\t\tm = pressEnter(m) // submit form → phaseSetupPreview\n509\t\tif m.phase != phaseSetupPreview {\n510\t\t\tt.Fatalf(\"expected phaseSetupPreview, got %d\", m.phase)\n511\t\t}\n512\t\treturn m\n513\t}\n514\t\n515\t// TestPreview_ShowsSetupInstallCommand verifies the preview screen renders the\n516\t// bin/magento setup:install command prefix.\n517\tfunc TestPreview_ShowsSetupInstallCommand(t *testing.T) {\n518\t\tm := advanceToSetupPreview(t)\n519\t\tview := m.View()\n520\t\tif !contains(view, \"setup:install\") {\n521\t\t\tt.Error(\"preview view should contain 'setup:install'\")\n522\t\t}\n523\t}\n524\t\n525\t// TestPreview_ShowsAllFlags verifies that all flags returned by SetupInstallFlags\n526\t// appear in the preview view.\n527\tfunc TestPreview_ShowsAllFlags(t *testing.T) {\n528\t\tm := advanceToSetupPreview(t)\n529\t\tview := m.View()\n530\t\tfor _, flag := range m.selected.Detector.SetupInstallFlags(&m.installCfg) {\n531\t\t\tif !contains(view, flag.Flag) {\n532\t\t\t\tt.Errorf(\"preview view should contain flag %q\", flag.Flag)\n533\t\t\t}\n534\t\t}\n535\t}\n536\t\n537\t// TestPreview_EditableValuesAppear verifies that editable (user-supplied) values\n538\t// appear in the preview view.\n539\tfunc TestPreview_EditableValuesAppear(t *testing.T) {\n540\t\tm := advanceToSetupPreview(t)\n541\t\tview := m.View()\n542\t\t// The admin user default is \"admin\"; it should appear as an editable value.\n543\t\tif !contains(view, m.installCfg.AdminUser) {\n544\t\t\tt.Errorf(\"preview view should show editable admin user value %q\", m.installCfg.AdminUser)\n545\t\t}\n546\t}\n547\t\n548\t// TestPreview_ScrollsWithArrowKeys verifies that up/down arrow keys change previewScroll.\n549\tfunc TestPreview_ScrollsWithArrowKeys(t *testing.T) {\n550\t\tm := advanceToSetupPreview(t)\n551\t\t// Set window height so there is room to scroll.\n552\t\tm.windowHeight = 5\n553\t\n554\t\tinitial := m.previewScroll\n555\t\n556\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n557\t\tif m.previewScroll == initial {\n558\t\t\t// It's possible all lines fit in the window; just verify no panic occurred.\n559\t\t\t// Skip if the command has fewer lines than the window.\n560\t\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n561\t\t\tmaxVisible := m.windowHeight - 10\n562\t\t\tif maxVisible < 3 {\n563\t\t\t\tmaxVisible = 3\n564\t\t\t}\n565\t\t\tif totalLines <= maxVisible {\n566\t\t\t\tt.Skip(\"not enough lines to scroll; skipping\")\n567\t\t\t}\n568\t\t\tt.Errorf(\"down arrow should increase previewScroll (was %d, still %d)\", initial, m.previewScroll)\n569\t\t}\n570\t\n571\t\t// Scroll back up\n572\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n573\t\tif m.previewScroll != initial {\n574\t\t\tt.Errorf(\"up arrow should decrease previewScroll back to %d, got %d\", initial, m.previewScroll)\n575\t\t}\n576\t}\n577\t\n578\t// TestPreview_UpArrowDoesNotGoNegative verifies that previewScroll stays >= 0.\n579\tfunc TestPreview_UpArrowDoesNotGoNegative(t *testing.T) {\n580\t\tm := advanceToSetupPreview(t)\n581\t\tm.previewScroll = 0\n582\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n583\t\tif m.previewScroll < 0 {\n584\t\t\tt.Errorf(\"previewScroll should not go negative, got %d\", m.previewScroll)\n585\t\t}\n586\t}\n587\t\n588\t// TestPreview_BackspaceGoesBackToSetupConfig verifies that pressing Backspace\n589\t// returns to the admin credentials form.\n590\tfunc TestPreview_BackspaceGoesBackToSetupConfig(t *testing.T) {\n591\t\tm := advanceToSetupPreview(t)\n592\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyBackspace})\n593\t\tif m.phase != phaseSetupConfig {\n594\t\t\tt.Errorf(\"Backspace should return to phaseSetupConfig, got %d\", m.phase)\n595\t\t}\n596\t}\n597\t\n598\t// TestPreview_EnterThenSudoCachedAdvancesToInstall verifies that pressing Enter on\n599\t// the preview screen and receiving the sudoCachedMsg transitions to phaseInstalling."}]},"parent_tool_use_id":null,"session_id":"287018b2-4458-456c-84c8-20bcb7a8b9ab","uuid":"37f10ca8-3fb0-41d8-8f2d-5f849a8eb069","timestamp":"2026-04-14T19:37:27.490Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/tui/tui_test.go","content":"\t\tt.Error(\"should not advance to phaseSetupPreview when validation fails\")\n\t}\n}\n\n// --- sample data toggle (US-004) ---\n\n// TestSampleData_DefaultIsOff verifies that the sample data toggle is off by default.\nfunc TestSampleData_DefaultIsOff(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tif m.installSampleData {\n\t\tt.Error(\"installSampleData should be false by default\")\n\t}\n}\n\n// TestSampleData_ToggledBySpace verifies that pressing space on the sample data\n// toggle switches it on, and pressing space again switches it off.\nfunc TestSampleData_ToggledBySpace(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\n\t// Tab through all admin fields to reach the sample data toggle\n\tfor i := 0; i < len(setupFieldDefs); i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\t// Now at sample data toggle (absPos == len(setupInputs))\n\tif !m.inTogglePhase || m.toggleFocus != -2 {\n\t\tt.Fatalf(\"expected focus on sample data toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n\t}\n\n\t// Press space: should enable sample data\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif !m.installSampleData {\n\t\tt.Error(\"space should enable installSampleData\")\n\t}\n\n\t// Press space again: should disable sample data\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif m.installSampleData {\n\t\tt.Error(\"second space should disable installSampleData\")\n\t}\n}\n\n// TestSampleData_ViewContainsToggle verifies the setup form renders the sample data toggle.\nfunc TestSampleData_ViewContainsToggle(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif !contains(view, \"Install sample data\") {\n\t\tt.Error(\"setup config view should contain 'Install sample data' toggle\")\n\t}\n}\n\n// TestSampleData_ViewShowsChecked verifies the toggle renders as [x] when enabled.\nfunc TestSampleData_ViewShowsChecked(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installSampleData = true\n\tview := m.View()\n\tif !contains(view, \"[x]\") {\n\t\tt.Error(\"view should show [x] when installSampleData is true\")\n\t}\n}\n\n// --- Hyvä theme toggle (US-005) ---\n\n// navigateToHyvaToggle tabs through all admin fields and the sample data toggle\n// to land on the Hyvä toggle.\nfunc navigateToHyvaToggle(m Model) Model {\n\t// len(setupFieldDefs) tabs → sample data toggle; one more → Hyvä toggle\n\tfor i := 0; i < len(setupFieldDefs)+1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\treturn m\n}\n\n// TestHyva_DefaultIsOff verifies that the Hyvä toggle is off by default.\nfunc TestHyva_DefaultIsOff(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tif m.installHyva {\n\t\tt.Error(\"installHyva should be false by default\")\n\t}\n}\n\n// TestHyva_ToggledBySpace verifies that pressing space on the Hyvä toggle\n// enables it, and pressing space again disables it.\nfunc TestHyva_ToggledBySpace(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm = navigateToHyvaToggle(m)\n\n\tif !m.inTogglePhase || m.toggleFocus != -1 {\n\t\tt.Fatalf(\"expected focus on Hyvä toggle; inTogglePhase=%v toggleFocus=%d\", m.inTogglePhase, m.toggleFocus)\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif !m.installHyva {\n\t\tt.Error(\"space should enable installHyva\")\n\t}\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune{' '}})\n\tif m.installHyva {\n\t\tt.Error(\"second space should disable installHyva\")\n\t}\n}\n\n// TestHyva_ViewContainsToggle verifies the setup form renders the Hyvä toggle.\nfunc TestHyva_ViewContainsToggle(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif !contains(view, \"Install Hyv\") {\n\t\tt.Error(\"setup config view should contain 'Install Hyvä' toggle label\")\n\t}\n}\n\n// TestHyva_ViewShowsChecked verifies the toggle renders as [x] when Hyvä is enabled.\nfunc TestHyva_ViewShowsChecked(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installHyva = true\n\tview := m.View()\n\tif !contains(view, \"[x]\") {\n\t\tt.Error(\"view should show [x] when installHyva is true\")\n\t}\n}\n\n// TestHyva_CredentialFieldsHiddenByDefault verifies that Hyvä repo/token fields\n// are not shown when the toggle is off (AC2).\nfunc TestHyva_CredentialFieldsHiddenByDefault(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tview := m.View()\n\tif contains(view, \"Repo URL\") {\n\t\tt.Error(\"'Repo URL' field should not appear when installHyva is false\")\n\t}\n\tif contains(view, \"Auth token\") {\n\t\tt.Error(\"'Auth token' field should not appear when installHyva is false\")\n\t}\n}\n\n// TestHyva_CredentialFieldsAppearsWhenEnabled verifies that enabling the toggle\n// shows the Hyvä repo URL and auth token fields (AC2).\nfunc TestHyva_CredentialFieldsAppearsWhenEnabled(t *testing.T) {\n\tm := advanceToSetupConfig(t)\n\tm.installHyva = true\n\tview := m.View()\n\tif !contains(view, \"Repo URL\") {\n\t\tt.Error(\"'Repo URL' field should appear when installHyva is true\")\n\t}\n\tif !contains(view, \"Auth token\") {\n\t\tt.Error(\"'Auth token' field should appear when installHyva is true\")\n\t}\n}\n\n// --- setup:install command preview (US-006) ---\n\n// advanceToSetupPreview drives the model through name → dir → setup config → preview.\nfunc advanceToSetupPreview(t *testing.T) Model {\n\tt.Helper()\n\tm := advanceToSetupConfig(t)\n\t// Navigate to the last field (Hyvä toggle) and press Enter to submit the form.\n\ttotalFields := len(m.setupInputs) + 2 // +2 for sample data + hyvä toggles\n\tfor i := 0; i < totalFields-1; i++ {\n\t\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyTab})\n\t}\n\tm = pressEnter(m) // submit form → phaseSetupPreview\n\tif m.phase != phaseSetupPreview {\n\t\tt.Fatalf(\"expected phaseSetupPreview, got %d\", m.phase)\n\t}\n\treturn m\n}\n\n// TestPreview_ShowsSetupInstallCommand verifies the preview screen renders the\n// bin/magento setup:install command prefix.\nfunc TestPreview_ShowsSetupInstallCommand(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tview := m.View()\n\tif !contains(view, \"setup:install\") {\n\t\tt.Error(\"preview view should contain 'setup:install'\")\n\t}\n}\n\n// TestPreview_ShowsAllFlags verifies that all flags returned by SetupInstallFlags\n// appear in the preview view.\nfunc TestPreview_ShowsAllFlags(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tview := m.View()\n\tfor _, flag := range m.selected.Detector.SetupInstallFlags(&m.installCfg) {\n\t\tif !contains(view, flag.Flag) {\n\t\t\tt.Errorf(\"preview view should contain flag %q\", flag.Flag)\n\t\t}\n\t}\n}\n\n// TestPreview_EditableValuesAppear verifies that editable (user-supplied) values\n// appear in the preview view.\nfunc TestPreview_EditableValuesAppear(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tview := m.View()\n\t// The admin user default is \"admin\"; it should appear as an editable value.\n\tif !contains(view, m.installCfg.AdminUser) {\n\t\tt.Errorf(\"preview view should show editable admin user value %q\", m.installCfg.AdminUser)\n\t}\n}\n\n// TestPreview_ScrollsWithArrowKeys verifies that up/down arrow keys change previewScroll.\nfunc TestPreview_ScrollsWithArrowKeys(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\t// Set window height so there is room to scroll.\n\tm.windowHeight = 5\n\n\tinitial := m.previewScroll\n\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyDown})\n\tif m.previewScroll == initial {\n\t\t// It's possible all lines fit in the window; just verify no panic occurred.\n\t\t// Skip if the command has fewer lines than the window.\n\t\ttotalLines := 1 + len(m.selected.Detector.SetupInstallFlags(&m.installCfg))\n\t\tmaxVisible := m.windowHeight - 10\n\t\tif maxVisible < 3 {\n\t\t\tmaxVisible = 3\n\t\t}\n\t\tif totalLines <= maxVisible {\n\t\t\tt.Skip(\"not enough lines to scroll; skipping\")\n\t\t}\n\t\tt.Errorf(\"down arrow should increase previewScroll (was %d, still %d)\", initial, m.previewScroll)\n\t}\n\n\t// Scroll back up\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.previewScroll != initial {\n\t\tt.Errorf(\"up arrow should decrease previewScroll back to %d, got %d\", initial, m.previewScroll)\n\t}\n}\n\n// TestPreview_UpArrowDoesNotGoNegative verifies that previewScroll stays >= 0.\nfunc TestPreview_UpArrowDoesNotGoNegative(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tm.previewScroll = 0\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyUp})\n\tif m.previewScroll < 0 {\n\t\tt.Errorf(\"previewScroll should not go negative, got %d\", m.previewScroll)\n\t}\n}\n\n// TestPreview_BackspaceGoesBackToSetupConfig verifies that pressing Backspace\n// returns to the admin credentials form.\nfunc TestPreview_BackspaceGoesBackToSetupConfig(t *testing.T) {\n\tm := advanceToSetupPreview(t)\n\tm = sendMsg(m, tea.KeyMsg{Type: tea.KeyBackspace})\n\tif m.phase != phaseSetupConfig {\n\t\tt.Errorf(\"Backspace should return to phaseSetupConfig, got %d\", m.phase)\n\t}\n}\n\n// TestPreview_EnterThenSudoCachedAdvancesToInstall verifies that pressing Enter on\n// the preview screen and receiving the sudoCachedMsg transitions to phaseInstalling.","numLines":250,"startLine":350,"totalLines":845}}}
