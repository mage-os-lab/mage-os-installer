{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RZRxABpMsUWWRNwRxiPoU9","type":"tool_result","content":"1\tname: Build, Test and Release\n2\t\n3\ton:\n4\t  push:\n5\t  pull_request:\n6\t  workflow_dispatch:\n7\t\n8\tpermissions:\n9\t  contents: write\n10\t\n11\tjobs:\n12\t  go-test:\n13\t    runs-on: ubuntu-latest\n14\t\n15\t    steps:\n16\t      - uses: actions/checkout@v4\n17\t\n18\t      - name: Set up Go\n19\t        uses: actions/setup-go@v5\n20\t        with:\n21\t          go-version: '1.24'\n22\t\n23\t      - name: Test\n24\t        run: go test -v ./...\n25\t\n26\t  ddev-test:\n27\t    runs-on: ubuntu-latest\n28\t    timeout-minutes: 60\n29\t\n30\t    strategy:\n31\t      fail-fast: false\n32\t      matrix:\n33\t        include:\n34\t          - name: regular\n35\t            sample_data: \"false\"\n36\t            hyva: \"false\"\n37\t          - name: sampledata\n38\t            sample_data: \"true\"\n39\t            hyva: \"false\"\n40\t          - name: hyva\n41\t            sample_data: \"false\"\n42\t            hyva: \"true\"\n43\t          - name: hyva-sampledata\n44\t            sample_data: \"true\"\n45\t            hyva: \"true\"\n46\t\n47\t    name: ddev-test (${{ matrix.name }})\n48\t\n49\t    steps:\n50\t      # Skip Hyvä variants when secrets are not available\n51\t      - name: Check if this variant should run\n52\t        id: should-run\n53\t        run: |\n54\t          if [[ \"${{ matrix.hyva }}\" == \"true\" && -z \"${{ secrets.HYVA_REPO_URL }}\" ]]; then\n55\t            echo \"skip=true\" >> \"$GITHUB_OUTPUT\"\n56\t            echo \"Skipping Hyvä variant because HYVA_REPO_URL is not configured\"\n57\t          fi\n58\t\n59\t      - uses: actions/checkout@v4\n60\t        if: steps.should-run.outputs.skip != 'true'\n61\t\n62\t      - name: Set up Go\n63\t        if: steps.should-run.outputs.skip != 'true'\n64\t        uses: actions/setup-go@v5\n65\t        with:\n66\t          go-version: '1.24'\n67\t\n68\t      - name: Build binary\n69\t        if: steps.should-run.outputs.skip != 'true'\n70\t        run: go build -o mage-os-install .\n71\t\n72\t      - name: Create .ddev/config.yaml\n73\t        if: steps.should-run.outputs.skip != 'true'\n74\t        run: |\n75\t          mkdir -p .ddev\n76\t          cat > .ddev/config.yaml << 'EOF'\n77\t          name: mage-os-install\n78\t          type: magento2\n79\t          docroot: pub\n80\t          EOF\n81\t\n82\t      - name: Setup DDEV\n83\t        if: steps.should-run.outputs.skip != 'true'\n84\t        uses: ddev/github-action-setup-ddev@v1\n85\t        with:\n86\t          autostart: false\n87\t\n88\t      - name: Run Mage-OS installer\n89\t        if: steps.should-run.outputs.skip != 'true'\n90\t        env:\n91\t          SAMPLE_DATA: ${{ matrix.sample_data }}\n92\t          HYVA: ${{ matrix.hyva }}\n93\t          HYVA_REPO_URL: ${{ secrets.HYVA_REPO_URL }}\n94\t          HYVA_AUTH_TOKEN: ${{ secrets.HYVA_AUTH_TOKEN }}\n95\t        run: |\n96\t          sudo apt-get install -y expect\n97\t          expect <<'EXPECT_EOF'\n98\t          set timeout 3600\n99\t          log_user 1\n100\t\n101\t          set sample_data $env(SAMPLE_DATA)\n102\t          set hyva $env(HYVA)\n103\t          set hyva_repo_url $env(HYVA_REPO_URL)\n104\t          set hyva_auth_token $env(HYVA_AUTH_TOKEN)\n105\t\n106\t          spawn ./mage-os-install\n107\t\n108\t          # Clear default and type a custom project name so a fresh directory is used\n109\t          expect \"Project name\"\n110\t          puts \">>> Entering project name...\"\n111\t          send \"\\025test-mageos\\r\"\n112\t\n113\t          # Accept default install directory (will be ./test-mageos)\n114\t          expect \"Install directory\"\n115\t          puts \">>> Accepting install directory...\"\n116\t          send \"\\r\"\n117\t\n118\t          # Setup config form - admin user is focused first (default: admin)\n119\t          expect \"Configure\"\n120\t          puts \">>> Filling in admin credentials...\"\n121\t          send \"\\r\"\n122\t\n123\t          # Admin password (empty by default)\n124\t          sleep 0.5\n125\t          send \"Admin123!\"\n126\t          send \"\\r\"\n127\t\n128\t          # Admin email (empty by default)\n129\t          sleep 0.5\n130\t          send \"admin@example.com\"\n131\t          send \"\\r\"\n132\t\n133\t          # Admin firstname (default: Admin)\n134\t          sleep 0.5\n135\t          send \"\\r\"\n136\t\n137\t          # Admin lastname (default: User) - moves to sample data toggle\n138\t          sleep 0.5\n139\t          send \"\\r\"\n140\t\n141\t          # Sample data toggle\n142\t          sleep 0.3\n143\t          if { $sample_data eq \"true\" } {\n144\t            puts \">>> Enabling sample data...\"\n145\t            send \" \"\n146\t          }\n147\t          send \"\\t\"\n148\t          sleep 0.3\n149\t\n150\t          # Hyvä toggle\n151\t          if { $hyva eq \"true\" } {\n152\t            puts \">>> Enabling Hyvä theme...\"\n153\t            send \" \"\n154\t            sleep 0.2\n155\t            send \"\\t\"\n156\t            sleep 0.2\n157\t            # Repo URL\n158\t            send \"$hyva_repo_url\"\n159\t            send \"\\t\"\n160\t            sleep 0.2\n161\t            # Auth token\n162\t            send \"$hyva_auth_token\"\n163\t          }\n164\t\n165\t          # Submit form\n166\t          sleep 0.3\n167\t          send \"\\r\"\n168\t\n169\t          # Setup preview - press enter to start install\n170\t          expect \"Review\"\n171\t          puts \">>> Starting installation...\"\n172\t          send \"\\r\"\n173\t\n174\t          # Wait for installation to complete\n175\t          expect {\n176\t            -timeout 3600\n177\t            \"installed successfully\" {\n178\t              puts \">>> Installation completed successfully!\"\n179\t              send \"n\"\n180\t            }\n181\t            \"Installation failed\" {\n182\t              puts \">>> Installation failed!\"\n183\t              exit 1\n184\t            }\n185\t          }\n186\t\n187\t          # Exit\n188\t          expect \"Press enter\"\n189\t          send \"\\r\"\n190\t\n191\t          expect eof\n192\t          EXPECT_EOF\n193\t\n194\t      - name: Run bin/magento to verify installation\n195\t        if: steps.should-run.outputs.skip != 'true'\n196\t        run: |\n197\t          sleep 5\n198\t          ddev php bin/magento\n199\t\n200\t      - name: Verify Mage-OS is running\n201\t        if: steps.should-run.outputs.skip != 'true'\n202\t        run: |\n203\t          HTTP_CODE=$(curl -sSk -L -D /tmp/curl-headers.txt -o /tmp/curl-body.txt -w \"%{http_code}\" https://test-mageos.ddev.site/)\n204\t          echo \"------- Response headers -------\"\n205\t          cat /tmp/curl-headers.txt\n206\t          echo \"------- Response body -------\"\n207\t          cat /tmp/curl-body.txt\n208\t          echo \"------- Checking HTTP status code -------\"\n209\t          echo \"HTTP status: $HTTP_CODE\"\n210\t          [ \"$HTTP_CODE\" = \"200\" ] || { echo \"Expected 200, got $HTTP_CODE\"; exit 1; }\n211\t          echo \"------- Checking x-dist header -------\"\n212\t          grep -qi \"^x-dist:.*Mage-OS\" /tmp/curl-headers.txt || { echo \"Expected x-dist: Mage-OS header not found\"; exit 1; }\n213\t\n214\t      - name: Verify sample data (if enabled)\n215\t        if: steps.should-run.outputs.skip != 'true' && matrix.sample_data == 'true'\n216\t        run: |\n217\t          PRODUCT_COUNT=$(ddev exec bin/magento catalog:product:count 2>/dev/null || ddev mysql -N -e \"SELECT COUNT(*) FROM catalog_product_entity\")\n218\t          echo \"Product count: $PRODUCT_COUNT\"\n219\t          [ \"$PRODUCT_COUNT\" -gt 0 ] || { echo \"Expected products from sample data, found none\"; exit 1; }\n220\t\n221\t      - name: Verify Hyvä theme (if enabled)\n222\t        if: steps.should-run.outputs.skip != 'true' && matrix.hyva == 'true'\n223\t        run: |\n224\t          THEME=$(ddev mysql -N -e \"SELECT value FROM core_config_data WHERE path='design/theme/theme_id'\")\n225\t          THEME_PATH=$(ddev mysql -N -e \"SELECT theme_path FROM theme WHERE theme_id=$THEME\")\n226\t          echo \"Active theme: $THEME_PATH\"\n227\t          [ \"$THEME_PATH\" = \"Hyva/default\" ] || { echo \"Expected Hyva/default theme, got $THEME_PATH\"; exit 1; }\n228\t\n229\t  warden-test:\n230\t    runs-on: ubuntu-latest\n231\t    timeout-minutes: 20\n232\t\n233\t    strategy:\n234\t      fail-fast: false\n235\t      matrix:\n236\t        include:\n237\t          - name: regular\n238\t            sample_data: \"false\"\n239\t            hyva: \"false\"\n240\t          - name: sampledata\n241\t            sample_data: \"true\"\n242\t            hyva: \"false\"\n243\t          - name: hyva\n244\t            sample_data: \"false\"\n245\t            hyva: \"true\"\n246\t          - name: hyva-sampledata\n247\t            sample_data: \"true\"\n248\t            hyva: \"true\"\n249\t\n250\t    name: warden-test (${{ matrix.name }})\n251\t\n252\t    steps:\n253\t      # Skip Hyvä variants when secrets are not available\n254\t      - name: Check if this variant should run\n255\t        id: should-run\n256\t        run: |\n257\t          if [[ \"${{ matrix.hyva }}\" == \"true\" && -z \"${{ secrets.HYVA_REPO_URL }}\" ]]; then\n258\t            echo \"skip=true\" >> \"$GITHUB_OUTPUT\"\n259\t            echo \"Skipping Hyvä variant because HYVA_REPO_URL is not configured\"\n260\t          fi\n261\t\n262\t      - uses: actions/checkout@v4\n263\t        if: steps.should-run.outputs.skip != 'true'\n264\t\n265\t      - name: Set up Go\n266\t        if: steps.should-run.outputs.skip != 'true'\n267\t        uses: actions/setup-go@v5\n268\t        with:\n269\t          go-version: '1.24'\n270\t\n271\t      - name: Build binary\n272\t        if: steps.should-run.outputs.skip != 'true'\n273\t        run: go build -o mage-os-install .\n274\t\n275\t      - name: Install Warden\n276\t        if: steps.should-run.outputs.skip != 'true'\n277\t        run: |\n278\t          sudo mkdir -p /opt/warden\n279\t          sudo chown $(whoami) /opt/warden\n280\t          git clone -b main https://github.com/wardenenv/warden.git /opt/warden\n281\t          echo \"/opt/warden/bin\" >> $GITHUB_PATH\n282\t\n283\t      - name: Initialize Warden\n284\t        if: steps.should-run.outputs.skip != 'true'\n285\t        run: |\n286\t          /opt/warden/bin/warden install\n287\t          /opt/warden/bin/warden svc up\n288\t\n289\t      - name: Add /etc/hosts entries\n290\t        if: steps.should-run.outputs.skip != 'true'\n291\t        run: |\n292\t          echo \"127.0.0.1 app.test-mageos.test\" | sudo tee -a /etc/hosts\n293\t          echo \"127.0.0.1 test-mageos.test\" | sudo tee -a /etc/hosts\n294\t\n295\t      - name: Run Mage-OS installer\n296\t        if: steps.should-run.outputs.skip != 'true'\n297\t        env:\n298\t          SAMPLE_DATA: ${{ matrix.sample_data }}\n299\t          HYVA: ${{ matrix.hyva }}\n300\t          HYVA_REPO_URL: ${{ secrets.HYVA_REPO_URL }}\n301\t          HYVA_AUTH_TOKEN: ${{ secrets.HYVA_AUTH_TOKEN }}\n302\t        run: |\n303\t          sudo apt-get install -y expect\n304\t          expect <<'EXPECT_EOF'\n305\t          set timeout 3600\n306\t          log_user 1\n307\t\n308\t          set sample_data $env(SAMPLE_DATA)\n309\t          set hyva $env(HYVA)\n310\t          set hyva_repo_url $env(HYVA_REPO_URL)\n311\t          set hyva_auth_token $env(HYVA_AUTH_TOKEN)\n312\t\n313\t          spawn ./mage-os-install\n314\t\n315\t          # Clear default and type a custom project name so a fresh directory is used\n316\t          expect \"Project name\"\n317\t          puts \">>> Entering project name...\"\n318\t          send \"\\025test-mageos\\r\"\n319\t\n320\t          # Accept default install directory (will be ./test-mageos)\n321\t          expect \"Install directory\"\n322\t          puts \">>> Accepting install directory...\"\n323\t          send \"\\r\"\n324\t\n325\t          # Setup config form - admin user is focused first (default: admin)\n326\t          expect \"Configure\"\n327\t          puts \">>> Filling in admin credentials...\"\n328\t          send \"\\r\"\n329\t\n330\t          # Admin password (empty by default)\n331\t          sleep 0.5\n332\t          send \"Admin123!\"\n333\t          send \"\\r\"\n334\t\n335\t          # Admin email (empty by default)\n336\t          sleep 0.5\n337\t          send \"admin@example.com\"\n338\t          send \"\\r\"\n339\t\n340\t          # Admin firstname (default: Admin)\n341\t          sleep 0.5\n342\t          send \"\\r\"\n343\t\n344\t          # Admin lastname (default: User) - moves to sample data toggle\n345\t          sleep 0.5\n346\t          send \"\\r\"\n347\t\n348\t          # Sample data toggle\n349\t          sleep 0.3\n350\t          if { $sample_data eq \"true\" } {\n351\t            puts \">>> Enabling sample data...\"\n352\t            send \" \"\n353\t          }\n354\t          send \"\\t\"\n355\t          sleep 0.3\n356\t\n357\t          # Hyvä toggle\n358\t          if { $hyva eq \"true\" } {\n359\t            puts \">>> Enabling Hyvä theme...\"\n360\t            send \" \"\n361\t            sleep 0.2\n362\t            send \"\\t\"\n363\t            sleep 0.2\n364\t            # Repo URL\n365\t            send \"$hyva_repo_url\"\n366\t            send \"\\t\"\n367\t            sleep 0.2\n368\t            # Auth token\n369\t            send \"$hyva_auth_token\"\n370\t          }\n371\t\n372\t          # Submit form\n373\t          sleep 0.3\n374\t          send \"\\r\"\n375\t\n376\t          # Setup preview - press enter to start install\n377\t          expect \"Review\"\n378\t          puts \">>> Starting installation...\"\n379\t          send \"\\r\"\n380\t\n381\t          # Wait for installation to complete\n382\t          expect {\n383\t            -timeout 3600\n384\t            \"installed successfully\" {\n385\t              puts \">>> Installation completed successfully!\"\n386\t              send \"n\"\n387\t            }\n388\t            \"Installation failed\" {\n389\t              puts \">>> Installation failed!\"\n390\t              exit 1\n391\t            }\n392\t          }\n393\t\n394\t          # Exit\n395\t          expect \"Press enter\"\n396\t          send \"\\r\"\n397\t\n398\t          expect eof\n399\t          EXPECT_EOF\n400\t\n401\t      - name: Run bin/magento to verify installation\n402\t        if: steps.should-run.outputs.skip != 'true'\n403\t        run: |\n404\t          sleep 5\n405\t          cd test-mageos\n406\t          /opt/warden/bin/warden env exec -T php-fpm bin/magento --version\n407\t\n408\t      - name: Verify Mage-OS is running\n409\t        if: steps.should-run.outputs.skip != 'true'\n410\t        run: |\n411\t          HTTP_CODE=$(curl -sSk -L -D /tmp/curl-headers.txt -o /tmp/curl-body.txt -w \"%{http_code}\" https://app.test-mageos.test/)\n412\t          echo \"------- Response headers -------\"\n413\t          cat /tmp/curl-headers.txt\n414\t          echo \"------- Response body -------\"\n415\t          cat /tmp/curl-body.txt\n416\t          echo \"------- Checking HTTP status code -------\"\n417\t          echo \"HTTP status: $HTTP_CODE\"\n418\t          [ \"$HTTP_CODE\" = \"200\" ] || { echo \"Expected 200, got $HTTP_CODE\"; exit 1; }\n419\t          echo \"------- Checking x-dist header -------\"\n420\t          grep -qi \"^x-dist:.*Mage-OS\" /tmp/curl-headers.txt || { echo \"Expected x-dist: Mage-OS header not found\"; exit 1; }\n421\t\n422\t      - name: Verify sample data (if enabled)\n423\t        if: steps.should-run.outputs.skip != 'true' && matrix.sample_data == 'true'\n424\t        run: |\n425\t          cd test-mageos\n426\t          PRODUCT_COUNT=$(/opt/warden/bin/warden env exec -T db mysql -u magento -pmagento magento -N -e \"SELECT COUNT(*) FROM catalog_product_entity\")\n427\t          echo \"Product count: $PRODUCT_COUNT\"\n428\t          [ \"$PRODUCT_COUNT\" -gt 0 ] || { echo \"Expected products from sample data, found none\"; exit 1; }\n429\t\n430\t      - name: Verify Hyvä theme (if enabled)\n431\t        if: steps.should-run.outputs.skip != 'true' && matrix.hyva == 'true'\n432\t        run: |\n433\t          cd test-mageos\n434\t          THEME=$(/opt/warden/bin/warden env exec -T db mysql -u magento -pmagento magento -N -e \"SELECT value FROM core_config_data WHERE path='design/theme/theme_id'\")\n435\t          THEME_PATH=$(/opt/warden/bin/warden env exec -T db mysql -u magento -pmagento magento -N -e \"SELECT theme_path FROM theme WHERE theme_id=$THEME\")\n436\t          echo \"Active theme: $THEME_PATH\"\n437\t          [ \"$THEME_PATH\" = \"Hyva/default\" ] || { echo \"Expected Hyva/default theme, got $THEME_PATH\"; exit 1; }\n438\t\n439\t      - name: Debug on failure\n440\t        if: failure() && steps.should-run.outputs.skip != 'true'\n441\t        run: |\n442\t          echo \"------- Docker containers -------\"\n443\t          docker ps -a\n444\t          echo \"------- Warden .env -------\"\n445\t          cat test-mageos/.env 2>/dev/null || echo \"No .env found\"\n446\t          echo \"------- Docker logs (last 50 lines per container) -------\"\n447\t          for c in $(docker ps -aq); do\n448\t            echo \"=== Container: $(docker inspect --format '{{.Name}}' $c) ===\"\n449\t            docker logs --tail 50 $c 2>&1 || true\n450\t          done\n451\t\n452\t  release:\n453\t    runs-on: ubuntu-latest\n454\t    needs: [go-test, ddev-test, warden-test]\n455\t    if: startsWith(github.ref, 'refs/tags/v')\n456\t\n457\t    steps:\n458\t      - uses: actions/checkout@v4\n459\t        with:\n460\t          fetch-depth: 0\n461\t\n462\t      - name: Set up Go\n463\t        uses: actions/setup-go@v5\n464\t        with:\n465\t          go-version: '1.24'\n466\t\n467\t      - name: Install GoReleaser\n468\t        run: go install github.com/goreleaser/goreleaser/v2@latest\n469\t\n470\t      - name: Release\n471\t        run: goreleaser release --clean\n472\t        env:\n473\t          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n474\t"}]},"parent_tool_use_id":null,"session_id":"7a1897f6-7841-4dc3-8643-7a1ba782e25f","uuid":"795108a2-e739-471a-badc-c98ebef7cbe3","timestamp":"2026-04-14T19:25:52.740Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/.github/workflows/build-and-test.yml","content":"name: Build, Test and Release\n\non:\n  push:\n  pull_request:\n  workflow_dispatch:\n\npermissions:\n  contents: write\n\njobs:\n  go-test:\n    runs-on: ubuntu-latest\n\n    steps:\n      - uses: actions/checkout@v4\n\n      - name: Set up Go\n        uses: actions/setup-go@v5\n        with:\n          go-version: '1.24'\n\n      - name: Test\n        run: go test -v ./...\n\n  ddev-test:\n    runs-on: ubuntu-latest\n    timeout-minutes: 60\n\n    strategy:\n      fail-fast: false\n      matrix:\n        include:\n          - name: regular\n            sample_data: \"false\"\n            hyva: \"false\"\n          - name: sampledata\n            sample_data: \"true\"\n            hyva: \"false\"\n          - name: hyva\n            sample_data: \"false\"\n            hyva: \"true\"\n          - name: hyva-sampledata\n            sample_data: \"true\"\n            hyva: \"true\"\n\n    name: ddev-test (${{ matrix.name }})\n\n    steps:\n      # Skip Hyvä variants when secrets are not available\n      - name: Check if this variant should run\n        id: should-run\n        run: |\n          if [[ \"${{ matrix.hyva }}\" == \"true\" && -z \"${{ secrets.HYVA_REPO_URL }}\" ]]; then\n            echo \"skip=true\" >> \"$GITHUB_OUTPUT\"\n            echo \"Skipping Hyvä variant because HYVA_REPO_URL is not configured\"\n          fi\n\n      - uses: actions/checkout@v4\n        if: steps.should-run.outputs.skip != 'true'\n\n      - name: Set up Go\n        if: steps.should-run.outputs.skip != 'true'\n        uses: actions/setup-go@v5\n        with:\n          go-version: '1.24'\n\n      - name: Build binary\n        if: steps.should-run.outputs.skip != 'true'\n        run: go build -o mage-os-install .\n\n      - name: Create .ddev/config.yaml\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          mkdir -p .ddev\n          cat > .ddev/config.yaml << 'EOF'\n          name: mage-os-install\n          type: magento2\n          docroot: pub\n          EOF\n\n      - name: Setup DDEV\n        if: steps.should-run.outputs.skip != 'true'\n        uses: ddev/github-action-setup-ddev@v1\n        with:\n          autostart: false\n\n      - name: Run Mage-OS installer\n        if: steps.should-run.outputs.skip != 'true'\n        env:\n          SAMPLE_DATA: ${{ matrix.sample_data }}\n          HYVA: ${{ matrix.hyva }}\n          HYVA_REPO_URL: ${{ secrets.HYVA_REPO_URL }}\n          HYVA_AUTH_TOKEN: ${{ secrets.HYVA_AUTH_TOKEN }}\n        run: |\n          sudo apt-get install -y expect\n          expect <<'EXPECT_EOF'\n          set timeout 3600\n          log_user 1\n\n          set sample_data $env(SAMPLE_DATA)\n          set hyva $env(HYVA)\n          set hyva_repo_url $env(HYVA_REPO_URL)\n          set hyva_auth_token $env(HYVA_AUTH_TOKEN)\n\n          spawn ./mage-os-install\n\n          # Clear default and type a custom project name so a fresh directory is used\n          expect \"Project name\"\n          puts \">>> Entering project name...\"\n          send \"\\025test-mageos\\r\"\n\n          # Accept default install directory (will be ./test-mageos)\n          expect \"Install directory\"\n          puts \">>> Accepting install directory...\"\n          send \"\\r\"\n\n          # Setup config form - admin user is focused first (default: admin)\n          expect \"Configure\"\n          puts \">>> Filling in admin credentials...\"\n          send \"\\r\"\n\n          # Admin password (empty by default)\n          sleep 0.5\n          send \"Admin123!\"\n          send \"\\r\"\n\n          # Admin email (empty by default)\n          sleep 0.5\n          send \"admin@example.com\"\n          send \"\\r\"\n\n          # Admin firstname (default: Admin)\n          sleep 0.5\n          send \"\\r\"\n\n          # Admin lastname (default: User) - moves to sample data toggle\n          sleep 0.5\n          send \"\\r\"\n\n          # Sample data toggle\n          sleep 0.3\n          if { $sample_data eq \"true\" } {\n            puts \">>> Enabling sample data...\"\n            send \" \"\n          }\n          send \"\\t\"\n          sleep 0.3\n\n          # Hyvä toggle\n          if { $hyva eq \"true\" } {\n            puts \">>> Enabling Hyvä theme...\"\n            send \" \"\n            sleep 0.2\n            send \"\\t\"\n            sleep 0.2\n            # Repo URL\n            send \"$hyva_repo_url\"\n            send \"\\t\"\n            sleep 0.2\n            # Auth token\n            send \"$hyva_auth_token\"\n          }\n\n          # Submit form\n          sleep 0.3\n          send \"\\r\"\n\n          # Setup preview - press enter to start install\n          expect \"Review\"\n          puts \">>> Starting installation...\"\n          send \"\\r\"\n\n          # Wait for installation to complete\n          expect {\n            -timeout 3600\n            \"installed successfully\" {\n              puts \">>> Installation completed successfully!\"\n              send \"n\"\n            }\n            \"Installation failed\" {\n              puts \">>> Installation failed!\"\n              exit 1\n            }\n          }\n\n          # Exit\n          expect \"Press enter\"\n          send \"\\r\"\n\n          expect eof\n          EXPECT_EOF\n\n      - name: Run bin/magento to verify installation\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          sleep 5\n          ddev php bin/magento\n\n      - name: Verify Mage-OS is running\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          HTTP_CODE=$(curl -sSk -L -D /tmp/curl-headers.txt -o /tmp/curl-body.txt -w \"%{http_code}\" https://test-mageos.ddev.site/)\n          echo \"------- Response headers -------\"\n          cat /tmp/curl-headers.txt\n          echo \"------- Response body -------\"\n          cat /tmp/curl-body.txt\n          echo \"------- Checking HTTP status code -------\"\n          echo \"HTTP status: $HTTP_CODE\"\n          [ \"$HTTP_CODE\" = \"200\" ] || { echo \"Expected 200, got $HTTP_CODE\"; exit 1; }\n          echo \"------- Checking x-dist header -------\"\n          grep -qi \"^x-dist:.*Mage-OS\" /tmp/curl-headers.txt || { echo \"Expected x-dist: Mage-OS header not found\"; exit 1; }\n\n      - name: Verify sample data (if enabled)\n        if: steps.should-run.outputs.skip != 'true' && matrix.sample_data == 'true'\n        run: |\n          PRODUCT_COUNT=$(ddev exec bin/magento catalog:product:count 2>/dev/null || ddev mysql -N -e \"SELECT COUNT(*) FROM catalog_product_entity\")\n          echo \"Product count: $PRODUCT_COUNT\"\n          [ \"$PRODUCT_COUNT\" -gt 0 ] || { echo \"Expected products from sample data, found none\"; exit 1; }\n\n      - name: Verify Hyvä theme (if enabled)\n        if: steps.should-run.outputs.skip != 'true' && matrix.hyva == 'true'\n        run: |\n          THEME=$(ddev mysql -N -e \"SELECT value FROM core_config_data WHERE path='design/theme/theme_id'\")\n          THEME_PATH=$(ddev mysql -N -e \"SELECT theme_path FROM theme WHERE theme_id=$THEME\")\n          echo \"Active theme: $THEME_PATH\"\n          [ \"$THEME_PATH\" = \"Hyva/default\" ] || { echo \"Expected Hyva/default theme, got $THEME_PATH\"; exit 1; }\n\n  warden-test:\n    runs-on: ubuntu-latest\n    timeout-minutes: 20\n\n    strategy:\n      fail-fast: false\n      matrix:\n        include:\n          - name: regular\n            sample_data: \"false\"\n            hyva: \"false\"\n          - name: sampledata\n            sample_data: \"true\"\n            hyva: \"false\"\n          - name: hyva\n            sample_data: \"false\"\n            hyva: \"true\"\n          - name: hyva-sampledata\n            sample_data: \"true\"\n            hyva: \"true\"\n\n    name: warden-test (${{ matrix.name }})\n\n    steps:\n      # Skip Hyvä variants when secrets are not available\n      - name: Check if this variant should run\n        id: should-run\n        run: |\n          if [[ \"${{ matrix.hyva }}\" == \"true\" && -z \"${{ secrets.HYVA_REPO_URL }}\" ]]; then\n            echo \"skip=true\" >> \"$GITHUB_OUTPUT\"\n            echo \"Skipping Hyvä variant because HYVA_REPO_URL is not configured\"\n          fi\n\n      - uses: actions/checkout@v4\n        if: steps.should-run.outputs.skip != 'true'\n\n      - name: Set up Go\n        if: steps.should-run.outputs.skip != 'true'\n        uses: actions/setup-go@v5\n        with:\n          go-version: '1.24'\n\n      - name: Build binary\n        if: steps.should-run.outputs.skip != 'true'\n        run: go build -o mage-os-install .\n\n      - name: Install Warden\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          sudo mkdir -p /opt/warden\n          sudo chown $(whoami) /opt/warden\n          git clone -b main https://github.com/wardenenv/warden.git /opt/warden\n          echo \"/opt/warden/bin\" >> $GITHUB_PATH\n\n      - name: Initialize Warden\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          /opt/warden/bin/warden install\n          /opt/warden/bin/warden svc up\n\n      - name: Add /etc/hosts entries\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          echo \"127.0.0.1 app.test-mageos.test\" | sudo tee -a /etc/hosts\n          echo \"127.0.0.1 test-mageos.test\" | sudo tee -a /etc/hosts\n\n      - name: Run Mage-OS installer\n        if: steps.should-run.outputs.skip != 'true'\n        env:\n          SAMPLE_DATA: ${{ matrix.sample_data }}\n          HYVA: ${{ matrix.hyva }}\n          HYVA_REPO_URL: ${{ secrets.HYVA_REPO_URL }}\n          HYVA_AUTH_TOKEN: ${{ secrets.HYVA_AUTH_TOKEN }}\n        run: |\n          sudo apt-get install -y expect\n          expect <<'EXPECT_EOF'\n          set timeout 3600\n          log_user 1\n\n          set sample_data $env(SAMPLE_DATA)\n          set hyva $env(HYVA)\n          set hyva_repo_url $env(HYVA_REPO_URL)\n          set hyva_auth_token $env(HYVA_AUTH_TOKEN)\n\n          spawn ./mage-os-install\n\n          # Clear default and type a custom project name so a fresh directory is used\n          expect \"Project name\"\n          puts \">>> Entering project name...\"\n          send \"\\025test-mageos\\r\"\n\n          # Accept default install directory (will be ./test-mageos)\n          expect \"Install directory\"\n          puts \">>> Accepting install directory...\"\n          send \"\\r\"\n\n          # Setup config form - admin user is focused first (default: admin)\n          expect \"Configure\"\n          puts \">>> Filling in admin credentials...\"\n          send \"\\r\"\n\n          # Admin password (empty by default)\n          sleep 0.5\n          send \"Admin123!\"\n          send \"\\r\"\n\n          # Admin email (empty by default)\n          sleep 0.5\n          send \"admin@example.com\"\n          send \"\\r\"\n\n          # Admin firstname (default: Admin)\n          sleep 0.5\n          send \"\\r\"\n\n          # Admin lastname (default: User) - moves to sample data toggle\n          sleep 0.5\n          send \"\\r\"\n\n          # Sample data toggle\n          sleep 0.3\n          if { $sample_data eq \"true\" } {\n            puts \">>> Enabling sample data...\"\n            send \" \"\n          }\n          send \"\\t\"\n          sleep 0.3\n\n          # Hyvä toggle\n          if { $hyva eq \"true\" } {\n            puts \">>> Enabling Hyvä theme...\"\n            send \" \"\n            sleep 0.2\n            send \"\\t\"\n            sleep 0.2\n            # Repo URL\n            send \"$hyva_repo_url\"\n            send \"\\t\"\n            sleep 0.2\n            # Auth token\n            send \"$hyva_auth_token\"\n          }\n\n          # Submit form\n          sleep 0.3\n          send \"\\r\"\n\n          # Setup preview - press enter to start install\n          expect \"Review\"\n          puts \">>> Starting installation...\"\n          send \"\\r\"\n\n          # Wait for installation to complete\n          expect {\n            -timeout 3600\n            \"installed successfully\" {\n              puts \">>> Installation completed successfully!\"\n              send \"n\"\n            }\n            \"Installation failed\" {\n              puts \">>> Installation failed!\"\n              exit 1\n            }\n          }\n\n          # Exit\n          expect \"Press enter\"\n          send \"\\r\"\n\n          expect eof\n          EXPECT_EOF\n\n      - name: Run bin/magento to verify installation\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          sleep 5\n          cd test-mageos\n          /opt/warden/bin/warden env exec -T php-fpm bin/magento --version\n\n      - name: Verify Mage-OS is running\n        if: steps.should-run.outputs.skip != 'true'\n        run: |\n          HTTP_CODE=$(curl -sSk -L -D /tmp/curl-headers.txt -o /tmp/curl-body.txt -w \"%{http_code}\" https://app.test-mageos.test/)\n          echo \"------- Response headers -------\"\n          cat /tmp/curl-headers.txt\n          echo \"------- Response body -------\"\n          cat /tmp/curl-body.txt\n          echo \"------- Checking HTTP status code -------\"\n          echo \"HTTP status: $HTTP_CODE\"\n          [ \"$HTTP_CODE\" = \"200\" ] || { echo \"Expected 200, got $HTTP_CODE\"; exit 1; }\n          echo \"------- Checking x-dist header -------\"\n          grep -qi \"^x-dist:.*Mage-OS\" /tmp/curl-headers.txt || { echo \"Expected x-dist: Mage-OS header not found\"; exit 1; }\n\n      - name: Verify sample data (if enabled)\n        if: steps.should-run.outputs.skip != 'true' && matrix.sample_data == 'true'\n        run: |\n          cd test-mageos\n          PRODUCT_COUNT=$(/opt/warden/bin/warden env exec -T db mysql -u magento -pmagento magento -N -e \"SELECT COUNT(*) FROM catalog_product_entity\")\n          echo \"Product count: $PRODUCT_COUNT\"\n          [ \"$PRODUCT_COUNT\" -gt 0 ] || { echo \"Expected products from sample data, found none\"; exit 1; }\n\n      - name: Verify Hyvä theme (if enabled)\n        if: steps.should-run.outputs.skip != 'true' && matrix.hyva == 'true'\n        run: |\n          cd test-mageos\n          THEME=$(/opt/warden/bin/warden env exec -T db mysql -u magento -pmagento magento -N -e \"SELECT value FROM core_config_data WHERE path='design/theme/theme_id'\")\n          THEME_PATH=$(/opt/warden/bin/warden env exec -T db mysql -u magento -pmagento magento -N -e \"SELECT theme_path FROM theme WHERE theme_id=$THEME\")\n          echo \"Active theme: $THEME_PATH\"\n          [ \"$THEME_PATH\" = \"Hyva/default\" ] || { echo \"Expected Hyva/default theme, got $THEME_PATH\"; exit 1; }\n\n      - name: Debug on failure\n        if: failure() && steps.should-run.outputs.skip != 'true'\n        run: |\n          echo \"------- Docker containers -------\"\n          docker ps -a\n          echo \"------- Warden .env -------\"\n          cat test-mageos/.env 2>/dev/null || echo \"No .env found\"\n          echo \"------- Docker logs (last 50 lines per container) -------\"\n          for c in $(docker ps -aq); do\n            echo \"=== Container: $(docker inspect --format '{{.Name}}' $c) ===\"\n            docker logs --tail 50 $c 2>&1 || true\n          done\n\n  release:\n    runs-on: ubuntu-latest\n    needs: [go-test, ddev-test, warden-test]\n    if: startsWith(github.ref, 'refs/tags/v')\n\n    steps:\n      - uses: actions/checkout@v4\n        with:\n          fetch-depth: 0\n\n      - name: Set up Go\n        uses: actions/setup-go@v5\n        with:\n          go-version: '1.24'\n\n      - name: Install GoReleaser\n        run: go install github.com/goreleaser/goreleaser/v2@latest\n\n      - name: Release\n        run: goreleaser release --clean\n        env:\n          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n","numLines":474,"startLine":1,"totalLines":474}}}
