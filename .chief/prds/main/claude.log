{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BQK2EBfXzKedgFsWCbcnsJ","type":"tool_result","content":"1\tpackage detector\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"os/exec\"\n7\t\t\"path/filepath\"\n8\t\t\"strings\"\n9\t)\n10\t\n11\t// WardenDetector checks for the Warden development environment.\n12\ttype WardenDetector struct {\n13\t\tsteps []Step\n14\t}\n15\t\n16\tfunc (d *WardenDetector) Info() DetectorInfo {\n17\t\treturn DetectorInfo{\n18\t\t\tName:       \"Warden\",\n19\t\t\tInstallURL: \"https://docs.warden.dev/\",\n20\t\t}\n21\t}\n22\t\n23\tfunc (d *WardenDetector) Steps() []Step {\n24\t\treturn d.steps\n25\t}\n26\t\n27\tfunc (d *WardenDetector) PrepareSteps(config *Config) {\n28\t\td.buildSteps(config)\n29\t}\n30\t\n31\tfunc (d *WardenDetector) buildSteps(config *Config) {\n32\t\td.steps = []Step{\n33\t\t\t{Name: \"Initialize Warden environment\"},\n34\t\t\t{Name: \"Sign SSL certificates\"},\n35\t\t\t{Name: \"Start environment\"},\n36\t\t\t{Name: \"Copy auth.json\"},\n37\t\t\t{Name: \"Create Mage-OS project\"},\n38\t\t\t{Name: \"Create composer home directory\"},\n39\t\t\t{Name: \"Copy auth.json to composer home\"},\n40\t\t\t{Name: \"Install Mage-OS\"},\n41\t\t\t{Name: \"Configure application\"},\n42\t\t\t{Name: \"Set developer mode\"},\n43\t\t}\n44\t\tif config != nil && config.InstallSampleData {\n45\t\t\td.steps = append(d.steps, Step{Name: \"Install sample data\"})\n46\t\t}\n47\t\tif config != nil && config.InstallHyva {\n48\t\t\td.steps = append(d.steps,\n49\t\t\t\tStep{Name: \"Configure Hyvä repository\"},\n50\t\t\t\tStep{Name: \"Install Hyvä theme\"},\n51\t\t\t\tStep{Name: \"Enable Hyvä modules\"},\n52\t\t\t)\n53\t\t}\n54\t}\n55\t\n56\tfunc (d *WardenDetector) SetupCommandPrefix() string {\n57\t\treturn \"warden env exec php-fpm bin/magento setup:install\"\n58\t}\n59\t\n60\tfunc (d *WardenDetector) BaseURL(projectName string) string {\n61\t\treturn \"https://app.\" + projectName + \".test\"\n62\t}\n63\t\n64\tfunc (d *WardenDetector) SetupInstallFlags(config *Config) []SetupFlag {\n65\t\treturn []SetupFlag{\n66\t\t\t{Flag: \"--backend-frontname\", Value: \"backend\"},\n67\t\t\t{Flag: \"--amqp-host\", Value: \"rabbitmq\"},\n68\t\t\t{Flag: \"--amqp-port\", Value: \"5672\"},\n69\t\t\t{Flag: \"--amqp-user\", Value: \"guest\"},\n70\t\t\t{Flag: \"--amqp-password\", Value: \"guest\"},\n71\t\t\t{Flag: \"--db-host\", Value: \"db\"},\n72\t\t\t{Flag: \"--db-name\", Value: \"magento\"},\n73\t\t\t{Flag: \"--db-user\", Value: \"magento\"},\n74\t\t\t{Flag: \"--db-password\", Value: \"magento\"},\n75\t\t\t{Flag: \"--search-engine\", Value: \"opensearch\"},\n76\t\t\t{Flag: \"--opensearch-host\", Value: \"opensearch\"},\n77\t\t\t{Flag: \"--opensearch-port\", Value: \"9200\"},\n78\t\t\t{Flag: \"--opensearch-index-prefix\", Value: \"magento2\"},\n79\t\t\t{Flag: \"--opensearch-enable-auth\", Value: \"0\"},\n80\t\t\t{Flag: \"--opensearch-timeout\", Value: \"15\"},\n81\t\t\t{Flag: \"--http-cache-hosts\", Value: \"varnish:80\"},\n82\t\t\t{Flag: \"--session-save\", Value: \"redis\"},\n83\t\t\t{Flag: \"--session-save-redis-host\", Value: \"redis\"},\n84\t\t\t{Flag: \"--session-save-redis-port\", Value: \"6379\"},\n85\t\t\t{Flag: \"--session-save-redis-db\", Value: \"2\"},\n86\t\t\t{Flag: \"--session-save-redis-max-concurrency\", Value: \"20\"},\n87\t\t\t{Flag: \"--cache-backend\", Value: \"redis\"},\n88\t\t\t{Flag: \"--cache-backend-redis-server\", Value: \"redis\"},\n89\t\t\t{Flag: \"--cache-backend-redis-db\", Value: \"0\"},\n90\t\t\t{Flag: \"--cache-backend-redis-port\", Value: \"6379\"},\n91\t\t\t{Flag: \"--page-cache\", Value: \"redis\"},\n92\t\t\t{Flag: \"--page-cache-redis-server\", Value: \"redis\"},\n93\t\t\t{Flag: \"--page-cache-redis-db\", Value: \"1\"},\n94\t\t\t{Flag: \"--page-cache-redis-port\", Value: \"6379\"},\n95\t\t\t{Flag: \"--timezone\", Value: \"Europe/Amsterdam\"},\n96\t\t\t{Flag: \"--currency\", Value: \"EUR\"},\n97\t\t\t{Flag: \"--admin-user\", Value: config.AdminUser, Editable: true},\n98\t\t\t{Flag: \"--admin-password\", Value: config.AdminPassword, Editable: true},\n99\t\t\t{Flag: \"--admin-email\", Value: config.AdminEmail, Editable: true},\n100\t\t\t{Flag: \"--admin-firstname\", Value: config.AdminFirstname, Editable: true},\n101\t\t\t{Flag: \"--admin-lastname\", Value: config.AdminLastname, Editable: true},\n102\t\t\t{Flag: \"--use-rewrites\", Value: \"1\"},\n103\t\t}\n104\t}\n105\t\n106\tfunc (d *WardenDetector) Install(config *Config) error {\n107\t\td.buildSteps(config)\n108\t\n109\t\trun := func(args ...string) error {\n110\t\t\tlogf(config, \"▸ %s\", strings.Join(args, \" \"))\n111\t\t\treturn runInDir(config.Directory, config.Log, args[0], args[1:]...)\n112\t\t}\n113\t\n114\t\tbaseURL := d.BaseURL(config.ProjectName) + \"/\"\n115\t\n116\t\tallSteps := []func() error{\n117\t\t\t// 0: Initialize Warden environment\n118\t\t\tfunc() error {\n119\t\t\t\tos.Remove(filepath.Join(config.Directory, \".env\"))\n120\t\t\t\treturn run(\"warden\", \"env-init\", config.ProjectName, \"magento2\")\n121\t\t\t},\n122\t\t\t// 1: Sign SSL certificates\n123\t\t\tfunc() error {\n124\t\t\t\tif err := run(\"warden\", \"sign-certificate\", config.ProjectName+\".test\"); err != nil {\n125\t\t\t\t\treturn err\n126\t\t\t\t}\n127\t\t\t\treturn run(\"warden\", \"sign-certificate\", \"app.\"+config.ProjectName+\".test\")\n128\t\t\t},\n129\t\t\t// 2: Start environment\n130\t\t\tfunc() error {\n131\t\t\t\treturn run(\"warden\", \"env\", \"up\")\n132\t\t\t},\n133\t\t\t// 3: Copy auth.json\n134\t\t\tfunc() error {\n135\t\t\t\treturn wardenCopyAuthJSON(config)\n136\t\t\t},\n137\t\t\t// 4: Create Mage-OS project\n138\t\t\tfunc() error {\n139\t\t\t\t// Wait for php-fpm entrypoint to finish setting up composer\n140\t\t\t\tif err := run(\n141\t\t\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n142\t\t\t\t\t\"bash\", \"-c\", \"while ! command -v composer &>/dev/null; do sleep 1; done\",\n143\t\t\t\t); err != nil {\n144\t\t\t\t\treturn err\n145\t\t\t\t}\n146\t\t\t\tif err := run(\n147\t\t\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n148\t\t\t\t\t\"composer\", \"create-project\",\n149\t\t\t\t\t\"--repository-url=https://repo.mage-os.org/\",\n150\t\t\t\t\t\"mage-os/project-community-edition\",\n151\t\t\t\t\t\"/tmp/mage-os-project\",\n152\t\t\t\t); err != nil {\n153\t\t\t\t\treturn err\n154\t\t\t\t}\n155\t\t\t\treturn run(\n156\t\t\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n157\t\t\t\t\t\"bash\", \"-c\", \"cp -a /tmp/mage-os-project/. /var/www/html/\",\n158\t\t\t\t)\n159\t\t\t},\n160\t\t\t// 5: Create composer home directory\n161\t\t\tfunc() error {\n162\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n163\t\t\t\t\t\"mkdir\", \"-p\", \"/var/www/html/var/composer_home\")\n164\t\t\t},\n165\t\t\t// 6: Copy auth.json to composer home\n166\t\t\tfunc() error {\n167\t\t\t\treturn wardenCopyAuthJSONComposerHome(config)\n168\t\t\t},\n169\t\t\t// 7: Install Mage-OS\n170\t\t\tfunc() error {\n171\t\t\t\tlogf(config, \"▸ bin/magento setup:install\")\n172\t\t\t\targs := []string{\"env\", \"exec\", \"php-fpm\", \"bin/magento\", \"setup:install\"}\n173\t\t\t\tfor _, f := range d.SetupInstallFlags(config) {\n174\t\t\t\t\targs = append(args, f.Flag+\"=\"+f.Value)\n175\t\t\t\t}\n176\t\t\t\treturn runInDir(config.Directory, config.Log, \"warden\", args...)\n177\t\t\t},\n178\t\t\t// 8: Configure application\n179\t\t\tfunc() error {\n180\t\t\t\tconfigs := [][]string{\n181\t\t\t\t\t{\"config:set\", \"--lock-env\", \"web/unsecure/base_url\", baseURL},\n182\t\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/base_url\", baseURL},\n183\t\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/offloader_header\", \"X-Forwarded-Proto\"},\n184\t\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/use_in_frontend\", \"1\"},\n185\t\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/use_in_adminhtml\", \"1\"},\n186\t\t\t\t\t{\"config:set\", \"--lock-env\", \"web/seo/use_rewrites\", \"1\"},\n187\t\t\t\t\t{\"config:set\", \"--lock-env\", \"system/full_page_cache/caching_application\", \"2\"},\n188\t\t\t\t\t{\"config:set\", \"--lock-env\", \"system/full_page_cache/ttl\", \"604800\"},\n189\t\t\t\t\t{\"config:set\", \"--lock-env\", \"catalog/search/enable_eav_indexer\", \"1\"},\n190\t\t\t\t\t{\"config:set\", \"--lock-env\", \"dev/static/sign\", \"0\"},\n191\t\t\t\t}\n192\t\t\t\tfor _, c := range configs {\n193\t\t\t\t\targs := append([]string{\"warden\", \"env\", \"exec\", \"php-fpm\", \"bin/magento\"}, c...)\n194\t\t\t\t\tif err := run(args...); err != nil {\n195\t\t\t\t\t\treturn err\n196\t\t\t\t\t}\n197\t\t\t\t}\n198\t\t\t\treturn nil\n199\t\t\t},\n200\t\t\t// 9: Set developer mode\n201\t\t\tfunc() error {\n202\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n203\t\t\t\t\t\"bin/magento\", \"deploy:mode:set\", \"-s\", \"developer\"); err != nil {\n204\t\t\t\t\treturn err\n205\t\t\t\t}\n206\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n207\t\t\t\t\t\"bin/magento\", \"cache:disable\", \"block_html\", \"full_page\"); err != nil {\n208\t\t\t\t\treturn err\n209\t\t\t\t}\n210\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n211\t\t\t\t\t\"bin/magento\", \"indexer:reindex\"); err != nil {\n212\t\t\t\t\treturn err\n213\t\t\t\t}\n214\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n215\t\t\t\t\t\"bin/magento\", \"cache:flush\")\n216\t\t\t},\n217\t\t}\n218\t\n219\t\tif config.InstallSampleData {\n220\t\t\tallSteps = append(allSteps, func() error {\n221\t\t\t\tlogf(config, \"▸ Deploying sample data\")\n222\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n223\t\t\t\t\t\"bin/magento\", \"sampledata:deploy\"); err != nil {\n224\t\t\t\t\treturn err\n225\t\t\t\t}\n226\t\t\t\t// If no Hyvä, run setup:upgrade + cache:flush now.\n227\t\t\t\t// If Hyvä is also enabled, setup:upgrade runs in the Hyvä enable step.\n228\t\t\t\tif !config.InstallHyva {\n229\t\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n230\t\t\t\t\t\t\"bin/magento\", \"setup:upgrade\"); err != nil {\n231\t\t\t\t\t\treturn err\n232\t\t\t\t\t}\n233\t\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n234\t\t\t\t\t\t\"bin/magento\", \"cache:flush\")\n235\t\t\t\t}\n236\t\t\t\treturn nil\n237\t\t\t})\n238\t\t}\n239\t\n240\t\tif config.InstallHyva {\n241\t\t\t// Configure Hyvä repository\n242\t\t\tallSteps = append(allSteps, func() error {\n243\t\t\t\tlogf(config, \"▸ Configuring Hyvä Private Packagist repository\")\n244\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n245\t\t\t\t\t\"composer\", \"config\", \"repositories.private-packagist\",\n246\t\t\t\t\t\"composer\", config.HyvaRepoURL); err != nil {\n247\t\t\t\t\treturn err\n248\t\t\t\t}\n249\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n250\t\t\t\t\t\"composer\", \"config\", \"--auth\",\n251\t\t\t\t\t\"http-basic.\"+extractHost(config.HyvaRepoURL),\n252\t\t\t\t\t\"token\", config.HyvaAuthToken)\n253\t\t\t})\n254\t\t\t// Install Hyvä theme\n255\t\t\tallSteps = append(allSteps, func() error {\n256\t\t\t\tlogf(config, \"▸ Installing Hyvä theme\")\n257\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n258\t\t\t\t\t\"composer\", \"require\", \"hyva-themes/magento2-default-theme\")\n259\t\t\t})\n260\t\t\t// Enable Hyvä modules\n261\t\t\tallSteps = append(allSteps, func() error {\n262\t\t\t\tlogf(config, \"▸ Enabling Hyvä modules and setting up theme\")\n263\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n264\t\t\t\t\t\"bin/magento\", \"module:enable\", \"--all\"); err != nil {\n265\t\t\t\t\treturn err\n266\t\t\t\t}\n267\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n268\t\t\t\t\t\"bin/magento\", \"setup:upgrade\"); err != nil {\n269\t\t\t\t\treturn err\n270\t\t\t\t}\n271\t\t\t\t// Look up the Hyvä theme ID and set it as default\n272\t\t\t\tlogf(config, \"▸ Setting Hyvä as default storefront theme\")\n273\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n274\t\t\t\t\t\"bash\", \"-c\",\n275\t\t\t\t\t`THEME_ID=$(mysql -h db -u magento -pmagento magento -N -e \"SELECT theme_id FROM theme WHERE theme_path='Hyva/default'\" 2>/dev/null) && bin/magento config:set design/theme/theme_id \"$THEME_ID\"`); err != nil {\n276\t\t\t\t\treturn err\n277\t\t\t\t}\n278\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n279\t\t\t\t\t\"bin/magento\", \"cache:flush\")\n280\t\t\t})\n281\t\t}\n282\t\n283\t\tfor i, fn := range allSteps {\n284\t\t\tif i < config.StartFromStep {\n285\t\t\t\tcontinue\n286\t\t\t}\n287\t\t\tstepStart(config, i)\n288\t\t\tif err := fn(); err != nil {\n289\t\t\t\treturn fmt.Errorf(\"step %q failed: %w\", d.Steps()[i].Name, err)\n290\t\t\t}\n291\t\t\tstepDone(config, i)\n292\t\t}\n293\t\n294\t\treturn nil\n295\t}\n296\t\n297\tfunc (d *WardenDetector) Detect() (*Environment, error) {\n298\t\tpath, err := exec.LookPath(\"warden\")\n299\t\tif err != nil {\n300\t\t\treturn nil, err\n301\t\t}\n302\t\n303\t\tversion := \"unknown\"\n304\t\tout, err := exec.Command(\"warden\", \"version\").Output()\n305\t\tif err == nil {\n306\t\t\tversion = parseWardenVersion(string(out))\n307\t\t}\n308\t\n309\t\treturn &Environment{\n310\t\t\tName:    \"Warden\",\n311\t\t\tVersion: version,\n312\t\t\tCommand: path,\n313\t\t}, nil\n314\t}\n315\t\n316\tfunc parseWardenVersion(output string) string {\n317\t\tfor _, line := range strings.Split(output, \"\\n\") {\n318\t\t\tline = strings.TrimSpace(line)\n319\t\t\tif strings.Contains(line, \"arden\") {\n320\t\t\t\tparts := strings.Fields(line)\n321\t\t\t\tfor _, p := range parts {\n322\t\t\t\t\tif len(p) > 0 && (p[0] >= '0' && p[0] <= '9') {\n323\t\t\t\t\t\treturn strings.TrimRight(p, \",\")\n324\t\t\t\t\t}\n325\t\t\t\t}\n326\t\t\t}\n327\t\t}\n328\t\treturn \"unknown\"\n329\t}\n330\t\n331\t// wardenPhpFpmContainer returns the Docker container ID for the php-fpm service.\n332\t// It generates a docker-compose.yml from the Warden env config and queries Docker Compose.\n333\tfunc wardenPhpFpmContainer(dir string) (string, error) {\n334\t\t// Generate docker-compose.yml from Warden config\n335\t\tcmd := exec.Command(\"warden\", \"env\", \"config\")\n336\t\tcmd.Dir = dir\n337\t\tcomposeYml, err := cmd.Output()\n338\t\tif err != nil {\n339\t\t\treturn \"\", fmt.Errorf(\"warden env config failed: %w\", err)\n340\t\t}\n341\t\tif err := os.WriteFile(filepath.Join(dir, \"docker-compose.yml\"), composeYml, 0644); err != nil {\n342\t\t\treturn \"\", fmt.Errorf(\"could not write docker-compose.yml: %w\", err)\n343\t\t}\n344\t\n345\t\t// Get container ID\n346\t\tcmd = exec.Command(\"docker\", \"compose\", \"ps\", \"-q\", \"php-fpm\")\n347\t\tcmd.Dir = dir\n348\t\tout, err := cmd.Output()\n349\t\tif err != nil {\n350\t\t\treturn \"\", fmt.Errorf(\"docker compose ps failed: %w\", err)\n351\t\t}\n352\t\n353\t\tcontainerID := strings.TrimSpace(string(out))\n354\t\tif containerID == \"\" {\n355\t\t\treturn \"\", fmt.Errorf(\"php-fpm container not found\")\n356\t\t}\n357\t\treturn containerID, nil\n358\t}\n359\t\n360\t// wardenCopyAuthJSON copies ~/.composer/auth.json into the Warden php-fpm container.\n361\t// If the file does not exist it is silently skipped.\n362\tfunc wardenCopyAuthJSON(config *Config) error {\n363\t\thome, err := os.UserHomeDir()\n364\t\tif err != nil {\n365\t\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n366\t\t}\n367\t\n368\t\tauthSrc := filepath.Join(home, \".composer\", \"auth.json\")\n369\t\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n370\t\t\treturn nil // nothing to copy\n371\t\t}\n372\t\n373\t\t// Ensure target directory exists\n374\t\tlogf(config, \"▸ creating /home/www-data/.composer/ in container\")\n375\t\tif err := runInDir(config.Directory, config.Log,\n376\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n377\t\t\t\"mkdir\", \"-p\", \"/home/www-data/.composer/\"); err != nil {\n378\t\t\treturn fmt.Errorf(\"could not create .composer directory: %w\", err)\n379\t\t}\n380\t\n381\t\tcontainerID, err := wardenPhpFpmContainer(config.Directory)\n382\t\tif err != nil {\n383\t\t\treturn fmt.Errorf(\"could not get php-fpm container: %w\", err)\n384\t\t}\n385\t\n386\t\tlogf(config, \"▸ docker cp auth.json → container\")\n387\t\treturn runInDir(config.Directory, config.Log,\n388\t\t\t\"docker\", \"cp\", authSrc, containerID+\":/home/www-data/.composer/auth.json\")\n389\t}\n390\t\n391\t// wardenCopyAuthJSONComposerHome copies ~/.composer/auth.json to the Mage-OS\n392\t// var/composer_home directory inside the container and fixes ownership.\n393\tfunc wardenCopyAuthJSONComposerHome(config *Config) error {\n394\t\thome, err := os.UserHomeDir()\n395\t\tif err != nil {\n396\t\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n397\t\t}\n398\t\n399\t\tauthSrc := filepath.Join(home, \".composer\", \"auth.json\")\n400\t\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n401\t\t\treturn nil // nothing to copy\n402\t\t}\n403\t\n404\t\tcontainerID, err := wardenPhpFpmContainer(config.Directory)\n405\t\tif err != nil {\n406\t\t\treturn fmt.Errorf(\"could not get php-fpm container: %w\", err)\n407\t\t}\n408\t\n409\t\tlogf(config, \"▸ docker cp auth.json → composer_home\")\n410\t\tif err := runInDir(config.Directory, config.Log,\n411\t\t\t\"docker\", \"cp\", authSrc, containerID+\":/var/www/html/var/composer_home/auth.json\"); err != nil {\n412\t\t\treturn err\n413\t\t}\n414\t\n415\t\treturn runInDir(config.Directory, config.Log,\n416\t\t\t\"warden\", \"env\", \"exec\", \"--user\", \"root\", \"php-fpm\",\n417\t\t\t\"chown\", \"www-data:www-data\", \"/var/www/html/var/composer_home/auth.json\")\n418\t}\n419\t"}]},"parent_tool_use_id":null,"session_id":"e204eeb6-4b6e-491a-8813-b964c2999bbd","uuid":"d7332c13-291c-4056-8796-05efacc817b5","timestamp":"2026-04-14T19:08:45.521Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/michielgerritsen/Sites/mage-os-install/internal/detector/warden.go","content":"package detector\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\n// WardenDetector checks for the Warden development environment.\ntype WardenDetector struct {\n\tsteps []Step\n}\n\nfunc (d *WardenDetector) Info() DetectorInfo {\n\treturn DetectorInfo{\n\t\tName:       \"Warden\",\n\t\tInstallURL: \"https://docs.warden.dev/\",\n\t}\n}\n\nfunc (d *WardenDetector) Steps() []Step {\n\treturn d.steps\n}\n\nfunc (d *WardenDetector) PrepareSteps(config *Config) {\n\td.buildSteps(config)\n}\n\nfunc (d *WardenDetector) buildSteps(config *Config) {\n\td.steps = []Step{\n\t\t{Name: \"Initialize Warden environment\"},\n\t\t{Name: \"Sign SSL certificates\"},\n\t\t{Name: \"Start environment\"},\n\t\t{Name: \"Copy auth.json\"},\n\t\t{Name: \"Create Mage-OS project\"},\n\t\t{Name: \"Create composer home directory\"},\n\t\t{Name: \"Copy auth.json to composer home\"},\n\t\t{Name: \"Install Mage-OS\"},\n\t\t{Name: \"Configure application\"},\n\t\t{Name: \"Set developer mode\"},\n\t}\n\tif config != nil && config.InstallSampleData {\n\t\td.steps = append(d.steps, Step{Name: \"Install sample data\"})\n\t}\n\tif config != nil && config.InstallHyva {\n\t\td.steps = append(d.steps,\n\t\t\tStep{Name: \"Configure Hyvä repository\"},\n\t\t\tStep{Name: \"Install Hyvä theme\"},\n\t\t\tStep{Name: \"Enable Hyvä modules\"},\n\t\t)\n\t}\n}\n\nfunc (d *WardenDetector) SetupCommandPrefix() string {\n\treturn \"warden env exec php-fpm bin/magento setup:install\"\n}\n\nfunc (d *WardenDetector) BaseURL(projectName string) string {\n\treturn \"https://app.\" + projectName + \".test\"\n}\n\nfunc (d *WardenDetector) SetupInstallFlags(config *Config) []SetupFlag {\n\treturn []SetupFlag{\n\t\t{Flag: \"--backend-frontname\", Value: \"backend\"},\n\t\t{Flag: \"--amqp-host\", Value: \"rabbitmq\"},\n\t\t{Flag: \"--amqp-port\", Value: \"5672\"},\n\t\t{Flag: \"--amqp-user\", Value: \"guest\"},\n\t\t{Flag: \"--amqp-password\", Value: \"guest\"},\n\t\t{Flag: \"--db-host\", Value: \"db\"},\n\t\t{Flag: \"--db-name\", Value: \"magento\"},\n\t\t{Flag: \"--db-user\", Value: \"magento\"},\n\t\t{Flag: \"--db-password\", Value: \"magento\"},\n\t\t{Flag: \"--search-engine\", Value: \"opensearch\"},\n\t\t{Flag: \"--opensearch-host\", Value: \"opensearch\"},\n\t\t{Flag: \"--opensearch-port\", Value: \"9200\"},\n\t\t{Flag: \"--opensearch-index-prefix\", Value: \"magento2\"},\n\t\t{Flag: \"--opensearch-enable-auth\", Value: \"0\"},\n\t\t{Flag: \"--opensearch-timeout\", Value: \"15\"},\n\t\t{Flag: \"--http-cache-hosts\", Value: \"varnish:80\"},\n\t\t{Flag: \"--session-save\", Value: \"redis\"},\n\t\t{Flag: \"--session-save-redis-host\", Value: \"redis\"},\n\t\t{Flag: \"--session-save-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--session-save-redis-db\", Value: \"2\"},\n\t\t{Flag: \"--session-save-redis-max-concurrency\", Value: \"20\"},\n\t\t{Flag: \"--cache-backend\", Value: \"redis\"},\n\t\t{Flag: \"--cache-backend-redis-server\", Value: \"redis\"},\n\t\t{Flag: \"--cache-backend-redis-db\", Value: \"0\"},\n\t\t{Flag: \"--cache-backend-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--page-cache\", Value: \"redis\"},\n\t\t{Flag: \"--page-cache-redis-server\", Value: \"redis\"},\n\t\t{Flag: \"--page-cache-redis-db\", Value: \"1\"},\n\t\t{Flag: \"--page-cache-redis-port\", Value: \"6379\"},\n\t\t{Flag: \"--timezone\", Value: \"Europe/Amsterdam\"},\n\t\t{Flag: \"--currency\", Value: \"EUR\"},\n\t\t{Flag: \"--admin-user\", Value: config.AdminUser, Editable: true},\n\t\t{Flag: \"--admin-password\", Value: config.AdminPassword, Editable: true},\n\t\t{Flag: \"--admin-email\", Value: config.AdminEmail, Editable: true},\n\t\t{Flag: \"--admin-firstname\", Value: config.AdminFirstname, Editable: true},\n\t\t{Flag: \"--admin-lastname\", Value: config.AdminLastname, Editable: true},\n\t\t{Flag: \"--use-rewrites\", Value: \"1\"},\n\t}\n}\n\nfunc (d *WardenDetector) Install(config *Config) error {\n\td.buildSteps(config)\n\n\trun := func(args ...string) error {\n\t\tlogf(config, \"▸ %s\", strings.Join(args, \" \"))\n\t\treturn runInDir(config.Directory, config.Log, args[0], args[1:]...)\n\t}\n\n\tbaseURL := d.BaseURL(config.ProjectName) + \"/\"\n\n\tallSteps := []func() error{\n\t\t// 0: Initialize Warden environment\n\t\tfunc() error {\n\t\t\tos.Remove(filepath.Join(config.Directory, \".env\"))\n\t\t\treturn run(\"warden\", \"env-init\", config.ProjectName, \"magento2\")\n\t\t},\n\t\t// 1: Sign SSL certificates\n\t\tfunc() error {\n\t\t\tif err := run(\"warden\", \"sign-certificate\", config.ProjectName+\".test\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\treturn run(\"warden\", \"sign-certificate\", \"app.\"+config.ProjectName+\".test\")\n\t\t},\n\t\t// 2: Start environment\n\t\tfunc() error {\n\t\t\treturn run(\"warden\", \"env\", \"up\")\n\t\t},\n\t\t// 3: Copy auth.json\n\t\tfunc() error {\n\t\t\treturn wardenCopyAuthJSON(config)\n\t\t},\n\t\t// 4: Create Mage-OS project\n\t\tfunc() error {\n\t\t\t// Wait for php-fpm entrypoint to finish setting up composer\n\t\t\tif err := run(\n\t\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bash\", \"-c\", \"while ! command -v composer &>/dev/null; do sleep 1; done\",\n\t\t\t); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err := run(\n\t\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"composer\", \"create-project\",\n\t\t\t\t\"--repository-url=https://repo.mage-os.org/\",\n\t\t\t\t\"mage-os/project-community-edition\",\n\t\t\t\t\"/tmp/mage-os-project\",\n\t\t\t); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\treturn run(\n\t\t\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bash\", \"-c\", \"cp -a /tmp/mage-os-project/. /var/www/html/\",\n\t\t\t)\n\t\t},\n\t\t// 5: Create composer home directory\n\t\tfunc() error {\n\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"mkdir\", \"-p\", \"/var/www/html/var/composer_home\")\n\t\t},\n\t\t// 6: Copy auth.json to composer home\n\t\tfunc() error {\n\t\t\treturn wardenCopyAuthJSONComposerHome(config)\n\t\t},\n\t\t// 7: Install Mage-OS\n\t\tfunc() error {\n\t\t\tlogf(config, \"▸ bin/magento setup:install\")\n\t\t\targs := []string{\"env\", \"exec\", \"php-fpm\", \"bin/magento\", \"setup:install\"}\n\t\t\tfor _, f := range d.SetupInstallFlags(config) {\n\t\t\t\targs = append(args, f.Flag+\"=\"+f.Value)\n\t\t\t}\n\t\t\treturn runInDir(config.Directory, config.Log, \"warden\", args...)\n\t\t},\n\t\t// 8: Configure application\n\t\tfunc() error {\n\t\t\tconfigs := [][]string{\n\t\t\t\t{\"config:set\", \"--lock-env\", \"web/unsecure/base_url\", baseURL},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/base_url\", baseURL},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/offloader_header\", \"X-Forwarded-Proto\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/use_in_frontend\", \"1\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"web/secure/use_in_adminhtml\", \"1\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"web/seo/use_rewrites\", \"1\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"system/full_page_cache/caching_application\", \"2\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"system/full_page_cache/ttl\", \"604800\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"catalog/search/enable_eav_indexer\", \"1\"},\n\t\t\t\t{\"config:set\", \"--lock-env\", \"dev/static/sign\", \"0\"},\n\t\t\t}\n\t\t\tfor _, c := range configs {\n\t\t\t\targs := append([]string{\"warden\", \"env\", \"exec\", \"php-fpm\", \"bin/magento\"}, c...)\n\t\t\t\tif err := run(args...); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t},\n\t\t// 9: Set developer mode\n\t\tfunc() error {\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"deploy:mode:set\", \"-s\", \"developer\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"cache:disable\", \"block_html\", \"full_page\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"indexer:reindex\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"cache:flush\")\n\t\t},\n\t}\n\n\tif config.InstallSampleData {\n\t\tallSteps = append(allSteps, func() error {\n\t\t\tlogf(config, \"▸ Deploying sample data\")\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"sampledata:deploy\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\t// If no Hyvä, run setup:upgrade + cache:flush now.\n\t\t\t// If Hyvä is also enabled, setup:upgrade runs in the Hyvä enable step.\n\t\t\tif !config.InstallHyva {\n\t\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\t\"bin/magento\", \"setup:upgrade\"); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\t\"bin/magento\", \"cache:flush\")\n\t\t\t}\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tif config.InstallHyva {\n\t\t// Configure Hyvä repository\n\t\tallSteps = append(allSteps, func() error {\n\t\t\tlogf(config, \"▸ Configuring Hyvä Private Packagist repository\")\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"composer\", \"config\", \"repositories.private-packagist\",\n\t\t\t\t\"composer\", config.HyvaRepoURL); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"composer\", \"config\", \"--auth\",\n\t\t\t\t\"http-basic.\"+extractHost(config.HyvaRepoURL),\n\t\t\t\t\"token\", config.HyvaAuthToken)\n\t\t})\n\t\t// Install Hyvä theme\n\t\tallSteps = append(allSteps, func() error {\n\t\t\tlogf(config, \"▸ Installing Hyvä theme\")\n\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"composer\", \"require\", \"hyva-themes/magento2-default-theme\")\n\t\t})\n\t\t// Enable Hyvä modules\n\t\tallSteps = append(allSteps, func() error {\n\t\t\tlogf(config, \"▸ Enabling Hyvä modules and setting up theme\")\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"module:enable\", \"--all\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"setup:upgrade\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\t// Look up the Hyvä theme ID and set it as default\n\t\t\tlogf(config, \"▸ Setting Hyvä as default storefront theme\")\n\t\t\tif err := run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bash\", \"-c\",\n\t\t\t\t`THEME_ID=$(mysql -h db -u magento -pmagento magento -N -e \"SELECT theme_id FROM theme WHERE theme_path='Hyva/default'\" 2>/dev/null) && bin/magento config:set design/theme/theme_id \"$THEME_ID\"`); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\treturn run(\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\t\t\"bin/magento\", \"cache:flush\")\n\t\t})\n\t}\n\n\tfor i, fn := range allSteps {\n\t\tif i < config.StartFromStep {\n\t\t\tcontinue\n\t\t}\n\t\tstepStart(config, i)\n\t\tif err := fn(); err != nil {\n\t\t\treturn fmt.Errorf(\"step %q failed: %w\", d.Steps()[i].Name, err)\n\t\t}\n\t\tstepDone(config, i)\n\t}\n\n\treturn nil\n}\n\nfunc (d *WardenDetector) Detect() (*Environment, error) {\n\tpath, err := exec.LookPath(\"warden\")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tversion := \"unknown\"\n\tout, err := exec.Command(\"warden\", \"version\").Output()\n\tif err == nil {\n\t\tversion = parseWardenVersion(string(out))\n\t}\n\n\treturn &Environment{\n\t\tName:    \"Warden\",\n\t\tVersion: version,\n\t\tCommand: path,\n\t}, nil\n}\n\nfunc parseWardenVersion(output string) string {\n\tfor _, line := range strings.Split(output, \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif strings.Contains(line, \"arden\") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tfor _, p := range parts {\n\t\t\t\tif len(p) > 0 && (p[0] >= '0' && p[0] <= '9') {\n\t\t\t\t\treturn strings.TrimRight(p, \",\")\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn \"unknown\"\n}\n\n// wardenPhpFpmContainer returns the Docker container ID for the php-fpm service.\n// It generates a docker-compose.yml from the Warden env config and queries Docker Compose.\nfunc wardenPhpFpmContainer(dir string) (string, error) {\n\t// Generate docker-compose.yml from Warden config\n\tcmd := exec.Command(\"warden\", \"env\", \"config\")\n\tcmd.Dir = dir\n\tcomposeYml, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"warden env config failed: %w\", err)\n\t}\n\tif err := os.WriteFile(filepath.Join(dir, \"docker-compose.yml\"), composeYml, 0644); err != nil {\n\t\treturn \"\", fmt.Errorf(\"could not write docker-compose.yml: %w\", err)\n\t}\n\n\t// Get container ID\n\tcmd = exec.Command(\"docker\", \"compose\", \"ps\", \"-q\", \"php-fpm\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"docker compose ps failed: %w\", err)\n\t}\n\n\tcontainerID := strings.TrimSpace(string(out))\n\tif containerID == \"\" {\n\t\treturn \"\", fmt.Errorf(\"php-fpm container not found\")\n\t}\n\treturn containerID, nil\n}\n\n// wardenCopyAuthJSON copies ~/.composer/auth.json into the Warden php-fpm container.\n// If the file does not exist it is silently skipped.\nfunc wardenCopyAuthJSON(config *Config) error {\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n\t}\n\n\tauthSrc := filepath.Join(home, \".composer\", \"auth.json\")\n\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n\t\treturn nil // nothing to copy\n\t}\n\n\t// Ensure target directory exists\n\tlogf(config, \"▸ creating /home/www-data/.composer/ in container\")\n\tif err := runInDir(config.Directory, config.Log,\n\t\t\"warden\", \"env\", \"exec\", \"php-fpm\",\n\t\t\"mkdir\", \"-p\", \"/home/www-data/.composer/\"); err != nil {\n\t\treturn fmt.Errorf(\"could not create .composer directory: %w\", err)\n\t}\n\n\tcontainerID, err := wardenPhpFpmContainer(config.Directory)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not get php-fpm container: %w\", err)\n\t}\n\n\tlogf(config, \"▸ docker cp auth.json → container\")\n\treturn runInDir(config.Directory, config.Log,\n\t\t\"docker\", \"cp\", authSrc, containerID+\":/home/www-data/.composer/auth.json\")\n}\n\n// wardenCopyAuthJSONComposerHome copies ~/.composer/auth.json to the Mage-OS\n// var/composer_home directory inside the container and fixes ownership.\nfunc wardenCopyAuthJSONComposerHome(config *Config) error {\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not determine home directory: %w\", err)\n\t}\n\n\tauthSrc := filepath.Join(home, \".composer\", \"auth.json\")\n\tif _, err := os.Stat(authSrc); os.IsNotExist(err) {\n\t\treturn nil // nothing to copy\n\t}\n\n\tcontainerID, err := wardenPhpFpmContainer(config.Directory)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"could not get php-fpm container: %w\", err)\n\t}\n\n\tlogf(config, \"▸ docker cp auth.json → composer_home\")\n\tif err := runInDir(config.Directory, config.Log,\n\t\t\"docker\", \"cp\", authSrc, containerID+\":/var/www/html/var/composer_home/auth.json\"); err != nil {\n\t\treturn err\n\t}\n\n\treturn runInDir(config.Directory, config.Log,\n\t\t\"warden\", \"env\", \"exec\", \"--user\", \"root\", \"php-fpm\",\n\t\t\"chown\", \"www-data:www-data\", \"/var/www/html/var/composer_home/auth.json\")\n}\n","numLines":419,"startLine":1,"totalLines":419}}}
